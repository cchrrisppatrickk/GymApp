@model GymApp.ViewModels.PaseDiarioListDTO

@{
    ViewData["Title"] = "Detalles del Pase Diario";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-info-circle me-2"></i>Detalles del Pase Diario</h5>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver a la lista
        </a>
    </div>
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="p-3 border rounded bg-light h-100">
                    <h6 class="text-uppercase text-muted mb-3"><i class="bi bi-person-badge me-2"></i>Información del Cliente</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Cliente</dt>
                        <dd class="col-sm-8 fw-medium">@Model.NombreCliente</dd>

                        <dt class="col-sm-4 text-muted">Turno</dt>
                        <dd class="col-sm-8"><span class="badge bg-info text-dark">@Model.NombreTurno</span></dd>
                    </dl>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded bg-light h-100">
                    <h6 class="text-uppercase text-muted mb-3"><i class="bi bi-wallet2 me-2"></i>Información de Pago</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Monto</dt>
                        <dd class="col-sm-8 fw-bold text-success">S/ @Model.Monto.ToString("0.00")</dd>

                        <dt class="col-sm-4 text-muted">Método</dt>
                        <dd class="col-sm-8">
                            @if(Model.MetodoPago == "Efectivo")
                            {
                                <span class="badge bg-success"><i class="bi bi-cash"></i> Efectivo</span>
                            }
                            else
                            {
                                <span class="badge bg-primary"><i class="bi bi-phone"></i> Yape</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="col-md-12">
                <div class="p-3 border rounded bg-light">
                    <h6 class="text-uppercase text-muted mb-3"><i class="bi bi-journal-text me-2"></i>Detalles Adicionales</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-2 text-muted">Fecha y Hora</dt>
                        <dd class="col-sm-10">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-2 text-muted">Atendido por</dt>
                        <dd class="col-sm-10">@Model.NombreEmpleado</dd>

                        <dt class="col-sm-2 text-muted">Observación</dt>
                        <dd class="col-sm-10">
                            @if (string.IsNullOrWhiteSpace(Model.Observacion))
                            {
                                <em class="text-muted">Ninguna</em>
                            }
                            else
                            {
                                @Model.Observacion
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
