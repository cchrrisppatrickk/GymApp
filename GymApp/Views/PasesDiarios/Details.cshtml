@model GymApp.ViewModels.PaseDiarioListDTO

@{
    ViewData["Title"] = "Detalles del Pase Diario";
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <div class="flex items-center gap-4 mb-1">
                <div class="w-12 h-12 rounded-2xl bg-purple-50 text-purple-600 flex items-center justify-center border border-purple-100/50 shadow-sm">
                    <i class="bi bi-info-circle text-2xl"></i>
                </div>
                <h1 class="text-3xl font-display font-extrabold text-slate-950 tracking-tight m-0">Detalle de Pase #@Model.PaseDiarioId</h1>
            </div>
            <p class="text-slate-600 text-sm font-medium ml-1">Comprobante de acceso rápido y registro de venta</p>
        </div>
        
        <a asp-action="Index" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-slate-600 hover:text-indigo-600 bg-white hover:bg-slate-50 px-5 py-2.5 rounded-xl border border-slate-200 transition-all active:scale-95">
            <i class="bi bi-arrow-left"></i>
            <span>Volver</span>
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Tarjeta: Info del Cliente -->
        <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden group">
            <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/30 flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white text-purple-600 flex items-center justify-center border border-slate-200 shadow-sm group-hover:scale-110 transition-transform">
                    <i class="bi bi-person-badge text-xl"></i>
                </div>
                <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Información del Cliente</h3>
            </div>
            <div class="p-8 space-y-6">
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Nombre / Identificación</p>
                    <p class="text-xl font-bold text-slate-900">@Model.NombreCliente</p>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Turno de Acceso</p>
                    <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-bold uppercase bg-purple-50 text-purple-700 border border-purple-100">
                        @Model.NombreTurno
                    </span>
                </div>
            </div>
        </div>

        <!-- Tarjeta: Info Financiera -->
        <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden group">
            <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/30 flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white text-emerald-600 flex items-center justify-center border border-slate-200 shadow-sm group-hover:scale-110 transition-transform">
                    <i class="bi bi-wallet2 text-xl"></i>
                </div>
                <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Registro de Pago</h3>
            </div>
            <div class="p-8 space-y-6 text-center sm:text-left">
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Monto de Inversión</p>
                    <p class="text-4xl font-display font-black text-emerald-600 tracking-tighter">S/ @Model.Monto.ToString("0.00")</p>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Método Utilizado</p>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-bold uppercase @(Model.MetodoPago == "Efectivo" ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : Model.MetodoPago == "Tarjeta" ? "bg-amber-50 text-amber-700 border border-amber-100" : "bg-indigo-50 text-indigo-700 border border-indigo-100")">
                        @if(Model.MetodoPago == "Efectivo") { <i class="bi bi-cash-stack"></i> }
                        else if(Model.MetodoPago == "Tarjeta") { <i class="bi bi-credit-card"></i> }
                        else { <i class="bi bi-phone-vibrate"></i> }
                        @Model.MetodoPago
                    </span>
                </div>
            </div>
        </div>

        <!-- Tarjeta: Detalles Técnicos -->
        <div class="md:col-span-2 bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden group">
            <div class="p-8 lg:p-10 grid grid-cols-1 sm:grid-cols-3 gap-8">
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Fecha y Hora de Emisión</p>
                    <p class="text-sm font-bold text-slate-900 font-mono">@Model.Fecha.ToString("dd 'de' MMMM, yyyy - HH:mm")</p>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Atendido por</p>
                    <p class="text-sm font-bold text-slate-700">@Model.NombreEmpleado</p>
                </div>
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Observación Registrada</p>
                    <p class="text-sm font-medium text-slate-600 italic">
                        @(string.IsNullOrWhiteSpace(Model.Observacion) ? "Sin comentarios adicionales" : Model.Observacion)
                    </p>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ComprobanteRuta))
        {
            <div class="md:col-span-2 bg-slate-950 rounded-[3rem] border border-white/5 shadow-2xl overflow-hidden p-8 lg:p-12">
                <div class="flex items-center justify-between mb-8">
                    <div class="flex items-center gap-3 text-white">
                        <div class="w-10 h-10 rounded-xl bg-white/10 text-white flex items-center justify-center border border-white/10 shadow-sm">
                            <i class="bi bi-image text-xl"></i>
                        </div>
                        <h3 class="text-lg font-display font-bold tracking-tight m-0">Evidencia de Operación</h3>
                    </div>
                    <a href="@Model.ComprobanteRuta" target="_blank" class="px-5 py-2 bg-white/10 hover:bg-white/20 text-white text-[10px] font-bold uppercase tracking-widest rounded-xl transition-all border border-white/10">
                        <i class="bi bi-fullscreen mr-2"></i> Pantalla Completa
                    </a>
                </div>
                
                <div class="relative group mx-auto max-w-2xl bg-black rounded-2xl overflow-hidden shadow-inner border border-white/5">
                    <img src="@Model.ComprobanteRuta" class="w-full h-auto max-h-[500px] object-contain transition-transform duration-700 group-hover:scale-[1.02]" alt="Comprobante de @Model.MetodoPago" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-center p-6">
                        <p class="text-white/80 text-[10px] font-bold uppercase tracking-[0.3em]">Captura del Comprobante</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
