@model IEnumerable<GymApp.ViewModels.PaseDiarioListDTO>
@{
    ViewData["Title"] = "Pases Diarios";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-ticket-perforated me-2"></i>Pases Diarios</h5>
        @if (User.HasClaim("Permiso", "PasesDiarios.Crear") || User.IsInRole("Admin"))
        {
            <a asp-action="Registrar" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Registrar Pase
            </a>
        }
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="pasesTable">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Turno</th>
                        <th>Método Pago</th>
                        <th>Monto</th>
                        <th>Atendido por</th>
                        <th>Observación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="fw-medium">@item.NombreCliente</span>
                            </td>
                            <td><span class="badge bg-info text-dark">@item.NombreTurno</span></td>
                            <td>
                                @if(item.MetodoPago == "Efectivo")
                                {
                                    <span class="badge bg-success"><i class="bi bi-cash"></i> Efectivo</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary"><i class="bi bi-phone"></i> Yape</span>
                                }
                            </td>
                            <td class="fw-bold text-success">S/ @item.Monto.ToString("0.00")</td>
                            <td><small class="text-muted">@item.NombreEmpleado</small></td>
                            <td>@item.Observacion</td>
                            <td>
                                @if (User.HasClaim("Permiso", "PasesDiarios.Eliminar") || User.IsInRole("Admin"))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-hard-delete-pase" data-id="@item.PaseDiarioId" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#pasesTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                },
                order: [[0, 'desc']]
            });

            // Lógica para Borrado Físico con SweetAlert
            $('.btn-hard-delete-pase').on('click', function () {
                const id = $(this).data('id');
                Swal.fire({
                    title: '¿Estás seguro?',
                    text: "Esta acción eliminará permanentemente el pase diario. ¡No se puede deshacer!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(`/PasesDiarios/EliminarFisicamente/${id}`, {
                            method: 'DELETE',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire('Eliminado!', data.message, 'success')
                                .then(() => location.reload());
                            } else {
                                Swal.fire('Error', data.message || 'No se pudo eliminar el pase diario.', 'error');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            Swal.fire('Error', 'Hubo un problema al procesar la solicitud.', 'error');
                        });
                    }
                });
            });
        });
    </script>
}
