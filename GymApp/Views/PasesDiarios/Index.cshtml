@model IEnumerable<GymApp.ViewModels.PaseDiarioListDTO>
@using GymApp.Constants
@{
    ViewData["Title"] = "Pases Diarios";
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center border border-purple-100/50 shadow-sm">
                    <i class="bi bi-ticket-perforated text-xl"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Pases Diarios</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Control de accesos rápidos y ventas por turno</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PasesDiariosCrear) || User.HasClaim(TipoClaim.Permiso, AppPermisos.AdminAccesoTotal) || User.IsInRole(AppRoles.Admin))
        {
            <a asp-action="Registrar" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-md shadow-indigo-600/20 font-medium active:scale-95 group">
                <i class="bi bi-plus-lg text-lg group-hover:scale-110 transition-transform"></i>
                <span>Registrar Pase</span>
            </a>
        }
    </div>

    <!-- Tabla -->
    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse" id="pasesTable">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Fecha / Hora</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Socio / Cliente</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Turno</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Inversión</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Atendido por</th>
                        <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100/80">
                    @foreach (var item in Model)
                    {
                        <tr class="group hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-slate-900">@item.Fecha.ToString("dd/MM/yyyy")</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">@item.Fecha.ToString("HH:mm")</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center font-bold text-xs border border-purple-100/50">
                                        @item.NombreCliente.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="text-sm font-bold text-slate-900 tracking-tight">@item.NombreCliente</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-slate-100 text-slate-600 border border-slate-200/50">
                                    @item.NombreTurno
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-emerald-600 font-mono tracking-tight">S/ @item.Monto.ToString("0.00")</span>
                                    <span class="inline-flex items-center gap-1 text-[9px] font-black uppercase text-slate-400">
                                        @if(item.MetodoPago == "Efectivo") { <i class="bi bi-cash-stack"></i> } else { <i class="bi bi-phone-vibrate"></i> }
                                        @item.MetodoPago
                                    </span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-xs font-medium text-slate-600 italic">@item.NombreEmpleado</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-action="Details" asp-route-id="@item.PaseDiarioId" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-200" title="Ver Detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PasesDiariosEliminar) || User.HasClaim(TipoClaim.Permiso, AppPermisos.AdminAccesoTotal) || User.IsInRole(AppRoles.Admin))
                                    {
                                        <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-400 hover:text-rose-600 hover:bg-rose-50 transition-all duration-200 btn-hard-delete-pase" data-id="@item.PaseDiarioId" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Ajustes sutiles para DataTables con Tailwind */
        .dataTables_wrapper .dataTables_length select,
        .dataTables_wrapper .dataTables_filter input {
            @apply bg-slate-50 border-slate-200 rounded-xl px-4 py-2 text-sm focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all;
        }
        .dataTables_wrapper .dataTables_info {
            @apply text-xs font-bold text-slate-400 uppercase tracking-widest mt-4 ml-4;
        }
        .dataTables_wrapper .dataTables_paginate {
            @apply mt-4 mr-4;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @apply bg-white border border-slate-200 rounded-xl px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-600 hover:bg-slate-50 transition-all !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            @apply bg-indigo-600 text-white border-indigo-600 hover:bg-indigo-700 !important;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#pasesTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'
                },
                order: [[0, 'desc']],
                pageLength: 10,
                dom: '<"flex flex-col md:flex-row items-center justify-between gap-4 p-6"fl>rt<"flex flex-col md:flex-row items-center justify-between gap-4 p-6"ip>'
            });

            // Lógica para Borrado Físico con SweetAlert
            $('.btn-hard-delete-pase').on('click', function () {
                const id = $(this).data('id');
                Swal.fire({
                    title: '¿ELIMINAR PASE?',
                    text: "Esta acción es definitiva y el ingreso ya no figurará en reportes.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar',
                    customClass: {
                        confirmButton: 'bg-rose-600 text-white px-6 py-2.5 rounded-xl font-bold uppercase tracking-widest text-xs ml-3',
                        cancelButton: 'bg-slate-100 text-slate-600 px-6 py-2.5 rounded-xl font-bold uppercase tracking-widest text-xs'
                    },
                    buttonsStyling: false
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(`/PasesDiarios/EliminarFisicamente/${id}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire('Eliminado!', data.message, 'success')
                                .then(() => location.reload());
                            } else {
                                Swal.fire('Error', data.message || 'No se pudo eliminar el pase diario.', 'error');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            Swal.fire('Error', 'Hubo un problema al procesar la solicitud.', 'error');
                        });
                    }
                });
            });
        });
    </script>
}
