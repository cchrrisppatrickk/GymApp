@model GymApp.ViewModels.PagedResult<GymApp.ViewModels.UsuarioViewModel>
@using GymApp.Constants

@{
    ViewData["Title"] = "Gestión de Usuarios";
    var rolesSelectList = ViewBag.Roles as SelectList;
    var mes = ViewBag.Mes as int?;
    var anio = ViewBag.Anio as int?;
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                    <i data-lucide="users" class="w-6 h-6"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">@ViewData["TituloListado"]</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Administra los accesos, membresías y perfiles de los socios</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-sm shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModalCrear()">
                <i data-lucide="user-plus" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                <span>Nuevo Usuario</span>
            </button>
        }
    </div>

    <!-- Filtros -->
    <form asp-action="Index" method="get" class="bg-white rounded-[2rem] border border-slate-200 p-2 shadow-sm">
        <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-2">
            <!-- Búsqueda por Texto -->
            <div class="flex-1 relative group">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-600 group-focus-within:text-indigo-500 transition-colors">
                    <i data-lucide="search" class="w-5 h-5"></i>
                </div>
                <input type="text" name="buscar" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl pl-11 pr-4 py-2.5 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" placeholder="Nombre o DNI..." value="@Model.SearchTerm">
            </div>

            <div class="grid grid-cols-2 md:grid-cols-2 lg:flex gap-2">
                <!-- Mes -->
                <div class="relative min-w-[160px]">
                    <select name="mes" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl px-4 py-2.5 text-sm font-bold text-slate-600 appearance-none cursor-pointer transition-all">
                        <option value="">Todos los meses</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            if (mes == i)
                            {
                                <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                            else
                            {
                                <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                        }
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600 text-xs">
                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                    </div>
                </div>

                <!-- Año -->
                <div class="relative min-w-[140px]">
                    <select name="anio" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl px-4 py-2.5 text-sm font-bold text-slate-600 appearance-none cursor-pointer transition-all">
                        <option value="">Todos los años</option>
                        @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                        {
                            if (anio == i)
                            {
                                <option value="@i" selected>@i</option>
                            }
                            else
                            {
                                <option value="@i">@i</option>
                            }
                        }
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600 text-xs">
                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                    </div>
                </div>

                <!-- Botones de Acción -->
                <div class="flex items-center gap-2 col-span-2">
                    <button type="submit" class="flex-1 lg:flex-none inline-flex items-center justify-center w-full lg:w-11 h-11 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-sm shadow-indigo-600/10 active:scale-95" title="Aplicar filtros">
                        <i data-lucide="filter" class="w-5 h-5"></i>
                        <span class="lg:hidden ml-2 font-bold uppercase tracking-widest text-xs">Filtrar</span>
                    </button>
                    <a asp-action="Index" class="flex-1 lg:flex-none inline-flex items-center justify-center w-full lg:w-11 h-11 bg-slate-100 text-slate-700 rounded-xl hover:bg-slate-200 transition-all duration-300 active:scale-95" title="Limpiar filtros">
                        <i data-lucide="x" class="w-5 h-5"></i>
                        <span class="lg:hidden ml-2 font-bold uppercase tracking-widest text-xs">Limpiar</span>
                    </a>
                </div>
            </div>
        </div>
    </form>

    <!-- Tabla -->
    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Socio / Cliente</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Rol</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">DNI</th>
                        <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100/80">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="group hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-sm border border-indigo-100/50 transition-transform group-hover:scale-110">
                                        @item.NombreCompleto.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-slate-950 tracking-tight">@item.NombreCompleto</div>
                                        <div class="text-[10px] font-medium text-slate-600 uppercase tracking-wider">Gym Member</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-indigo-50 text-indigo-700 border border-indigo-100/50">
                                    @item.NombreRol
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                @if (string.IsNullOrEmpty(item.Dni))
                                {
                                    <span class="text-xs font-medium text-slate-500 italic">No registrado</span>
                                }
                                else
                                {
                                    <span class="text-xs font-bold text-slate-600 font-mono">@item.Dni</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <!-- Botón Detalles -->
                                    <a asp-action="Details" asp-route-id="@item.UserId" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-200" title="Ver Detalles">
                                        <i data-lucide="eye" class="w-4 h-4"></i>
                                    </a>
                                    <!-- Botón Ver QR -->
                                    <button class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-all duration-200" onclick="verQR(@item.UserId, '@item.NombreCompleto')" title="Ver Código QR">
                                        <i data-lucide="qr-code" class="w-4 h-4"></i>
                                    </button>
                                    <!-- Botón Editar -->
                                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosEditar) || User.IsInRole(AppRoles.Admin))
                                    {
                                        <button class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-amber-600 hover:bg-amber-50 transition-all duration-200" onclick="abrirModalEditar(@item.UserId)" title="Editar">
                                            <i data-lucide="pencil" class="w-4 h-4"></i>
                                        </button>
                                    }
                                    <!-- Botón Eliminar -->
                                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosEliminar) || User.IsInRole(AppRoles.Admin))
                                    {
                                        <button class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-rose-600 hover:bg-rose-50 transition-all duration-200" onclick="eliminarUsuario(@item.UserId)" title="Eliminar">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-8 pb-12">
            @if (Model.HasPreviousPage)
            {
                <a class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage - 1)" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    <span class="hidden sm:inline">Anterior</span>
                </a>
            }
            else
            {
                <div class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-slate-50 border border-slate-100 text-slate-500 rounded-xl cursor-not-allowed font-medium text-sm">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    <span class="hidden sm:inline">Anterior</span>
                </div>
            }

            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <div class="w-10 h-10 flex items-center justify-center bg-indigo-600 text-white rounded-xl font-bold text-sm shadow-sm shadow-indigo-600/20">@i</div>
                    }
                    else if (i <= 3 || i > Model.TotalPages - 3 || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                    {
                        <a class="w-10 h-10 flex items-center justify-center bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">@i</a>
                    }
                    else if (i == 4 && Model.CurrentPage > 5)
                    {
                        <div class="w-10 h-10 flex items-center justify-center text-slate-600">...</div>
                    }
                    else if (i == Model.TotalPages - 3 && Model.CurrentPage < Model.TotalPages - 4)
                    {
                        <div class="w-10 h-10 flex items-center justify-center text-slate-600">...</div>
                    }
                }
            </div>

            @if (Model.HasNextPage)
            {
                <a class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage + 1)" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">
                    <span class="hidden sm:inline">Siguiente</span>
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
            }
            else
            {
                <div class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-slate-50 border border-slate-100 text-slate-500 rounded-xl cursor-not-allowed font-medium text-sm">
                    <span class="hidden sm:inline">Siguiente</span>
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </div>
            }
        </div>
    }
</div>

<!-- ========================= -->
<!-- MODAL DE GESTIÓN (UPSERT) -->
<!-- ========================= -->
<div class="modal fade" id="modalUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div>
                    <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight" id="tituloModal">Usuario</h5>
                    <p class="text-slate-700 text-xs font-medium uppercase tracking-widest mt-1">Gestión de datos personales</p>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-600 transition-colors" data-bs-dismiss="modal" aria-label="Close">
                    <i data-lucide="x" class="w-6 h-6"></i>
                </button>
            </div>
            <div class="p-8">
                <form id="formUsuario" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="UserId" value="0" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <!-- Columna Izquierda -->
                        <div class="space-y-5">
                            <div>
                                <label for="RoleId" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Rol del Usuario</label>
                                <div class="relative">
                                    <select id="RoleId" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 appearance-none transition-all" asp-items="rolesSelectList" required>
                                        <option value="">-- Seleccione Rol --</option>
                                    </select>
                                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label for="NombreCompleto" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Nombre Completo</label>
                                <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" id="NombreCompleto" required placeholder="Ej. Juan Pérez" />
                            </div>

                            <div>
                                <label for="Dni" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">DNI / Identificación</label>
                                <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" id="Dni" placeholder="Opcional" />
                            </div>

                            <div>
                                <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Foto de Perfil</label>
                                <div class="relative group">
                                    <input type="file" id="FotoArchivo" name="FotoArchivo" class="block w-full text-xs text-slate-700 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 transition-all cursor-pointer" accept="image/*" />
                                </div>
                            </div>
                        </div>

                        <!-- Columna Derecha -->
                        <div class="space-y-5">
                            <div>
                                <label for="Email" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Correo Electrónico</label>
                                <input type="email" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" id="Email" placeholder="ejemplo@gym.com" />
                            </div>

                            <div>
                                <label for="Telefono" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Teléfono</label>
                                <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" id="Telefono" placeholder="+51 987..." />
                            </div>

                            <div class="flex items-center justify-between bg-slate-50 p-4 rounded-2xl border border-slate-100">
                                <label class="text-xs font-bold text-slate-600 uppercase tracking-widest" for="Estado">Usuario Activo</label>
                                <div class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" id="Estado" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                                </div>
                            </div>

                            <!-- Webcam Capture Area -->
                            <div class="bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200 p-4">
                                <div class="flex items-center gap-2 mb-3">
                                    <div class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                                        <i data-lucide="video" class="w-4 h-4"></i>
                                    </div>
                                    <span class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Capturar desde Webcam</span>
                                </div>
                                
                                <!-- Viewport Container -->
                                <div class="relative bg-slate-900 rounded-xl overflow-hidden mb-4 shadow-inner aspect-[4/3] flex items-center justify-center">
                                    <!-- Placeholders -->
                                    <div id="camaraPlaceholder" class="text-center p-6 transition-all duration-300 text-slate-700">
                                        <i data-lucide="camera-off" class="w-10 h-10 mx-auto mb-2 opacity-20"></i>
                                        <p class="text-[10px] font-bold uppercase tracking-widest">Cámara Desactivada</p>
                                    </div>
                                    
                                    <!-- Video Stream (WebRTC) -->
                                    <video id="videoWebcam" autoplay playsinline class="absolute inset-0 w-full h-full object-cover hidden"></video>
                                    
                                    <!-- Image Preview -->
                                    <img id="imgPrevisualizacion" src="" alt="Previsualización" class="absolute inset-0 w-full h-full object-cover hidden" />
                                </div>

                                <!-- Controls -->
                                <div class="flex gap-2">
                                    <button type="button" id="btnActivarCamara" class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 bg-indigo-50 text-indigo-600 rounded-xl hover:bg-indigo-100 transition-colors text-[10px] font-bold uppercase tracking-widest" onclick="activarWebcam()">
                                        <i data-lucide="video" class="w-3.5 h-3.5"></i> Activar
                                    </button>
                                    <button type="button" id="btnDesactivarCamara" class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 bg-rose-50 text-rose-600 rounded-xl hover:bg-rose-100 transition-colors text-[10px] font-bold uppercase tracking-widest hidden" onclick="desactivarWebcamManualmente()">
                                        <i data-lucide="video-off" class="w-3.5 h-3.5"></i> Apagar
                                    </button>
                                    <button type="button" id="btnTomarFoto" class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition-colors text-[10px] font-bold uppercase tracking-widest hidden" onclick="tomarFotoWebcam()">
                                        <i data-lucide="camera" class="w-3.5 h-3.5"></i> Capturar
                                    </button>
                                </div>
                                
                                <canvas id="canvasFoto" class="hidden"></canvas>
                                <input type="hidden" id="FotoBase64" name="FotoBase64" />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-6 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-600/20 transition-all active:scale-95 font-bold text-xs uppercase tracking-widest" onclick="guardarUsuario()">Guardar Datos</button>
            </div>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL DE CÓDIGO QR       -->
<!-- ========================= -->
<div class="modal fade" id="modalQR" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm text-center">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fs-6" id="qrTitulo">Código QR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- La imagen se carga dinámicamente -->
                <img id="imgQR" src="" alt="Cargando QR..." class="img-fluid border p-2" />
                <p class="mt-2 text-muted small">Escanee este código en la entrada</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var modalUsuario, modalQR;
        let webcamStream = null;

        document.addEventListener('DOMContentLoaded', function () {
            modalUsuario = new bootstrap.Modal(document.getElementById('modalUsuario'));
            modalQR = new bootstrap.Modal(document.getElementById('modalQR'));

            // Escuchar el evento de cierre del modal para apagar la cámara y limpiar
            document.getElementById('modalUsuario').addEventListener('hidden.bs.modal', function () {
                desactivarWebcamSilencioso();
            });

            // Escuchar el cambio en el input file manual para previsualizarlo y desactivar webcam
            document.getElementById('FotoArchivo').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    desactivarWebcamSilencioso();

                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const imgPreview = document.getElementById('imgPrevisualizacion');
                        const placeholder = document.getElementById('camaraPlaceholder');
                        const video = document.getElementById('videoWebcam');
                        
                        placeholder.style.display = 'none';
                        video.style.display = 'none';
                        imgPreview.src = event.target.result;
                        imgPreview.style.display = 'block';

                        // Limpiar el hidden de base64 ya que se subió un archivo físico
                        document.getElementById('FotoBase64').value = '';
                    };
                    reader.readAsDataURL(file);
                }
            });
        });

        // ==========================================
        // FUNCIONES DE CONTROL DE WEBCAM (WebRTC)
        // ==========================================
        function activarWebcam() {
            const video = document.getElementById('videoWebcam');
            const placeholder = document.getElementById('camaraPlaceholder');
            const imgPreview = document.getElementById('imgPrevisualizacion');
            const btnActivar = document.getElementById('btnActivarCamara');
            const btnDesactivar = document.getElementById('btnDesactivarCamara');
            const btnTomar = document.getElementById('btnTomarFoto');

            // Limpiar previsualizaciones anteriores
            imgPreview.style.display = 'none';
            imgPreview.src = '';
            document.getElementById('FotoBase64').value = '';

            // Solicitar permisos y obtener stream
            navigator.mediaDevices.getUserMedia({
                video: {
                    width: { ideal: 640 },
                    height: { ideal: 480 },
                    facingMode: "user"
                },
                audio: false
            })
            .then(function (stream) {
                webcamStream = stream;
                video.srcObject = stream;
                
                placeholder.style.display = 'none';
                video.style.display = 'block';
                btnActivar.style.display = 'none';
                btnDesactivar.style.display = 'inline-flex';
                btnTomar.style.display = 'inline-flex';
            })
            .catch(function (err) {
                console.error("No se pudo acceder a la webcam: ", err);
                Swal.fire({
                    title: 'Acceso a Cámara Denegado',
                    text: 'Asegúrese de otorgar permisos de cámara al sitio o conectar un dispositivo USB.',
                    icon: 'error'
                });
            });
        }

        function detenerWebcam() {
            if (webcamStream) {
                webcamStream.getTracks().forEach(track => track.stop());
                webcamStream = null;
            }
            const video = document.getElementById('videoWebcam');
            if (video) {
                video.srcObject = null;
            }
        }

        function desactivarWebcamSilencioso() {
            detenerWebcam();
            const placeholder = document.getElementById('camaraPlaceholder');
            const video = document.getElementById('videoWebcam');
            const btnActivar = document.getElementById('btnActivarCamara');
            const btnDesactivar = document.getElementById('btnDesactivarCamara');
            const btnTomar = document.getElementById('btnTomarFoto');

            if (placeholder) placeholder.style.display = 'block';
            if (video) video.style.display = 'none';
            if (btnActivar) btnActivar.style.display = 'inline-flex';
            if (btnDesactivar) btnDesactivar.style.display = 'none';
            if (btnTomar) btnTomar.style.display = 'none';
        }

        function desactivarWebcamManualmente() {
            desactivarWebcamSilencioso();
            // Limpiar foto previa si la cámara se apaga voluntariamente
            const imgPreview = document.getElementById('imgPrevisualizacion');
            if (imgPreview) {
                imgPreview.style.display = 'none';
                imgPreview.src = '';
            }
            document.getElementById('FotoBase64').value = '';
        }

        function tomarFotoWebcam() {
            const video = document.getElementById('videoWebcam');
            const canvas = document.getElementById('canvasFoto');
            const context = canvas.getContext('2d');
            const imgPreview = document.getElementById('imgPrevisualizacion');
            const btnActivar = document.getElementById('btnActivarCamara');
            const btnDesactivar = document.getElementById('btnDesactivarCamara');
            const btnTomar = document.getElementById('btnTomarFoto');

            if (!video.srcObject) return;

            // Fijar resolución del canvas según stream real de la webcam
            canvas.width = video.videoWidth || 640;
            canvas.height = video.videoHeight || 480;

            // Dibujar el cuadro actual en el canvas
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            // Exportar a base64
            const dataUrl = canvas.toDataURL('image/jpeg', 0.9);

            // Almacenar en hidden input
            document.getElementById('FotoBase64').value = dataUrl;

            // Mostrar previsualización
            imgPreview.src = dataUrl;
            imgPreview.style.display = 'block';

            // Ocultar viewport de video
            video.style.display = 'none';

            // Restaurar botones de control
            btnActivar.style.display = 'inline-flex';
            btnDesactivar.style.display = 'none';
            btnTomar.style.display = 'none';

            // Limpiar selección de archivo físico si existía
            document.getElementById('FotoArchivo').value = '';

            // Detener transmisión para no consumir recursos
            detenerWebcam();
        }

        // Utilidad para convertir Base64 DataURL a un objeto File de JS
        function dataURLtoFile(dataurl, filename) {
            var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],
                bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
            while(n--){
                u8arr[n] = bstr.charCodeAt(n);
            }
            return new File([u8arr], filename, {type:mime});
        }

        // Limpieza de estados visuales del capturador
        function resetearEstadoCapturador() {
            desactivarWebcamSilencioso();
            const imgPreview = document.getElementById('imgPrevisualizacion');
            if (imgPreview) {
                imgPreview.style.display = 'none';
                imgPreview.src = '';
            }
            const base64Input = document.getElementById('FotoBase64');
            if (base64Input) base64Input.value = '';
        }

        // 1. ABRIR MODAL CREAR
        function abrirModalCrear() {
            document.getElementById('tituloModal').innerText = "Nuevo Usuario";
            document.getElementById('formUsuario').reset();
            document.getElementById('UserId').value = "0";

            // Limpiar permisos
            document.querySelectorAll('.permiso-checkbox').forEach(cb => cb.checked = false);

            resetearEstadoCapturador();
            modalUsuario.show();
        }

        // 2. ABRIR MODAL EDITAR
        function abrirModalEditar(id) {
            document.getElementById('tituloModal').innerText = "Editar Usuario";
            resetearEstadoCapturador();

            fetch(`/Usuarios/GetUsuario/${id}`)
                .then(res => res.json())
                .then(response => {
                    if (response.success) {
                        const d = response.data;
                        document.getElementById('UserId').value = d.userId;
                        document.getElementById('RoleId').value = d.roleId;
                        document.getElementById('NombreCompleto').value = d.nombreCompleto;
                        document.getElementById('Dni').value = d.dni;
                        document.getElementById('Email').value = d.email;
                        document.getElementById('Telefono').value = d.telefono;
                        document.getElementById('Estado').checked = d.estado;

                        // Cargar permisos
                        document.querySelectorAll('.permiso-checkbox').forEach(cb => cb.checked = false);
                        if (d.permisosSeleccionados && d.permisosSeleccionados.length > 0) {
                            d.permisosSeleccionados.forEach(p => {
                                const cb = document.querySelector(`.permiso-checkbox[value="${p}"]`);
                                if (cb) cb.checked = true;
                            });
                        }

                        modalUsuario.show();
                    } else {
                        Swal.fire('Error', 'No se pudieron cargar los datos', 'error');
                    }
                });
        }

        // 3. GUARDAR USUARIO (Usando FormData para archivos)
        function guardarUsuario() {
            var rolId = document.getElementById("RoleId").value;
            if (!rolId) {
                Swal.fire("Atención", "Debe seleccionar un Rol", "warning");
                return;
            }

            var formData = new FormData();
            formData.append("UserId", document.getElementById("UserId").value);
            formData.append("RoleId", rolId);
            formData.append("NombreCompleto", document.getElementById("NombreCompleto").value);
            formData.append("Dni", document.getElementById("Dni").value);
            formData.append("Email", document.getElementById("Email").value);
            formData.append("Telefono", document.getElementById("Telefono").value);
            formData.append("Estado", document.getElementById("Estado").checked);

            // Permisos
            var permisosSeleccionados = Array.from(document.querySelectorAll('.permiso-checkbox:checked')).map(cb => cb.value);
            permisosSeleccionados.forEach(p => formData.append("PermisosSeleccionados", p));

            // Manejo de fotos: Priorizar archivo físico, si no usar webcam (Base64)
            var foto = document.getElementById("FotoArchivo").files[0];
            if (foto) {
                formData.append("FotoArchivo", foto);
            } else {
                var fotoBase64 = document.getElementById("FotoBase64").value;
                if (fotoBase64) {
                    var file = dataURLtoFile(fotoBase64, "webcam_photo.jpg");
                    formData.append("FotoArchivo", file);
                }
            }

            // C. ENVÍO AJAX
            $.ajax({
                url: "/Usuarios/Save",
                type: "POST",
                data: formData,
                processData: false, 
                contentType: false, 
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (response) {
                    if (response.success) {
                        modalUsuario.hide();
                        Swal.fire({
                            title: "¡Éxito!",
                            text: response.message,
                            icon: "success"
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        var msg = response.message;
                        if(response.errors){
                            msg += ": " + JSON.stringify(response.errors);
                        }
                        Swal.fire("Error", msg, "error");
                    }
                },
                error: function (xhr) {
                    console.log(xhr.responseText);
                    Swal.fire("Error del Servidor", "Revise la consola para más detalles", "error");
                }
            });
        }

        // 4. ELIMINAR
        function eliminarUsuario(id) {
            Swal.fire({
                title: '¿Eliminar usuario?',
                text: "Esta acción no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Usuarios/Delete', { id: id }, function(data) {
                         if (data.success) {
                            Swal.fire('Eliminado', data.message, 'success').then(() => location.reload());
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    });
                }
            });
        }

        // 5. VER QR
        function verQR(id, nombre) {
            document.getElementById('qrTitulo').innerText = "QR: " + nombre;
            const img = document.getElementById('imgQR');
            img.src = `/Usuarios/ObtenerQR/${id}?t=${new Date().getTime()}`;
            modalQR.show();
        }
    </script>
}