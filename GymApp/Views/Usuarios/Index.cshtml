@model GymApp.ViewModels.PagedResult<GymApp.ViewModels.UsuarioViewModel>
@using GymApp.Constants

@{
    ViewData["Title"] = "Gestión de Usuarios";
    var rolesSelectList = ViewBag.Roles as SelectList;
    var mes = ViewBag.Mes as int?;
    var anio = ViewBag.Anio as int?;
}

<div class="space-y-4 mt-2">
    <!-- Encabezado Compacto -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-1">
        <div>
            <div class="flex items-center gap-2 mb-0.5">
                <div class="w-8 h-8 rounded-lg bg-slate-900 text-white flex items-center justify-center shadow-sm">
                    <i data-lucide="users" class="w-5 h-5"></i>
                </div>
                <h2 class="text-xl font-display font-bold text-slate-900 tracking-tight m-0">@ViewData["TituloListado"]</h2>
            </div>
            <p class="text-slate-500 text-xs font-medium ml-0.5">Gestión de accesos y perfiles de socios</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-3 py-1.5 bg-slate-900 text-white rounded-lg hover:bg-slate-800 transition-all shadow-sm font-bold text-xs active:scale-95 group" onclick="abrirModalCrear()">
                <i data-lucide="user-plus" class="w-3.5 h-3.5"></i>
                <span>NUEVO USUARIO</span>
            </button>
        }
    </div>

    <!-- Filtros Optimizados -->
    <form asp-action="Index" method="get" class="bg-white rounded-xl border border-slate-200 p-1.5 shadow-sm">
        <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-2">
            <!-- Búsqueda -->
            <div class="flex-1 relative group">
                <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-slate-600 transition-colors">
                    <i data-lucide="search" class="w-4 h-4"></i>
                </div>
                <input type="text" name="buscar" class="w-full bg-slate-50 border-slate-200 focus:bg-white focus:ring-2 focus:ring-slate-900/5 focus:border-slate-900 rounded-lg pl-9 pr-3 py-1.5 text-xs font-medium text-slate-900 transition-all placeholder:text-slate-400" placeholder="Buscar por nombre o DNI..." value="@Model.SearchTerm">
            </div>

            <div class="flex flex-wrap items-center gap-2">
                <!-- Mes -->
                <div class="relative">
                    <select name="mes" class="bg-slate-50 border-slate-200 focus:bg-white focus:ring-2 focus:ring-slate-900/5 focus:border-slate-900 rounded-lg pl-3 pr-8 py-1.5 text-xs font-bold text-slate-600 appearance-none cursor-pointer transition-all min-w-[140px]">
                        <option value="">TODOS LOS MESES</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            if (mes == i)
                            {
                                <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                            else
                            {
                                <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                        }
                    </select>
                    <div class="absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </div>
                </div>

                <!-- Año -->
                <div class="relative">
                    <select name="anio" class="bg-slate-50 border-slate-200 focus:bg-white focus:ring-2 focus:ring-slate-900/5 focus:border-slate-900 rounded-lg pl-3 pr-8 py-1.5 text-xs font-bold text-slate-600 appearance-none cursor-pointer transition-all min-w-[100px]">
                        <option value="">AÑO</option>
                        @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                        {
                            if (anio == i)
                            {
                                <option value="@i" selected>@i</option>
                            }
                            else
                            {
                                <option value="@i">@i</option>
                            }
                        }
                    </select>
                    <div class="absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </div>
                </div>

                <!-- Botones -->
                <div class="flex items-center gap-1.5">
                    <button type="submit" class="inline-flex items-center justify-center px-4 py-1.5 bg-slate-900 text-white rounded-lg hover:bg-slate-800 transition-all font-bold text-xs active:scale-95 gap-2">
                        <i data-lucide="filter" class="w-3.5 h-3.5"></i>
                        <span>APLICAR FILTRO</span>
                    </button>
                    <a asp-action="Index" class="inline-flex items-center justify-center w-8 h-8 bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition-all active:scale-95" title="Limpiar">
                        <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
                    </a>
                </div>
            </div>
        </div>
    </form>

    <!-- Tabla Optimizada -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-slate-900 text-white border-b border-slate-800">
                        <th class="px-3 py-2.5 text-left text-[10px] font-bold uppercase tracking-wider">TIPO</th>
                        <th class="px-3 py-2.5 text-left text-[10px] font-bold uppercase tracking-wider">NOMBRES</th>
                        <th class="px-3 py-2.5 text-left text-[10px] font-bold uppercase tracking-wider">APELLIDOS</th>
                        <th class="px-3 py-2.5 text-center text-[10px] font-bold uppercase tracking-wider">CODE</th>
                        <th class="px-3 py-2.5 text-center text-[10px] font-bold uppercase tracking-wider">PIN</th>
                        <th class="px-3 py-2.5 text-left text-[10px] font-bold uppercase tracking-wider">NRO DOCUMENTO</th>
                        <th class="px-3 py-2.5 text-left text-[10px] font-bold uppercase tracking-wider">GENERO</th>
                        <th class="px-3 py-2.5 text-center text-[10px] font-bold uppercase tracking-wider">ESTADO</th>
                        <th class="px-3 py-2.5 text-left text-[10px] font-bold uppercase tracking-wider">CREADO POR</th>
                        <th class="px-3 py-2.5 text-right text-[10px] font-bold uppercase tracking-wider">ACCIONES</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="group hover:bg-slate-50/80 transition-colors">
                            <td class="px-3 py-2">
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider bg-slate-100 text-slate-700 border border-slate-200">
                                    @item.NombreRol
                                </span>
                            </td>
                            <td class="px-3 py-2">
                                <div class="flex items-center gap-2">
                                    @if (!string.IsNullOrEmpty(item.FotoBase64))
                                    {
                                        var fotoUrl = item.FotoBase64.StartsWith("/") ? item.FotoBase64 : "/uploads/fotos/" + item.FotoBase64;
                                        <img src="@fotoUrl" class="w-6 h-6 rounded-md object-cover border border-slate-200 shadow-sm" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <div class="w-6 h-6 rounded-md bg-slate-100 text-slate-600 flex items-center justify-center font-bold text-[10px] border border-slate-200 uppercase">
                                            @item.NombreCompleto.Substring(0, 1)
                                        </div>
                                    }
                                    <span class="text-[11px] font-bold text-slate-900 uppercase">@item.NombreCompleto</span>
                                </div>
                            </td>
                            <td class="px-3 py-2 text-[11px] font-medium text-slate-600 uppercase">
                                @(string.IsNullOrEmpty(item.ApellidoPaterno + item.ApellidoMaterno) ? "-" : $"{item.ApellidoPaterno} {item.ApellidoMaterno}".Trim())
                            </td>
                            <td class="px-3 py-2 text-center text-[10px] font-bold text-slate-500">
                                #@item.UserId
                            </td>
                            <td class="px-3 py-2 text-center">
                                <span class="text-[10px] font-bold tracking-widest text-slate-400">
                                    @(string.IsNullOrEmpty(item.PinAcceso) ? "----" : item.PinAcceso)
                                </span>
                            </td>
                            <td class="px-3 py-2 text-[11px] font-bold text-slate-700">
                                @(string.IsNullOrEmpty(item.Dni) ? "S/DNI" : item.Dni)
                            </td>
                            <td class="px-3 py-2 text-center">
                                @if (item.Genero == "Masculino")
                                {
                                    <i data-lucide="mars" class="w-4 h-4 text-blue-500 mx-auto" title="Masculino"></i>
                                }
                                else if (item.Genero == "Femenino")
                                {
                                    <i data-lucide="venus" class="w-4 h-4 text-rose-500 mx-auto" title="Femenino"></i>
                                }
                                else
                                {
                                    <i data-lucide="circle" class="w-3 h-3 text-slate-400 mx-auto" title="@(string.IsNullOrEmpty(item.Genero) ? "No especificado" : item.Genero)"></i>
                                }
                            </td>
                            <td class="px-3 py-2 text-center">
                                @if (item.Estado)
                                {
                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">
                                        ACTIVO
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider bg-rose-50 text-rose-700 border border-rose-100">
                                        INACTIVO
                                    </span>
                                }
                            </td>
                            <td class="px-3 py-2 text-[10px] font-medium text-slate-500 uppercase truncate max-w-[100px]" title="@item.ModificadoPorNombre">
                                @item.ModificadoPorNombre
                            </td>
                            <td class="px-3 py-2 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-action="Details" asp-route-id="@item.UserId" class="w-7 h-7 flex items-center justify-center rounded-lg bg-slate-50 text-slate-600 hover:bg-slate-900 hover:text-white transition-all shadow-sm border border-slate-200 active:scale-90" title="Ver Detalles">
                                        <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                                    </a>
                                    <button class="w-7 h-7 flex items-center justify-center rounded-lg bg-slate-50 text-slate-600 hover:bg-slate-900 hover:text-white transition-all shadow-sm border border-slate-200 active:scale-90" onclick="verQR(@item.UserId, '@item.NombreCompleto')" title="Ver QR">
                                        <i data-lucide="qr-code" class="w-3.5 h-3.5"></i>
                                    </button>
                                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosEditar) || User.IsInRole(AppRoles.Admin))
                                    {
                                        <button class="w-7 h-7 flex items-center justify-center rounded-lg bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white transition-all shadow-sm border border-amber-100" onclick="abrirModalEditar(@item.UserId)" title="Editar">
                                            <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                        </button>
                                    }
                                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosEliminar) || User.IsInRole(AppRoles.Admin))
                                    {
                                        <button class="w-7 h-7 flex items-center justify-center rounded-lg bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all shadow-sm border border-rose-100" onclick="eliminarUsuario(@item.UserId)" title="Eliminar">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación Compacta -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-1.5 mt-4 pb-8">
            @if (Model.HasPreviousPage)
            {
                <a class="inline-flex items-center justify-center w-8 h-8 bg-white border border-slate-200 text-slate-600 rounded-lg hover:bg-slate-50 transition-all font-bold text-xs active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage - 1)" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </a>
            }
            
            <div class="flex items-center gap-1">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <div class="w-8 h-8 flex items-center justify-center bg-slate-900 text-white rounded-lg font-bold text-xs shadow-sm">@i</div>
                    }
                    else if (i <= 2 || i > Model.TotalPages - 2 || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                    {
                        <a class="w-8 h-8 flex items-center justify-center bg-white border border-slate-200 text-slate-600 rounded-lg hover:bg-slate-50 transition-all font-bold text-xs active:scale-95" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">@i</a>
                    }
                    else if (i == 3 && Model.CurrentPage > 4)
                    {
                        <div class="w-8 h-8 flex items-center justify-center text-slate-400 text-xs">...</div>
                    }
                    else if (i == Model.TotalPages - 2 && Model.CurrentPage < Model.TotalPages - 3)
                    {
                        <div class="w-8 h-8 flex items-center justify-center text-slate-400 text-xs">...</div>
                    }
                }
            </div>

            @if (Model.HasNextPage)
            {
                <a class="inline-flex items-center justify-center w-8 h-8 bg-white border border-slate-200 text-slate-600 rounded-lg hover:bg-slate-50 transition-all font-bold text-xs active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage + 1)" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
            }
        </div>
    }
</div>

<!-- ========================= -->
<!-- MODAL DE GESTIÓN (UPSERT) -->
<!-- ========================= -->
<div class="modal fade" id="modalUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden" x-data="{ tab: 'personales' }">
            <!-- Header con Tabs -->
            <div class="px-8 pt-6 border-b border-slate-100 bg-white sticky top-0 z-10">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight" id="tituloModal">Usuario</h5>
                        <p class="text-slate-700 text-xs font-medium uppercase tracking-widest mt-1">Gestión de datos de cliente y acceso</p>
                    </div>
                    <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-600 transition-colors" data-bs-dismiss="modal" aria-label="Close">
                        <i data-lucide="x" class="w-6 h-6"></i>
                    </button>
                </div>

                <!-- Navegación de Pestañas -->
                <div class="flex gap-8 overflow-x-auto no-scrollbar">
                    <button @@click="tab = 'personales'" :class="tab === 'personales' ? 'text-indigo-600 border-indigo-600' : 'text-slate-500 border-transparent hover:text-slate-700'" class="pb-4 border-b-2 font-bold text-xs uppercase tracking-widest transition-all whitespace-nowrap">
                        <span class="flex items-center gap-2">
                            <i data-lucide="user" class="w-4 h-4"></i>
                            Datos Personales
                        </span>
                    </button>
                    <button @@click="tab = 'demografia'" :class="tab === 'demografia' ? 'text-indigo-600 border-indigo-600' : 'text-slate-500 border-transparent hover:text-slate-700'" class="pb-4 border-b-2 font-bold text-xs uppercase tracking-widest transition-all whitespace-nowrap">
                        <span class="flex items-center gap-2">
                            <i data-lucide="map-pin" class="w-4 h-4"></i>
                            Contacto y Demografía
                        </span>
                    </button>
                    <button @@click="tab = 'acceso'" :class="tab === 'acceso' ? 'text-indigo-600 border-indigo-600' : 'text-slate-500 border-transparent hover:text-slate-700'" class="pb-4 border-b-2 font-bold text-xs uppercase tracking-widest transition-all whitespace-nowrap">
                        <span class="flex items-center gap-2">
                            <i data-lucide="shield-check" class="w-4 h-4"></i>
                            Acceso y Configuración
                        </span>
                    </button>
                </div>
            </div>

            <div class="p-8 max-h-[70vh] overflow-y-auto custom-scrollbar">
                <form id="formUsuario" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="UserId" value="0" />

                    <!-- Tab 1: Datos Personales -->
                    <div x-show="tab === 'personales'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-5">
                                <div>
                                    <label for="RoleId" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Rol del Usuario</label>
                                    <div class="relative">
                                        <select id="RoleId" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 appearance-none transition-all" asp-items="rolesSelectList" required>
                                            <option value="">-- Seleccione Rol --</option>
                                        </select>
                                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600">
                                            <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                        </div>
                                    </div>
                                </div>

                                <div>
                                    <label for="NombreCompleto" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Nombres (Nombre Completo)</label>
                                    <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" id="NombreCompleto" required placeholder="Ej. Juan Manuel" />
                                </div>

                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label for="ApellidoPaterno" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Apellido Paterno</label>
                                        <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all" id="ApellidoPaterno" placeholder="Ej. Pérez" />
                                    </div>
                                    <div>
                                        <label for="ApellidoMaterno" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">Apellido Materno</label>
                                        <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all" id="ApellidoMaterno" placeholder="Ej. Quispe" />
                                    </div>
                                </div>

                                <div>
                                    <label for="Dni" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2">DNI / Identificación</label>
                                    <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" id="Dni" placeholder="Opcional" />
                                </div>
                            </div>

                            <div class="space-y-5">
                                <!-- Webcam Capture Area -->
                                <div class="bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200 p-4">
                                    <div class="flex items-center justify-between mb-3">
                                        <div class="flex items-center gap-2">
                                            <div class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                                                <i data-lucide="video" class="w-4 h-4"></i>
                                            </div>
                                            <span class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Foto de Perfil</span>
                                        </div>
                                        <input type="file" id="FotoArchivo" name="FotoArchivo" class="hidden" accept="image/*" />
                                        <label for="FotoArchivo" class="cursor-pointer text-[10px] font-bold text-indigo-600 hover:text-indigo-700 uppercase tracking-widest">
                                            Subir Archivo
                                        </label>
                                    </div>
                                    
                                    <div class="relative bg-slate-900 rounded-xl overflow-hidden mb-4 shadow-inner aspect-[4/3] flex items-center justify-center">
                                        <div id="camaraPlaceholder" class="text-center p-6 text-slate-700">
                                            <i data-lucide="camera" class="w-10 h-10 mx-auto mb-2 opacity-20"></i>
                                            <p class="text-[10px] font-bold uppercase tracking-widest">Cámara Desactivada</p>
                                        </div>
                                        <video id="videoWebcam" autoplay playsinline class="absolute inset-0 w-full h-full object-cover hidden"></video>
                                        <img id="imgPrevisualizacion" src="" alt="Previsualización" class="absolute inset-0 w-full h-full object-cover hidden" />
                                    </div>

                                    <div class="flex gap-2">
                                        <button type="button" id="btnActivarCamara" class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 bg-indigo-50 text-indigo-600 rounded-xl hover:bg-indigo-100 transition-colors text-[10px] font-bold uppercase tracking-widest" onclick="activarWebcam()">
                                            <i data-lucide="video" class="w-3.5 h-3.5"></i> Activar
                                        </button>
                                        <button type="button" id="btnDesactivarCamara" class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 bg-rose-50 text-rose-600 rounded-xl hover:bg-rose-100 transition-colors text-[10px] font-bold uppercase tracking-widest hidden" onclick="desactivarWebcamManualmente()">
                                            <i data-lucide="video-off" class="w-3.5 h-3.5"></i> Apagar
                                        </button>
                                        <button type="button" id="btnTomarFoto" class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-2 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition-colors text-[10px] font-bold uppercase tracking-widest hidden" onclick="tomarFotoWebcam()">
                                            <i data-lucide="camera" class="w-3.5 h-3.5"></i> Capturar
                                        </button>
                                    </div>
                                    <canvas id="canvasFoto" class="hidden"></canvas>
                                    <input type="hidden" id="FotoBase64" name="FotoBase64" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tab 2: Contacto y Demografía -->
                    <div x-show="tab === 'demografia'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
