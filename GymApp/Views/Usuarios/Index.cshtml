@model GymApp.ViewModels.PagedResult<GymApp.ViewModels.UsuarioViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    var rolesSelectList = ViewBag.Roles as SelectList;
    var mes = ViewBag.Mes as int?;
    var anio = ViewBag.Anio as int?;
}

<div class="container-fluid mt-4">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="bi bi-people"></i> @ViewData["TituloListado"]</h2>
        <button class="btn btn-success shadow-sm" onclick="abrirModalCrear()">
            <i class="bi bi-person-plus"></i> Nuevo Usuario
        </button>
    </div>

    <!-- Filtros -->
    <form asp-action="Index" method="get" class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light rounded">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <label class="small text-muted fw-bold">BÚSQUEDA</label>
                    <input type="text" name="buscar" class="form-control" placeholder="Nombre o DNI..." value="@Model.SearchTerm">
                </div>
                <div class="col-md-3">
                    <label class="small text-muted fw-bold">MES DE REGISTRO</label>
                    <select name="mes" class="form-select">
                        <option value="">Todos los meses</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            if (mes == i)
                            {
                                <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                            else
                            {
                                <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small text-muted fw-bold">AÑO</label>
                    <select name="anio" class="form-select">
                        <option value="">Todos los años</option>
                        @for (int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                        {
                            if (anio == i)
                            {
                                <option value="@i" selected>@i</option>
                            }
                            else
                            {
                                <option value="@i">@i</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end gap-1">
                    <button type="submit" class="btn btn-primary flex-grow-1" style="margin-top: 1.5rem;">
                        <i class="bi bi-filter"></i>
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" style="margin-top: 1.5rem;" title="Limpiar filtros">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>
        </div>
    </form>

    <!-- Tabla -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th>DNI</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.NombreCompleto</div>
                            </td>
                            <td><span class="badge bg-info text-dark">@item.NombreRol</span></td>
                            <td>@(string.IsNullOrEmpty(item.Dni) ? Html.Raw("<span class='text-muted fst-italic'>Sin DNI</span>") : item.Dni)</td>
                            <td class="text-end">
                                <!-- Botón Detalles -->
                                <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-info text-white" title="Ver Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <!-- Botón Ver QR -->
                                <button class="btn btn-sm btn-dark me-1" onclick="verQR(@item.UserId, '@item.NombreCompleto')" title="Ver Código QR">
                                    <i class="bi bi-qr-code"></i>
                                </button>
                                <!-- Botón Editar -->
                                <button class="btn btn-sm btn-warning me-1" onclick="abrirModalEditar(@item.UserId)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <!-- Botón Eliminar -->
                                <button class="btn btn-sm btn-danger" onclick="eliminarUsuario(@item.UserId)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Navegacion de usuarios" class="mt-4">
            <ul class="pagination justify-content-center pagination-lg">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.CurrentPage - 1)" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.CurrentPage + 1)" asp-route-buscar="@Model.SearchTerm" asp-route-mes="@mes" asp-route-anio="@anio">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- ========================= -->
<!-- MODAL DE GESTIÓN (UPSERT) -->
<!-- ========================= -->
<div class="modal fade" id="modalUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="tituloModal">Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formUsuario" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="UserId" value="0" />

                    <div class="row">
                        <!-- Columna Izquierda -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="RoleId" class="form-label">Rol del Usuario</label>
                                <select id="RoleId" class="form-select" asp-items="rolesSelectList" required>
                                    <option value="">-- Seleccione Rol --</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="NombreCompleto" class="form-label">Nombre Completo</label>
                                <input type="text" class="form-control" id="NombreCompleto" required />
                            </div>
                            <div class="mb-3">
                                <label for="Dni" class="form-label">DNI / Identificación (Opcional)</label>
                                <input type="text" class="form-control" id="Dni" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Foto de Perfil</label>
                                <input type="file" id="FotoArchivo" name="FotoArchivo" class="form-control" accept="image/*" />
                            </div>
                        </div>

                        <!-- Columna Derecha -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="Email" class="form-label">Correo Electrónico</label>
                                <input type="email" class="form-control" id="Email" />
                            </div>
                            <div class="mb-3">
                                <label for="Telefono" class="form-label">Teléfono</label>
                                <input type="text" class="form-control" id="Telefono" />
                            </div>

                            <div class="form-check form-switch mt-4 mb-4">
                                <input class="form-check-input" type="checkbox" id="Estado" checked>
                                <label class="form-check-label" for="Estado">Usuario Activo</label>
                            </div>

                            <!-- Webcam Capture Area -->
                            <div class="card border-primary-subtle shadow-sm mb-3">
                                <div class="card-header bg-primary-subtle text-primary-emphasis d-flex align-items-center gap-2 py-2">
                                    <i class="bi bi-camera-video-fill"></i>
                                    <span class="fw-bold small">Capturar Foto desde Webcam</span>
                                </div>
                                <div class="card-body p-3">
                                    <!-- Viewport Container -->
                                    <div class="position-relative bg-dark rounded overflow-hidden d-flex justify-content-center align-items-center mb-3 shadow-inner" style="min-height: 200px; border: 2px dashed var(--bs-primary-border-subtle);">
                                        <!-- Placeholders -->
                                        <div id="camaraPlaceholder" class="text-center text-muted p-3">
                                            <i class="bi bi-camera display-5 d-block mb-2 text-primary"></i>
                                            <span class="small fw-semibold text-secondary">Cámara Desactivada</span>
                                            <p class="x-small text-muted mb-0 mt-1">Haga clic en Activar para iniciar la captura en vivo</p>
                                        </div>
                                        
                                        <!-- Video Stream (WebRTC) -->
                                        <video id="videoWebcam" autoplay playsinline class="w-100" style="display: none; object-fit: cover; aspect-ratio: 4/3; max-height: 220px;"></video>
                                        
                                        <!-- Image Preview -->
                                        <img id="imgPrevisualizacion" src="" alt="Previsualización" class="w-100" style="display: none; object-fit: cover; aspect-ratio: 4/3; max-height: 220px;" />
                                    </div>

                                    <!-- Controls -->
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <button type="button" id="btnActivarCamara" class="btn btn-outline-primary btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-1 py-2 fw-semibold" onclick="activarWebcam()">
                                                <i class="bi bi-camera-video"></i> Activar
                                            </button>
                                            <button type="button" id="btnDesactivarCamara" class="btn btn-outline-danger btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-1 py-2 fw-semibold" style="display: none;" onclick="desactivarWebcamManualmente()">
                                                <i class="bi bi-camera-video-off"></i> Desactivar
                                            </button>
                                        </div>
                                        <div class="col-6">
                                            <button type="button" id="btnTomarFoto" class="btn btn-success btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-1 py-2 fw-semibold" style="display: none;" onclick="tomarFotoWebcam()">
                                                <i class="bi bi-camera"></i> Capturar
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <!-- Canvas Hidden -->
                                    <canvas id="canvasFoto" style="display:none;"></canvas>
                                    <!-- Hidden Input Base64 -->
                                    <input type="hidden" id="FotoBase64" name="FotoBase64" />
                                </div>
                            </div>
                        </div>
                    </div>

                </form>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarUsuario()">Guardar Datos</button>
            </div>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL DE CÓDIGO QR       -->
<!-- ========================= -->
<div class="modal fade" id="modalQR" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm text-center">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fs-6" id="qrTitulo">Código QR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- La imagen se carga dinámicamente -->
                <img id="imgQR" src="" alt="Cargando QR..." class="img-fluid border p-2" />
                <p class="mt-2 text-muted small">Escanee este código en la entrada</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var modalUsuario, modalQR;
        let webcamStream = null;

        document.addEventListener('DOMContentLoaded', function () {
            modalUsuario = new bootstrap.Modal(document.getElementById('modalUsuario'));
            modalQR = new bootstrap.Modal(document.getElementById('modalQR'));

            // Escuchar el evento de cierre del modal para apagar la cámara y limpiar
            document.getElementById('modalUsuario').addEventListener('hidden.bs.modal', function () {
                desactivarWebcamSilencioso();
            });

            // Escuchar el cambio en el input file manual para previsualizarlo y desactivar webcam
            document.getElementById('FotoArchivo').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    desactivarWebcamSilencioso();

                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const imgPreview = document.getElementById('imgPrevisualizacion');
                        const placeholder = document.getElementById('camaraPlaceholder');
                        const video = document.getElementById('videoWebcam');
                        
                        placeholder.style.display = 'none';
                        video.style.display = 'none';
                        imgPreview.src = event.target.result;
                        imgPreview.style.display = 'block';

                        // Limpiar el hidden de base64 ya que se subió un archivo físico
                        document.getElementById('FotoBase64').value = '';
                    };
                    reader.readAsDataURL(file);
                }
            });
        });

        // ==========================================
        // FUNCIONES DE CONTROL DE WEBCAM (WebRTC)
        // ==========================================
        function activarWebcam() {
            const video = document.getElementById('videoWebcam');
            const placeholder = document.getElementById('camaraPlaceholder');
            const imgPreview = document.getElementById('imgPrevisualizacion');
            const btnActivar = document.getElementById('btnActivarCamara');
            const btnDesactivar = document.getElementById('btnDesactivarCamara');
            const btnTomar = document.getElementById('btnTomarFoto');

            // Limpiar previsualizaciones anteriores
            imgPreview.style.display = 'none';
            imgPreview.src = '';
            document.getElementById('FotoBase64').value = '';

            // Solicitar permisos y obtener stream
            navigator.mediaDevices.getUserMedia({
                video: {
                    width: { ideal: 640 },
                    height: { ideal: 480 },
                    facingMode: "user"
                },
                audio: false
            })
            .then(function (stream) {
                webcamStream = stream;
                video.srcObject = stream;
                
                placeholder.style.display = 'none';
                video.style.display = 'block';
                btnActivar.style.display = 'none';
                btnDesactivar.style.display = 'inline-flex';
                btnTomar.style.display = 'inline-flex';
            })
            .catch(function (err) {
                console.error("No se pudo acceder a la webcam: ", err);
                Swal.fire({
                    title: 'Acceso a Cámara Denegado',
                    text: 'Asegúrese de otorgar permisos de cámara al sitio o conectar un dispositivo USB.',
                    icon: 'error'
                });
            });
        }

        function detenerWebcam() {
            if (webcamStream) {
                webcamStream.getTracks().forEach(track => track.stop());
                webcamStream = null;
            }
            const video = document.getElementById('videoWebcam');
            if (video) {
                video.srcObject = null;
            }
        }

        function desactivarWebcamSilencioso() {
            detenerWebcam();
            const placeholder = document.getElementById('camaraPlaceholder');
            const video = document.getElementById('videoWebcam');
            const btnActivar = document.getElementById('btnActivarCamara');
            const btnDesactivar = document.getElementById('btnDesactivarCamara');
            const btnTomar = document.getElementById('btnTomarFoto');

            if (placeholder) placeholder.style.display = 'block';
            if (video) video.style.display = 'none';
            if (btnActivar) btnActivar.style.display = 'inline-flex';
            if (btnDesactivar) btnDesactivar.style.display = 'none';
            if (btnTomar) btnTomar.style.display = 'none';
        }

        function desactivarWebcamManualmente() {
            desactivarWebcamSilencioso();
            // Limpiar foto previa si la cámara se apaga voluntariamente
            const imgPreview = document.getElementById('imgPrevisualizacion');
            if (imgPreview) {
                imgPreview.style.display = 'none';
                imgPreview.src = '';
            }
            document.getElementById('FotoBase64').value = '';
        }

        function tomarFotoWebcam() {
            const video = document.getElementById('videoWebcam');
            const canvas = document.getElementById('canvasFoto');
            const context = canvas.getContext('2d');
            const imgPreview = document.getElementById('imgPrevisualizacion');
            const btnActivar = document.getElementById('btnActivarCamara');
            const btnDesactivar = document.getElementById('btnDesactivarCamara');
            const btnTomar = document.getElementById('btnTomarFoto');

            if (!video.srcObject) return;

            // Fijar resolución del canvas según stream real de la webcam
            canvas.width = video.videoWidth || 640;
            canvas.height = video.videoHeight || 480;

            // Dibujar el cuadro actual en el canvas
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            // Exportar a base64
            const dataUrl = canvas.toDataURL('image/jpeg', 0.9);

            // Almacenar en hidden input
            document.getElementById('FotoBase64').value = dataUrl;

            // Mostrar previsualización
            imgPreview.src = dataUrl;
            imgPreview.style.display = 'block';

            // Ocultar viewport de video
            video.style.display = 'none';

            // Restaurar botones de control
            btnActivar.style.display = 'inline-flex';
            btnDesactivar.style.display = 'none';
            btnTomar.style.display = 'none';

            // Limpiar selección de archivo físico si existía
            document.getElementById('FotoArchivo').value = '';

            // Detener transmisión para no consumir recursos
            detenerWebcam();
        }

        // Utilidad para convertir Base64 DataURL a un objeto File de JS
        function dataURLtoFile(dataurl, filename) {
            var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],
                bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);
            while(n--){
                u8arr[n] = bstr.charCodeAt(n);
            }
            return new File([u8arr], filename, {type:mime});
        }

        // Limpieza de estados visuales del capturador
        function resetearEstadoCapturador() {
            desactivarWebcamSilencioso();
            const imgPreview = document.getElementById('imgPrevisualizacion');
            if (imgPreview) {
                imgPreview.style.display = 'none';
                imgPreview.src = '';
            }
            const base64Input = document.getElementById('FotoBase64');
            if (base64Input) base64Input.value = '';
        }

        // 1. ABRIR MODAL CREAR
        function abrirModalCrear() {
            document.getElementById('tituloModal').innerText = "Nuevo Usuario";
            document.getElementById('formUsuario').reset();
            document.getElementById('UserId').value = "0";

            // Limpiar permisos
            document.querySelectorAll('.permiso-checkbox').forEach(cb => cb.checked = false);

            resetearEstadoCapturador();
            modalUsuario.show();
        }

        // 2. ABRIR MODAL EDITAR
        function abrirModalEditar(id) {
            document.getElementById('tituloModal').innerText = "Editar Usuario";
            resetearEstadoCapturador();

            fetch(`/Usuarios/GetUsuario/${id}`)
                .then(res => res.json())
                .then(response => {
                    if (response.success) {
                        const d = response.data;
                        document.getElementById('UserId').value = d.userId;
                        document.getElementById('RoleId').value = d.roleId;
                        document.getElementById('NombreCompleto').value = d.nombreCompleto;
                        document.getElementById('Dni').value = d.dni;
                        document.getElementById('Email').value = d.email;
                        document.getElementById('Telefono').value = d.telefono;
                        document.getElementById('Estado').checked = d.estado;

                        // Cargar permisos
                        document.querySelectorAll('.permiso-checkbox').forEach(cb => cb.checked = false);
                        if (d.permisosSeleccionados && d.permisosSeleccionados.length > 0) {
                            d.permisosSeleccionados.forEach(p => {
                                const cb = document.querySelector(`.permiso-checkbox[value="${p}"]`);
                                if (cb) cb.checked = true;
                            });
                        }

                        modalUsuario.show();
                    } else {
                        Swal.fire('Error', 'No se pudieron cargar los datos', 'error');
                    }
                });
        }

        // 3. GUARDAR USUARIO (Usando FormData para archivos)
        function guardarUsuario() {
            var rolId = document.getElementById("RoleId").value;
            if (!rolId) {
                Swal.fire("Atención", "Debe seleccionar un Rol", "warning");
                return;
            }

            var formData = new FormData();
            formData.append("UserId", document.getElementById("UserId").value);
            formData.append("RoleId", rolId);
            formData.append("NombreCompleto", document.getElementById("NombreCompleto").value);
            formData.append("Dni", document.getElementById("Dni").value);
            formData.append("Email", document.getElementById("Email").value);
            formData.append("Telefono", document.getElementById("Telefono").value);
            formData.append("Estado", document.getElementById("Estado").checked);

            // Permisos
            var permisosSeleccionados = Array.from(document.querySelectorAll('.permiso-checkbox:checked')).map(cb => cb.value);
            permisosSeleccionados.forEach(p => formData.append("PermisosSeleccionados", p));

            // Manejo de fotos: Priorizar archivo físico, si no usar webcam (Base64)
            var foto = document.getElementById("FotoArchivo").files[0];
            if (foto) {
                formData.append("FotoArchivo", foto);
            } else {
                var fotoBase64 = document.getElementById("FotoBase64").value;
                if (fotoBase64) {
                    var file = dataURLtoFile(fotoBase64, "webcam_photo.jpg");
                    formData.append("FotoArchivo", file);
                }
            }

            // C. ENVÍO AJAX
            $.ajax({
                url: "/Usuarios/Save",
                type: "POST",
                data: formData,
                processData: false, 
                contentType: false, 
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                success: function (response) {
                    if (response.success) {
                        modalUsuario.hide();
                        Swal.fire({
                            title: "¡Éxito!",
                            text: response.message,
                            icon: "success"
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        var msg = response.message;
                        if(response.errors){
                            msg += ": " + JSON.stringify(response.errors);
                        }
                        Swal.fire("Error", msg, "error");
                    }
                },
                error: function (xhr) {
                    console.log(xhr.responseText);
                    Swal.fire("Error del Servidor", "Revise la consola para más detalles", "error");
                }
            });
        }

        // 4. ELIMINAR
        function eliminarUsuario(id) {
            Swal.fire({
                title: '¿Eliminar usuario?',
                text: "Esta acción no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Usuarios/Delete', { id: id }, function(data) {
                         if (data.success) {
                            Swal.fire('Eliminado', data.message, 'success').then(() => location.reload());
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    });
                }
            });
        }

        // 5. VER QR
        function verQR(id, nombre) {
            document.getElementById('qrTitulo').innerText = "QR: " + nombre;
            const img = document.getElementById('imgQR');
            img.src = `/Usuarios/ObtenerQR/${id}?t=${new Date().getTime()}`;
            modalQR.show();
        }
    </script>
}