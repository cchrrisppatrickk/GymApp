@model GymApp.Models.Usuario

@{
    ViewData["Title"] = "Detalles del Socio";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-vcard text-primary me-2"></i>Ficha de Socio</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver a Usuarios
        </a>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Perfil -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center mt-3">
                    @if (!string.IsNullOrEmpty(Model.FotoUrl))
                    {
                        <img src="~/uploads/fotos/@Model.FotoUrl" class="img-fluid rounded-circle mb-3 shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Foto de Perfil" />
                    }
                    else
                    {
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.NombreCompleto)&background=random&size=150" class="img-fluid rounded-circle mb-3 shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Default User" />
                    }

                    <h4 class="card-title fw-bold">@Model.NombreCompleto</h4>
                    <span class="badge @(Model.Role?.Nombre == "Admin" ? "bg-danger" : Model.Role?.Nombre == "Empleado" ? "bg-warning text-dark" : "bg-success") px-3 py-2 fs-6 mb-3">
                        @Model.Role?.Nombre
                    </span>
                    
                    @if (Model.Estado == true)
                    {
                        <div class="badge bg-success mb-3"><i class="bi bi-check-circle"></i> Activo</div>
                    }
                    else
                    {
                        <div class="badge bg-danger mb-3"><i class="bi bi-x-circle"></i> Inactivo</div>
                    }
                </div>
                
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-card-text text-muted me-2"></i> <strong>DNI:</strong> @Model.Dni
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-telephone text-muted me-2"></i> <strong>Teléfono:</strong> @(Model.Telefono ?? "No registrado")
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-envelope text-muted me-2"></i> <strong>Email:</strong> @(Model.Email ?? "No registrado")
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-calendar-date text-muted me-2"></i> <strong>Fecha Reg.:</strong> @(Model.FechaRegistro?.ToString("dd/MM/yyyy") ?? "Desconocida")
                    </li>
                </ul>
            </div>
        </div>

        <!-- Columna Derecha: Membresías -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-card-checklist me-2"></i>Historial de Membresías</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Plan</th>
                                    <th>Fecha Inicio</th>
                                    <th>Fecha Fin</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Membresia != null && Model.Membresia.Any())
                                {
                                    @foreach (var membership in Model.Membresia.OrderByDescending(m => m.FechaVencimiento))
                                    {
                                        <tr>
                                            <td class="ps-3 fw-medium">@membership.Plan?.Nombre</td>
                                            <td>@membership.FechaInicio.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @membership.FechaVencimiento.ToString("dd/MM/yyyy")
                                                    @if (membership.FechaVencimiento >= DateOnly.FromDateTime(DateTime.Today))
                                                    {
                                                        var dias = membership.FechaVencimiento.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
                                                        <span class="ms-2 text-success fw-bold" title="Días restantes">
                                                            (@dias días)
                                                        </span>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                @if (membership.FechaVencimiento >= DateOnly.FromDateTime(DateTime.Today))
                                                {
                                                    <span class="badge bg-success">Activa</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Vencida</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                                            No hay registros de membresías para este usuario.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
