@model GymApp.ViewModels.UsuarioDetailsDTO
@using GymApp.Constants

@{
    ViewData["Title"] = "Expediente del Socio";
    var hoy = DateOnly.FromDateTime(DateTime.Today);
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6" x-data="{ activeTab: 'perfil' }">
    <!-- Header Minimalista -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
            <a asp-action="Index" class="flex items-center justify-center w-10 h-10 rounded-xl bg-white border border-slate-200 shadow-sm hover:bg-slate-50 transition-all">
                <i data-lucide="arrow-left" class="w-4 h-4 text-slate-600"></i>
            </a>
            <div>
                <nav class="flex mb-0.5" aria-label="Breadcrumb">
                    <ol class="flex items-center space-x-1.5 text-[9px] font-bold uppercase tracking-widest text-slate-500">
                        <li><a asp-action="Index" class="hover:text-indigo-600 transition-colors">Usuarios</a></li>
                        <li><i data-lucide="chevron-right" class="w-2.5 h-2.5"></i></li>
                        <li class="text-slate-600">Expediente</li>
                    </ol>
                </nav>
                <h1 class="text-2xl font-display font-black text-slate-900 tracking-tight">Ficha Digital del Socio</h1>
            </div>
        </div>

        <div class="flex items-center gap-2">
            @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosEditar) || User.IsInRole(AppRoles.Admin))
            {
                <button @@click="$dispatch('open-modal-restriccion', { userId: @Model.UserId })" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-rose-50 text-rose-700 border border-rose-100 hover:bg-rose-100 transition-all font-bold text-xs shadow-sm">
                    <i data-lucide="shield-alert" class="w-3.5 h-3.5"></i>
                    <span>Restringir</span>
                </button>
                <button onclick="editarUsuario(@Model.UserId)" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition-all font-bold text-xs shadow-md shadow-indigo-100">
                    <i data-lucide="edit-3" class="w-3.5 h-3.5"></i>
                    <span>Editar Perfil</span>
                </button>
            }
        </div>
    </div>

    <!-- Layout de Cards Superiores Optimizado (3 Columnas) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 mb-8">
        <!-- Card 1: Perfil y Acceso Integrado (40% de ancho en LG) -->
        <div class="lg:col-span-5 bg-white rounded-2xl border border-slate-200 p-6 flex flex-col justify-between shadow-sm relative overflow-hidden">
            <div class="flex items-center gap-5 relative z-10">
                <div @@click="$dispatch('open-photo-viewer', { url: '@(string.IsNullOrEmpty(Model.FotoUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.NombreCompleto) + "&background=f1f5f9&color=64748b&size=512" : (Model.FotoUrl.StartsWith("/") ? Model.FotoUrl : "/uploads/fotos/" + Model.FotoUrl))' })" 
                     class="relative w-24 h-24 rounded-2xl p-1 bg-slate-100 border border-slate-200 overflow-hidden shrink-0 cursor-zoom-in group/avatar transition-all active:scale-95 hover:border-indigo-300 shadow-inner">
                    @if (!string.IsNullOrEmpty(Model.FotoUrl))
                    {
                        <img src="@(Model.FotoUrl.StartsWith("/") ? Model.FotoUrl : "/uploads/fotos/" + Model.FotoUrl)" class="w-full h-full rounded-xl object-cover" alt="@Model.NombreCompleto" />
                    }
                    else
                    {
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.NombreCompleto)&background=f1f5f9&color=64748b&size=128" class="w-full h-full rounded-xl object-cover" alt="Default" />
                    }
                    <div class="absolute inset-0 bg-slate-900/10 opacity-0 group-hover/avatar:opacity-100 transition-opacity flex items-center justify-center">
                        <i data-lucide="maximize-2" class="w-5 h-5 text-white drop-shadow-md"></i>
                    </div>
                </div>
                <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2 mb-1">
                         <span class="inline-flex items-center px-2 py-0.5 rounded text-[8px] font-black uppercase tracking-widest @(Model.Estado ? "bg-emerald-50 text-emerald-700 border border-emerald-200" : "bg-rose-50 text-rose-700 border border-rose-200") border">
                            @(Model.Estado ? "Habilitado" : "Bloqueado")
                        </span>
                        @if (Model.Genero == "Masculino") { <i data-lucide="mars" class="w-3 h-3 text-blue-500"></i> }
                        else if (Model.Genero == "Femenino") { <i data-lucide="venus" class="w-3 h-3 text-pink-500"></i> }
                    </div>
                    <h2 class="text-xl font-display font-black text-slate-900 truncate leading-tight mb-3">@Model.NombreCompleto</h2>
                    
                    <div class="grid grid-cols-2 gap-x-4 gap-y-2">
                        <div class="flex items-center gap-2 text-[10px] font-bold text-slate-500 uppercase tracking-wider">
                            <i data-lucide="id-card" class="w-3 h-3 text-slate-400"></i>
                            <span>@(Model.Dni ?? "S/DNI")</span>
                        </div>
                        <div class="flex items-center gap-2 text-[10px] font-bold text-slate-500 uppercase tracking-wider">
                            <i data-lucide="phone" class="w-3 h-3 text-slate-400"></i>
                            <span>@(Model.Telefono ?? "S/TEL")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- PIN Section at bottom of profile card -->
            <div class="mt-6 pt-4 border-t border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100">
                        <i data-lucide="hash" class="w-4 h-4"></i>
                    </div>
                    <div>
                        <p class="text-[8px] font-black text-slate-500 uppercase tracking-widest leading-none mb-1">PIN Acceso</p>
                        <p class="text-sm font-display font-black text-slate-900 tracking-[0.2em]">@(Model.PinAcceso ?? "----")</p>
                    </div>
                </div>
                <div class="text-right">
                     <p class="text-[8px] font-black text-slate-500 uppercase tracking-widest leading-none mb-1">ID Socio</p>
                     <p class="text-xs font-black text-slate-400">#@Model.UserId.ToString("D5")</p>
                </div>
            </div>
        </div>

        <!-- Card 2: Plan Actual (35% de ancho en LG) -->
        <div class="lg:col-span-4 bg-white rounded-2xl border border-slate-200 p-6 shadow-sm flex flex-col justify-center items-center text-center">
            <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center mb-4 border border-slate-100">
                <i data-lucide="award" class="w-5 h-5 text-slate-400"></i>
            </div>
            <p class="text-[10px] font-black text-slate-600 uppercase tracking-[0.2em] mb-3">Suscripción Vigente</p>
            @{
                var memActiva = Model.Membresias.FirstOrDefault(m => m.Estado == "Activa");
                if (memActiva != null)
                {
                    <div class="bg-emerald-50 text-emerald-800 px-5 py-2.5 rounded-2xl border border-emerald-100 mb-3 shadow-sm shadow-emerald-50">
                        <div class="flex items-center justify-center gap-2 mb-0.5">
                            <i data-lucide="zap" class="w-4 h-4 fill-emerald-500 text-emerald-500"></i>
                            <span class="text-sm font-black uppercase tracking-tight">@memActiva.NombrePlan</span>
                        </div>
                        <p class="text-[9px] font-bold opacity-80 uppercase">Turno: @memActiva.NombreTurno</p>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                        <i data-lucide="calendar" class="w-3 h-3"></i>
                        <span>Vence el @memActiva.FechaVencimiento</span>
                    </div>
                }
                else
                {
                    <div class="bg-slate-50 text-slate-500 px-5 py-2.5 rounded-2xl border border-slate-200 mb-3 grayscale opacity-60">
                         <div class="flex items-center justify-center gap-2">
                            <i data-lucide="inbox" class="w-4 h-4"></i>
                            <span class="text-sm font-black uppercase tracking-tight">Sin Plan Activo</span>
                        </div>
                    </div>
                    <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">No registra servicios vigentes</p>
                }
            }
        </div>

        <!-- Card 3: Efectividad (35% de ancho en LG) -->
        <div class="lg:col-span-3 bg-white rounded-2xl border border-slate-200 p-5 shadow-sm flex flex-col">
            <div class="flex items-center gap-3 mb-1">
                <div class="w-8 h-8 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100">
                    <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-900 uppercase tracking-tight">Efectividad Asistencias</p>
                    <p class="text-[9px] font-bold text-slate-500">@Model.TotalAsistencias asistencias de @Model.DiasTranscurridos sesiones</p>
                </div>
            </div>

            <div class="flex-1 flex flex-col items-center justify-center py-1">
                <div class="relative inline-flex items-center justify-center">
                    <h3 class="text-4xl font-display font-black tracking-tighter @(Model.PorcentajeEfectividad <= 40 ? "text-rose-600" : Model.PorcentajeEfectividad <= 60 ? "text-amber-500" : "text-indigo-600")">
                        @Model.PorcentajeEfectividad.ToString("0")%
                    </h3>
                    <div class="absolute -top-1 -right-4">
                         <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full @(Model.PorcentajeEfectividad >= 80 ? "bg-emerald-400" : "bg-indigo-400") opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 @(Model.PorcentajeEfectividad >= 80 ? "bg-emerald-500" : "bg-indigo-500")"></span>
                        </span>
                    </div>
                </div>
                
                <!-- Leyenda de Estados Completa (Igual a la imagen) -->
                <div class="mt-5 flex flex-wrap justify-center items-center gap-x-3 gap-y-1.5">
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-rose-500 @(Model.NivelFidelidad == "Muy bajo" ? "ring-4 ring-rose-100" : "opacity-30")"></span>
                        <span class="text-[9px] font-bold @(Model.NivelFidelidad == "Muy bajo" ? "text-slate-900" : "text-slate-400")">Muy bajo</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-orange-500 @(Model.NivelFidelidad == "Bajo" ? "ring-4 ring-orange-100" : "opacity-30")"></span>
                        <span class="text-[9px] font-bold @(Model.NivelFidelidad == "Bajo" ? "text-slate-900" : "text-slate-400")">Bajo</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 @(Model.NivelFidelidad == "Regular" ? "ring-4 ring-yellow-100" : "opacity-30")"></span>
                        <span class="text-[9px] font-bold @(Model.NivelFidelidad == "Regular" ? "text-slate-900" : "text-slate-400")">Regular</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 @(Model.NivelFidelidad == "Bueno" ? "ring-4 ring-emerald-100" : "opacity-30")"></span>
                        <span class="text-[9px] font-bold @(Model.NivelFidelidad == "Bueno" ? "text-slate-900" : "text-slate-400")">Bueno</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-indigo-500 @(Model.NivelFidelidad == "Excelente" ? "ring-4 ring-indigo-100" : "opacity-30")"></span>
                        <span class="text-[9px] font-bold @(Model.NivelFidelidad == "Excelente" ? "text-slate-900" : "text-slate-400")">Excelente</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenido Inferior (Tabs y Listado) -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <!-- Tabs Navigation Minimal -->
        <div class="flex items-center gap-6 px-8 border-b border-slate-100 bg-slate-50/30">
            <button @@click="activeTab = 'perfil'" :class="activeTab === 'perfil' ? 'text-indigo-600 border-indigo-600' : 'text-slate-500 border-transparent hover:text-slate-800'" class="py-4 border-b-2 font-black text-[10px] uppercase tracking-widest transition-all">
                Detalles CRM
            </button>
            <button @@click="activeTab = 'membresias'" :class="activeTab === 'membresias' ? 'text-indigo-600 border-indigo-600' : 'text-slate-500 border-transparent hover:text-slate-800'" class="py-4 border-b-2 font-black text-[10px] uppercase tracking-widest transition-all">
                Historial Membresías
            </button>
            <button @@click="activeTab = 'restricciones'" :class="activeTab === 'restricciones' ? 'text-indigo-600 border-indigo-600' : 'text-slate-500 border-transparent hover:text-slate-800'" class="py-4 border-b-2 font-black text-[10px] uppercase tracking-widest transition-all relative">
                Trazabilidad
                @if (Model.Restricciones.Any(r => r.EstadoActiva))
                {
                    <span class="absolute top-3 -right-2 w-1.5 h-1.5 bg-rose-500 rounded-full animate-ping"></span>
                }
            </button>
        </div>

        <!-- TAB: PERFIL / CRM -->
        <div x-show="activeTab === 'perfil'" class="p-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
                <!-- Datos demográficos -->
                <div class="lg:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-y-8 gap-x-6">
                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center gap-2 text-slate-500">
                            <i data-lucide="share-2" class="w-3.5 h-3.5"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest">Origen de Captación</p>
                        </div>
                        <p class="text-xs font-black text-slate-900">@(Model.Origen ?? "No registrado")</p>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center gap-2 text-slate-500">
                            <i data-lucide="message-circle" class="w-3.5 h-3.5"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest">WhatsApp / Celular</p>
                        </div>
                        <div class="flex items-center gap-2">
                            <p class="text-xs font-black text-slate-900">@(Model.WhatsApp ?? "No registrado")</p>
                            @if (!string.IsNullOrEmpty(Model.WhatsApp))
                            {
                                <a href="https://wa.me/@Model.WhatsApp" target="_blank" class="text-emerald-600 hover:text-emerald-700 transition-colors">
                                    <i data-lucide="external-link" class="w-3 h-3"></i>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center gap-2 text-slate-500">
                            <i data-lucide="heart" class="w-3.5 h-3.5"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest">Estado Civil</p>
                        </div>
                        <p class="text-xs font-black text-slate-900">@(Model.EstadoCivil ?? "No especificado")</p>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center gap-2 text-slate-500">
                            <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest">Fecha Nacimiento</p>
                        </div>
                        <p class="text-xs font-black text-slate-900">@(Model.FechaNacimiento?.ToString("dd 'de' MMMM, yyyy") ?? "No registrada")</p>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center gap-2 text-slate-500">
                            <i data-lucide="briefcase" class="w-3.5 h-3.5"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest">Ocupación</p>
                        </div>
                        <p class="text-xs font-black text-slate-900">@(Model.Ocupacion ?? "No registrada")</p>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <div class="flex items-center gap-2 text-slate-500">
                            <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                            <p class="text-[9px] font-black uppercase tracking-widest">Dirección Residencia</p>
                        </div>
                        <p class="text-xs font-black text-slate-950 truncate" title="@Model.Direccion">@(Model.Direccion ?? "No registrada")</p>
                    </div>
                </div>
                <!-- Notas -->
                <div class="lg:col-span-4 bg-slate-50 rounded-2xl p-6 border border-slate-200">
                    <p class="text-[9px] font-black text-slate-600 uppercase tracking-widest mb-3 flex items-center gap-2">
                        <i data-lucide="sticky-note" class="w-3 h-3"></i>
                        Notas Administrativas
                    </p>
                    <p class="text-xs font-medium text-slate-800 leading-relaxed italic">
                        @(string.IsNullOrEmpty(Model.Nota) ? "Sin anotaciones en este expediente." : Model.Nota)
                    </p>
                </div>
            </div>
        </div>

        <!-- TAB: MEMBRESIAS -->
        <div x-show="activeTab === 'membresias'" class="overflow-x-auto">
            <table class="w-full border-collapse text-left">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-8 py-3 text-[9px] font-black text-slate-600 uppercase tracking-widest">Plan Suscrito</th>
                        <th class="px-6 py-3 text-[9px] font-black text-slate-600 uppercase tracking-widest">Vigencia</th>
                        <th class="px-6 py-3 text-[9px] font-black text-slate-600 uppercase tracking-widest text-center">Estado</th>
                        <th class="px-8 py-3 text-right text-[9px] font-black text-slate-600 uppercase tracking-widest">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Membresias.Any())
                    {
                        @foreach (var mem in Model.Membresias)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-8 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-500">
                                            <i data-lucide="zap" class="w-4 h-4"></i>
                                        </div>
                                        <div>
                                            <p class="text-xs font-black text-slate-900">@mem.NombrePlan</p>
                                            <p class="text-[9px] font-bold text-slate-600 uppercase">@mem.NombreTurno</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-xs font-black text-slate-800">@mem.FechaInicio — @mem.FechaVencimiento</p>
                                    @if (mem.Estado == "Activa") { <p class="text-[9px] font-bold text-emerald-700 uppercase">Quedan @mem.DiasRestantes días</p> }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-widest @(mem.Estado == "Activa" ? "bg-emerald-50 text-emerald-800 border border-emerald-100" : "bg-slate-100 text-slate-500")">
                                        @mem.Estado
                                    </span>
                                </td>
                                <td class="px-8 py-4 text-right">
                                    <a asp-controller="Membresias" asp-action="Details" asp-route-id="@mem.MembresiaId" class="inline-flex w-8 h-8 rounded-lg bg-white border border-slate-200 text-slate-500 hover:text-indigo-600 hover:border-indigo-200 hover:bg-indigo-50 items-center justify-center transition-all shadow-sm active:scale-90">
                                        <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="px-8 py-20 text-center text-[10px] font-bold text-slate-500 uppercase tracking-widest">Sin registros</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- TAB: RESTRICCIONES -->
        <div x-show="activeTab === 'restricciones'" class="overflow-x-auto">
             <table class="w-full border-collapse text-left">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-8 py-3 text-[9px] font-black text-slate-600 uppercase tracking-widest">Motivo / Tipo</th>
                        <th class="px-6 py-3 text-[9px] font-black text-slate-600 uppercase tracking-widest">Responsable</th>
                        <th class="px-6 py-3 text-[9px] font-black text-slate-600 uppercase tracking-widest">Fecha</th>
                        <th class="px-8 py-3 text-right text-[9px] font-black text-slate-600 uppercase tracking-widest">Estado</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Restricciones.Any())
                    {
                        @foreach (var res in Model.Restricciones)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-8 py-4">
                                    <p class="text-xs font-black text-slate-900">@res.TipoRestriccion</p>
                                    <p class="text-[10px] font-medium text-slate-600">@res.Descripcion</p>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-xs font-black text-slate-800">@res.UsuarioAplicadorNombre</p>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-xs font-black text-slate-900">@res.FechaAplicacion.ToString("dd/MM/yyyy")</p>
                                </td>
                                <td class="px-8 py-4 text-right">
                                    @if (res.EstadoActiva) {
                                        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosEditar) || User.IsInRole(AppRoles.Admin)) {
                                            <button onclick="levantarRestriccion(@res.Id)" class="px-3 py-1 rounded-lg bg-rose-50 text-rose-700 border border-rose-100 text-[9px] font-black uppercase tracking-widest">Levantar</button>
                                        } else { <span class="text-[9px] font-black text-rose-700 uppercase">Activo</span> }
                                    } else { <span class="text-[9px] font-black text-slate-400 uppercase italic">Inactivo</span> }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="px-8 py-20 text-center text-[10px] font-bold text-slate-500 uppercase tracking-widest">Sin restricciones</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Modales {
<!-- Visor de Foto a Detalle -->
<div x-data="{ open: false, url: '' }"
     @@open-photo-viewer.window="open = true; url = $event.detail.url; setTimeout(() => lucide.createIcons(), 50)"
     x-show="open" 
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 scale-100"
     x-transition:leave-end="opacity-0 scale-95"
     class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-slate-950/90 backdrop-blur-md" 
     @@click="open = false"
     @@keydown.escape.window="open = false"
     x-cloak>
    
    <div class="relative max-w-2xl w-full" @@click.stop>
        <button @@click="open = false" class="absolute -top-12 right-0 text-white/70 hover:text-white transition-colors">
            <i data-lucide="x" class="w-8 h-8"></i>
        </button>
        
        <div class="bg-white p-2 rounded-[2.5rem] shadow-2xl overflow-hidden border border-white/20">
            <img :src="url" class="w-full h-auto rounded-[2.2rem] shadow-sm" alt="Detalle Socio" />
            
            <div class="p-6 text-center">
                <p class="text-lg font-display font-black text-slate-900">@Model.NombreCompleto</p>
                <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-1">Socio #@Model.UserId.ToString("D5")</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Aplicar Restricción -->
<div x-data="{ open: false, userId: 0 }" 
     @@open-modal-restriccion.window="open = true; userId = $event.detail.userId"
     x-show="open" 
     class="fixed inset-0 z-[100] overflow-y-auto" 
     style="display: none;">
    <div class="flex items-center justify-center min-h-screen p-4 text-left">
        <div x-show="open" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm transition-opacity" @@click="open = false"></div>
        <div x-show="open" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" class="relative bg-white rounded-2xl w-full max-w-md overflow-hidden shadow-2xl border border-slate-200">
            <div class="p-8">
                <h3 class="text-xl font-display font-black text-slate-900 mb-6 uppercase tracking-tight">Aplicar Restricción</h3>
                <form onsubmit="submitRestriccion(event)">
                    <input type="hidden" name="userId" :value="userId" />
                    <div class="space-y-4">
                        <select name="tipo" required class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-[10px] font-black uppercase tracking-widest">
                            <option value="Conducta">Conducta</option>
                            <option value="Higiene">Higiene</option>
                            <option value="Pago">Deuda</option>
                            <option value="Seguridad">Seguridad</option>
                            <option value="Otro">Otro</option>
                        </select>
                        <textarea name="descripcion" required rows="3" class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 text-xs font-medium" placeholder="Motivo del bloqueo..."></textarea>
                    </div>
                    <div class="mt-8 flex gap-3">
                        <button type="button" @@click="open = false" class="flex-1 py-3 rounded-xl bg-slate-100 text-slate-600 font-black text-[10px] uppercase tracking-widest">Cancelar</button>
                        <button type="submit" class="flex-1 py-3 rounded-xl bg-rose-600 text-white font-black text-[10px] uppercase tracking-widest shadow-lg shadow-rose-100">Bloquear</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
    <script>
        function submitRestriccion(e) {
            e.preventDefault();
            fetch('@Url.Action("AplicarRestriccion", "Usuarios")', { method: 'POST', body: new FormData(e.target) })
            .then(res => res.json()).then(data => {
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Bloqueado', showConfirmButton: false, timer: 1500, customClass: { popup: 'rounded-2xl border-0 shadow-2xl' } })
                    .then(() => window.location.reload());
                } else Swal.fire('Error', data.message, 'error');
            });
        }
        function levantarRestriccion(id) {
            Swal.fire({ title: '¿Levantar?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#10b981', cancelButtonColor: '#f43f5e', customClass: { popup: 'rounded-2xl border-0 shadow-2xl' } })
            .then((result) => {
                if (result.isConfirmed) {
                    fetch('@Url.Action("LevantarRestriccion", "Usuarios")/' + id, { method: 'POST' })
                    .then(res => res.json()).then(data => { if (data.success) window.location.reload(); });
                }
            });
        }
        function editarUsuario(id) { window.location.href = '@Url.Action("Index", "Usuarios")?id=' + id + '&openEdit=true'; }
    </script>
}

<style>
    [x-cloak] { display: none !important; }
    .font-display { font-family: 'Outfit', sans-serif; }
</style>