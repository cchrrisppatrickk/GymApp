@{
    ViewData["Title"] = "Punto de Venta";
}

<div class="flex flex-col lg:flex-row h-[calc(100vh-100px)] gap-6 mt-4">
    <!-- Panel Izquierdo: Productos -->
    <div class="flex-grow flex flex-col min-w-0 bg-slate-50/50 rounded-[2.5rem] border border-slate-200/60 p-6 overflow-hidden shadow-sm">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-10 h-10 rounded-xl bg-indigo-600 text-white flex items-center justify-center shadow-md shadow-indigo-600/20">
                        <i data-lucide="shopping-bag" class="w-6 h-6"></i>
                    </div>
                    <h2 class="text-2xl font-display font-bold text-slate-950 tracking-tight m-0">Productos Disponibles</h2>
                </div>
                <p class="text-slate-600 text-xs font-medium ml-1">Selecciona los productos para agregar al ticket</p>
            </div>
            
            <div class="w-full sm:w-72 relative group">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                    <i data-lucide="search" class="w-4 h-4"></i>
                </div>
                <input type="text" id="buscador" onkeyup="filtrarProductos()" 
                       class="w-full bg-white border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl pl-10 pr-4 py-2.5 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-400" 
                       placeholder="Buscar producto...">
            </div>
        </div>

        <div class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
            <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-4" id="gridProductos">
                <div class="col-span-full flex flex-col items-center justify-center py-20 opacity-50">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600 mb-4"></div>
                    <p class="text-slate-600 font-medium">Cargando inventario...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Panel Derecho: Ticket -->
    <div class="w-full lg:w-[400px] shrink-0 bg-white rounded-[2.5rem] border border-slate-200 shadow-xl flex flex-col overflow-hidden relative">
        <div class="bg-slate-950 px-6 py-5 flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                <i data-lucide="receipt" class="w-5 h-5"></i>
            </div>
            <h5 class="text-lg font-display font-bold text-white m-0">Ticket de Venta</h5>
        </div>

        <div class="flex-grow overflow-y-auto px-6 py-4 custom-scrollbar">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-100">
                        <th class="pb-3 text-[10px] uppercase tracking-widest font-bold text-slate-400">Cant.</th>
                        <th class="pb-3 text-[10px] uppercase tracking-widest font-bold text-slate-400">Producto</th>
                        <th class="pb-3 text-[10px] uppercase tracking-widest font-bold text-slate-400 text-right">Precio</th>
                        <th class="pb-3"></th>
                    </tr>
                </thead>
                <tbody id="listaCarrito" class="divide-y divide-slate-50">
                    <!-- Dinámico -->
                </tbody>
            </table>
            
            <div id="msgCarritoVacio" class="flex flex-col items-center justify-center py-20 opacity-40">
                <i data-lucide="shopping-cart" class="w-12 h-12 text-slate-400 mb-4"></i>
                <p class="text-slate-500 font-bold text-sm">Carrito vacío</p>
            </div>
        </div>

        <div class="p-6 bg-slate-50/50 border-t border-slate-100 space-y-4">
            <!-- Cliente -->
            <div class="space-y-1.5">
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 ml-1">Cliente (Opcional)</label>
                <div class="flex gap-2">
                    <div class="relative flex-grow group">
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                            <i data-lucide="user" class="w-3.5 h-3.5"></i>
                        </div>
                        <input type="text" id="txtCliente" class="w-full bg-white border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-xl pl-9 pr-4 py-2 text-xs font-bold text-slate-900 transition-all placeholder:text-slate-400" 
                               placeholder="Público General" readonly>
                        <input type="hidden" id="userId">
                    </div>
                    <button class="w-9 h-9 flex items-center justify-center bg-white border border-slate-200 rounded-xl text-slate-600 hover:text-indigo-600 hover:border-indigo-600 transition-all shadow-sm" onclick="abrirModalClientes()">
                        <i data-lucide="user-plus" class="w-4 h-4"></i>
                    </button>
                    <button class="w-9 h-9 flex items-center justify-center bg-white border border-slate-200 rounded-xl text-slate-600 hover:text-rose-600 hover:border-rose-600 transition-all shadow-sm" onclick="limpiarCliente()">
                        <i data-lucide="user-x" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            <!-- Método de Pago -->
            <div class="space-y-1.5">
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 ml-1">Método de Pago</label>
                <div class="relative">
                    <select class="w-full bg-white border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-xl px-4 py-2 text-xs font-bold text-slate-700 appearance-none cursor-pointer transition-all" id="cboMetodo">
                        <option value="Efectivo">💵 Efectivo</option>
                        <option value="Yape">📱 Yape / Plin</option>
                    </select>
                    <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5"></i>
                    </div>
                </div>
            </div>

            <div class="pt-2 border-t border-slate-200">
                <div class="flex justify-between items-end mb-4">
                    <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Total a Pagar</span>
                    <span class="text-3xl font-display font-bold text-indigo-600 leading-none" id="lblTotal">$ 0.00</span>
                </div>

                <button class="w-full bg-indigo-600 text-white rounded-2xl py-4 font-display font-bold text-sm tracking-widest uppercase hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-600/20 active:scale-[0.98] disabled:opacity-50 disabled:grayscale disabled:cursor-not-allowed group" 
                        onclick="procesarVenta()" id="btnPagar" disabled>
                    <div class="flex items-center justify-center gap-2">
                        <i data-lucide="check-circle" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                        <span>Confirmar Venta</span>
                    </div>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Clientes -->
<div class="modal fade" id="modalClientes" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content !rounded-[2.5rem] border-0 shadow-2xl overflow-hidden">
            <div class="bg-slate-950 px-6 py-5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                        <i data-lucide="users" class="w-5 h-5"></i>
                    </div>
                    <h5 class="text-lg font-display font-bold text-white m-0">Asignar Cliente</h5>
                </div>
                <button type="button" class="text-white/60 hover:text-white transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-6 h-6"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div class="relative group">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </div>
                    <input type="text" class="w-full bg-slate-50 border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl pl-10 pr-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-400" 
                           id="inputBuscarCliente" placeholder="Escribe DNI o Nombre...">
                </div>
                <div class="max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                    <ul class="divide-y divide-slate-100 rounded-2xl border border-slate-100 overflow-hidden" id="resultadosClientes">
                        <!-- Resultados -->
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 5px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
</style>

@section Scripts {
    <script>
        // ESTADO DE LA APLICACIÓN
        let inventario = [];
        let carrito = [];

        document.addEventListener("DOMContentLoaded", () => {
            cargarInventario();
            if (typeof lucide !== 'undefined') lucide.createIcons();
        });

        // 1. CARGAR PRODUCTOS
        function cargarInventario() {
            fetch('/Productos/Listar')
                .then(res => res.json())
                .then(json => {
                    inventario = json.data;
                    renderizarProductos(inventario);
                });
        }

        // 2. RENDERIZAR GRID
        function renderizarProductos(lista) {
            const container = document.getElementById('gridProductos');
            container.innerHTML = '';

            if (lista.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full flex flex-col items-center justify-center py-20 opacity-40">
                        <i data-lucide="package-search" class="w-12 h-12 mb-4"></i>
                        <p class="text-slate-600 font-bold">No se encontraron productos</p>
                    </div>`;
                if (typeof lucide !== 'undefined') lucide.createIcons();
                return;
            }

            lista.forEach(p => {
                const esServicio = p.categoria === 'Servicio';
                const sinStock = !esServicio && p.stockActual <= 0;

                let stockBadge;
                if(esServicio) {
                    stockBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-indigo-100 text-indigo-700 border border-indigo-200 uppercase tracking-tighter">Servicio</span>';
                } else {
                    stockBadge = sinStock
                        ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-rose-100 text-rose-700 border border-rose-200 uppercase tracking-tighter">Agotado</span>'
                        : `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700 border border-emerald-200 uppercase tracking-tighter">${p.stockActual} disp.</span>`;
                }

                const html = `
                    <div class="group relative bg-white rounded-3xl border border-slate-200 p-4 transition-all hover:shadow-xl hover:-translate-y-1 cursor-pointer overflow-hidden ${sinStock ? 'opacity-60 grayscale' : ''}" 
                         onclick="${sinStock ? '' : `agregarAlCarrito(${p.productoId})`}">
                        <div class="absolute -right-2 -top-2 w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center -rotate-12 group-hover:rotate-0 transition-transform opacity-50">
                            <i data-lucide="box" class="w-8 h-8 text-slate-200"></i>
                        </div>
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="mb-4 w-10 h-10 rounded-xl bg-slate-50 text-indigo-600 flex items-center justify-center border border-slate-100 group-hover:bg-indigo-600 group-hover:text-white transition-colors shadow-sm">
                                <i data-lucide="${esServicio ? 'zap' : 'package'}" class="w-5 h-5"></i>
                            </div>
                            <h6 class="text-sm font-bold text-slate-900 mb-1 line-clamp-2 min-h-[40px]" title="${p.nombre}">${p.nombre}</h6>
                            <div class="mt-auto pt-3 flex items-end justify-between">
                                <span class="text-lg font-display font-bold text-emerald-600">$ ${p.precioVenta.toFixed(2)}</span>
                                ${stockBadge}
                            </div>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        // 3. LÓGICA DEL CARRITO
        function agregarAlCarrito(id) {
            const producto = inventario.find(p => p.productoId === id);
            const enCarrito = carrito.find(item => item.productoId === id);
            const esServicio = producto.categoria === 'Servicio';

            if (enCarrito) {
                if (esServicio || enCarrito.cantidad < producto.stockActual) {
                    enCarrito.cantidad++;
                } else {
                    Swal.fire({ icon: 'warning', title: 'Sin stock', text: 'No hay más stock disponible', timer: 1500, showConfirmButton: false });
                }
            } else {
                carrito.push({
                    productoId: id,
                    nombre: producto.nombre,
                    precio: producto.precioVenta,
                    cantidad: 1,
                    maxStock: producto.stockActual,
                    esServicio: esServicio
                });
            }
            renderizarCarrito();
        }

        function quitarDelCarrito(id) {
            carrito = carrito.filter(item => item.productoId !== id);
            renderizarCarrito();
        }

        function cambiarCantidad(id, delta) {
            const item = carrito.find(i => i.productoId === id);
            if (!item) return;

            const nuevaCant = item.cantidad + delta;
            const limite = item.esServicio ? 9999 : item.maxStock;

            if (nuevaCant > 0 && nuevaCant <= limite) {
                item.cantidad = nuevaCant;
            } else if (nuevaCant <= 0) {
                quitarDelCarrito(id);
                return;
            }
            renderizarCarrito();
        }

        function cambiarPrecio(id, nuevoPrecio) {
            const item = carrito.find(i => i.productoId === id);
            if (!item) return;

            let precio = parseFloat(nuevoPrecio);
            if (isNaN(precio) || precio < 0) return;

            item.precio = precio;
            renderizarCarrito();
        }

        function renderizarCarrito() {
            const tbody = document.getElementById('listaCarrito');
            const msgVacio = document.getElementById('msgCarritoVacio');
            const lblTotal = document.getElementById('lblTotal');
            const btnPagar = document.getElementById('btnPagar');

            tbody.innerHTML = '';
            let total = 0;

            if (carrito.length === 0) {
                msgVacio.classList.remove('hidden');
                btnPagar.disabled = true;
            } else {
                msgVacio.classList.add('hidden');
                btnPagar.disabled = false;

                carrito.forEach(item => {
                    const subtotal = item.cantidad * item.precio;
                    total += subtotal;

                    tbody.innerHTML += `
                        <tr class="group hover:bg-slate-50/50 transition-colors">
                            <td class="py-3 pr-2">
                                <div class="flex items-center gap-1.5 bg-slate-100 rounded-lg p-1 w-fit border border-slate-200/50">
                                    <button class="w-5 h-5 flex items-center justify-center bg-white rounded border border-slate-200 text-slate-600 hover:text-indigo-600 active:scale-90 transition-all shadow-xs" onclick="cambiarCantidad(${item.productoId}, -1)">-</button>
                                    <span class="text-[10px] font-bold text-slate-900 w-4 text-center">${item.cantidad}</span>
                                    <button class="w-5 h-5 flex items-center justify-center bg-white rounded border border-slate-200 text-slate-600 hover:text-indigo-600 active:scale-90 transition-all shadow-xs" onclick="cambiarCantidad(${item.productoId}, 1)">+</button>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="text-[11px] font-bold text-slate-800 block line-clamp-1 leading-tight">${item.nombre}</span>
                            </td>
                            <td class="py-3 text-right">
                                <div class="flex items-center justify-end">
                                    <span class="text-[10px] font-bold text-slate-400 mr-1">$</span>
                                    <input type="number"
                                           class="w-16 bg-transparent border-0 text-[13px] font-display font-bold text-indigo-600 text-right p-0 focus:ring-0"
                                           value="${item.precio.toFixed(2)}"
                                           onchange="cambiarPrecio(${item.productoId}, this.value)"
                                           step="0.50" min="0">
                                </div>
                            </td>
                            <td class="py-3 text-right pl-2">
                                <button class="w-6 h-6 flex items-center justify-center rounded-lg text-slate-300 hover:text-rose-600 transition-colors" onclick="quitarDelCarrito(${item.productoId})">
                                    <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            }
            lblTotal.innerText = '$ ' + total.toFixed(2);
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function filtrarProductos() {
            const texto = document.getElementById('buscador').value.toLowerCase();
            const filtrados = inventario.filter(p => p.nombre.toLowerCase().includes(texto));
            renderizarProductos(filtrados);
        }

        function procesarVenta() {
            if(carrito.length === 0) return;
            
            Swal.fire({
                title: '¿Confirmar Venta?',
                text: "Se registrará una venta por " + document.getElementById('lblTotal').innerText,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#4f46e5',
                confirmButtonText: 'Sí, confirmar',
                cancelButtonText: 'Cancelar',
                customClass: { popup: '!rounded-[2.5rem]' }
            }).then((result) => {
                if (result.isConfirmed) {
                    const data = {
                        UserId: document.getElementById('userId').value ? parseInt(document.getElementById('userId').value) : null,
                        MetodoPago: document.getElementById('cboMetodo').value,
                        Items: carrito.map(i => ({
                            ProductoId: i.productoId,
                            Cantidad: i.cantidad,
                            PrecioUnitario: i.precio
                        }))
                    };

                    fetch('/Ventas/Registrar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            Swal.fire({ icon: 'success', title: '¡Éxito!', text: "Venta registrada. Ticket #" + json.ventaId, timer: 2000, showConfirmButton: false, customClass: { popup: '!rounded-[2.5rem]' } });
                            carrito = [];
                            limpiarCliente();
                            renderizarCarrito();
                            cargarInventario();
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: json.message, customClass: { popup: '!rounded-[2.5rem]' } });
                        }
                    })
                    .catch(err => Swal.fire('Error', 'Error de conexión', 'error'));
                }
            });
        }

        // CLIENTES
        const modalElement = document.getElementById('modalClientes');
        const modalCli = new bootstrap.Modal(modalElement);

        function abrirModalClientes() { modalCli.show(); }

        document.getElementById('inputBuscarCliente').addEventListener('input', function() {
            const val = this.value;
            if(val.length < 3) return;
            fetch(`/Membresias/BuscarUsuario?q=${val}`)
                .then(r => r.json())
                .then(data => {
                    const ul = document.getElementById('resultadosClientes');
                    ul.innerHTML = '';
                    if(data.length === 0) {
                        ul.innerHTML = '<li class="p-4 text-center text-slate-400 text-xs font-medium">No se encontraron socios</li>';
                        return;
                    }
                    data.forEach(u => {
                        ul.innerHTML += `
                            <li class="p-3 hover:bg-slate-50 cursor-pointer transition-colors flex items-center justify-between group" onclick="seleccionarCliente(${u.id}, '${u.text}')">
                                <span class="text-xs font-bold text-slate-700">${u.text}</span>
                                <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-slate-300 group-hover:text-indigo-600 transition-colors"></i>
                            </li>`;
                    });
                    if (typeof lucide !== 'undefined') lucide.createIcons();
                });
        });

        function seleccionarCliente(id, nombre) {
            document.getElementById('userId').value = id;
            document.getElementById('txtCliente').value = nombre;
            modalCli.hide();
        }

        function limpiarCliente() {
            document.getElementById('userId').value = '';
            document.getElementById('txtCliente').value = '';
        }

    </script>
}