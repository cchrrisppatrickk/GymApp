@{
    ViewData["Title"] = "Punto de Venta";
}

<div class="flex flex-col lg:flex-row h-[calc(100vh-100px)] gap-4 mt-2 overflow-hidden">
    <!-- Panel Izquierdo: Productos -->
    <div class="flex-1 min-w-0 flex flex-col bg-slate-50/50 rounded-3xl border border-slate-200/60 p-4 overflow-hidden shadow-sm">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-4">
            <div>
                <div class="flex items-center gap-2 mb-0.5">
                    <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center shadow-md shadow-indigo-600/20">
                        <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                    </div>
                    <h2 class="text-xl font-display font-bold text-slate-950 tracking-tight m-0">Productos Disponibles</h2>
                </div>
                <p class="text-slate-500 text-[10px] font-medium ml-1 uppercase tracking-wider">Gestión de inventario</p>
            </div>
            
            <div class="w-full sm:w-64 relative group">
                <div class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                    <i data-lucide="search" class="w-4 h-4"></i>
                </div>
                <input type="text" id="buscador" onkeyup="filtrarProductos()" 
                       class="w-full bg-white border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-xl pl-9 pr-4 py-2 text-xs font-medium text-slate-900 transition-all placeholder:text-slate-400" 
                       placeholder="Buscar producto...">
            </div>
        </div>

        <div class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
            <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-6 gap-3" id="gridProductos">
                <!-- Dinámico -->
            </div>
        </div>
    </div>

    <!-- Panel Derecho: Ticket -->
    <div class="w-full lg:w-[260px] shrink-0 min-w-0 bg-white rounded-3xl border border-slate-200 shadow-xl flex flex-col overflow-hidden relative">
        <div class="bg-slate-950 px-5 py-4 flex items-center gap-3">
            <div class="w-7 h-7 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                <i data-lucide="receipt" class="w-4 h-4"></i>
            </div>
            <h5 class="text-base font-display font-bold text-white m-0 tracking-tight">Ticket</h5>
        </div>

        <div class="flex-grow overflow-y-auto px-3 py-3 custom-scrollbar">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-100">
                        <th class="pb-2 text-[9px] uppercase tracking-widest font-bold text-slate-400">Cant.</th>
                        <th class="pb-2 text-[9px] uppercase tracking-widest font-bold text-slate-400">Item</th>
                        <th class="pb-2 text-[9px] uppercase tracking-widest font-bold text-slate-400 text-right">$$</th>
                        <th class="pb-2"></th>
                    </tr>
                </thead>
                <tbody id="listaCarrito" class="divide-y divide-slate-50"></tbody>
            </table>
            
            <div id="msgCarritoVacio" class="flex flex-col items-center justify-center py-16 opacity-30">
                <i data-lucide="shopping-cart" class="w-10 h-10 text-slate-400 mb-3"></i>
                <p class="text-slate-500 font-bold text-xs">Vacío</p>
            </div>
        </div>

        <div class="p-4 bg-slate-50/50 border-t border-slate-100 space-y-3">
            <div class="space-y-1">
                <label class="text-[9px] uppercase tracking-widest font-bold text-slate-500 ml-1">Socio</label>
                <div class="flex gap-1">
                    <input type="text" id="txtCliente" class="w-full bg-white border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-lg px-2.5 py-1.5 text-[10px] font-bold text-slate-900 transition-all" placeholder="Público General" readonly>
                    <input type="hidden" id="userId">
                    <button class="w-7 h-7 flex items-center justify-center bg-white border border-slate-200 rounded-lg text-slate-600 hover:text-indigo-600 transition-all shadow-sm" onclick="abrirModalClientes()">
                        <i data-lucide="user-plus" class="w-3.5 h-3.5"></i>
                    </button>
                </div>
            </div>

            <div class="space-y-1">
                <label class="text-[9px] uppercase tracking-widest font-bold text-slate-500 ml-1">Pago</label>
                <select class="w-full bg-white border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-lg px-2 py-1.5 text-[10px] font-bold text-slate-700 appearance-none cursor-pointer transition-all" id="cboMetodo">
                    <option value="Efectivo">💵 Efectivo</option>
                    <option value="Yape">📱 Yape / Plin</option>
                </select>
            </div>

            <div class="pt-2 border-t border-slate-200">
                <div class="flex justify-between items-end mb-3">
                    <span class="text-[9px] font-bold text-slate-500 uppercase tracking-widest">Total</span>
                    <span class="text-xl font-display font-bold text-indigo-600 leading-none tracking-tighter" id="lblTotal">$ 0.00</span>
                </div>
                <button class="w-full bg-indigo-600 text-white rounded-xl py-3 font-display font-bold text-[10px] tracking-widest uppercase hover:bg-indigo-700 transition-all shadow-lg active:scale-95 disabled:opacity-50" onclick="procesarVenta()" id="btnPagar" disabled>
                    Vender
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Clientes -->
<div class="modal fade" id="modalClientes" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content !rounded-3xl border-0 shadow-2xl overflow-hidden">
            <div class="bg-slate-950 px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-7 h-7 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                        <i data-lucide="users" class="w-4 h-4"></i>
                    </div>
                    <h5 class="text-base font-display font-bold text-white m-0 tracking-tight">Asignar Cliente</h5>
                </div>
                <button type="button" class="text-white/60 hover:text-white transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-5 space-y-4">
                <div class="relative group">
                    <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                        <i data-lucide="search" class="w-3.5 h-3.5"></i>
                    </div>
                    <input type="text" class="w-full bg-slate-50 border-slate-200 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-xl pl-9 pr-4 py-2 text-xs font-medium text-slate-900 transition-all placeholder:text-slate-400" id="inputBuscarCliente" placeholder="Escribe DNI o Nombre...">
                </div>
                <div class="max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                    <ul class="divide-y divide-slate-100 rounded-xl border border-slate-100 overflow-hidden" id="resultadosClientes"></ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
</style>

@section Scripts {
    <script>
        let inventario = [];
        let carrito = [];

        document.addEventListener("DOMContentLoaded", () => {
            cargarInventario();
            if (typeof lucide !== 'undefined') lucide.createIcons();
        });

        function cargarInventario() {
            fetch('/Productos/Listar').then(res => res.json()).then(json => {
                inventario = json.data;
                renderizarProductos(inventario);
            });
        }

        function renderizarProductos(lista) {
            const container = document.getElementById('gridProductos');
            container.innerHTML = '';
            if (lista.length === 0) {
                container.innerHTML = `<div class="col-span-full py-16 text-center opacity-40 text-xs font-bold">No hay productos</div>`;
                return;
            }
            lista.forEach(p => {
                const esServicio = p.categoria === 'Servicio';
                const sinStock = !esServicio && p.stockActual <= 0;
                const html = `
                    <div class="group relative bg-white rounded-2xl border border-slate-200 p-3 transition-all hover:shadow-lg cursor-pointer overflow-hidden ${sinStock ? 'opacity-60 grayscale' : ''}" onclick="${sinStock ? '' : `agregarAlCarrito(${p.productoId})`}">
                        <div class="absolute -right-2 -top-2 w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center -rotate-12 opacity-20"><i data-lucide="box" class="w-6 h-6 text-slate-300"></i></div>
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="mb-2 w-8 h-8 rounded-lg bg-slate-50 text-indigo-600 flex items-center justify-center border border-slate-100 group-hover:bg-indigo-600 group-hover:text-white transition-colors shadow-sm">
                                <i data-lucide="${esServicio ? 'zap' : 'package'}" class="w-4 h-4"></i>
                            </div>
                            <h6 class="text-[10px] font-bold text-slate-900 mb-1 line-clamp-2 min-h-[25px] leading-tight">${p.nombre}</h6>
                            <div class="mt-auto pt-2 flex flex-col items-start gap-1">
                                <span class="text-[13px] font-display font-bold text-emerald-600">$ ${p.precioVenta.toFixed(2)}</span>
                                <span class="text-[8px] font-bold uppercase tracking-tighter ${sinStock ? 'text-rose-600' : 'text-slate-500'}">${esServicio ? 'Servicio' : (sinStock ? 'Agotado' : p.stockActual + ' disp.')}</span>
                            </div>
                        </div>
                    </div>`;
                container.insertAdjacentHTML('beforeend', html);
            });
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function agregarAlCarrito(id) {
            const producto = inventario.find(p => p.productoId === id);
            const enCarrito = carrito.find(item => item.productoId === id);
            const esServicio = producto.categoria === 'Servicio';
            if (enCarrito) {
                if (esServicio || enCarrito.cantidad < producto.stockActual) enCarrito.cantidad++;
                else Swal.fire({ icon: 'warning', title: 'Sin stock', text: 'Límite alcanzado', timer: 1000, showConfirmButton: false, customClass: { popup: '!rounded-2xl' } });
            } else {
                carrito.push({ productoId: id, nombre: producto.nombre, precio: producto.precioVenta, cantidad: 1, maxStock: producto.stockActual, esServicio: esServicio });
            }
            renderizarCarrito();
        }

        function quitarDelCarrito(id) { carrito = carrito.filter(item => item.productoId !== id); renderizarCarrito(); }

        function cambiarCantidad(id, delta) {
            const item = carrito.find(i => i.productoId === id);
            if (!item) return;
            const nuevaCant = item.cantidad + delta;
            const limite = item.esServicio ? 9999 : item.maxStock;
            if (nuevaCant > 0 && nuevaCant <= limite) item.cantidad = nuevaCant;
            else if (nuevaCant <= 0) quitarDelCarrito(id);
            renderizarCarrito();
        }

        function cambiarPrecio(id, nuevoPrecio) {
            const item = carrito.find(i => i.productoId === id);
            if (!item) return;
            let precio = parseFloat(nuevoPrecio);
            if (!isNaN(precio) && precio >= 0) item.precio = precio;
            renderizarCarrito();
        }

        function renderizarCarrito() {
            const tbody = document.getElementById('listaCarrito');
            const msgVacio = document.getElementById('msgCarritoVacio');
            const lblTotal = document.getElementById('lblTotal');
            const btnPagar = document.getElementById('btnPagar');
            tbody.innerHTML = '';
            let total = 0;
            if (carrito.length === 0) {
                msgVacio.classList.remove('hidden');
                btnPagar.disabled = true;
            } else {
                msgVacio.classList.add('hidden');
                btnPagar.disabled = false;
                carrito.forEach(item => {
                    const subtotal = item.cantidad * item.precio;
                    total += subtotal;
                    tbody.innerHTML += `
                        <tr class="group hover:bg-slate-50/50 transition-colors border-b border-slate-50 last:border-0 text-[10px]">
                            <td class="py-2 pr-1">
                                <div class="flex items-center gap-1 bg-slate-100 rounded p-0.5 w-fit">
                                    <button class="w-3.5 h-3.5 bg-white rounded border border-slate-200" onclick="cambiarCantidad(${item.productoId}, -1)">-</button>
                                    <span class="w-3 text-center">${item.cantidad}</span>
                                    <button class="w-3.5 h-3.5 bg-white rounded border border-slate-200" onclick="cambiarCantidad(${item.productoId}, 1)">+</button>
                                </div>
                            </td>
                            <td class="py-2 font-bold text-slate-800 truncate max-w-[80px]">${item.nombre}</td>
                            <td class="py-2 text-right">
                                <input type="number" class="w-10 bg-transparent border-0 text-indigo-600 text-right p-0 focus:ring-0 font-bold" value="${item.precio.toFixed(2)}" onchange="cambiarPrecio(${item.productoId}, this.value)" step="0.50">
                            </td>
                            <td class="py-2 text-right pl-1">
                                <button class="text-slate-300 hover:text-rose-600" onclick="quitarDelCarrito(${item.productoId})"><i data-lucide="trash-2" class="w-3 h-3"></i></button>
                            </td>
                        </tr>`;
                });
            }
            lblTotal.innerText = '$ ' + total.toFixed(2);
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function filtrarProductos() {
            const texto = document.getElementById('buscador').value.toLowerCase();
            const filtrados = inventario.filter(p => p.nombre.toLowerCase().includes(texto));
            renderizarProductos(filtrados);
        }

        function procesarVenta() {
            if(carrito.length === 0) return;
            Swal.fire({ title: '¿Vender?', text: "Total: " + document.getElementById('lblTotal').innerText, icon: 'question', showCancelButton: true, confirmButtonColor: '#4f46e5', customClass: { popup: '!rounded-3xl' } }).then((result) => {
                if (result.isConfirmed) {
                    const data = { UserId: document.getElementById('userId').value ? parseInt(document.getElementById('userId').value) : null, MetodoPago: document.getElementById('cboMetodo').value, Items: carrito.map(i => ({ ProductoId: i.productoId, Cantidad: i.cantidad, PrecioUnitario: i.precio })) };
                    fetch('/Ventas/Registrar', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) })
                    .then(res => res.json()).then(json => {
                        if(json.success) { Swal.fire({ icon: 'success', title: '¡Éxito!', timer: 1500, showConfirmButton: false }); carrito = []; limpiarCliente(); renderizarCarrito(); cargarInventario(); }
                        else Swal.fire({ icon: 'error', title: 'Error', text: json.message });
                    }).catch(err => Swal.fire('Error', 'Error de conexión', 'error'));
                }
            });
        }

        const modalCli = new bootstrap.Modal(document.getElementById('modalClientes'));
        function abrirModalClientes() { modalCli.show(); }
        document.getElementById('inputBuscarCliente').addEventListener('input', function() {
            const val = this.value;
            if(val.length < 3) return;
            fetch(`/Membresias/BuscarUsuario?q=${val}`).then(r => r.json()).then(data => {
                const ul = document.getElementById('resultadosClientes');
                ul.innerHTML = data.length === 0 ? '<li class="p-3 text-center text-slate-400 text-[10px]">Sin resultados</li>' : '';
                data.forEach(u => {
                    ul.innerHTML += `<li class="p-2 hover:bg-slate-50 cursor-pointer flex items-center justify-between group text-[10px]" onclick="seleccionarCliente(${u.id}, '${u.text}')"><span class="font-bold text-slate-700">${u.text}</span><i data-lucide="chevron-right" class="w-3 h-3 text-slate-300"></i></li>`;
                });
                if (typeof lucide !== 'undefined') lucide.createIcons();
            });
        });
        function seleccionarCliente(id, nombre) { document.getElementById('userId').value = id; document.getElementById('txtCliente').value = nombre; modalCli.hide(); }
        function limpiarCliente() { document.getElementById('userId').value = ''; document.getElementById('txtCliente').value = ''; }
    </script>
}