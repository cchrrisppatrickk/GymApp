@model IEnumerable<GymApp.ViewModels.RoleViewModel>
@using GymApp.Constants

@{
    ViewData["Title"] = "Gestión de Roles";
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                    <i data-lucide="shield-check" class="w-6 h-6"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Roles y Permisos</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Define y administra los niveles de seguridad y acceso al sistema</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.RolesCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button type="button" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-md shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModalCrear()">
                <i data-lucide="plus" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                <span>Nuevo Rol</span>
            </button>
        }
    </div>

    <!-- Rejilla de Roles -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @if (!Model.Any())
        {
            <div class="col-span-full py-20 text-center bg-white rounded-[2.5rem] border border-slate-200 border-dashed">
                <div class="w-20 h-20 bg-slate-50 rounded-[2rem] flex items-center justify-center mx-auto mb-4 border border-slate-100">
                    <i data-lucide="shield-off" class="text-slate-200 w-10 h-10"></i>
                </div>
                <h3 class="text-sm font-black text-slate-400 uppercase tracking-[0.2em]">Sin roles definidos</h3>
                <p class="text-xs text-slate-400 mt-2">No se encontraron perfiles de acceso en el sistema.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                var isAdmin = item.Nombre.ToLower() == "admin";
                
                <div class="group bg-white rounded-[2.5rem] border border-slate-200 shadow-sm hover:shadow-2xl hover:shadow-indigo-500/10 transition-all duration-500 hover:-translate-y-1.5 overflow-hidden flex flex-col relative">
                    <!-- Acento Superior -->
                    <div class="h-2 w-full @(isAdmin ? "bg-rose-500" : "bg-indigo-500")"></div>
                    
                    <div class="p-8 flex-1 flex flex-col">
                        <div class="flex items-start justify-between mb-6">
                            <div class="flex items-center gap-4">
                                <div class="w-14 h-14 rounded-2xl @(isAdmin ? "bg-rose-50 text-rose-600" : "bg-indigo-50 text-indigo-600") flex items-center justify-center border @(isAdmin ? "border-rose-100/50" : "border-indigo-100/50") shadow-sm transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3">
                                    <i data-lucide="@(isAdmin ? "shield-lock" : "user-cog")" class="w-7 h-7"></i>
                                </div>
                                <div>
                                    <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight m-0">@item.Nombre</h5>
                                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Nivel de Acceso</span>
                                </div>
                            </div>
                            @if(isAdmin) {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-lg bg-rose-50 text-rose-700 text-[8px] font-black uppercase tracking-widest border border-rose-100 shadow-sm shadow-rose-500/10">SISTEMA</span>
                            }
                        </div>

                        <div class="bg-slate-50/80 rounded-2xl p-5 mb-8 flex-1 border border-slate-100 group-hover:bg-white transition-colors duration-500">
                            <p class="text-sm font-medium text-slate-700 leading-relaxed italic">
                                "@(string.IsNullOrEmpty(item.Descripcion) ? "Este rol no tiene una descripción técnica definida aún." : item.Descripcion)"
                            </p>
                        </div>

                        <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
                            @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.RolesEditar) || User.IsInRole(AppRoles.Admin))
                            {
                                <button class="w-11 h-11 flex items-center justify-center rounded-xl bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white transition-all duration-300 shadow-sm shadow-amber-100/50 active:scale-95" onclick="abrirModalEditar(@item.RoleId)" title="Configurar Permisos">
                                    <i data-lucide="pencil" class="w-5 h-5"></i>
                                </button>
                            }

                            @if (!isAdmin)
                            {
                                @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.RolesEliminar) || User.IsInRole(AppRoles.Admin))
                                {
                                    <button class="w-11 h-11 flex items-center justify-center rounded-xl bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all duration-300 shadow-sm shadow-rose-100/50 active:scale-95" onclick="eliminarRol(@item.RoleId)" title="Eliminar Perfil">
                                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="w-11 h-11 flex items-center justify-center rounded-xl bg-slate-50 text-slate-300 cursor-not-allowed border border-slate-100" title="Rol Protegido por el Sistema">
                                    <i data-lucide="lock" class="w-5 h-5"></i>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Modal de Gestión de Rol -->
<div class="modal fade" id="modalRol" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                        <i data-lucide="shield-plus" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight" id="tituloModal">Configuración de Rol</h5>
                        <p class="text-slate-700 text-[10px] font-bold uppercase tracking-widest mt-1">Definición de perfil de seguridad</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-700 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-8">
                <form id="formRol" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="RoleId" name="RoleId" value="0" />

                    <div>
                        <label for="Nombre" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Nombre del Perfil</label>
                        <div class="relative group">
                            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                                <i data-lucide="tag" class="w-4 h-4"></i>
                            </div>
                            <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl pl-11 pr-4 py-3 text-sm font-bold text-slate-950 transition-all placeholder:text-slate-600 uppercase" id="Nombre" name="Nombre" placeholder="Ej: VENDEDOR, MONITOR..." required autocomplete="off">
                        </div>
                    </div>

                    <div>
                        <label for="Descripcion" class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Descripción del Acceso</label>
                        <textarea class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-2xl px-4 py-3 text-sm font-medium text-slate-950 transition-all placeholder:text-slate-600" id="Descripcion" name="Descripcion" rows="3" placeholder="Define qué responsabilidades tendrá este perfil..."></textarea>
                    </div>

                    <div class="flex items-start gap-3 bg-rose-50/50 p-4 rounded-2xl border border-rose-100">
                        <i data-lucide="alert-triangle" class="text-rose-500 w-4 h-4 mt-0.5"></i>
                        <p class="text-[10px] font-black text-rose-900 leading-relaxed uppercase tracking-wider">
                            Los permisos detallados (PBAC) deben ser asignados por un Administrador del Sistema después de crear el perfil.
                        </p>
                    </div>
                </form>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 text-slate-700 hover:text-slate-950 transition-colors font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-8 py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-xl shadow-indigo-600/20 transition-all active:scale-95 font-black text-xs uppercase tracking-widest flex items-center justify-center gap-2" onclick="guardarRol()">
                    <i data-lucide="shield-check" class="w-5 h-5"></i>Guardar Perfil
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var myModal;

        document.addEventListener('DOMContentLoaded', function () {
            myModal = new bootstrap.Modal(document.getElementById('modalRol'));
        });

        // 1. ABRIR MODAL PARA CREAR
        function abrirModalCrear() {
            document.getElementById('tituloModal').innerText = "Crear Nuevo Rol";
            document.getElementById('formRol').reset();
            document.getElementById('RoleId').value = "0";
            myModal.show();
            setTimeout(() => document.getElementById("Nombre").focus(), 500);
        }

        // 2. ABRIR MODAL PARA EDITAR
        function abrirModalEditar(id) {
            document.getElementById('tituloModal').innerText = "Actualizar Perfil de Acceso";

            fetch(`/Roles/GetRole/${id}`)
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        document.getElementById('RoleId').value = res.data.roleId;
                        document.getElementById('Nombre').value = res.data.nombre;
                        document.getElementById('Descripcion').value = res.data.descripcion;
                        myModal.show();
                    } else {
                        Swal.fire('Error', 'No se pudo cargar el rol', 'error');
                    }
                })
                .catch(() => Swal.fire('Error', 'Error de conexión', 'error'));
        }

        // 3. GUARDAR
        function guardarRol() {
            const id = document.getElementById('RoleId').value;
            const nombre = document.getElementById('Nombre').value;
            const descripcion = document.getElementById('Descripcion').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if(!nombre.trim()){
                Swal.fire('Atención', 'El nombre del rol es obligatorio', 'warning');
                return;
            }

            const url = id == "0" ? '/Roles/Create' : '/Roles/Edit';
            const payload = {
                RoleId: parseInt(id),
                Nombre: nombre,
                Descripcion: descripcion
            };

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    myModal.hide();
                    Swal.fire({
                        title: '¡Éxito!',
                        text: data.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            })
            .catch(() => Swal.fire('Error', 'Error de conexión', 'error'));
        }

        // 4. ELIMINAR
        function eliminarRol(id) {
            Swal.fire({
                title: '¿Eliminar Rol?',
                text: "Esta acción restringirá el acceso a los usuarios que dependan de este perfil.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                customClass: {
                    confirmButton: 'px-6 py-2 bg-rose-600 text-white rounded-xl font-bold text-xs uppercase tracking-widest mx-2',
                    cancelButton: 'px-6 py-2 bg-slate-100 text-slate-700 rounded-xl font-bold text-xs uppercase tracking-widest mx-2'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Roles/Delete', { id: id }, function (data) {
                        if (data.success) {
                            Swal.fire('Eliminado', data.message, 'success')
                                .then(() => location.reload());
                        } else {
                            Swal.fire('No se pudo eliminar', data.message, 'error');
                        }
                    });
                }
            })
        }
    </script>
}
