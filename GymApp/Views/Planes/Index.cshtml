@{
    ViewData["Title"] = "Planes y Precios";
}

<div class="container-fluid px-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h2 class="mb-0 text-dark fw-bold"><i class="bi bi-tags-fill text-primary me-2"></i>Planes de Suscripción</h2>
            <p class="text-muted small mb-0">Configura los paquetes que ofreces a tus socios.</p>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="abrirModal(0)">
            <i class="bi bi-plus-lg me-1"></i> Nuevo Plan
        </button>
    </div>

    <div class="row g-4" id="contenedorPlanes">
    </div>
</div>

<div class="modal fade" id="modalPlan" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="tituloModal">Gestión de Plan</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formPlan">
                    <input type="hidden" id="PlanId" value="0">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre del Plan</label>
                        <input type="text" class="form-control" id="Nombre" placeholder="Ej: Mensual Full" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Duración</label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="DuracionDias" min="1" required>
                                <span class="input-group-text bg-light">días</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Precio</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input type="number" class="form-control" id="PrecioBase" step="0.01" min="0" required>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-light border d-flex align-items-center" role="alert">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="PermiteCongelar" style="cursor: pointer;">
                            <label class="form-check-label fw-bold" for="PermiteCongelar" style="cursor: pointer;">Permite Congelamiento</label>
                            <div class="text-muted small mt-1">Si activas esto, el socio podrá pausar su membresía por viajes o salud.</div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-decoration-none text-muted" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" onclick="guardarPlan()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            cargarPlanes();
        });

        const modal = new bootstrap.Modal(document.getElementById('modalPlan'));

        function cargarPlanes() {
            const contenedor = document.getElementById("contenedorPlanes");
            contenedor.innerHTML = '<div class="col-12 text-center py-5"><div class="spinner-border text-primary"></div></div>';

            fetch('/Planes/Listar')
                .then(res => res.json())
                .then(json => {
                    let html = '';

                    if(json.data.length === 0) {
                        contenedor.innerHTML = '<div class="col-12 text-center text-muted py-5"><h4>No hay planes creados</h4><p>Crea el primero para empezar a vender.</p></div>';
                        return;
                    }

                    json.data.forEach(p => {
                        // Badge congelamiento
                        const badgeCongela = p.permiteCongelar
                            ? `<span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3"><i class="bi bi-snow2 me-1"></i>Congelable</span>`
                            : `<span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">No Congelable</span>`;

                        html += `
                            <div class="col-md-4 col-lg-3">
                                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                                    <div class="card-body p-4 text-center d-flex flex-column">
                                        <h5 class="fw-bold text-dark mb-3">${p.nombre}</h5>
                                        <h2 class="display-6 fw-bold text-primary mb-0">$${p.precioBase.toFixed(2)}</h2>
                                        <p class="text-muted small mb-4">por ${p.duracionDias} días</p>

                                        <div class="mb-4">
                                            ${badgeCongela}
                                        </div>

                                        <div class="mt-auto pt-3 border-top d-flex justify-content-center gap-2">
                                            <button class="btn btn-sm btn-outline-primary" onclick="editarPlan(${p.planId})">
                                                <i class="bi bi-pencil me-1"></i> Editar
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" onclick="eliminarPlan(${p.planId})">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    contenedor.innerHTML = html;
                });
        }

        function abrirModal(id) {
            document.getElementById('formPlan').reset();
            document.getElementById('PlanId').value = 0;
            document.getElementById('tituloModal').innerText = "Nuevo Plan";
            modal.show();
        }

        function editarPlan(id) {
            fetch('/Planes/Obtener?id=' + id)
                .then(res => res.json())
                .then(json => {
                    if(json.success) {
                        const d = json.data;
                        document.getElementById('PlanId').value = d.planId;
                        document.getElementById('Nombre').value = d.nombre;
                        document.getElementById('DuracionDias').value = d.duracionDias;
                        document.getElementById('PrecioBase').value = d.precioBase;
                        document.getElementById('PermiteCongelar').checked = d.permiteCongelar;

                        document.getElementById('tituloModal').innerText = "Editar Plan";
                        modal.show();
                    }
                });
        }

        function guardarPlan() {
            const data = {
                PlanId: parseInt(document.getElementById('PlanId').value),
                Nombre: document.getElementById('Nombre').value,
                DuracionDias: parseInt(document.getElementById('DuracionDias').value),
                PrecioBase: parseFloat(document.getElementById('PrecioBase').value),
                PermiteCongelar: document.getElementById('PermiteCongelar').checked
            };

            if(!data.Nombre || data.DuracionDias <= 0 || data.PrecioBase < 0) {
                Swal.fire('Atención', 'Revisa los datos ingresados', 'warning');
                return;
            }

            fetch('/Planes/Guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    modal.hide();
                    cargarPlanes();
                    Swal.fire('Guardado', 'El plan se actualizó correctamente', 'success');
                } else {
                    Swal.fire('Error', json.message, 'error');
                }
            });
        }

        function eliminarPlan(id) {
            Swal.fire({
                title: '¿Eliminar Plan?',
                text: "No podrás eliminarlo si ya tiene ventas asociadas.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Planes/Eliminar?id=' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            cargarPlanes();
                            Swal.fire('Eliminado', 'El plan ha sido eliminado.', 'success');
                        } else {
                            Swal.fire('No se pudo eliminar', json.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}