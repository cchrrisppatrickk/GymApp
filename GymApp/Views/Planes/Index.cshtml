@using GymApp.Constants
@{
    ViewData["Title"] = "Planes y Precios";
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                    <i data-lucide="tag" class="w-6 h-6"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Planes de Suscripción</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Configura los paquetes y beneficios para tus socios</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PlanesCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-md shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModal(0)">
                <i data-lucide="plus" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                <span>Nuevo Plan</span>
            </button>
        }
    </div>

    <!-- Rejilla de Planes -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="contenedorPlanes">
        <!-- Generación dinámica -->
    </div>
</div>

<!-- Modal de Gestión -->
<div class="modal fade" id="modalPlan" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                        <i data-lucide="pencil" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight" id="tituloModal">Gestión de Plan</h5>
                        <p class="text-slate-700 text-[10px] font-bold uppercase tracking-widest mt-1">Configuración técnica de oferta</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-700 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-8">
                <form id="formPlan" class="space-y-6">
                    <input type="hidden" id="PlanId" value="0">

                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Nombre del Plan</label>
                        <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 transition-all placeholder:text-slate-600" id="Nombre" placeholder="Ej: Mensual Full Access" required>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Duración</label>
                            <div class="relative">
                                <input type="number" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 transition-all" id="DuracionDias" min="1" required>
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-slate-400 uppercase">Días</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Precio</label>
                            <div class="relative group">
                                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">S/</div>
                                <input type="number" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl pl-10 pr-4 py-3 text-sm font-bold text-slate-950 transition-all" id="PrecioBase" step="0.01" min="0" required>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                        <label class="flex items-center justify-between cursor-pointer group" for="PermiteCongelar">
                            <div>
                                <span class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-1">Permite Pausa</span>
                                <p class="text-[10px] text-slate-500 font-medium">Habilita el congelamiento de membresía</p>
                            </div>
                            <div class="relative inline-flex items-center">
                                <input type="checkbox" id="PermiteCongelar" class="sr-only peer">
                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500 shadow-inner transition-colors"></div>
                            </div>
                        </label>
                    </div>
                </form>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 text-slate-700 hover:text-slate-950 transition-colors font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-8 py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-xl shadow-indigo-600/20 transition-all active:scale-95 font-black text-xs uppercase tracking-widest flex items-center justify-center gap-2" onclick="guardarPlan()">
                    <i data-lucide="save" class="w-4 h-4"></i>Guardar Plan
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            cargarPlanes();
        });

        const modalElement = document.getElementById('modalPlan');
        const modal = new bootstrap.Modal(modalElement);

        function cargarPlanes() {
            const contenedor = document.getElementById("contenedorPlanes");
            contenedor.innerHTML = '<div class="col-span-full text-center py-20"><div class="inline-block w-8 h-8 border-4 border-indigo-100 border-t-indigo-600 rounded-full animate-spin"></div></div>';

            fetch('/Planes/Listar')
                .then(res => res.json())
                .then(json => {
                    let html = '';

                    if(json.data.length === 0) {
                        contenedor.innerHTML = `
                            <div class="col-span-full py-20 text-center">
                                <div class="w-20 h-20 bg-slate-50 rounded-[2rem] flex items-center justify-center mx-auto mb-4 border border-slate-100">
                                    <i data-lucide="inbox" class="text-slate-200 w-10 h-10"></i>
                                </div>
                                <h3 class="text-sm font-black text-slate-400 uppercase tracking-[0.2em]">Sin planes activos</h3>
                                <p class="text-xs text-slate-400 mt-2">Crea el primer plan para comenzar a operar.</p>
                            </div>`;
                        lucide.createIcons();
                        return;
                    }

                    json.data.forEach(p => {
                        const badgeCongela = p.permiteCongelar
                            ? `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest bg-emerald-50 text-emerald-700 border border-emerald-100 shadow-sm"><i data-lucide="snowflake" class="w-3 h-3"></i>Congelable</span>`
                            : `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest bg-slate-100 text-slate-500 border border-slate-200">No Congelable</span>`;

                        const puedeEditar = @(User.HasClaim(TipoClaim.Permiso, AppPermisos.PlanesEditar) || User.IsInRole(AppRoles.Admin) ? "true" : "false");
                        const puedeEliminar = @(User.HasClaim(TipoClaim.Permiso, AppPermisos.PlanesEliminar) || User.IsInRole(AppRoles.Admin) ? "true" : "false");

                        html += `
                            <div class="group bg-white rounded-[2.5rem] border border-slate-200 shadow-sm hover:shadow-2xl hover:shadow-indigo-500/10 transition-all duration-500 hover:-translate-y-2 overflow-hidden flex flex-col">
                                <div class="p-8 flex-1 flex flex-col items-center text-center">
                                    <div class="mb-6">${badgeCongela}</div>
                                    <h5 class="text-xs font-black text-slate-500 uppercase tracking-[0.3em] mb-2">${p.nombre}</h5>
                                    <div class="flex items-baseline gap-1 mb-1">
                                        <span class="text-2xl font-black text-slate-950 font-display">S/</span>
                                        <h2 class="text-5xl font-black text-slate-950 tracking-tighter">${p.precioBase.toFixed(2)}</h2>
                                    </div>
                                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-8">Válido por ${p.duracionDias} días</p>

                                    <div class="w-full h-px bg-slate-100 mb-6"></div>

                                    <div class="flex items-center justify-center gap-3">
                                        ${puedeEditar ? `
                                        <button class="w-11 h-11 flex items-center justify-center rounded-xl bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white transition-all shadow-sm active:scale-95" onclick="editarPlan(${p.planId})" title="Editar">
                                            <i data-lucide="pencil" class="w-5 h-5"></i>
                                        </button>` : ''}
                                        ${puedeEliminar ? `
                                        <button class="w-11 h-11 flex items-center justify-center rounded-xl bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all shadow-sm active:scale-95" onclick="eliminarPlan(${p.planId})" title="Eliminar">
                                            <i data-lucide="trash-2" class="w-5 h-5"></i>
                                        </button>` : ''}
                                    </div>
                                </div>
                                <div class="h-2 bg-indigo-600 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
                            </div>
                        `;
                    });
                    contenedor.innerHTML = html;
                    lucide.createIcons();
                });
        }

        function abrirModal(id) {
            document.getElementById('formPlan').reset();
            document.getElementById('PlanId').value = 0;
            document.getElementById('tituloModal').innerText = "Nuevo Plan de Entrenamiento";
            modal.show();
        }

        function editarPlan(id) {
            fetch('/Planes/Obtener?id=' + id)
                .then(res => res.json())
                .then(json => {
                    if(json.success) {
                        const d = json.data;
                        document.getElementById('PlanId').value = d.planId;
                        document.getElementById('Nombre').value = d.nombre;
                        document.getElementById('DuracionDias').value = d.duracionDias;
                        document.getElementById('PrecioBase').value = d.precioBase;
                        // Forzar a booleano para evitar problemas con null
                        document.getElementById('PermiteCongelar').checked = d.permiteCongelar === true;

                        document.getElementById('tituloModal').innerText = "Actualizar Plan";
                        modal.show();
                    }
                });
        }

        function guardarPlan() {
            const data = {
                PlanId: parseInt(document.getElementById('PlanId').value),
                Nombre: document.getElementById('Nombre').value,
                DuracionDias: parseInt(document.getElementById('DuracionDias').value),
                PrecioBase: parseFloat(document.getElementById('PrecioBase').value),
                PermiteCongelar: document.getElementById('PermiteCongelar').checked
            };

            if(!data.Nombre || data.DuracionDias <= 0 || data.PrecioBase < 0) {
                Swal.fire('Atención', 'Por favor, completa todos los campos requeridos.', 'warning');
                return;
            }

            fetch('/Planes/Guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    modal.hide();
                    cargarPlanes();
                    Swal.fire({ title: '¡Guardado!', text: 'El plan ha sido actualizado.', icon: 'success', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
                } else {
                    Swal.fire('Error', json.message, 'error');
                }
            });
        }

        function eliminarPlan(id) {
            Swal.fire({
                title: '¿Eliminar Plan?',
                text: "Esta acción no se puede deshacer y fallará si existen membresías vinculadas.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                customClass: {
                    confirmButton: 'px-6 py-2 bg-rose-600 text-white rounded-xl font-bold text-xs uppercase tracking-widest mx-2',
                    cancelButton: 'px-6 py-2 bg-slate-100 text-slate-700 rounded-xl font-bold text-xs uppercase tracking-widest mx-2'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Planes/Eliminar?id=' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            cargarPlanes();
                            Swal.fire('¡Eliminado!', 'El plan ha sido removido del catálogo.', 'success');
                        } else {
                            Swal.fire('Restricción', json.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
