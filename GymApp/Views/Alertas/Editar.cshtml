@model GymApp.Models.ConfiguracionAlerta
@{
    ViewData["Title"] = "Editar Alerta";
    var diasGuardados = Model?.DiasSemana?.Split(',') ?? Array.Empty<string>();
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-pencil-square text-primary me-2"></i> Editar Configuración de Alerta</h4>
                <p class="text-muted small mt-1 mb-0">Modifica las reglas para el envío automático de reportes a Telegram/n8n.</p>
            </div>
            
            <div class="card-body p-4">
                <form asp-action="Editar" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row g-5">
                        <!-- Columna Izquierda: Configuración Básica -->
                        <div class="col-md-6 border-end-md">
                            <h5 class="fw-bold mb-4 text-secondary">Configuración General</h5>
                            
                            <div class="mb-4">
                                <label asp-for="HoraEnvio" class="form-label fw-bold">Hora de Envío</label>
                                <input asp-for="HoraEnvio" type="time" class="form-control form-control-lg bg-light" required />
                                <span asp-validation-for="HoraEnvio" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ChatIdDestino" class="form-label fw-bold">ID de Chat Destino (Telegram)</label>
                                <div class="input-group">
                                    <input asp-for="ChatIdDestino" type="text" class="form-control form-control-lg bg-light" placeholder="Ej: -10012345678" required />
                                    <button type="button" class="btn btn-outline-info" id="btnProbarConexion">
                                        <i class="bi bi-send me-1"></i> Probar Conexión
                                    </button>
                                </div>
                                <div class="form-text text-muted small">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Para obtener el ID de un grupo, agrega a <a href="#" class="text-decoration-none">@("@RawDataBot")</a> y copia el ID (con el signo menos si es grupo).
                                </div>
                                <span asp-validation-for="ChatIdDestino" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold d-block mb-3">Días de Ejecución</label>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var dia in new[] { 
                                        new { Val = "1", Text = "Lun" },
                                        new { Val = "2", Text = "Mar" },
                                        new { Val = "3", Text = "Mie" },
                                        new { Val = "4", Text = "Jue" },
                                        new { Val = "5", Text = "Vie" },
                                        new { Val = "6", Text = "Sab" },
                                        new { Val = "0", Text = "Dom" }
                                    })
                                    {
                                        <div class="form-check form-check-inline me-0">
                                            <input type="checkbox" class="btn-check" name="diasSeleccionados" id="dia_@dia.Val" value="@dia.Val" autocomplete="off" @(diasGuardados.Contains(dia.Val) ? "checked" : "")>
                                            <label class="btn btn-outline-primary btn-sm rounded-pill px-3" for="dia_@dia.Val">@dia.Text</label>
                                        </div>
                                    }
                                </div>
                            </div>
                            
                            <div class="card bg-light border-0 mt-4">
                                <div class="card-body p-3">
                                    <div class="form-check form-switch fs-5 mb-0 d-flex align-items-center justify-content-between p-0 m-0">
                                        <label class="form-check-label fw-bold text-dark cursor-pointer" asp-for="Activo">
                                            Estado de la Alerta
                                        </label>
                                        <input class="form-check-input shadow-none cursor-pointer ms-3 mt-0" type="checkbox" role="switch" asp-for="Activo">
                                    </div>
                                    <small class="text-muted d-block mt-2">Al desactivar, esta alerta no generará reportes en n8n.</small>
                                </div>
                            </div>
                        </div>

                        <!-- Columna Derecha: Contenido del Reporte -->
                        <div class="col-md-6 ps-md-4">
                            <h5 class="fw-bold mb-4 text-secondary">Contenido del Reporte</h5>
                            <p class="text-muted small mb-4">Selecciona qué información incluir en el mensaje diario.</p>
                            
                            <div class="list-group list-group-flush border-0">
                                <div class="list-group-item bg-transparent px-0 py-3 border-bottom">
                                    <div class="form-check form-switch fs-5 d-flex align-items-center justify-content-between p-0 m-0">
                                        <label class="form-check-label cursor-pointer" asp-for="EnviarPagosHoy">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-info bg-opacity-10 text-info rounded p-2 me-3">
                                                    <i class="bi bi-cash-coin fs-4"></i>
                                                </div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark fs-6">Pagos del Día</span>
                                                    <small class="text-muted fs-7">Resumen de ingresos y pagos recibidos hoy.</small>
                                                </div>
                                            </div>
                                        </label>
                                        <input class="form-check-input shadow-none cursor-pointer ms-3 mt-0" type="checkbox" role="switch" asp-for="EnviarPagosHoy">
                                    </div>
                                </div>

                                <div class="list-group-item bg-transparent px-0 py-3 border-bottom">
                                    <div class="form-check form-switch fs-5 d-flex align-items-center justify-content-between p-0 m-0">
                                        <label class="form-check-label cursor-pointer" asp-for="EnviarNuevosMiembros">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3">
                                                    <i class="bi bi-person-plus fs-4"></i>
                                                </div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark fs-6">Nuevos Miembros</span>
                                                    <small class="text-muted fs-7">Lista de clientes registrados durante el día.</small>
                                                </div>
                                            </div>
                                        </label>
                                        <input class="form-check-input shadow-none cursor-pointer ms-3 mt-0" type="checkbox" role="switch" asp-for="EnviarNuevosMiembros">
                                    </div>
                                </div>

                                <div class="list-group-item bg-transparent px-0 py-3 border-bottom">
                                    <div class="form-check form-switch fs-5 d-flex align-items-center justify-content-between p-0 m-0">
                                        <label class="form-check-label cursor-pointer" asp-for="EnviarProximosVencimientos">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-warning bg-opacity-10 text-warning rounded p-2 me-3">
                                                    <i class="bi bi-calendar-event fs-4"></i>
                                                </div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark fs-6">Próximos Vencimientos</span>
                                                    <small class="text-muted fs-7">Membresías que expiran en los próximos días.</small>
                                                </div>
                                            </div>
                                        </label>
                                        <input class="form-check-input shadow-none cursor-pointer ms-3 mt-0" type="checkbox" role="switch" asp-for="EnviarProximosVencimientos">
                                    </div>
                                </div>

                                <div class="list-group-item bg-transparent px-0 py-3">
                                    <div class="form-check form-switch fs-5 d-flex align-items-center justify-content-between p-0 m-0">
                                        <label class="form-check-label cursor-pointer" asp-for="EnviarDeudasPendientes">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-danger bg-opacity-10 text-danger rounded p-2 me-3">
                                                    <i class="bi bi-exclamation-octagon fs-4"></i>
                                                </div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark fs-6">Deudas Pendientes</span>
                                                    <small class="text-muted fs-7">Clientes con pagos atrasados registrados.</small>
                                                </div>
                                            </div>
                                        </label>
                                        <input class="form-check-input shadow-none cursor-pointer ms-3 mt-0" type="checkbox" role="switch" asp-for="EnviarDeudasPendientes">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-top mt-4 pt-4 pb-2 px-0 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light btn-lg px-4 border shadow-sm rounded-pill text-secondary fw-bold">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow rounded-pill fw-bold">
                            <i class="bi bi-save me-2"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .fs-7 { font-size: 0.85rem; }
    /* Agrandar un poco los switches para hacerlos más "móviles" */
    .form-switch .form-check-input {
        width: 3em;
        height: 1.5em;
    }
</style>

@section Scripts {
    <script>
        document.getElementById('btnProbarConexion').addEventListener('click', async function () {
            const chatId = document.getElementById('ChatIdDestino').value;
            if (!chatId) {
                Swal.fire('Atención', 'Por favor ingresa un ID de Chat primero.', 'warning');
                return;
            }

            const btn = this;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Probando...';
            btn.disabled = true;

            try {
                const response = await fetch('/Alertas/ProbarConexion', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(chatId)
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire('¡Éxito!', result.message, 'success');
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Ocurrió un problema al intentar conectar.', 'error');
            } finally {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    </script>
}
