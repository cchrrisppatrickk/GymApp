@model IEnumerable<GymApp.Models.ConfiguracionAlerta>
@{
    ViewData["Title"] = "Gestión de Alertas Automáticas";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h2>
            <p class="text-muted mb-0">Configure y administre los reportes automáticos enviados a Telegram vía n8n.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary shadow-sm rounded-pill px-4 py-2">
            <i class="bi bi-plus-circle-fill me-2"></i> Nueva Alerta
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0" id="tablaAlertas">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold">Hora de Envío</th>
                            <th class="py-3 text-uppercase small fw-bold">Días de Ejecución</th>
                            <th class="py-3 text-uppercase small fw-bold">Chat Destino</th>
                            <th class="py-3 text-uppercase small fw-bold">Reportes Activos</th>
                            <th class="py-3 text-uppercase small fw-bold">Estado</th>
                            <th class="pe-4 py-3 text-uppercase small fw-bold text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-info-circle display-4 mb-3 d-block"></i>
                                        <p class="mb-0">No hay alertas configuradas. ¡Crea la primera!</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3">
                                            <i class="bi bi-clock-fill"></i>
                                        </div>
                                        <span class="fw-bold fs-5">
                                            @DateTime.Today.Add(item.HoraEnvio).ToString("hh:mm tt")
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var dias = item.DiasSemana?.Split(',') ?? Array.Empty<string>();
                                        var diasNombres = new Dictionary<string, string> { 
                                            { "1", "Lun" }, { "2", "Mar" }, { "3", "Mie" }, 
                                            { "4", "Jue" }, { "5", "Vie" }, { "6", "Sab" }, { "0", "Dom" } 
                                        };
                                    }
                                    @foreach (var dia in dias)
                                    {
                                        if (diasNombres.ContainsKey(dia))
                                        {
                                            <span class="badge border text-dark fw-normal me-1">@diasNombres[dia]</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <code>@item.ChatIdDestino</code>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @if (item.EnviarNuevosMiembros) { <span class="badge bg-success bg-opacity-75">Miembros</span> }
                                        @if (item.EnviarPagosHoy) { <span class="badge bg-info bg-opacity-75">Pagos</span> }
                                        @if (item.EnviarProximosVencimientos) { <span class="badge bg-warning bg-dark bg-opacity-75 text-dark">Vencimientos</span> }
                                        @if (item.EnviarDeudasPendientes) { <span class="badge bg-danger bg-opacity-75">Deudas</span> }
                                    </div>
                                </td>
                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge rounded-pill bg-success px-3">
                                            <i class="bi bi-check-circle-fill me-1"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary px-3">
                                            <i class="bi bi-pause-fill me-1"></i> Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 text-center">
                                    <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                        <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm border-0" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger btn-sm border-0" onclick="eliminarAlerta(@item.Id)" title="Eliminar">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function eliminarAlerta(id) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción no se puede deshacer y detendrá este reporte automático.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Eliminar", "Alertas")',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire(
                                    '¡Eliminado!',
                                    response.message,
                                    'success'
                                ).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire(
                                    'Error',
                                    response.message,
                                    'error'
                                );
                            }
                        }
                    });
                }
            });
        }
    </script>
}
