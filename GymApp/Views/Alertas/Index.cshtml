@model IEnumerable<GymApp.Models.ConfiguracionAlerta>
@{
    ViewData["Title"] = "Listado de Alertas";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <div class="notif-icon-header me-3">
            <i class="bi bi-bell-fill"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0">Configuraciones de Alertas</h2>
            <p class="text-muted mb-0 small">Gestiona múltiples destinos y horarios para tus notificaciones.</p>
        </div>
        <div class="ms-auto">
            <a asp-action="Crear" class="btn btn-primary btn-lg rounded-pill shadow-sm px-4 fw-bold">
                <i class="bi bi-plus-lg me-2"></i> Nueva Configuración
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Chat Destino</th>
                        <th>Hora Programada</th>
                        <th>Días</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="chat-icon-sm me-2 bg-primary-subtle text-primary">
                                        <i class="bi bi-telegram"></i>
                                    </div>
                                    <span class="fw-semibold">@item.ChatIdDestino</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-2 py-1">
                                    <i class="bi bi-clock me-1"></i> @item.HoraEnvio.ToString(@"hh\:mm")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    @{
                                        var dias = item.DiasSemana?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                                    }
                                    @foreach (var dia in dias)
                                    {
                                        <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle" style="font-size: 0.7rem;">
                                            @(dia == "1" ? "Lun" : dia == "2" ? "Mar" : dia == "3" ? "Mié" : dia == "4" ? "Jue" : dia == "5" ? "Vie" : dia == "6" ? "Sáb" : "Dom")
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="text-center">
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                                        <i class="bi bi-check-circle-fill me-1"></i> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-pill">
                                        <i class="bi bi-pause-circle-fill me-1"></i> Pausado
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                        <i class="bi bi-pencil-square me-1"></i> Editar
                                    </a>
                                    <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Estás seguro de eliminar esta configuración?');" style="display:inline;">
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                            <i class="bi bi-trash3-fill me-1"></i> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                No hay configuraciones de alertas creadas aún.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .notif-icon-header {
        width: 52px; height: 52px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: white;
    }
    .chat-icon-sm {
        width: 32px; height: 32px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
    }
</style>
