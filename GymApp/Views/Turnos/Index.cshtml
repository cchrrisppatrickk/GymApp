@using GymApp.Constants
@{
    ViewData["Title"] = "Horarios y Turnos";
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-100/50 shadow-sm">
                    <i data-lucide="clock" class="w-6 h-6"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Horarios y Turnos</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Define los bloques de acceso y franjas horarias del gimnasio</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.TurnosCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-md shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModal(0)">
                <i data-lucide="plus" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                <span>Nuevo Turno</span>
            </button>
        }
    </div>

    <!-- Tabla -->
    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse" id="tablaTurnos">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Nombre del Turno</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Horario de Inicio</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Horario de Cierre</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Estado</th>
                        <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100/80">
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal de Gestión -->
<div class="modal fade" id="modalTurno" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-100/50 shadow-sm">
                        <i data-lucide="pencil" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight" id="tituloModal">Gestión de Turno</h5>
                        <p class="text-slate-700 text-[10px] font-bold uppercase tracking-widest mt-1">Configuración de franja horaria</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-700 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-8">
                <form id="formTurno" class="space-y-6">
                    <input type="hidden" id="TurnoId" value="0">

                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Etiqueta del Turno</label>
                        <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 transition-all placeholder:text-slate-600" id="Nombre" placeholder="Ej: Mañana, Tarde, Full Day..." required>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Hora Inicio</label>
                            <input type="time" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 transition-all" id="HoraInicio" required>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Hora Fin</label>
                            <input type="time" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 transition-all" id="HoraFin" required>
                        </div>
                    </div>

                    <div class="flex items-start gap-3 bg-indigo-50/50 p-4 rounded-2xl border border-indigo-100">
                        <i data-lucide="info" class="text-indigo-500 w-4 h-4 mt-0.5"></i>
                        <p class="text-[11px] font-medium text-indigo-900 leading-relaxed uppercase tracking-wide">
                            El sistema restringirá el acceso de los socios fuera de estos rangos.
                        </p>
                    </div>
                </form>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 text-slate-700 hover:text-slate-950 transition-colors font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-8 py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-xl shadow-indigo-600/20 transition-all active:scale-95 font-black text-xs uppercase tracking-widest flex items-center justify-center gap-2" onclick="guardarTurno()">
                    <i data-lucide="save" class="w-4 h-4"></i>Guardar Turno
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            cargarTurnos();
        });

        const modalElement = document.getElementById('modalTurno');
        const modal = new bootstrap.Modal(modalElement);

        function cargarTurnos() {
            const tbody = document.querySelector("#tablaTurnos tbody");
            tbody.innerHTML = '<tr><td colspan="5" class="text-center py-20"><div class="inline-block w-8 h-8 border-4 border-amber-100 border-t-amber-600 rounded-full animate-spin"></div></td></tr>';

            fetch('/Turnos/ListarTurnos')
                .then(response => response.json())
                .then(json => {
                    let html = '';

                    if(json.data.length === 0) {
                        tbody.innerHTML = `
                            <tr>
                                <td colspan="5" class="px-6 py-20 text-center">
                                    <div class="max-w-xs mx-auto">
                                        <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
                                            <i data-lucide="calendar-x" class="text-slate-300 w-10 h-10"></i>
                                        </div>
                                        <h3 class="text-sm font-bold text-slate-950 uppercase tracking-widest mb-2">Sin turnos</h3>
                                        <p class="text-xs text-slate-500 leading-relaxed font-medium">Configura los horarios para empezar a asignar socios.</p>
                                    </div>
                                </td>
                            </tr>`;
                        lucide.createIcons();
                        return;
                    }

                    const puedeEditar = @(User.HasClaim(TipoClaim.Permiso, AppPermisos.TurnosEditar) || User.IsInRole(AppRoles.Admin) ? "true" : "false");
                    const puedeEliminar = @(User.HasClaim(TipoClaim.Permiso, AppPermisos.TurnosEliminar) || User.IsInRole(AppRoles.Admin) ? "true" : "false");

                    json.data.forEach(t => {
                        html += `
                            <tr class="group hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center font-bold text-xs border border-amber-100/50">
                                            ${t.nombre.substring(0, 1).toUpperCase()}
                                        </div>
                                        <span class="text-sm font-bold text-slate-950 tracking-tight">${t.nombre}</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest bg-emerald-50 text-emerald-700 border border-emerald-100">
                                        <i data-lucide="sun" class="w-3 h-3"></i>${t.horaInicio}
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest bg-indigo-50 text-indigo-700 border border-indigo-100">
                                        <i data-lucide="moon" class="w-3 h-3"></i>${t.horaFin}
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[9px] font-black uppercase tracking-wider bg-slate-100 text-slate-500 border border-slate-200">
                                        Activo
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        ${puedeEditar ? `
                                        <button class="w-9 h-9 flex items-center justify-center rounded-xl bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white transition-all duration-300 shadow-sm shadow-amber-100/50" onclick="editarTurno(${t.turnoId})" title="Editar">
                                            <i data-lucide="pencil" class="w-4 h-4"></i>
                                        </button>` : ''}
                                        ${puedeEliminar ? `
                                        <button class="w-9 h-9 flex items-center justify-center rounded-xl bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all duration-300 shadow-sm shadow-rose-100/50" onclick="eliminarTurno(${t.turnoId})" title="Eliminar">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>` : ''}
                                    </div>
                                </td>
                            </tr>
                        `;
                    });
                    tbody.innerHTML = html;
                    lucide.createIcons();
                });
        }

        function abrirModal(id) {
            document.getElementById('TurnoId').value = 0;
            document.getElementById('formTurno').reset();
            document.getElementById('tituloModal').innerText = "Nuevo Turno";
            modal.show();
        }

        function editarTurno(id) {
            fetch('/Turnos/ObtenerTurno?id=' + id)
                .then(res => res.json())
                .then(json => {
                    if(json.success) {
                        const t = json.data;
                        document.getElementById('TurnoId').value = t.turnoId;
                        document.getElementById('Nombre').value = t.nombre;
                        document.getElementById('HoraInicio').value = t.horaInicio;
                        document.getElementById('HoraFin').value = t.horaFin;

                        document.getElementById('tituloModal').innerText = "Editar Turno";
                        modal.show();
                    }
                });
        }

        function guardarTurno() {
            const data = {
                TurnoId: parseInt(document.getElementById('TurnoId').value),
                Nombre: document.getElementById('Nombre').value,
                HoraInicio: document.getElementById('HoraInicio').value,
                HoraFin: document.getElementById('HoraFin').value
            };

            if(!data.Nombre || !data.HoraInicio || !data.HoraFin) {
                Swal.fire('Atención', 'Por favor, completa todos los campos de horario.', 'warning');
                return;
            }

            fetch('/Turnos/Guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    modal.hide();
                    cargarTurnos();
                    Swal.fire({ title: '¡Guardado!', text: 'Turno actualizado correctamente.', icon: 'success', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
                } else {
                    Swal.fire('Error', json.message, 'error');
                }
            });
        }

        function eliminarTurno(id) {
            Swal.fire({
                title: '¿Eliminar Turno?',
                text: "Esta acción podría afectar a membresías activas vinculadas a este horario.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                customClass: {
                    confirmButton: 'px-6 py-2 bg-rose-600 text-white rounded-xl font-bold text-xs uppercase tracking-widest mx-2',
                    cancelButton: 'px-6 py-2 bg-slate-100 text-slate-700 rounded-xl font-bold text-xs uppercase tracking-widest mx-2'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Turnos/Eliminar?id=' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            cargarTurnos();
                            Swal.fire('Eliminado', 'El turno ha sido removido.', 'success');
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
