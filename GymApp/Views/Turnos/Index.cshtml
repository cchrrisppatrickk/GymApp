@{
    ViewData["Title"] = "Horarios y Turnos";
}

<div class="container-fluid px-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h2 class="mb-0 text-dark fw-bold"><i class="bi bi-clock-history text-warning me-2"></i>Horarios y Turnos</h2>
            <p class="text-muted small mb-0">Define los bloques de acceso al gimnasio.</p>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="abrirModal(0)">
            <i class="bi bi-plus-lg me-1"></i> Nuevo Turno
        </button>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaTurnos">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Nombre del Turno</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Duración Total</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTurno" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning bg-gradient text-dark">
                <h5 class="modal-title fw-bold" id="tituloModal">Gestión de Turno</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formTurno">
                    <input type="hidden" id="TurnoId" value="0">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre</label>
                        <input type="text" class="form-control" id="Nombre" placeholder="Ej: Mañana" required>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Hora Inicio</label>
                            <input type="time" class="form-control text-center fw-bold" id="HoraInicio" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Hora Fin</label>
                            <input type="time" class="form-control text-center fw-bold" id="HoraFin" required>
                        </div>
                    </div>

                    <div class="alert alert-info small mb-0">
                        <i class="bi bi-info-circle me-1"></i> El sistema validará el acceso solo dentro de este rango.
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-decoration-none text-muted" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-warning px-4 fw-bold" onclick="guardarTurno()">Guardar Turno</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            cargarTurnos();
        });

        const modal = new bootstrap.Modal(document.getElementById('modalTurno'));

        function cargarTurnos() {
            const tbody = document.querySelector("#tablaTurnos tbody");
            tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4"><div class="spinner-border text-warning"></div></td></tr>';

            fetch('/Turnos/ListarTurnos')
                .then(response => response.json())
                .then(json => {
                    let html = '';

                    if(json.data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">No hay turnos configurados.</td></tr>';
                        return;
                    }

                    json.data.forEach(t => {
                        // Calcular duración simple (visual)
                        // Aquí asumimos formato HH:mm:ss

                        html += `
                            <tr>
                                <td class="ps-4 fw-bold text-dark">${t.nombre}</td>
                                <td><span class="badge bg-light text-dark border"><i class="bi bi-sun me-1"></i>${t.horaInicio}</span></td>
                                <td><span class="badge bg-light text-dark border"><i class="bi bi-moon me-1"></i>${t.horaFin}</span></td>
                                <td><small class="text-muted">Calculado por sistema</small></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-light border me-1" onclick="editarTurno(${t.turnoId})"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-light border text-danger" onclick="eliminarTurno(${t.turnoId})"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        `;
                    });
                    tbody.innerHTML = html;
                });
        }

        function abrirModal(id) {
            document.getElementById('TurnoId').value = 0;
            document.getElementById('formTurno').reset();
            document.getElementById('tituloModal').innerText = "Nuevo Turno";
            modal.show();
        }

        function editarTurno(id) {
            fetch('/Turnos/ObtenerTurno?id=' + id)
                .then(res => res.json())
                .then(json => {
                    if(json.success) {
                        const t = json.data;
                        document.getElementById('TurnoId').value = t.turnoId;
                        document.getElementById('Nombre').value = t.nombre;
                        document.getElementById('HoraInicio').value = t.horaInicio;
                        document.getElementById('HoraFin').value = t.horaFin;

                        document.getElementById('tituloModal').innerText = "Editar Turno";
                        modal.show();
                    }
                });
        }

        function guardarTurno() {
            const data = {
                TurnoId: parseInt(document.getElementById('TurnoId').value),
                Nombre: document.getElementById('Nombre').value,
                HoraInicio: document.getElementById('HoraInicio').value,
                HoraFin: document.getElementById('HoraFin').value
            };

            if(!data.Nombre || !data.HoraInicio || !data.HoraFin) {
                Swal.fire('Atención', 'Completa todos los campos de hora', 'warning');
                return;
            }

            fetch('/Turnos/Guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    modal.hide();
                    cargarTurnos();
                    Swal.fire('Éxito', 'Turno guardado correctamente', 'success');
                } else {
                    Swal.fire('Error', json.message, 'error');
                }
            });
        }

        function eliminarTurno(id) {
            Swal.fire({
                title: '¿Eliminar Turno?',
                text: "Esto podría afectar a membresías activas.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Turnos/Eliminar?id=' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            cargarTurnos();
                            Swal.fire('Eliminado', 'El turno ha sido eliminado.', 'success');
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}