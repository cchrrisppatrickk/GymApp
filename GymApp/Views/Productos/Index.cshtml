@{
    ViewData["Title"] = "Inventario de Productos";
}

<div class="container-fluid px-4 fade-in">
    <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h2 class="mb-0 text-dark fw-bold"><i class="bi bi-box-seam-fill text-primary me-2"></i>Inventario</h2>
            <p class="text-muted small mb-0">Gestiona el stock de suplementos, bebidas y accesorios.</p>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="abrirModal(0)">
            <i class="bi bi-plus-lg me-1"></i> Nuevo Producto
        </button>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm border-start border-4 border-primary h-100">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small fw-bold mb-1">Total Items</h6>
                    <h3 class="mb-0 fw-bold text-dark" id="kpiTotalItems">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm border-start border-4 border-danger h-100">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small fw-bold mb-1">Stock Crítico (< 5)</h6>
                    <h3 class="mb-0 fw-bold text-danger" id="kpiCritico">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-12 col-lg-6">
            <div class="card border-0 shadow-sm bg-light h-100">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-info-circle text-primary fs-3 me-3"></i>
                    <div>
                        <small class="text-muted d-block">Tip de gestión:</small>
                        <span class="fw-bold text-dark">Mantén el stock actualizado para evitar errores en el Punto de Venta.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="input-group input-group-sm" style="max-width: 300px;">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" id="txtBuscar" placeholder="Buscar producto..." onkeyup="filtrarTabla()">
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaProductos">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Producto</th>
                            <th>Precio Venta</th>
                            <th>Stock Actual</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                    </tbody>
                </table>
            </div>
            <div id="emptyState" class="text-center py-5 d-none">
                <i class="bi bi-box2 text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-2">No se encontraron productos.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalProducto" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="tituloModal">Gestión de Producto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formProducto">
                    <input type="hidden" id="ProductoId" value="0">

                    <div class="mb-4 text-center">
                        <div class="bg-light rounded-circle d-inline-flex p-3 mb-2">
                            <i class="bi bi-box-seam text-primary" style="font-size: 2rem;"></i>
                        </div>
                        <p class="text-muted small">Ingresa los detalles del ítem para venta.</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre del Producto</label>
                        <input type="text" class="form-control" id="Nombre" placeholder="Ej: Gatorade Azul 500ml" required>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Precio ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input type="number" class="form-control" id="PrecioVenta" step="0.50" min="0" required>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Stock Inicial</label>
                            <input type="number" class="form-control" id="StockActual" min="0" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-decoration-none text-muted" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" onclick="guardarProducto()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Cache de datos para el buscador
        let listaProductos = [];

        document.addEventListener("DOMContentLoaded", () => {
            cargarProductos();
        });

        const modal = new bootstrap.Modal(document.getElementById('modalProducto'));

        function cargarProductos() {
            const tbody = document.querySelector("#tablaProductos tbody");
            tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4"><div class="spinner-border text-primary"></div></td></tr>';

            fetch('/Productos/Listar')
                .then(res => res.json())
                .then(json => {
                    listaProductos = json.data; // Guardar en memoria
                    renderTabla(listaProductos);
                    actualizarKPIs(listaProductos);
                });
        }

        function renderTabla(datos) {
            const tbody = document.querySelector("#tablaProductos tbody");
            let html = '';

            if (datos.length === 0) {
                tbody.innerHTML = '';
                document.getElementById("emptyState").classList.remove("d-none");
                return;
            }

            document.getElementById("emptyState").classList.add("d-none");

            datos.forEach(p => {
                // Semáforo de Stock
                let stockBadge = `<span class="badge bg-success bg-opacity-75 text-white">Normal</span>`;
                let rowClass = "";

                if(p.stockActual <= 5) {
                    stockBadge = `<span class="badge bg-danger bg-opacity-75 text-white"><i class="bi bi-exclamation-circle me-1"></i>Crítico</span>`;
                    rowClass = "table-danger bg-opacity-10"; // Resaltar fila
                } else if(p.stockActual <= 15) {
                    stockBadge = `<span class="badge bg-warning text-dark">Bajo</span>`;
                }

                html += `
                    <tr class="${rowClass}">
                        <td class="ps-4">
                            <span class="fw-bold text-dark">${p.nombre}</span>
                        </td>
                        <td>
                            <span class="fw-bold text-success">$ ${p.precioVenta.toFixed(2)}</span>
                        </td>
                        <td>
                            <span class="fw-bold">${p.stockActual}</span> u.
                        </td>
                        <td>${stockBadge}</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-light border me-1" onclick="editar(${p.productoId})" title="Editar">
                                <i class="bi bi-pencil text-primary"></i>
                            </button>
                            <button class="btn btn-sm btn-light border" onclick="eliminar(${p.productoId})" title="Eliminar">
                                <i class="bi bi-trash text-danger"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function actualizarKPIs(datos) {
            document.getElementById('kpiTotalItems').innerText = datos.length;
            // Contar críticos
            const criticos = datos.filter(p => p.stockActual <= 5).length;
            document.getElementById('kpiCritico').innerText = criticos;
        }

        function filtrarTabla() {
            const texto = document.getElementById("txtBuscar").value.toLowerCase();
            const filtrados = listaProductos.filter(p => p.nombre.toLowerCase().includes(texto));
            renderTabla(filtrados);
        }

        function abrirModal(id) {
            if(id === 0) {
                document.getElementById('formProducto').reset();
                document.getElementById('ProductoId').value = 0;
                document.getElementById('tituloModal').innerText = "Nuevo Producto";
                modal.show();
                setTimeout(() => document.getElementById("Nombre").focus(), 500);
            }
        }

        function editar(id) {
            // Buscar en memoria para más velocidad, o fetch si prefieres seguridad
            const p = listaProductos.find(x => x.productoId === id);
            if(p) {
                document.getElementById('ProductoId').value = p.productoId;
                document.getElementById('Nombre').value = p.nombre;
                document.getElementById('PrecioVenta').value = p.precioVenta;
                document.getElementById('StockActual').value = p.stockActual;

                document.getElementById('tituloModal').innerText = "Editar Producto";
                modal.show();
            } else {
                // Fallback a fetch
                fetch('/Productos/Obtener?id=' + id)
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) { /* ... lógica de llenado ... */ }
                    });
            }
        }

        function guardarProducto() {
            const data = {
                ProductoId: parseInt(document.getElementById('ProductoId').value),
                Nombre: document.getElementById('Nombre').value,
                PrecioVenta: parseFloat(document.getElementById('PrecioVenta').value),
                StockActual: parseInt(document.getElementById('StockActual').value)
            };

            if(!data.Nombre || data.PrecioVenta < 0 || data.StockActual < 0) {
                Swal.fire('Atención', 'Datos incorrectos', 'warning');
                return;
            }

            fetch('/Productos/Guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    modal.hide();
                    cargarProductos();
                    Swal.fire('Éxito', 'Inventario actualizado', 'success');
                } else {
                    Swal.fire('Error', json.message, 'error');
                }
            });
        }

        function eliminar(id) {
            Swal.fire({
                title: '¿Eliminar producto?',
                text: "Esta acción es irreversible.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Productos/Eliminar?id=' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            cargarProductos();
                            Swal.fire('Eliminado', 'Producto retirado.', 'success');
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}