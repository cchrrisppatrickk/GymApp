@using GymApp.Constants
@{
    ViewData["Title"] = "Inventario de Productos";
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                    <i data-lucide="package" class="w-6 h-6"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Inventario de Productos</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Gestiona el stock, bebidas y servicios del gimnasio</p>
        </div>

        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.ProductosCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-sm shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModal(0)">
                <i data-lucide="plus-circle" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                <span>Nuevo Producto</span>
            </button>
        }
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Total Items -->
        <div class="bg-white rounded-[2rem] border border-slate-200 p-6 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i data-lucide="layers" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Total Items</p>
                    <h3 class="text-3xl font-display font-bold text-slate-950 m-0" id="kpiTotalItems">0</h3>
                </div>
            </div>
        </div>

        <!-- Stock Crítico -->
        <div class="bg-white rounded-[2rem] border border-slate-200 p-6 shadow-sm hover:shadow-md transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-rose-50 text-rose-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <i data-lucide="alert-triangle" class="w-6 h-6"></i>
                </div>
                <div>
                    <p class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-1">Stock Crítico (< 5)</p>
                    <h3 class="text-3xl font-display font-bold text-rose-600 m-0" id="kpiCritico">0</h3>
                </div>
            </div>
        </div>

        <!-- Nota Informativa -->
        <div class="bg-slate-50 rounded-[2rem] border border-slate-200 p-6 flex items-center gap-4 lg:col-span-1">
            <div class="w-12 h-12 rounded-2xl bg-white text-indigo-600 flex items-center justify-center shadow-sm shrink-0">
                <i data-lucide="info" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-slate-900 text-sm font-bold mb-0.5">Nota Importante</p>
                <p class="text-slate-600 text-xs font-medium m-0 leading-relaxed">Los productos "Servicio" no descuentan stock físico.</p>
            </div>
        </div>
    </div>

    <!-- Filtros y Tabla -->
    <div class="space-y-4">
        <div class="bg-white rounded-[2rem] border border-slate-200 p-2 shadow-sm">
            <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-2">
                <div class="flex-1 relative group">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-600 group-focus-within:text-indigo-500 transition-colors">
                        <i data-lucide="search" class="w-5 h-5"></i>
                    </div>
                    <input type="text" id="txtBuscar" onkeyup="filtrarTabla()" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl pl-11 pr-4 py-2.5 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" placeholder="Buscar producto por nombre o categoría...">
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse" id="tablaProductos">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-200">
                            <th class="px-6 py-4 text-xs uppercase tracking-wider font-bold text-slate-500">Producto</th>
                            <th class="px-6 py-4 text-xs uppercase tracking-wider font-bold text-slate-500">Categoría</th>
                            <th class="px-6 py-4 text-xs uppercase tracking-wider font-bold text-slate-500">Precio Venta</th>
                            <th class="px-6 py-4 text-xs uppercase tracking-wider font-bold text-slate-500">Stock Actual</th>
                            <th class="px-6 py-4 text-xs uppercase tracking-wider font-bold text-slate-500 text-center">Estado</th>
                            <th class="px-6 py-4 text-xs uppercase tracking-wider font-bold text-slate-500 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <!-- Renderizado por JS -->
                    </tbody>
                </table>
            </div>

            <!-- Empty State -->
            <div id="emptyState" class="hidden flex flex-col items-center justify-center py-16 px-4">
                <div class="w-20 h-20 rounded-[2.5rem] bg-slate-50 flex items-center justify-center mb-4 border border-slate-100 shadow-inner">
                    <i data-lucide="package-search" class="w-10 h-10 text-slate-400"></i>
                </div>
                <h3 class="text-lg font-display font-bold text-slate-900 mb-1">No se encontraron productos</h3>
                <p class="text-slate-500 text-sm font-medium text-center max-w-xs">Intenta ajustar tu búsqueda para encontrar lo que necesitas.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalProducto" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="tituloModal">Gestión de Producto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formProducto">
                    <input type="hidden" id="ProductoId" value="0">

                    <div class="mb-4 text-center">
                        <div class="bg-light rounded-circle d-inline-flex p-3 mb-2">
                            <i class="bi bi-box-seam text-primary" style="font-size: 2rem;"></i>
                        </div>
                        <p class="text-muted small">Ingresa los detalles del ítem para venta.</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre del Producto</label>
                        <input type="text" class="form-control" id="Nombre" placeholder="Ej: Pase Diario Mañana / Gatorade" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Categoría (Reportes)</label>
                        <select class="form-select" id="Categoria" required>
                            <option value="General">General (Bebidas, Agua, etc.)</option>
                            <option value="XB">XB (Energizantes)</option>
                            <option value="Servicio">Servicio (Pases Libres / Diarios)</option>
                        </select>
                        <div class="form-text small">Selecciona "Servicio" para ítems intangibles (no controlan stock).</div>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Precio ($)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">$</span>
                                <input type="number" class="form-control" id="PrecioVenta" step="0.50" min="0" required>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Stock Inicial</label>
                            <input type="number" class="form-control" id="StockActual" min="0" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-decoration-none text-muted" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" onclick="guardarProducto()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Cache de datos
        let listaProductos = [];
        const modalElement = document.getElementById('modalProducto');
        const modal = new bootstrap.Modal(modalElement);

        document.addEventListener("DOMContentLoaded", () => {
            cargarProductos();
        });

        function cargarProductos() {
            const tbody = document.querySelector("#tablaProductos tbody");
            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-primary"></div></td></tr>';

            fetch('/Productos/Listar')
                .then(res => res.json())
                .then(json => {
                    listaProductos = json.data;
                    renderTabla(listaProductos);
                    actualizarKPIs(listaProductos);
                })
                .catch(err => {
                    console.error(err);
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-danger">Error al cargar datos</td></tr>';
                });
        }

        function renderTabla(datos) {
            const tbody = document.querySelector("#tablaProductos tbody");
            let html = '';

            if (!datos || datos.length === 0) {
                tbody.innerHTML = '';
                document.getElementById("emptyState").classList.remove("d-none");
                return;
            }

            document.getElementById("emptyState").classList.add("d-none");

            const puedeEditar = @(User.HasClaim(TipoClaim.Permiso, AppPermisos.ProductosEditar) || User.IsInRole(AppRoles.Admin) ? "true" : "false");
            const puedeEliminar = @(User.HasClaim(TipoClaim.Permiso, AppPermisos.ProductosEliminar) || User.IsInRole(AppRoles.Admin) ? "true" : "false");

            datos.forEach(p => {
                // 1. Estilos por Categoría
                let catBadge = `<span class="badge bg-secondary bg-opacity-75 text-white">General</span>`;
                if(p.categoria === 'XB') catBadge = `<span class="badge bg-warning text-dark border border-warning">XB</span>`;
                if(p.categoria === 'Servicio') catBadge = `<span class="badge bg-info text-dark border border-info">Servicio</span>`;

                // 2. Lógica de Stock (Visual)
                let stockDisplay = `<span class="fw-bold">${p.stockActual}</span> u.`;
                let stockBadge = `<span class="badge bg-success bg-opacity-75 text-white">Normal</span>`;
                let rowClass = "";

                if (p.categoria === 'Servicio') {
                    // Los servicios no tienen stock crítico
                    stockDisplay = `<span class="text-muted small"><i class="bi bi-infinity fs-5"></i> Ilimitado</span>`;
                    stockBadge = `<span class="badge bg-light text-dark border">Activo</span>`;
                } else {
                    // Productos físicos
                    if(p.stockActual <= 5) {
                        stockBadge = `<span class="badge bg-danger bg-opacity-75 text-white"><i class="bi bi-exclamation-circle me-1"></i>Crítico</span>`;
                        rowClass = "table-danger bg-opacity-10";
                    } else if(p.stockActual <= 15) {
                        stockBadge = `<span class="badge bg-warning text-dark">Bajo</span>`;
                    }
                }

                html += `
                    <tr class="${rowClass}">
                        <td class="ps-4">
                            <span class="fw-bold text-dark">${p.nombre}</span>
                        </td>
                        <td>${catBadge}</td> <td>
                            <span class="fw-bold text-success">S/. ${p.precioVenta.toFixed(2)}</span>
                        </td>
                        <td>${stockDisplay}</td>
                        <td>${stockBadge}</td>
                        <td class="text-center">
                            ${puedeEditar ? `<button class="btn btn-sm btn-light border me-1" onclick="editar(${p.productoId})" title="Editar">
                                <i class="bi bi-pencil text-primary"></i>
                            </button>` : ''}
                            ${puedeEliminar ? `<button class="btn btn-sm btn-light border" onclick="eliminar(${p.productoId})" title="Eliminar">
                                <i class="bi bi-trash text-danger"></i>
                            </button>` : ''}
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function actualizarKPIs(datos) {
            document.getElementById('kpiTotalItems').innerText = datos.length;
            // Solo contamos stock crítico de productos FÍSICOS (No servicios)
            const criticos = datos.filter(p => p.categoria !== 'Servicio' && p.stockActual <= 5).length;
            document.getElementById('kpiCritico').innerText = criticos;
        }

        function filtrarTabla() {
            const texto = document.getElementById("txtBuscar").value.toLowerCase();
            const filtrados = listaProductos.filter(p =>
                p.nombre.toLowerCase().includes(texto) ||
                (p.categoria && p.categoria.toLowerCase().includes(texto))
            );
            renderTabla(filtrados);
        }

        function abrirModal(id) {
            if(id === 0) {
                document.getElementById('formProducto').reset();
                document.getElementById('ProductoId').value = 0;
                document.getElementById('Categoria').value = "General"; // Default
                document.getElementById('tituloModal').innerText = "Nuevo Producto";
                modal.show();
                setTimeout(() => document.getElementById("Nombre").focus(), 500);
            }
        }

        function editar(id) {
            const p = listaProductos.find(x => x.productoId === id);
            if(p) {
                document.getElementById('ProductoId').value = p.productoId;
                document.getElementById('Nombre').value = p.nombre;
                // Asignar Categoría (fallback a General si es null)
                document.getElementById('Categoria').value = p.categoria || "General";
                document.getElementById('PrecioVenta').value = p.precioVenta;
                document.getElementById('StockActual').value = p.stockActual;

                document.getElementById('tituloModal').innerText = "Editar Producto";
                modal.show();
            }
        }

        function guardarProducto() {
            const data = {
                ProductoId: parseInt(document.getElementById('ProductoId').value),
                Nombre: document.getElementById('Nombre').value,
                Categoria: document.getElementById('Categoria').value, // Nuevo
                PrecioVenta: parseFloat(document.getElementById('PrecioVenta').value),
                StockActual: parseInt(document.getElementById('StockActual').value)
            };

            if(!data.Nombre || isNaN(data.PrecioVenta) || isNaN(data.StockActual)) {
                Swal.fire('Atención', 'Por favor completa los datos correctamente.', 'warning');
                return;
            }

            fetch('/Productos/Guardar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    modal.hide();
                    cargarProductos();
                    Swal.fire({
                        icon: 'success',
                        title: 'Éxito',
                        text: json.message,
                        timer: 1500,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire('Error', json.message, 'error');
                }
            })
            .catch(err => {
                console.error(err);
                Swal.fire('Error', 'Ocurrió un error en la conexión.', 'error');
            });
        }

        function eliminar(id) {
            Swal.fire({
                title: '¿Eliminar producto?',
                text: "Esta acción es irreversible.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Productos/Eliminar?id=' + id, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if(json.success) {
                            cargarProductos();
                            Swal.fire('Eliminado', 'Producto retirado.', 'success');
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    })
                    .catch(err => Swal.fire('Error', 'No se pudo eliminar.', 'error'));
                }
            });
        }
    </script>
}