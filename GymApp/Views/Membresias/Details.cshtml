</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function abrirModalRenovacion() {
            // Cargar Planes y Turnos si no están cargados (o refrescar)
            fetch('/Membresias/ObtenerRecursosCreacion')
                .then(res => res.json())
                .then(json => {
                    let pSelect = document.getElementById('cboRenovarPlan');
                    pSelect.innerHTML = '<option value="" disabled selected>-- Seleccione Plan --</option>';
                    json.planes.forEach(p => pSelect.innerHTML += `<option value="${p.planId}">${p.nombre} (${p.duracionDias} días)</option>`);

                    let tSelect = document.getElementById('cboRenovarTurno');
                    tSelect.innerHTML = '';
                    json.turnos.forEach(t => tSelect.innerHTML += `<option value="${t.turnoId}" ${t.turnoId == @Model.TurnoId ? 'selected' : ''}>${t.nombre}</option>`);
                });

            // Obtener Propuesta de Fecha
            fetch(`/Membresias/GetPropuestaRenovacion/@Model.MembresiaId`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('txtRenovarInicio').value = data.fechaInicio;
                });

            new bootstrap.Modal(document.getElementById('modalRenovacion')).show();
        }

        // LÓGICA DE BORRADO FÍSICO (EXCLUSIVO ADMIN / PERMISO)
        $(document).on('click', '.btn-hard-delete-details', function() {
            const id = $(this).data('id');
            
            Swal.fire({
                title: '¿ELIMINACIÓN DEFINITIVA?',
                text: "Esta acción borrará permanentemente la membresía, todos sus PAGOS y CONGELAMIENTOS asociados. ¡No se puede deshacer!",
                icon: 'warning',
                input: 'text',
                inputPlaceholder: 'Escribe ELIMINAR para confirmar',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, borrar todo',
                cancelButtonText: 'Cancelar',
                preConfirm: (inputValue) => {
                    if (inputValue.trim().toUpperCase() !== 'ELIMINAR') {
                        Swal.showValidationMessage('Debes escribir ELIMINAR para proceder');
                        return false;
                    }
                    return true;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Procesando...',
                        didOpen: () => { Swal.showLoading(); }
                    });

                    fetch(`/Membresias/EliminarFisicamente/${id}`, { method: 'POST' })
                        .then(res => res.json())
                        .then(json => {
                            if (json.success) {
                                Swal.fire('Eliminado', json.message, 'success').then(() => {
                                    window.location.href = '/Membresias';
                                });
                            } else {
                                Swal.fire('Error', json.message, 'error');
                            }
                        })
                        .catch(error => {
                            Swal.fire('Error', 'No se pudo completar la operación.', 'error');
                        });
                }
            });
        });
    </script>
}

