@model GymApp.Models.Membresia
@{
    ViewData["Title"] = "Detalles de Membresía";
    var totalPagado = Model.PagosMembresia.Where(p => !p.EsAnulado).Sum(p => p.Monto);
    var deuda = Model.PrecioAcordado - totalPagado;
    
    // Cálculo de días restantes de forma robusta
    var hoy = DateTime.Today;
    var vencimiento = Model.FechaVencimiento.ToDateTime(TimeOnly.MinValue);
    var diasRestantes = (vencimiento - hoy).Days;
    var diasVencidos = vencimiento < hoy ? (hoy - vencimiento).Days : 0;
}

<div class="container-fluid px-4 mt-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">
                <i class="bi bi-info-circle text-primary me-2"></i>Suscripción #@Model.MembresiaId
            </h2>
            <p class="text-muted small mb-0">Socio: <span class="fw-bold">@Model.User.NombreCompleto</span> (@Model.User.Dni)</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Volver al Listado
            </a>
        </div>
    </div>

    <!-- Botones de Acción Global -->
    <div class="mb-4 d-flex gap-2">
        @if (Model.Plan?.PermiteCongelar == true)
        {
            <button class="btn btn-info text-white shadow-sm" data-bs-toggle="modal" data-bs-target="#modalCongelar">
                <i class="bi bi-snow2 me-1"></i> Congelar Cuenta
            </button>
        }
        else
        {
            <button class="btn btn-info text-white shadow-sm opacity-50" disabled title="El plan no permite congelar">
                <i class="bi bi-snow2 me-1"></i> El plan no permite congelar
            </button>
        }
        
        <button class="btn btn-primary shadow-sm" style="background-color: #276CF5;" onclick="abrirModalRenovacion()">
            <i class="bi bi-arrow-repeat me-1"></i> Renovar Membresía
        </button>

        @if (User.IsInRole("Admin"))
        {
            <button class="btn btn-warning shadow-sm" data-bs-toggle="modal" data-bs-target="#modalEditarMembresia">
                <i class="bi bi-pencil-square me-1"></i> Editar Membresía
            </button>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i> @Html.Raw(TempData["Success"])
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4 mb-4">
        <!-- Tarjeta Izquierda: Info del Plan -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary"><i class="bi bi-calendar3 me-2"></i>Información de Vigencia</h6>
                </div>
                <div class="card-body">
                    <div class="row mb-3 pb-2 border-bottom border-light">
                        <div class="col-6 text-muted small">Plan Contratado:</div>
                        <div class="col-6 fw-bold">@Model.Plan.Nombre</div>
                    </div>
                    <div class="row mb-3 pb-2 border-bottom border-light">
                        <div class="col-6 text-muted small">Horario / Turno:</div>
                        <div class="col-6 fw-bold text-muted">@Model.Turno.Nombre (@Model.Turno.HoraInicio - @Model.Turno.HoraFin)</div>
                    </div>
                    <div class="row mb-3 pb-2 border-bottom border-light">
                        <div class="col-6 text-muted small">Vigencia:</div>
                        <div class="col-6">
                            <span class="d-block fw-bold text-success">@Model.FechaInicio.ToString("dd/MM/yyyy")</span>
                            <span class="d-block fw-bold text-danger">@Model.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6 text-muted small">Estado:</div>
                        <div class="col-6">
                            @if (Model.Estado == "Activa") { <span class="badge bg-success bg-opacity-75"><i class="bi bi-check-circle me-1"></i>Activa</span> }
                            else if (Model.Estado == "Vencida")
                            {
                                <span class="badge bg-danger bg-opacity-75"><i class="bi bi-x-circle me-1"></i>Vencida</span>
                                <span class="d-block text-danger small mt-1">
                                    <i class="bi bi-clock-history me-1"></i>Vencida hace @diasVencidos día@(diasVencidos != 1 ? "s" : "")
                                </span>
                            }
                            else if (Model.Estado == "Congelada") { <span class="badge bg-primary bg-opacity-75"><i class="bi bi-snow2 me-1"></i>Congelada</span> }
                            else { <span class="badge bg-warning text-dark border">@Model.Estado</span> }
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 text-muted small">Tiempo Restante:</div>
                        <div class="col-6">
                            @if(diasRestantes > 0) {
                                <span class="fw-bold @(diasRestantes <= 5 ? "text-danger" : "text-success")">@diasRestantes días</span>
                            } else {
                                <span class="text-danger fw-bold">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Vencida hace @diasVencidos día@(diasVencidos != 1 ? "s" : "")
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tarjeta Derecha: Info Financiera -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between">
                    <h6 class="m-0 fw-bold text-success"><i class="bi bi-cash-coin me-2"></i>Estado Financiero</h6>
                    @if(deuda > 0) {
                        <span class="badge bg-danger-soft text-danger border border-danger border-opacity-25 rounded-pill px-3">Cuenta con deuda</span>
                    }
                </div>
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="text-center mb-4">
                        <h6 class="text-muted small text-uppercase fw-bold mb-1">Costo Total del Plan</h6>
                        <h2 class="fw-bold display-6">@Model.PrecioAcordado.ToString("C")</h2>
                        <div class="mt-1">
                            <strong>Precio Acordado:</strong> <span class="text-success fw-bold">S/ @Model.PrecioAcordado.ToString("0.00")</span>
                        </div>
                    </div>
                    <div class="row text-center mt-3">
                        <div class="col-6 border-end">
                            <h6 class="text-muted small text-uppercase fw-bold mb-1">Total Pagado</h6>
                            <h4 class="text-success fw-bold">@totalPagado.ToString("C")</h4>
                        </div>
                        <div class="col-6">
                            <h6 class="text-muted small text-uppercase fw-bold mb-1">Deuda Pendiente</h6>
                            <h4 class="@(deuda > 0 ? "text-danger" : "text-success") fw-bold">@deuda.ToString("C")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pestañas de Historial -->
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-light p-0 border-bottom">
            <ul class="nav nav-tabs border-bottom-0" id="historialTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active py-3 px-4 border-end-0 rounded-0" id="pagos-tab" data-bs-toggle="tab" data-bs-target="#pagos" type="button" role="tab">
                        <i class="bi bi-wallet2 me-2"></i>Historial de Pagos
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link py-3 px-4 rounded-0" id="congelamientos-tab" data-bs-toggle="tab" data-bs-target="#congelamientos" type="button" role="tab">
                        <i class="bi bi-snow2 me-2"></i>Historial de Congelamientos
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body p-0">
            <div class="tab-content" id="historialTabsContent">
                <!-- Pestaña: Pagos -->
                <div class="tab-pane fade show active" id="pagos" role="tabpanel">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-secondary">
                                <tr>
                                    <th class="ps-4">Fecha y Hora de Operación</th>
                                    <th>Monto Recibido</th>
                                    <th>Método de Pago</th>
                                    @if (User.IsInRole("Admin")) { <th class="text-center">Acciones Críticas</th> }
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.PagosMembresia.Any())
                                {
                                    @foreach (var pago in Model.PagosMembresia.OrderByDescending(p => p.FechaPago))
                                    {
                                        <tr class="@(pago.EsAnulado ? "opacity-50 text-muted table-light" : "")">
                                            <td class="ps-4">
                                                <div class="fw-bold @(pago.EsAnulado ? "text-decoration-line-through" : "")">@pago.FechaPago?.ToString("dd/MM/yyyy")</div>
                                                <small class="text-muted">@pago.FechaPago?.ToString("HH:mm:ss")</small>
                                                @if (pago.EsAnulado)
                                                {
                                                    <span class="badge bg-danger ms-2">Anulado</span>
                                                }
                                            </td>
                                            <td class="fw-bold @(pago.EsAnulado ? "text-decoration-line-through" : "text-success") font-monospace">@pago.Monto.ToString("C")</td>
                                            <td><span class="badge bg-white text-dark border px-2">@pago.MetodoPago</span></td>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <td class="text-center">
                                                    @if (!pago.EsAnulado)
                                                    {
                                                        <div class="btn-group">
                                                            <button class="btn btn-sm btn-outline-warning" title="Editar Pago"><i class="bi bi-pencil"></i></button>
                                                            <button class="btn btn-sm btn-outline-danger" title="Anular Pago"><i class="bi bi-trash"></i></button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-light text-muted border">Sin acciones</span>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="@(User.IsInRole("Admin") ? 4 : 3)" class="text-center py-5">
                                            <i class="bi bi-cash-stack text-muted opacity-25 display-4 d-block mb-3"></i>
                                            <p class="text-muted">No se registran pagos para este período.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pestaña: Congelamientos -->
                <div class="tab-pane fade" id="congelamientos" role="tabpanel">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-secondary">
                                <tr>
                                    <th class="ps-4">Desde</th>
                                    <th>Hasta</th>
                                    <th>Motivo / Observación</th>
                                    <th>Autorizado por</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Congelamientos.Any())
                                {
                                    @foreach (var c in Model.Congelamientos.OrderByDescending(c => c.FechaInicio))
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">@c.FechaInicio.ToString("dd/MM/yyyy")</td>
                                            <td class="fw-bold text-primary">@c.FechaFin.ToString("dd/MM/yyyy")</td>
                                            <td class="small text-muted">@(c.Motivo ?? "-")</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-light rounded-circle p-1 me-2"><i class="bi bi-person-badge text-primary"></i></div>
                                                    <span class="small">@(c.UsuarioEmpleado?.NombreCompleto ?? "Sistema")</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5">
                                            <i class="bi bi-snow2 text-muted opacity-25 display-4 d-block mb-3"></i>
                                            <p class="text-muted">No hay historial de congelamientos.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Congelar -->
<div class="modal fade" id="modalCongelar" tabindex="-1" aria-labelledby="modalCongelarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title fw-bold" id="modalCongelarLabel"><i class="bi bi-snow2 me-2"></i>Congelar Membresía</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Membresias" asp-action="Congelar" method="post">
                <input type="hidden" name="membresiaId" value="@Model.MembresiaId" />
                <div class="modal-body p-4">
                    <div class="alert alert-warning small mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Esta acción extenderá la fecha de vencimiento y pausará el acceso hasta la fecha seleccionada.
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Fecha Fin de Congelamiento</label>
                        <input type="date" name="fechaFin" class="form-control" required min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")">
                        <div class="form-text small text-muted">A partir de esta fecha, el socio volverá a tener acceso.</div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-bold small">Motivo</label>
                        <textarea name="motivo" class="form-control" rows="3" placeholder="Ej: Viaje, Salud, Vacaciones..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-info text-white px-4">
                        <i class="bi bi-check-lg me-1"></i> Confirmar Congelamiento
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Renovar -->
<div class="modal fade" id="modalRenovacion" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-arrow-repeat me-2"></i>Renovación Inteligente</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Membresias" asp-action="Renovar" method="post">
                <input type="hidden" name="userId" value="@Model.UserId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Elegir Plan</label>
                        <select name="planId" id="cboRenovarPlan" class="form-select" required></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Elegir Turno</label>
                        <select name="turnoId" id="cboRenovarTurno" class="form-select" required></select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-bold small">Fecha de Inicio de Nueva Membresía</label>
                        <input type="date" name="fechaInicio" id="txtRenovarInicio" class="form-control" required>
                        <div class="form-text small text-info">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            Calculado automáticamente para no perder días de la membresía actual.
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i> Confirmar Renovación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Editar Membresía -->
<div class="modal fade" id="modalEditarMembresia" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Datos de Membresía</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Membresias" asp-action="Editar" method="post">
                <input type="hidden" name="MembresiaId" value="@Model.MembresiaId" />
                <div class="modal-body p-4">
                    <div class="alert alert-warning small mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Esta acción modifica directamente los valores de la base de datos. Usar solo para corregir errores de registro.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Plan Contratado</label>
                            <select name="PlanId" class="form-select" asp-items="ViewBag.Planes">
                                <option value="@Model.PlanId" selected>@Model.Plan?.Nombre (Actual)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Turno</label>
                            <select name="TurnoId" class="form-select" asp-items="ViewBag.Turnos">
                                <option value="@Model.TurnoId" selected>@Model.Turno?.Nombre (Actual)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Fecha de Inicio</label>
                            <input type="date" name="FechaInicio" class="form-control" value="@Model.FechaInicio.ToString("yyyy-MM-dd")" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Fecha de Vencimiento (Fin)</label>
                            <input type="date" name="FechaVencimiento" class="form-control" value="@Model.FechaVencimiento.ToString("yyyy-MM-dd")" required>
                            <div class="form-text small text-muted">El estado Activo/Vencido se recalculará en base a esta fecha.</div>
                        </div>
                        <div class="col-md-12 mt-3">
                            <label for="EditPrecioAcordado" class="form-label fw-bold small">Precio Acordado</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" step="0.01" id="EditPrecioAcordado" name="PrecioAcordadoPersonalizado" class="form-control" value="@Model.PrecioAcordado.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                            </div>
                            <div class="form-text">Modifica este valor solo si el precio inicial fue registrado incorrectamente.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="bi bi-save me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function abrirModalRenovacion() {
        // Cargar Planes y Turnos si no están cargados (o refrescar)
        fetch('/Membresias/ObtenerRecursosCreacion')
            .then(res => res.json())
            .then(json => {
                let pSelect = document.getElementById('cboRenovarPlan');
                pSelect.innerHTML = '<option value="" disabled selected>-- Seleccione Plan --</option>';
                json.planes.forEach(p => pSelect.innerHTML += `<option value="${p.planId}">${p.nombre} (${p.duracionDias} días)</option>`);

                let tSelect = document.getElementById('cboRenovarTurno');
                tSelect.innerHTML = '';
                json.turnos.forEach(t => tSelect.innerHTML += `<option value="${t.turnoId}" ${t.turnoId == @Model.TurnoId ? 'selected' : ''}>${t.nombre}</option>`);
            });

        // Obtener Propuesta de Fecha
        fetch(`/Membresias/GetPropuestaRenovacion/@Model.MembresiaId`)
            .then(res => res.json())
            .then(data => {
                document.getElementById('txtRenovarInicio').value = data.fechaInicio;
            });

        new bootstrap.Modal(document.getElementById('modalRenovacion')).show();
    }
</script>

<style>
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.05); }
    .animate-fade-in { animation: fadeIn 0.3s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .nav-tabs .nav-link { color: #6c757d; font-weight: 500; font-size: 0.9rem; }
    .nav-tabs .nav-link.active { color: #276CF5; border-top: 3px solid #276CF5 !important; background: white; }
</style>

