@model GymApp.Models.Membresia
@using GymApp.Constants
@{
    ViewData["Title"] = "Detalles de Membresía";
    var totalPagado = Model.PagosMembresia.Where(p => !p.EsAnulado).Sum(p => p.Monto);
    var deuda = Model.PrecioAcordado - totalPagado;
    
    // Cálculo de días restantes de forma robusta
    var hoy = DateTime.Today;
    var vencimiento = Model.FechaVencimiento.ToDateTime(TimeOnly.MinValue);
    var diasRestantes = (vencimiento - hoy).Days;
    var diasVencidos = vencimiento < hoy ? (hoy - vencimiento).Days : 0;
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
    <!-- Encabezado -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
        <div>
            <div class="flex items-center gap-4 mb-1">
                <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                    <i data-lucide="info" class="w-8 h-8"></i>
                </div>
                <h1 class="text-3xl font-display font-extrabold text-slate-950 tracking-tight m-0">Suscripción #@Model.MembresiaId</h1>
            </div>
            <p class="text-slate-600 text-sm font-medium ml-1">
                Socio: <a href="/Usuarios/Details/@Model.UserId" class="text-indigo-600 font-bold hover:underline">@Model.User.NombreCompleto</a> 
                <span class="mx-2 text-slate-300">|</span> 
                ID: <span class="font-mono text-slate-950">@Model.User.Dni</span>
            </p>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
            <a asp-action="Index" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-slate-600 hover:text-indigo-600 bg-white hover:bg-slate-50 px-5 py-2.5 rounded-xl border border-slate-200 transition-all active:scale-95">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                <span>Volver</span>
            </a>
            
            @if (deuda > 0 && (User.HasClaim(TipoClaim.Permiso, AppPermisos.PagosCrear) || User.IsInRole(AppRoles.Admin)))
            {
                <a href="/Pagos/Index?buscar=@Model.User.Dni" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-emerald-600 bg-emerald-50 hover:bg-emerald-600 hover:text-white px-5 py-2.5 rounded-xl transition-all duration-300 shadow-sm shadow-emerald-100/50 active:scale-95">
                    <i data-lucide="banknote" class="w-5 h-5"></i>
                    <span>Registrar Pago</span>
                </a>
            }
        </div>
    </div>

    <!-- Botones de Acción de Membresía -->
    <div class="flex flex-wrap items-center gap-3 bg-slate-50/50 p-4 rounded-[2rem] border border-slate-100">
        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] ml-4 mr-2">Gestión:</span>
        
        @if (Model.Plan?.PermiteCongelar == true && (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasCongelar) || User.IsInRole(AppRoles.Admin)))
        {
            <button class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-blue-600 bg-blue-50 hover:bg-blue-600 hover:text-white px-4 py-2 rounded-xl transition-all duration-300 shadow-sm shadow-blue-100/50 active:scale-95" data-bs-toggle="modal" data-bs-target="#modalCongelar">
                <i data-lucide="snowflake" class="w-4 h-4"></i> Congelar
            </button>
        }
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasRenovar) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-indigo-600 bg-indigo-50 hover:bg-indigo-600 hover:text-white px-4 py-2 rounded-xl transition-all duration-300 shadow-sm shadow-indigo-100/50 active:scale-95" onclick="abrirModalRenovacion()">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i> Renovar
            </button>
        }

        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasEditar) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-amber-600 bg-amber-50 hover:bg-amber-600 hover:text-white px-4 py-2 rounded-xl transition-all duration-300 shadow-sm shadow-amber-100/50 active:scale-95" data-bs-toggle="modal" data-bs-target="#modalEditarMembresia">
                <i data-lucide="pencil" class="w-4 h-4"></i> Editar
            </button>
        }

        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasEliminar) || User.IsInRole(AppRoles.Admin))
        {
            <button type="button" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-rose-600 bg-rose-50 hover:bg-rose-600 hover:text-white px-4 py-2 rounded-xl transition-all duration-300 shadow-sm shadow-rose-100/50 active:scale-95 btn-hard-delete-details" data-id="@Model.MembresiaId">
                <i data-lucide="trash-2" class="w-4 h-4"></i> Eliminar
            </button>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-4 bg-emerald-50 border border-emerald-100 p-5 rounded-3xl animate-fade-in shadow-sm">
            <div class="w-10 h-10 rounded-xl bg-emerald-500 text-white flex items-center justify-center flex-shrink-0 shadow-lg shadow-emerald-500/20">
                <i data-lucide="check-circle-2" class="w-6 h-6"></i>
            </div>
            <div class="flex-1">
                <p class="text-sm font-bold text-emerald-900 leading-tight">@Html.Raw(TempData["Success"])</p>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Tarjeta Izquierda: Info del Plan -->
        <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden flex flex-col group transition-all hover:shadow-md">
            <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/30 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-white text-indigo-600 flex items-center justify-center border border-slate-200 shadow-sm group-hover:scale-110 transition-transform">
                        <i data-lucide="calendar-range" class="w-6 h-6"></i>
                    </div>
                    <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Vigencia del Servicio</h3>
                </div>
                @if (Model.Estado == "Activa") { 
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Activa
                    </span>
                }
                else if (Model.Estado == "Vencida") {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-rose-50 text-rose-700 border border-rose-100">Vencida</span>
                }
                else {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-100">@Model.Estado</span>
                }
            </div>
            
            <div class="p-8 space-y-6 flex-1">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div class="space-y-1">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Plan Suscrito</p>
                        <p class="text-base font-bold text-slate-900">@Model.Plan.Nombre</p>
                    </div>
                    <div class="space-y-1 text-right">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Horario Asignado</p>
                        <p class="text-base font-bold text-slate-700">@Model.Turno.Nombre (@Model.Turno.HoraInicio - @Model.Turno.HoraFin)</p>
                    </div>
                </div>

                <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-wide">Fecha Inicio</span>
                        <span class="text-sm font-bold text-emerald-600 font-mono">@Model.FechaInicio.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="h-px bg-slate-200/50"></div>
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-wide">Fecha Vencimiento</span>
                        <span class="text-sm font-bold text-rose-600 font-mono">@Model.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>

                <div class="flex items-center justify-between gap-4 pt-2">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tiempo de Acceso</span>
                        <div class="flex items-baseline gap-1 mt-1">
                            @if(diasRestantes > 0) {
                                <span class="text-4xl font-display font-black tracking-tighter @(diasRestantes <= 5 ? "text-rose-600" : "text-emerald-600")">@diasRestantes</span>
                                <span class="text-xs font-bold text-slate-500 uppercase">días restantes</span>
                            } else {
                                <span class="text-2xl font-display font-black tracking-tighter text-rose-400 uppercase italic">Caducado</span>
                            }
                        </div>
                    </div>
                    @if(diasVencidos > 0) {
                        <div class="px-4 py-2 bg-rose-50 border border-rose-100 rounded-2xl text-rose-600 text-xs font-bold flex items-center gap-2">
                            <i data-lucide="history" class="w-4 h-4"></i>
                            Vencido hace @diasVencidos día@(diasVencidos != 1 ? "s" : "")
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Tarjeta Derecha: Info Financiera -->
        <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden flex flex-col group transition-all hover:shadow-md">
            <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/30 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-white text-emerald-600 flex items-center justify-center border border-slate-200 shadow-sm group-hover:scale-110 transition-transform">
                        <i data-lucide="dollar-sign" class="w-6 h-6"></i>
                    </div>
                    <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Estado Financiero</h3>
                </div>
                @if(deuda > 0) {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-rose-600 text-white shadow-sm shadow-rose-600/20">Deuda Pendiente</span>
                } else {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">Totalmente Pagado</span>
                }
            </div>

            <div class="p-8 flex flex-col h-full space-y-8">
                <div class="text-center py-6 bg-slate-50 rounded-[2rem] border border-slate-100 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-24 h-24 bg-gradient-to-br from-emerald-500/5 to-transparent rounded-br-full"></div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-1">Inversión Total Acordada</p>
                    <h2 class="text-5xl font-display font-black text-slate-950 tracking-tighter">@Model.PrecioAcordado.ToString("C")</h2>
                    <div class="mt-2 inline-flex items-center gap-2 px-3 py-1 bg-white border border-slate-200 rounded-full text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                        <i data-lucide="shield-check" class="text-emerald-500 w-4 h-4"></i>
                        Confirmado en Contrato
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="p-6 bg-white border border-slate-100 rounded-3xl flex flex-col items-center text-center shadow-sm">
                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">Abonado</p>
                        <span class="text-xl font-bold text-emerald-600 font-mono tracking-tight">@totalPagado.ToString("C")</span>
                    </div>
                    <div class="p-6 bg-white border border-slate-100 rounded-3xl flex flex-col items-center text-center shadow-sm">
                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">Saldo</p>
                        <span class="text-xl font-bold font-mono tracking-tight @(deuda > 0 ? "text-rose-600" : "text-emerald-600")">@deuda.ToString("C")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Observaciones))
    {
        <div class="flex items-start gap-5 p-6 bg-indigo-50/50 border border-indigo-100 rounded-3xl group transition-all hover:bg-indigo-50">
            <div class="w-12 h-12 rounded-2xl bg-white text-indigo-500 flex items-center justify-center flex-shrink-0 border border-indigo-100 shadow-sm group-hover:scale-110 transition-transform">
                <i data-lucide="sticky-note" class="w-6 h-6"></i>
            </div>
            <div>
                <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest">Comentarios del Staff</span>
                <p class="text-sm font-medium text-indigo-900 mt-1 leading-relaxed">@Model.Observaciones</p>
            </div>
        </div>
    }

    <!-- Historial Tabs -->
    <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden flex flex-col">
        <div class="px-8 pt-6 border-b border-slate-100 bg-slate-50/30">
            <ul class="flex items-center gap-8 nav nav-tabs border-0" id="historialTabs" role="tablist">
                <li class="pb-4 relative" role="presentation">
                    <button class="flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-slate-400 hover:text-slate-900 transition-all active" id="pagos-tab" data-bs-toggle="tab" data-bs-target="#pagos" type="button" role="tab">
                        <i data-lucide="wallet" class="w-5 h-5"></i> Historial de Pagos
                    </button>
                </li>
                <li class="pb-4 relative" role="presentation">
                    <button class="flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-slate-400 hover:text-slate-900 transition-all" id="congelamientos-tab" data-bs-toggle="tab" data-bs-target="#congelamientos" type="button" role="tab">
                        <i data-lucide="snowflake" class="w-5 h-5"></i> Congelamientos
                    </button>
                </li>
            </ul>
        </div>
        
        <div class="tab-content" id="historialTabsContent">
            <!-- Pestaña: Pagos -->
            <div class="tab-pane fade show active" id="pagos" role="tabpanel">
                <div class="overflow-x-auto">
                    <table class="w-full border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50 border-b border-slate-100">
                                <th class="px-8 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Fecha Operación</th>
                                <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Monto Recibido</th>
                                <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Método</th>
                                <th class="px-8 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Estado</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100/80">
                            @if (Model.PagosMembresia.Any())
                            {
                                @foreach (var pago in Model.PagosMembresia.OrderByDescending(p => p.FechaPago))
                                {
                                    <tr class="group hover:bg-slate-50/50 transition-colors @(pago.EsAnulado ? "opacity-50" : "")">
                                        <td class="px-8 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-9 h-9 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100/50">
                                                    <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                                                </div>
                                                <div>
                                                    <div class="text-sm font-bold text-slate-900 @(pago.EsAnulado ? "line-through" : "")">@pago.FechaPago?.ToString("dd/MM/yyyy")</div>
                                                    <div class="text-[10px] font-bold text-slate-400 uppercase">@pago.FechaPago?.ToString("HH:mm:ss")</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="text-sm font-bold font-mono tracking-tight @(pago.EsAnulado ? "text-slate-400 line-through" : "text-emerald-600")">@pago.Monto.ToString("C")</span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-slate-100 text-slate-600 border border-slate-200/50">@pago.MetodoPago</span>
                                        </td>
                                        <td class="px-8 py-4 text-right">
                                            @if (pago.EsAnulado) {
                                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-rose-500">ANULADO</span>
                                            } else {
                                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-emerald-500">PROCESADO</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="px-8 py-20 text-center text-slate-400 italic">No hay pagos registrados.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pestaña: Congelamientos -->
            <div class="tab-pane fade" id="congelamientos" role="tabpanel">
                <div class="overflow-x-auto">
                    <table class="w-full border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50 border-b border-slate-100">
                                <th class="px-8 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Período Pausa</th>
                                <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Motivo / Causa</th>
                                <th class="px-8 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Autorizado por</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100/80">
                            @if (Model.Congelamientos.Any())
                            {
                                @foreach (var c in Model.Congelamientos.OrderByDescending(c => c.FechaInicio))
                                {
                                    <tr class="group hover:bg-slate-50/50 transition-colors">
                                        <td class="px-8 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-9 h-9 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50">
                                                    <i data-lucide="snowflake" class="w-4 h-4"></i>
                                                </div>
                                                <div class="text-sm font-bold text-slate-900">@c.FechaInicio.ToString("dd/MM/yyyy") - @c.FechaFin.ToString("dd/MM/yyyy")</div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-xs font-medium text-slate-600 italic">"@c.Motivo"</p>
                                        </td>
                                        <td class="px-8 py-4 text-right text-[11px] font-bold text-slate-500 uppercase tracking-wider">
                                            @(c.UsuarioEmpleado?.NombreCompleto ?? "Sistema")
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="px-8 py-20 text-center text-slate-400 italic">No hay historial de pausas.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ========================= -->
<!-- MODALES DE GESTIÓN -->
<!-- ========================= -->

<!-- Modal Congelar -->
<div class="modal fade" id="modalCongelar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-white text-slate-950">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50 shadow-sm">
                        <i data-lucide="snowflake" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight m-0">Congelar Membresía</h5>
                        <p class="text-slate-600 text-[10px] font-bold uppercase tracking-widest mt-1">Pausar acceso temporalmente</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <form asp-controller="Membresias" asp-action="Congelar" method="post">
                <input type="hidden" name="membresiaId" value="@Model.MembresiaId" />
                <div class="p-8">
                    <div class="flex items-start gap-4 bg-amber-50/50 border border-amber-100 p-4 rounded-2xl mb-8">
                        <div class="w-8 h-8 rounded-lg bg-amber-500 text-white flex items-center justify-center flex-shrink-0 shadow-sm shadow-amber-500/20">
                            <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                        </div>
                        <p class="text-[11px] font-bold text-amber-900 leading-relaxed uppercase tracking-wide">
                            Esta acción extenderá la fecha de vencimiento y pausará el acceso hasta la fecha seleccionada.
                        </p>
                    </div>
                    
                    <div class="space-y-6">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Fecha de Fin (Hasta cuando)</label>
                            <input type="date" name="fechaFin" class="w-full bg-white border border-slate-200 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 transition-all" required min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")">
                            <p class="mt-2 text-[10px] text-slate-400 font-medium">A partir de esta fecha, el socio volverá a tener acceso.</p>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Justificación / Motivo</label>
                            <textarea name="motivo" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-2xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-400" rows="3" placeholder="Ej: Viaje, Salud, Vacaciones..." required></textarea>
                        </div>
                    </div>
                </div>
                <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
