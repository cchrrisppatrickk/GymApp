@model GymApp.ViewModels.PagedResult<GymApp.ViewModels.MembresiaListDTO>
@using GymApp.Constants
@{
    ViewData["Title"] = "Gestión de Membresías";
    var buscar = ViewBag.Buscar as string;
    var mes = ViewBag.Mes as int?;
    var anio = ViewBag.Anio as int?;
    var filtro = ViewBag.Filtro as string;
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center border border-rose-100/50 shadow-sm">
                    <i class="bi bi-card-checklist text-xl"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Suscripciones</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Administra los accesos, renovaciones y estados de cuenta</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-md shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModal()">
                <i class="bi bi-plus-lg text-lg group-hover:scale-110 transition-transform"></i>
                <span>Nueva Suscripción</span>
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(filtro))
    {
        <div class="flex items-center justify-between bg-indigo-50 border border-indigo-100/50 p-4 rounded-2xl shadow-sm">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center shadow-sm">
                    <i class="bi bi-filter-circle-fill text-sm"></i>
                </div>
                <div class="text-sm">
                    <span class="text-indigo-600 font-bold uppercase tracking-widest text-[10px]">Filtrando por:</span>
                    <p class="text-indigo-900 font-bold m-0 leading-tight">
                        @(filtro == "deudores" ? "Usuarios con Deuda Pendiente" : 
                          filtro == "porVencer" ? "Próximos Vencimientos (7 días)" : 
                          filtro == "nuevos" ? "Nuevos Miembros del Mes" : 
                          filtro == "congeladas" ? "Membresías en Pausa" : filtro)
                    </p>
                </div>
            </div>
            <a asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2 bg-white text-indigo-600 rounded-xl hover:bg-indigo-100 transition-colors text-xs font-bold uppercase tracking-widest border border-indigo-100 shadow-sm">
                <i class="bi bi-x-circle"></i>
                Ver Todos
            </a>
        </div>
    }



    <!-- Filtros -->
    <form method="get" asp-action="Index" class="bg-white rounded-[2rem] border border-slate-200 p-2 shadow-sm">
        <input type="hidden" name="filtro" value="@filtro" />
        <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-2">
            <!-- Búsqueda por Texto -->
            <div class="flex-1 relative group">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-600 group-focus-within:text-indigo-500 transition-colors">
                    <i class="bi bi-search"></i>
                </div>
                <input type="text" name="buscar" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl pl-11 pr-4 py-2.5 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" placeholder="Socio o DNI..." value="@buscar">
            </div>

            <div class="grid grid-cols-2 md:grid-cols-2 lg:flex gap-2">
                <!-- Mes -->
                <div class="relative min-w-[200px]">
                    <select name="mes" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl px-4 py-2.5 text-sm font-bold text-slate-700 appearance-none cursor-pointer transition-all">
                        <option value="">Mes Actual (Default)</option>
                        @for(int i = 1; i <= 12; i++)
                        {
                            if (mes == i) {
                                <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            } else {
                                <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                        }
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600 text-xs">
                        <i class="bi bi-chevron-down"></i>
                    </div>
                </div>

                <!-- Año -->
                <div class="relative min-w-[160px]">
                    <select name="anio" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl px-4 py-2.5 text-sm font-bold text-slate-700 appearance-none cursor-pointer transition-all">
                        <option value="">Año Actual (Default)</option>
                        @for(int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                        {
                            if (anio == i) {
                                <option value="@i" selected>@i</option>
                            } else {
                                <option value="@i">@i</option>
                            }
                        }
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600 text-xs">
                        <i class="bi bi-chevron-down"></i>
                    </div>
                </div>

                <!-- Botones de Acción -->
                <div class="flex items-center gap-2 col-span-2">
                    <button type="submit" class="flex-1 lg:flex-none inline-flex items-center justify-center w-full lg:w-11 h-11 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-sm shadow-indigo-600/10 active:scale-95" title="Aplicar filtros">
                        <i class="bi bi-filter text-lg"></i>
                        <span class="lg:hidden ml-2 font-bold uppercase tracking-widest text-xs">Filtrar</span>
                    </button>
                    <a asp-action="Index" class="flex-1 lg:flex-none inline-flex items-center justify-center w-full lg:w-11 h-11 bg-slate-100 text-slate-700 rounded-xl hover:bg-slate-200 transition-all duration-300 active:scale-95" title="Limpiar filtros">
                        <i class="bi bi-x-lg"></i>
                        <span class="lg:hidden ml-2 font-bold uppercase tracking-widest text-xs">Limpiar</span>
                    </a>
                </div>
            </div>
        </div>
    </form>

    <!-- Tabla -->
    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden mt-6">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">ID</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Socio</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Estado / Vigencia</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Deuda</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Obs.</th>
                        <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100/80">
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-20 text-center">
                                <div class="max-w-xs mx-auto">
                                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
                                        <i class="bi bi-inbox text-slate-300 text-3xl"></i>
                                    </div>
                                    <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest mb-2">Sin Suscripciones</h3>
                                    <p class="text-xs text-slate-500 leading-relaxed font-medium">No se encontraron registros que coincidan con los filtros aplicados.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            bool isFinalized = item.Estado == "Vencida" || item.Estado == "Cancelada";
                            <tr class="group hover:bg-slate-50/50 transition-colors @(isFinalized ? "opacity-60" : "")">
                                <td class="px-6 py-4">
                                    <span class="text-xs font-bold text-slate-400 font-mono tracking-tighter">#@item.MembresiaId</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-sm border border-indigo-100/50 group-hover:scale-110 transition-transform">
                                            @item.NombreUsuario.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="text-sm font-bold text-slate-950 tracking-tight">@item.NombreUsuario</div>
                                            <div class="flex items-center gap-2 mt-1">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[9px] font-bold uppercase tracking-wider bg-slate-100 text-slate-600 border border-slate-200/50">
                                                    @item.NombrePlan
                                                </span>
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[9px] font-bold uppercase tracking-wider bg-indigo-50 text-indigo-700 border border-indigo-100/50">
                                                    @item.NombreTurno
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col gap-1">
                                        @if (isFinalized) { 
                                            <span class="inline-flex items-center w-fit px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-slate-100 text-slate-500 border border-slate-200">Finalizada</span> 
                                        }
                                        else if (item.Estado == "Activa") { 
                                            @if (item.DiasRestantes <= 3) {
                                                <span class="inline-flex items-center w-fit px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-rose-50 text-rose-700 border border-rose-200">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse mr-1.5"></span>
                                                    Por Vencer (@item.DiasRestantes d)
                                                </span>
                                            } else if (item.DiasRestantes <= 7) {
                                                <span class="inline-flex items-center w-fit px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200">
                                                    Prox. Vencimiento (@item.DiasRestantes d)
                                                </span>
                                            } else {
                                                <span class="inline-flex items-center w-fit px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-200">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span>
                                                    Activa
                                                </span>
                                            }
                                        }
                                        else if (item.Estado == "Congelada") { 
                                            <span class="inline-flex items-center w-fit px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-blue-50 text-blue-700 border border-blue-200">Congelada</span> 
                                        }
                                        else { 
                                            <span class="inline-flex items-center w-fit px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200">@item.Estado</span> 
                                        }
                                        
                                        <div class="text-[10px] font-bold text-slate-400 font-mono">@item.FechaInicio - @item.FechaVencimiento</div>
                                        
                                        @if (!isFinalized && item.DiasVencidos > 0) {
                                            <div class="inline-flex items-center text-[10px] font-bold text-rose-600 bg-rose-50 px-2 py-0.5 rounded-md w-fit">
                                                <i class="bi bi-exclamation-circle mr-1"></i> Vencido hace @item.DiasVencidos días
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.DeudaPendiente > 0)
                                    {
                                        <div class="flex flex-col">
                                            <span class="text-sm font-bold text-rose-600 font-mono tracking-tight">S/. @item.DeudaPendiente.ToString("F2")</span>
                                            <span class="text-[9px] font-bold text-rose-400 uppercase tracking-tighter">Pendiente</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex items-center gap-1.5 text-emerald-600">
                                            <i class="bi bi-check-circle-fill text-[10px]"></i>
                                            <span class="text-xs font-bold uppercase tracking-widest">Al día</span>
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (!string.IsNullOrEmpty(item.Observaciones))
                                    {
                                        <div class="group/obs relative">
                                            <i class="bi bi-chat-dots text-slate-300 hover:text-indigo-500 cursor-help transition-colors"></i>
                                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 bg-slate-950 text-white text-[10px] p-3 rounded-xl opacity-0 pointer-events-none group-hover/obs:opacity-100 group-hover/obs:pointer-events-auto transition-all duration-300 z-10 shadow-xl border border-white/10 backdrop-blur-sm">
                                                <div class="font-bold uppercase tracking-widest text-[8px] text-slate-400 mb-1">Observaciones</div>
                                                @item.Observaciones
                                                <div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-slate-950"></div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-200 text-xs">-</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <!-- Detalles -->
                                        <a href="/Membresias/Details/@item.MembresiaId" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-200" title="Ver Detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <!-- Pagar -->
                                        @if (item.DeudaPendiente > 0 && (User.HasClaim(TipoClaim.Permiso, AppPermisos.PagosCrear) || User.IsInRole(AppRoles.Admin)))
                                        {
                                            <a href="/Pagos/Index?buscar=@item.Dni" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-emerald-600 hover:bg-emerald-50 transition-all duration-200" title="Registrar Pago">
                                                <i class="bi bi-cash-coin"></i>
                                            </a>
                                        }

                                        <!-- Renovar -->
                                        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasRenovar) || User.IsInRole(AppRoles.Admin))
                                        {
                                            <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-all duration-200" onclick="renovar('@item.Dni', '@item.NombreUsuario', @item.UserId)" title="Renovar Membresía">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                        }

                                        <!-- Congelar/Reactivar -->
                                        @if (item.Estado == "Activa" && (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasCongelar) || User.IsInRole(AppRoles.Admin)))
                                        {
                                            <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-blue-600 hover:bg-blue-50 transition-all duration-200" onclick="abrirModalCongelar(@item.MembresiaId)" title="Congelar Membresía">
                                                <i class="bi bi-snow2"></i>
                                            </button>
                                        }
                                        else if (item.Estado == "Congelada" && (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasCongelar) || User.IsInRole(AppRoles.Admin)))
                                        {
                                            <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-emerald-600 hover:bg-emerald-50 transition-all duration-200" onclick="descongelarMembresia(@item.MembresiaId)" title="Descongelar Membresía">
                                                <i class="bi bi-sun"></i>
                                            </button>
                                        }

                                        <!-- Eliminar Físicamente (Solo Admin) -->
                                        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasEliminar) || User.IsInRole(AppRoles.Admin))
                                        {
                                            <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl text-slate-600 hover:text-rose-600 hover:bg-rose-50 transition-all duration-200 btn-hard-delete" data-id="@item.MembresiaId" title="ELIMINACIÓN DEFINITIVA">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-8 pb-12">
            @if (Model.HasPreviousPage)
            {
                <a class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage - 1)" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio" asp-route-filtro="@filtro">
                    <i class="bi bi-chevron-left"></i>
                    <span class="hidden sm:inline">Anterior</span>
                </a>
            }
            else
            {
                <div class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-slate-50 border border-slate-100 text-slate-500 rounded-xl cursor-not-allowed font-medium text-sm">
                    <i class="bi bi-chevron-left"></i>
                    <span class="hidden sm:inline">Anterior</span>
                </div>
            }

            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <div class="w-10 h-10 flex items-center justify-center bg-indigo-600 text-white rounded-xl font-bold text-sm shadow-sm shadow-indigo-600/20">@i</div>
                    }
                    else if (i <= 3 || i > Model.TotalPages - 3 || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                    {
                        <a class="w-10 h-10 flex items-center justify-center bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio" asp-route-filtro="@filtro">@i</a>
                    }
                    else if (i == 4 && Model.CurrentPage > 5)
                    {
                        <div class="w-10 h-10 flex items-center justify-center text-slate-600">...</div>
                    }
                    else if (i == Model.TotalPages - 3 && Model.CurrentPage < Model.TotalPages - 4)
                    {
                        <div class="w-10 h-10 flex items-center justify-center text-slate-600">...</div>
                    }
                }
            </div>

            @if (Model.HasNextPage)
            {
                <a class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage + 1)" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio" asp-route-filtro="@filtro">
                    <span class="hidden sm:inline">Siguiente</span>
                    <i class="bi bi-chevron-right"></i>
                </a>
            }
            else
            {
                <div class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-slate-50 border border-slate-100 text-slate-500 rounded-xl cursor-not-allowed font-medium text-sm">
                    <span class="hidden sm:inline">Siguiente</span>
                    <i class="bi bi-chevron-right"></i>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="modalMembresia" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                        <i class="bi bi-plus-circle text-xl"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight" id="tituloModal">Gestión de Suscripción</h5>
                        <p class="text-slate-600 text-xs font-medium uppercase tracking-widest mt-1">Configuración de acceso y vigencia</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="p-8">
                <form id="formMembresia">
                    <div class="mb-8">
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-3">1. Seleccionar Cliente</label>
                        <div class="relative group">
                            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors">
                                <i class="bi bi-search"></i>
                            </div>
                            <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-2xl pl-12 pr-4 py-4 text-sm font-bold text-slate-900 transition-all placeholder:text-slate-400" id="txtBuscarUsuario" list="listaUsuarios" placeholder="Buscar por Nombre o DNI..." autocomplete="off">
                            <datalist id="listaUsuarios"></datalist>
                            <input type="hidden" id="userIdSeleccionado">
                        </div>
                        <div id="usuarioFeedback" class="mt-2 flex items-center gap-2 text-emerald-600 text-xs font-bold uppercase tracking-wide px-2 d-none animate-pulse">
                            <i class="bi bi-check-circle-fill"></i> <span id="lblUsuarioSeleccionado">Usuario seleccionado.</span>
                        </div>
                    </div>

                    <div class="space-y-8">
                        <div class="pt-2">
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-4">2. Detalles del Plan</label>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-5">
                                    <div>
                                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Plan de Entrenamiento</label>
                                        <div class="relative">
                                            <select class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 appearance-none transition-all" id="cboPlan" onchange="actualizarInfoPrecio()">
                                                <option value="" selected disabled>-- Seleccione --</option>
                                            </select>
                                            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                                                <i class="bi bi-chevron-down"></i>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div>
                                        <label for="txtPrecioPersonalizado" class="block text-xs font-bold text-indigo-600 uppercase tracking-widest mb-2 ml-1">Precio Personalizado (Opcional)</label>
                                        <div class="relative">
                                            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-indigo-300 font-bold">S/</div>
                                            <input type="number" step="0.01" id="txtPrecioPersonalizado" name="PrecioAcordadoPersonalizado" class="w-full bg-indigo-50/30 border border-indigo-100 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl pl-10 pr-4 py-3 text-sm font-bold text-indigo-900 transition-all placeholder:text-indigo-200" placeholder="Ej: 120.00" />
                                        </div>
                                        <p class="mt-2 text-[10px] text-slate-500 font-medium leading-relaxed">
                                            <i class="bi bi-info-circle mr-1"></i> Déjalo en blanco para usar el precio estándar del plan. Úsalo para aplicar descuentos manuales.
                                        </p>
                                    </div>
                                </div>

                                <div class="space-y-5">
                                    <div>
                                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Horario / Turno</label>
                                        <div class="relative">
                                            <select class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 appearance-none transition-all" id="cboTurno">
                                            </select>
                                            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                                                <i class="bi bi-chevron-down"></i>
                                            </div>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">Fecha de Inicio</label>
                                        <input type="date" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 transition-all" id="txtFechaInicio">
                                        <p class="mt-2 text-[10px] text-slate-400 font-medium leading-relaxed italic">Para renovaciones, el sistema ajustará automáticamente si hay días vigentes.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Preview Card -->
                        <div class="bg-indigo-600 rounded-3xl p-6 shadow-xl shadow-indigo-600/20 flex flex-col sm:flex-row items-center justify-between gap-4">
                            <div class="text-center sm:text-left">
                                <p class="text-indigo-100 text-[10px] font-bold uppercase tracking-[0.2em] mb-1">Monto de Inversión</p>
                                <h3 class="text-3xl font-display font-black text-white m-0 tracking-tight" id="lblPrecioPreview">$0.00</h3>
                            </div>
                            <div class="h-10 w-px bg-white/20 hidden sm:block"></div>
                            <div class="text-center sm:text-right">
                                <p class="text-indigo-100 text-[10px] font-bold uppercase tracking-[0.2em] mb-1">Duración Acceso</p>
                                <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-lg text-white text-xs font-bold" id="lblDuracionPreview">
                                    <i class="bi bi-calendar-check"></i>
                                    <span>- días</span>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-3">3. Observaciones (Opcional)</label>
                            <textarea class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-2xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-400" id="txtObservaciones" rows="2" placeholder="Notas sobre el cliente o el servicio..." maxlength="200"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-6 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-600/20 transition-all active:scale-95 font-bold text-xs uppercase tracking-widest flex items-center justify-center gap-2" onclick="guardarMembresia()">
                    <i class="bi bi-check-lg"></i>
                    Confirmar y Generar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL CONGELAR -->
<div class="modal fade" id="modalCongelar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50 shadow-sm">
                        <i class="bi bi-snow2 text-xl"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight">Congelar Membresía</h5>
                        <p class="text-slate-600 text-xs font-medium uppercase tracking-widest mt-1">Pausar acceso temporalmente</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-600 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="p-8">
                <div class="flex items-start gap-4 bg-blue-50/50 border border-blue-100 p-4 rounded-2xl mb-8">
                    <div class="w-8 h-8 rounded-lg bg-blue-600 text-white flex items-center justify-center flex-shrink-0 shadow-sm shadow-blue-600/20">
                        <i class="bi bi-info-circle-fill text-sm"></i>
                    </div>
                    <p class="text-[11px] font-bold text-blue-900 leading-relaxed uppercase tracking-wide">
                        Esta acción pausará el acceso del socio y <span class="underline decoration-2">extenderá</span> su fecha de vencimiento automáticamente.
                    </p>
                </div>
                
                <form id="formCongelar" class="space-y-6">
                    <input type="hidden" id="freezeIdMembresia">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Fecha de Inicio</label>
                            <input type="date" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-slate-400 cursor-not-allowed" id="txtFreezeInicio" readonly>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Fecha de Fin (Proyectada)</label>
                            <input type="date" class="w-full bg-white border border-slate-200 focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 transition-all" id="txtFreezeFin">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Motivo de la Pausa</label>
                        <textarea class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-2xl px-4 py-3 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-400" id="txtFreezeMotivo" rows="2" placeholder="Ej: Viaje, Salud, Vacaciones..."></textarea>
                    </div>
                </form>

                <div id="historialFreeze" class="mt-8 d-none">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="h-px flex-1 bg-slate-100"></div>
                        <h6 class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em]">Historial de Pausas</h6>
                        <div class="h-px flex-1 bg-slate-100"></div>
                    </div>
                    <div id="listadoHistorial" class="space-y-3"></div>
                </div>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="px-6 py-2.5 bg-blue-600 text-white rounded-xl hover:bg-blue-700 shadow-md shadow-blue-600/20 transition-all active:scale-95 font-bold text-xs uppercase tracking-widest flex items-center justify-center gap-2" id="btnConfirmarCongelar" onclick="confirmarCongelar()">
                    <i class="bi bi-snow"></i>
                    Congelar Ahora
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let catalogoPlanes = [];

        document.addEventListener("DOMContentLoaded", () => {
            cargarRecursos();
            document.getElementById('txtFechaInicio').valueAsDate = new Date();

            @if (ViewBag.PreselectUserId != null)
            {
                <text>
                const preselectedId = @ViewBag.PreselectUserId;
                fetch(`/Membresias/BuscarUsuario?q=` + preselectedId)
                    .then(res => res.json())
                    .then(data => {
                        const user = data.find(u => u.id == preselectedId) || data[0];
                        if (user) {
                            document.getElementById('userIdSeleccionado').value = user.id;
                            document.getElementById('txtBuscarUsuario').value = user.text;
                            mostrarFeedbackUsuario(user.text);
                            abrirModal();
                        }
                    });
                </text>
            }
        });



        // ==========================================
        // 2. LÓGICA DE RENOVACIÓN (AUTOCOMPLETADO)
        // ==========================================
        function renovar(dni, nombre, userId) {
            // 1. Abrir Modal
            abrirModal();

            // 2. Pre-llenar datos visuales
            const inputBuscar = document.getElementById('txtBuscarUsuario');
            inputBuscar.value = `${nombre} - ${dni}`; // Visual para el admin

            // 3. Setear ID (Si tu DTO backend no enviaba userId, usaremos la búsqueda por DNI abajo como fallback)
            if(userId > 0) {
                 document.getElementById('userIdSeleccionado').value = userId;
                 mostrarFeedbackUsuario(nombre);
            } else {
                // Fallback: Si no tenemos el ID directo, disparamos la búsqueda por DNI
                inputBuscar.value = dni;
                inputBuscar.dispatchEvent(new Event('input')); // Dispara la búsqueda
            }

            // 4. Enfocar en el Plan para agilizar
            setTimeout(() => document.getElementById('cboPlan').focus(), 500);
        }

        // ==========================================
        // 3. FUNCIONES AUXILIARES (MODAL, RECURSOS)
        // ==========================================
        function cargarRecursos() {
            fetch('/Membresias/ObtenerRecursosCreacion')
                .then(res => res.json())
                .then(json => {
                    catalogoPlanes = json.planes;
                    let planesHtml = '<option value="" selected disabled>-- Seleccione --</option>';
                    json.planes.forEach(p => planesHtml += `<option value="${p.planId}">${p.nombre}</option>`);
                    document.getElementById('cboPlan').innerHTML = planesHtml;

                    let turnosHtml = '';
                    json.turnos.forEach(t => turnosHtml += `<option value="${t.turnoId}">${t.nombre} (${t.horaInicio} - ${t.horaFin})</option>`);
                    document.getElementById('cboTurno').innerHTML = turnosHtml;
                });
        }

        function actualizarInfoPrecio() {
            const planId = parseInt(document.getElementById('cboPlan').value);
            const plan = catalogoPlanes.find(p => p.planId === planId);
            if (plan) {
                const precio = new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(plan.precioBase);
                document.getElementById('lblPrecioPreview').innerText = precio;
                document.getElementById('lblDuracionPreview').innerHTML = `<i class="bi bi-calendar-check mr-1"></i><span>${plan.duracionDias} días de duración</span>`;
            } else {
                document.getElementById('lblPrecioPreview').innerText = "$0.00";
                document.getElementById('lblDuracionPreview').innerHTML = `<i class="bi bi-calendar-check mr-1"></i><span>- días</span>`;
            }
        }

        // Lógica de Búsqueda (Autocomplete)
        const inputBuscar = document.getElementById('txtBuscarUsuario');
        const dataList = document.getElementById('listaUsuarios');

        inputBuscar.addEventListener('input', function() {
            const val = this.value;
            // Si estamos escribiendo, limpiamos la selección previa
            if(val.length < 3) {
                 document.getElementById('userIdSeleccionado').value = "";
                 document.getElementById('usuarioFeedback').classList.add('d-none');
                 return;
            }

            fetch(`/Membresias/BuscarUsuario?q=${val}`)
                .then(res => res.json())
                .then(data => {
                    dataList.innerHTML = '';
                    data.forEach(item => {
                        const option = document.createElement('option');
                        option.value = item.text; // Lo que se ve en el input
                        option.setAttribute('data-id', item.id);
                        dataList.appendChild(option);
                    });

                    // Auto-selección si hay coincidencia exacta (útil para la renovación automática)
                    const coincidencia = data.find(x => x.text.includes(val));
                    if(coincidencia && data.length === 1) {
                         document.getElementById('userIdSeleccionado').value = coincidencia.id;
                         mostrarFeedbackUsuario(coincidencia.text);
                    }
                });
        });

        // Evento Change para detectar click en datalist
        inputBuscar.addEventListener('change', function() {
            const val = this.value;
            const options = dataList.childNodes;
            for (let i = 0; i < options.length; i++) {
                if (options[i].value === val) {
                    const id = options[i].getAttribute('data-id');
                    document.getElementById('userIdSeleccionado').value = id;
                    mostrarFeedbackUsuario(val);
                    break;
                }
            }
        });

        function mostrarFeedbackUsuario(texto) {
            document.getElementById('usuarioFeedback').classList.remove('d-none');
            document.getElementById('lblUsuarioSeleccionado').innerText = texto.split('(')[0] + " seleccionado.";
        }

        function guardarMembresia() {
            const userId = document.getElementById('userIdSeleccionado').value;
            const planId = document.getElementById('cboPlan').value;
            const turnoId = document.getElementById('cboTurno').value;

            if (!userId) return Swal.fire('Error', 'Debes buscar y seleccionar un cliente válido.', 'warning');
            if (!planId) return Swal.fire('Error', 'Selecciona un plan.', 'warning');

            const pre = document.getElementById('txtPrecioPersonalizado').value;
            const data = {
                UserId: parseInt(userId),
                PlanId: parseInt(planId),
                TurnoId: parseInt(turnoId),
                FechaInicio: document.getElementById('txtFechaInicio').value,
                PrecioAcordadoPersonalizado: pre ? parseFloat(pre) : null,
                Observaciones: document.getElementById('txtObservaciones').value
            };

            Swal.fire({
                title: '¿Generar Membresía?',
                html: "Se creará con estado <b>Pendiente de Pago</b>.<br>El cliente deberá pasar por caja para activar el acceso.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, generar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Membresias/Crear', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            bootstrap.Modal.getInstance(document.getElementById('modalMembresia')).hide();
                            Swal.fire('¡Creada!', 'La membresía está pendiente de pago.', 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }

        function abrirModal() {
            // Limpiar modal para nueva venta limpia
            document.getElementById('formMembresia').reset();
            document.getElementById('usuarioFeedback').classList.add('d-none');
            document.getElementById('userIdSeleccionado').value = "";
            document.getElementById('txtFechaInicio').valueAsDate = new Date();
            document.getElementById('txtPrecioPersonalizado').value = '';
            document.getElementById('txtObservaciones').value = '';
            actualizarInfoPrecio();

            new bootstrap.Modal(document.getElementById('modalMembresia')).show();
        }

        // ==========================================
        // 4. LÓGICA DE CONGELAMIENTO
        // ==========================================
        function abrirModalCongelar(id) {
            document.getElementById('freezeIdMembresia').value = id;
            document.getElementById('txtFreezeInicio').valueAsDate = new Date();
            document.getElementById('txtFreezeFin').value = "";
            document.getElementById('txtFreezeMotivo').value = "";
            
            // Cargar Historial
            fetch(`/Congelamientos/Historial/${id}`)
                .then(res => res.json())
                .then(json => {
                    const div = document.getElementById('historialFreeze');
                    const lista = document.getElementById('listadoHistorial');
                    lista.innerHTML = "";

                    if(json.success && json.data.length > 0) {
                        div.classList.remove('d-none');
                        json.data.forEach(c => {
                            lista.innerHTML += `
                                <div class="relative pl-6 pb-2 border-l-2 border-indigo-100 last:border-0 group/item">
                                    <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full border-4 border-white bg-indigo-500 shadow-sm"></div>
                                    <div class="bg-white rounded-2xl border border-slate-100 p-4 shadow-sm hover:shadow-md transition-shadow group-hover/item:border-indigo-100">
                                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
                                            <span class="text-xs font-bold text-slate-900 flex items-center gap-1.5">
                                                <i class="bi bi-calendar-event text-indigo-500"></i>
                                                ${c.inicio} al ${c.fin}
                                            </span>
                                            <span class="w-fit px-2 py-0.5 rounded-lg bg-emerald-50 text-emerald-700 text-[9px] font-black uppercase tracking-widest border border-emerald-100">PROCESADO</span>
                                        </div>
                                        <div class="text-[11px] font-medium text-slate-600 italic mb-2">"${c.motivo || 'Sin motivo especificado'}"</div>
                                        <div class="flex items-center gap-1.5 text-[9px] font-bold text-slate-400 uppercase tracking-widest">
                                            <i class="bi bi-person-check text-indigo-400"></i>
                                            Autorizado por: <span class="text-slate-500">${c.empleado || 'Administrador'}</span>
                                        </div>
                                    </div>
                                </div>
                            `;
                        });
                    } else {
                        div.classList.add('d-none');
                    }
                });

            new bootstrap.Modal(document.getElementById('modalCongelar')).show();
        }

        function confirmarCongelar() {
            const id = document.getElementById('freezeIdMembresia').value;
            const fin = document.getElementById('txtFreezeFin').value;
            const motivo = document.getElementById('txtFreezeMotivo').value;

            if(!fin) return Swal.fire('Error', 'Indica una fecha de fin proyectada.', 'warning');

            const data = {
                MembresiaId: parseInt(id),
                FechaInicio: new Date(),
                FechaFin: new Date(fin),
                Motivo: motivo
            };

            Swal.fire({
                title: '¿Congelar Membresía?',
                text: "El socio no podrá ingresar hasta que se cumpla la fecha o sea reactivado manualmente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, pausar',
                cancelButtonText: 'Dudar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Congelamientos/Congelar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            bootstrap.Modal.getInstance(document.getElementById('modalCongelar')).hide();
                            Swal.fire('¡Congelada!', json.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }

        function descongelarMembresia(id) {
            Swal.fire({
                title: '¿Reactivar Membresía?',
                text: "El socio volverá a tener acceso inmediato.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, reactivar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/Congelamientos/Descongelar/${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            Swal.fire('¡Reactivada!', json.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }

        // LÓGICA DE BORRADO FÍSICO (EXCLUSIVO ADMIN)
        $(document).on('click', '.btn-hard-delete', function() {
            const id = $(this).data('id');
            
            Swal.fire({
                title: '¿ELIMINACIÓN DEFINITIVA?',
                text: "Esta acción borrará permanentemente la membresía, todos sus PAGOS y CONGELAMIENTOS asociados. ¡No se puede deshacer!",
                icon: 'warning',
                input: 'text',
                inputPlaceholder: 'Escribe ELIMINAR para confirmar',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, borrar todo',
                cancelButtonText: 'Cancelar',
                preConfirm: (inputValue) => {
                    if (inputValue.trim().toUpperCase() !== 'ELIMINAR') {
                        Swal.showValidationMessage('Debes escribir ELIMINAR para proceder');
                        return false;
                    }
                    return true;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Procesando...',
                        didOpen: () => { Swal.showLoading(); }
                    });

                    fetch(`/Membresias/EliminarFisicamente/${id}`, { method: 'POST' })
                        .then(res => res.json())
                        .then(json => {
                            if (json.success) {
                                Swal.fire('Eliminado', json.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error', json.message, 'error');
                            }
                        })
                        .catch(err => {
                            Swal.fire('Error', 'Error de conexión con el servidor.', 'error');
                        });
                }
            });
        });
    </script>
}