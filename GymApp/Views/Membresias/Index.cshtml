@{
    ViewData["Title"] = "Gestión de Membresías";
}

<div class="container-fluid px-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h2 class="mb-0 text-dark fw-bold"><i class="bi bi-card-checklist text-danger me-2"></i>Suscripciones</h2>
            <p class="text-muted small mb-0">Administra los accesos, renovaciones y deudas.</p>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="abrirModal()">
            <i class="bi bi-plus-lg me-1"></i> Nueva Suscripción
        </button>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-3 col-lg">
            <div class="card border-0 shadow-sm border-start border-4 border-success h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-1">Activas</h6>
                            <h3 class="mb-0 fw-bold text-success" id="kpiActivas">--</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                            <i class="bi bi-check-circle-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-lg">
            <div class="card border-0 shadow-sm border-start border-4 border-info h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-1">Pendiente Pago</h6>
                            <h3 class="mb-0 fw-bold text-info" id="kpiPendientes">--</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                            <i class="bi bi-wallet2 fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-lg">
            <div class="card border-0 shadow-sm border-start border-4 border-primary h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-1">Congeladas</h6>
                            <h3 class="mb-0 fw-bold text-primary" id="kpiCongeladas">--</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                            <i class="bi bi-snow2 fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-lg">
            <div class="card border-0 shadow-sm border-start border-4 border-warning h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-1">Por Vencer</h6>
                            <h3 class="mb-0 fw-bold text-warning" id="kpiPorVencer">--</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-lg">
            <div class="card border-0 shadow-sm border-start border-4 border-danger h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-1">Vencidas</h6>
                            <h3 class="mb-0 fw-bold text-danger" id="kpiVencidas">--</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                            <i class="bi bi-x-circle-fill fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 d-flex flex-wrap justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-table me-1"></i> Listado de Socios</h6>

            <div class="btn-group btn-group-sm mt-2 mt-md-0" role="group">
                <button type="button" class="btn btn-outline-secondary active" onclick="cargarMembresias('todas', this)">Todas</button>
                <button type="button" class="btn btn-outline-success" onclick="cargarMembresias('activas', this)">Activas</button>
                <button type="button" class="btn btn-outline-primary" onclick="cargarMembresias('congeladas', this)">Congeladas</button>
                <button type="button" class="btn btn-outline-info" onclick="cargarMembresias('pendientes', this)">Pendientes</button>
                <button type="button" class="btn btn-outline-warning" onclick="cargarMembresias('por_vencer', this)">Por Vencer</button>
                <button type="button" class="btn btn-outline-danger" onclick="cargarMembresias('vencidas', this)">Vencidas</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaMembresias">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Socio</th>
                            <th>Estado</th>
                            <th>Deuda</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                    </tbody>
                </table>
            </div>
            <div id="emptyState" class="text-center py-5 d-none">
                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-2">No se encontraron registros con este filtro.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMembresia" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2"></i>Gestión de Suscripción</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formMembresia">
                    <div class="mb-4 position-relative">
                        <label class="form-label fw-bold text-secondary text-uppercase small">1. Seleccionar Cliente</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control form-control-lg" id="txtBuscarUsuario" list="listaUsuarios" placeholder="Buscar por Nombre o DNI..." autocomplete="off">
                            <datalist id="listaUsuarios"></datalist>
                            <input type="hidden" id="userIdSeleccionado">
                        </div>
                        <div id="usuarioFeedback" class="form-text text-success d-none animate-fade-in">
                            <i class="bi bi-check-circle-fill"></i> <span id="lblUsuarioSeleccionado">Usuario seleccionado.</span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12"><hr class="text-muted opacity-25"></div>
                        <div class="col-12"><label class="form-label fw-bold text-secondary text-uppercase small">2. Detalles del Plan</label></div>

                        <div class="col-md-6">
                            <label class="form-label">Plan</label>
                            <select class="form-select" id="cboPlan" onchange="actualizarInfoPrecio()">
                                <option value="" selected disabled>-- Seleccione --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Turno</label>
                            <select class="form-select" id="cboTurno">
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Fecha de Inicio</label>
                            <input type="date" class="form-control" id="txtFechaInicio">
                            <div class="form-text small text-muted">Para renovaciones, el sistema ajustará automáticamente si hay días vigentes.</div>
                        </div>

                        <div class="col-md-6">
                            <div class="card bg-light border-0 h-100">
                                <div class="card-body d-flex flex-column justify-content-center align-items-center py-2">
                                    <small class="text-muted text-uppercase fw-bold">Total a Pagar</small>
                                    <h3 class="text-primary fw-bold mb-0" id="lblPrecioPreview">$0.00</h3>
                                    <small class="text-muted" id="lblDuracionPreview">- días</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" onclick="guardarMembresia()">
                    <i class="bi bi-check-lg me-1"></i> Confirmar y Generar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL CONGELAR -->
<div class="modal fade" id="modalCongelar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-snow2 me-2"></i>Congelar Membresía</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-info small mb-4">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Esta acción pausará el acceso del socio y <b>extenderá</b> su fecha de vencimiento automáticamente.
                </div>
                
                <form id="formCongelar">
                    <input type="hidden" id="freezeIdMembresia">
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Fecha de Inicio</label>
                            <input type="date" class="form-control" id="txtFreezeInicio" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">Fecha Proyectada de Fin</label>
                            <input type="date" class="form-control" id="txtFreezeFin">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small">Motivo</label>
                            <textarea class="form-control" id="txtFreezeMotivo" rows="2" placeholder="Ej: Viaje, Salud, Vacaciones..."></textarea>
                        </div>
                    </div>
                </form>

                <div id="historialFreeze" class="mt-4 d-none">
                    <hr>
                    <h6 class="fw-bold small text-muted text-uppercase mb-3">Historial de Pausas</h6>
                    <div id="listadoHistorial" class="small"></div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary px-4" id="btnConfirmarCongelar" onclick="confirmarCongelar()">
                    <i class="bi bi-check-lg me-1"></i> Congelar Ahora
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let catalogoPlanes = [];

        document.addEventListener("DOMContentLoaded", () => {
            cargarMembresias('todas');
            cargarRecursos();
            document.getElementById('txtFechaInicio').valueAsDate = new Date();

            @if (ViewBag.PreselectUserId != null)
            {
                <text>
                const preselectedId = @ViewBag.PreselectUserId;
                fetch(`/Membresias/BuscarUsuario?q=` + preselectedId)
                    .then(res => res.json())
                    .then(data => {
                        const user = data.find(u => u.id == preselectedId) || data[0];
                        if (user) {
                            document.getElementById('userIdSeleccionado').value = user.id;
                            document.getElementById('txtBuscarUsuario').value = user.text;
                            mostrarFeedbackUsuario(user.text);
                            abrirModal();
                        }
                    });
                </text>
            }
        });

        // ==========================================
        // 1. CARGA DE MEMBRESÍAS CON FILTRO PENDIENTE
        // ==========================================
        function cargarMembresias(filtro, btn) {
            if(btn) {
                document.querySelectorAll('.btn-group .btn').forEach(b => {
                    b.classList.remove('active');
                    // Restaurar clases outline
                    if(b.classList.contains('btn-secondary')) b.classList.replace('btn-secondary', 'btn-outline-secondary');
                    if(b.classList.contains('btn-success')) b.classList.replace('btn-success', 'btn-outline-success');
                    if(b.classList.contains('btn-info')) b.classList.replace('btn-info', 'btn-outline-info');
                    if(b.classList.contains('btn-warning')) b.classList.replace('btn-warning', 'btn-outline-warning');
                    if(b.classList.contains('btn-danger')) b.classList.replace('btn-danger', 'btn-outline-danger');
                });

                // Activar botón actual
                btn.classList.add('active');
            }

            const tbody = document.querySelector("#tablaMembresias tbody");
            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></td></tr>';
            document.getElementById("emptyState").classList.add("d-none");

            fetch(`/Membresias/Listar?filtro=${filtro}`)
                .then(res => res.json())
                .then(json => {
                    let html = '';
                    let contActivas = 0, contVencidas = 0, contPorVencer = 0, contPendientes = 0, contCongeladas = 0;

                    if(json.data.length === 0){
                        tbody.innerHTML = '';
                        document.getElementById("emptyState").classList.remove("d-none");
                        // Reset contadores a 0 visualmente si quieres
                        return;
                    }

                    json.data.forEach(m => {
                        // Lógica de Contadores (KPIs simulados)
                        if (m.estado === 'Activa') contActivas++;
                        else if (m.estado === 'Vencida') contVencidas++;
                        else if (m.estado === 'Pendiente Pago') contPendientes++;
                        else if (m.estado === 'Congelada') contCongeladas++;

                        // "Por Vencer" es un estado calculado, puede solaparse con Activa
                        if (m.diasRestantes >= 0 && m.diasRestantes <= 5 && m.estado === 'Activa') contPorVencer++;

                        // Lógica de Badges
                        let badgeHtml = `<span class="badge bg-secondary">Inactiva</span>`;
                        if (m.estado === 'Activa') badgeHtml = `<span class="badge bg-success bg-opacity-75 text-white"><i class="bi bi-check-circle me-1"></i>Activa</span>`;
                        if (m.estado === 'Vencida') badgeHtml = `<span class="badge bg-danger bg-opacity-75 text-white"><i class="bi bi-x-circle me-1"></i>Vencida</span>`;
                        if (m.estado === 'Pendiente Pago') badgeHtml = `<span class="badge bg-info text-dark border border-info"><i class="bi bi-hourglass-split me-1"></i>Pendiente Pago</span>`;
                        if (m.estado === 'Congelada') badgeHtml = `<span class="badge bg-primary bg-opacity-75 text-white"><i class="bi bi-cloud-snow me-1"></i>Congelada</span>`;

                        // Deuda
                        let deudaFormatter = new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' });
                        let deudaHtml = '';
                        if (m.deuda > 0) {
                            deudaHtml = `<span class="text-danger fw-bold"><i class="fas fa-exclamation-circle me-1"></i>${deudaFormatter.format(m.deuda)}</span>`;
                        } else {
                            deudaHtml = `<span class="badge bg-success bg-opacity-75 text-white"><i class="bi bi-check-circle me-1"></i>Pagado</span>`;
                        }

                        html += `
                            <tr class="align-middle">
                                <td class="ps-4 fw-bold text-muted">#${m.membresiaId}</td>
                                <td>
                                    <div class="fw-bold text-dark">${m.nombreUsuario}</div>
                                </td>
                                <td>${badgeHtml}</td>
                                <td>${deudaHtml}</td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="/Pagos/Registrar?membresiaId=${m.membresiaId}" class="btn btn-sm btn-success" title="Registrar Pago">
                                            <i class="fas fa-money-bill-wave"></i>
                                        </a>
                                        <a href="/Membresias/Details/${m.membresiaId}" class="btn btn-sm" style="background-color: #276CF5; color: white;" title="Ver Detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        `;
                    });

                    tbody.innerHTML = html;

                    // Actualizar KPIs (Solo si estamos viendo 'todas' para tener el panorama completo)
                    if(filtro === 'todas'){
                        document.getElementById('kpiActivas').innerText = contActivas;
                        document.getElementById('kpiVencidas').innerText = contVencidas;
                        document.getElementById('kpiPorVencer').innerText = contPorVencer;
                        document.getElementById('kpiPendientes').innerText = contPendientes;
                        document.getElementById('kpiCongeladas').innerText = contCongeladas;
                    }
                });
        }

        // ==========================================
        // 2. LÓGICA DE RENOVACIÓN (AUTOCOMPLETADO)
        // ==========================================
        function renovar(dni, nombre, userId) {
            // 1. Abrir Modal
            abrirModal();

            // 2. Pre-llenar datos visuales
            const inputBuscar = document.getElementById('txtBuscarUsuario');
            inputBuscar.value = `${nombre} - ${dni}`; // Visual para el admin

            // 3. Setear ID (Si tu DTO backend no enviaba userId, usaremos la búsqueda por DNI abajo como fallback)
            if(userId > 0) {
                 document.getElementById('userIdSeleccionado').value = userId;
                 mostrarFeedbackUsuario(nombre);
            } else {
                // Fallback: Si no tenemos el ID directo, disparamos la búsqueda por DNI
                inputBuscar.value = dni;
                inputBuscar.dispatchEvent(new Event('input')); // Dispara la búsqueda
            }

            // 4. Enfocar en el Plan para agilizar
            setTimeout(() => document.getElementById('cboPlan').focus(), 500);
        }

        // ==========================================
        // 3. FUNCIONES AUXILIARES (MODAL, RECURSOS)
        // ==========================================
        function cargarRecursos() {
            fetch('/Membresias/ObtenerRecursosCreacion')
                .then(res => res.json())
                .then(json => {
                    catalogoPlanes = json.planes;
                    let planesHtml = '<option value="" selected disabled>-- Seleccione --</option>';
                    json.planes.forEach(p => planesHtml += `<option value="${p.planId}">${p.nombre}</option>`);
                    document.getElementById('cboPlan').innerHTML = planesHtml;

                    let turnosHtml = '';
                    json.turnos.forEach(t => turnosHtml += `<option value="${t.turnoId}">${t.nombre} (${t.horaInicio} - ${t.horaFin})</option>`);
                    document.getElementById('cboTurno').innerHTML = turnosHtml;
                });
        }

        function actualizarInfoPrecio() {
            const planId = parseInt(document.getElementById('cboPlan').value);
            const plan = catalogoPlanes.find(p => p.planId === planId);
            if (plan) {
                const precio = new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(plan.precioBase);
                document.getElementById('lblPrecioPreview').innerText = precio;
                document.getElementById('lblDuracionPreview').innerText = plan.duracionDias + " días de duración";
            } else {
                document.getElementById('lblPrecioPreview').innerText = "$0.00";
                document.getElementById('lblDuracionPreview').innerText = "-";
            }
        }

        // Lógica de Búsqueda (Autocomplete)
        const inputBuscar = document.getElementById('txtBuscarUsuario');
        const dataList = document.getElementById('listaUsuarios');

        inputBuscar.addEventListener('input', function() {
            const val = this.value;
            // Si estamos escribiendo, limpiamos la selección previa
            if(val.length < 3) {
                 document.getElementById('userIdSeleccionado').value = "";
                 document.getElementById('usuarioFeedback').classList.add('d-none');
                 return;
            }

            fetch(`/Membresias/BuscarUsuario?q=${val}`)
                .then(res => res.json())
                .then(data => {
                    dataList.innerHTML = '';
                    data.forEach(item => {
                        const option = document.createElement('option');
                        option.value = item.text; // Lo que se ve en el input
                        option.setAttribute('data-id', item.id);
                        dataList.appendChild(option);
                    });

                    // Auto-selección si hay coincidencia exacta (útil para la renovación automática)
                    const coincidencia = data.find(x => x.text.includes(val));
                    if(coincidencia && data.length === 1) {
                         document.getElementById('userIdSeleccionado').value = coincidencia.id;
                         mostrarFeedbackUsuario(coincidencia.text);
                    }
                });
        });

        // Evento Change para detectar click en datalist
        inputBuscar.addEventListener('change', function() {
            const val = this.value;
            const options = dataList.childNodes;
            for (let i = 0; i < options.length; i++) {
                if (options[i].value === val) {
                    const id = options[i].getAttribute('data-id');
                    document.getElementById('userIdSeleccionado').value = id;
                    mostrarFeedbackUsuario(val);
                    break;
                }
            }
        });

        function mostrarFeedbackUsuario(texto) {
            document.getElementById('usuarioFeedback').classList.remove('d-none');
            document.getElementById('lblUsuarioSeleccionado').innerText = texto.split('(')[0] + " seleccionado.";
        }

        function guardarMembresia() {
            const userId = document.getElementById('userIdSeleccionado').value;
            const planId = document.getElementById('cboPlan').value;
            const turnoId = document.getElementById('cboTurno').value;

            if (!userId) return Swal.fire('Error', 'Debes buscar y seleccionar un cliente válido.', 'warning');
            if (!planId) return Swal.fire('Error', 'Selecciona un plan.', 'warning');

            const data = {
                UserId: parseInt(userId),
                PlanId: parseInt(planId),
                TurnoId: parseInt(turnoId),
                FechaInicio: document.getElementById('txtFechaInicio').value
            };

            Swal.fire({
                title: '¿Generar Membresía?',
                html: "Se creará con estado <b>Pendiente de Pago</b>.<br>El cliente deberá pasar por caja para activar el acceso.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, generar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Membresias/Crear', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            bootstrap.Modal.getInstance(document.getElementById('modalMembresia')).hide();
                            cargarMembresias('todas');
                            Swal.fire('¡Creada!', 'La membresía está pendiente de pago.', 'success');
                            document.getElementById('formMembresia').reset();
                            actualizarInfoPrecio();
                            // Limpiar estados visuales
                            document.getElementById('usuarioFeedback').classList.add('d-none');
                            document.getElementById('userIdSeleccionado').value = "";
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }

        function abrirModal() {
            // Limpiar modal para nueva venta limpia
            document.getElementById('formMembresia').reset();
            document.getElementById('usuarioFeedback').classList.add('d-none');
            document.getElementById('userIdSeleccionado').value = "";
            document.getElementById('txtFechaInicio').valueAsDate = new Date();
            actualizarInfoPrecio();

            new bootstrap.Modal(document.getElementById('modalMembresia')).show();
        }

        // ==========================================
        // 4. LÓGICA DE CONGELAMIENTO
        // ==========================================
        function abrirModalCongelar(id) {
            document.getElementById('freezeIdMembresia').value = id;
            document.getElementById('txtFreezeInicio').valueAsDate = new Date();
            document.getElementById('txtFreezeFin').value = "";
            document.getElementById('txtFreezeMotivo').value = "";
            
            // Cargar Historial
            fetch(`/Congelamientos/Historial/${id}`)
                .then(res => res.json())
                .then(json => {
                    const div = document.getElementById('historialFreeze');
                    const lista = document.getElementById('listadoHistorial');
                    lista.innerHTML = "";

                    if(json.success && json.data.length > 0) {
                        div.classList.remove('d-none');
                        json.data.forEach(c => {
                            lista.innerHTML += `
                                <div class="mb-2 p-2 border-start border-3 border-info bg-light">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-bold text-dark">${c.inicio} al ${c.fin}</span>
                                        <span class="badge bg-secondary" style="font-size:0.6rem">OK</span>
                                    </div>
                                    <div class="text-muted" style="font-size:0.75rem">${c.motivo || 'Sin motivo'}</div>
                                    <div class="text-muted" style="font-size:0.7rem">Autorizado por: ${c.empleado || 'Admin'}</div>
                                </div>
                            `;
                        });
                    } else {
                        div.classList.add('d-none');
                    }
                });

            new bootstrap.Modal(document.getElementById('modalCongelar')).show();
        }

        function confirmarCongelar() {
            const id = document.getElementById('freezeIdMembresia').value;
            const fin = document.getElementById('txtFreezeFin').value;
            const motivo = document.getElementById('txtFreezeMotivo').value;

            if(!fin) return Swal.fire('Error', 'Indica una fecha de fin proyectada.', 'warning');

            const data = {
                MembresiaId: parseInt(id),
                FechaInicio: new Date(),
                FechaFin: new Date(fin),
                Motivo: motivo
            };

            Swal.fire({
                title: '¿Congelar Membresía?',
                text: "El socio no podrá ingresar hasta que se cumpla la fecha o sea reactivado manualmente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, pausar',
                cancelButtonText: 'Dudar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Congelamientos/Congelar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            bootstrap.Modal.getInstance(document.getElementById('modalCongelar')).hide();
                            cargarMembresias('todas');
                            Swal.fire('¡Congelada!', json.message, 'success');
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }

        function descongelarMembresia(id) {
            Swal.fire({
                title: '¿Reactivar Membresía?',
                text: "El socio volverá a tener acceso inmediato.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, reactivar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/Congelamientos/Descongelar/${id}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            cargarMembresias('todas');
                            Swal.fire('¡Reactivada!', json.message, 'success');
                        } else {
                            Swal.fire('Error', json.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}