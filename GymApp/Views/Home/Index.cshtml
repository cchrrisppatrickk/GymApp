@{
    ViewData["Title"] = "Dashboard de Estadísticas";
}

@section Styles {
    <style>
        .card-stats {
            border: none;
            border-radius: 1.5rem;
            transition: all 0.2s ease;
            box-shadow: 0 8px 20px rgba(0,0,0,0.03), 0 2px 6px rgba(0,0,0,0.05);
            background: white;
        }

        .card-stats:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 25px -12px rgba(0,0,0,0.1);
        }

        .stat-icon {
            width: 52px;
            height: 52px;
            background: rgba(13, 110, 253, 0.12);
            border-radius: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #0d6efd;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #1e2f41;
        }

        .stat-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 700;
            color: #5e6f8d;
            letter-spacing: 0.3px;
        }
    </style>
}

<div class="container-fluid mt-4">
    <!-- ================= SECCIÓN USUARIOS ================= -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="fas fa-users fa-xl text-primary"></i>
            <h3 class="fw-semibold m-0">Panel de Usuarios</h3>
            <span class="badge bg-secondary bg-opacity-25 text-dark">Membresías · Deudas · Vencimientos</span>
        </div>

        <div class="row g-4">
            <!-- Nuevos registros del mes -->
            <div class="col-md-3 col-sm-6">
                <div class="card-stats card h-100 p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">NUEVOS MIEMBROS</div>
                            <div class="stat-value" id="newUsersCount">0</div>
                            <small class="text-success"><i class="fas fa-user-plus me-1"></i>registrados este mes</small>
                        </div>
                        <div class="stat-icon"><i class="fas fa-user-check"></i></div>
                    </div>
                </div>
            </div>

            <!-- Membresías vencidas SIN renovar -->
            <div class="col-md-3 col-sm-6">
                <div class="card-stats card h-100 p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">SIN RENOVAR (VENCIDOS)</div>
                            <div class="stat-value" id="expiredNoRenewCount">0</div>
                            <small class="text-danger"><i class="fas fa-hourglass-end me-1"></i>no han renovado</small>
                        </div>
                        <div class="stat-icon text-danger" style="background: rgba(220, 53, 69, 0.12);"><i class="fas fa-user-slash"></i></div>
                    </div>
                </div>
            </div>

            <!-- Membresías Congeladas -->
            <div class="col-md-4 col-sm-6">
                <div class="card-stats card h-100 p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">MEMBRESÍAS CONGELADAS</div>
                            <div class="stat-value" id="frozenCount">0</div>
                            <small class="text-primary"><i class="fas fa-snowflake me-1"></i>pausa temporal</small>
                        </div>
                        <div class="stat-icon text-primary" style="background: rgba(13, 110, 253, 0.12);"><i class="fas fa-ice-cream"></i></div>
                    </div>
                </div>
            </div>

            <!-- Por vencer en 7 días -->
            <div class="col-md-4 col-sm-6">
                <div class="card-stats card h-100 p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">PRÓXIMO VENCIMIENTO (7d)</div>
                            <div class="stat-value" id="expiringWeekCount">0</div>
                            <small class="text-warning"><i class="fas fa-calendar-week me-1"></i>por vencer</small>
                        </div>
                        <div class="stat-icon text-warning" style="background: rgba(255, 193, 7, 0.12);"><i class="fas fa-clock"></i></div>
                    </div>
                </div>
            </div>

            <!-- Usuarios con deudas pendientes -->
            <div class="col-md-4 col-sm-6">
                <div class="card-stats card h-100 p-4">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">CON DEUDAS PENDIENTES</div>
                            <div class="stat-value" id="debtUsersCount">0</div>
                            <small class="text-danger"><i class="fas fa-coins me-1"></i>saldo adeudado total: <strong id="totalDebtAmount">$0</strong></small>
                        </div>
                        <div class="stat-icon text-danger" style="background: rgba(220, 53, 69, 0.12);"><i class="fas fa-file-invoice-dollar"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- ================= SECCIÓN RENDIMIENTO FINANCIERO ================= -->
    <div class="mb-4 mt-5">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="fas fa-chart-line fa-xl text-success"></i>
            <h3 class="fw-semibold m-0">Rendimiento Financiero</h3>
            <span class="badge bg-success bg-opacity-25 text-dark">ingresos + pagos libres</span>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3">
                    <div class="card-body p-0">
                        <h5 class="card-title fw-bold"><i class="fas fa-chart-bar me-2 text-primary"></i> Ingresos por Membresías (últimos 6 meses)</h5>
                        <div style="height: 300px;">
                            <canvas id="monthlyRevenueChart"></canvas>
                        </div>
                        <div class="mt-3 small bg-light p-2 rounded-2 d-flex justify-content-between" id="monthlyExtraNote">
                            <span><i class="fas fa-calendar-alt"></i> <strong>Abril 2026:</strong> S/ 17,640.00 en membresías</span>
                            <span><i class="fas fa-arrow-up text-success"></i> Crecimiento +11% vs marzo</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3">
                    <div class="card-body p-0">
                        <h5 class="card-title fw-bold"><i class="fas fa-chart-line me-2 text-info"></i> Ingresos por Semana (últimas 4 semanas)</h5>
                        <div style="height: 300px;">
                            <canvas id="weeklyRevenueChart"></canvas>
                        </div>
                        <div class="mt-3 small bg-light p-2 rounded-2 d-flex justify-content-between" id="weeklyExtraNote">
                            <span><i class="fas fa-chart-simple"></i> <strong>Semana actual:</strong> S/ 5,180.00</span>
                            <span><i class="fas fa-arrow-up text-success"></i> +5.2% vs semana anterior</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        $(document).ready(function () {
            cargarEstadisticas();
            inicializarGraficos();
        });

        function cargarEstadisticas() {
            $.ajax({
                url: '/Reportes/ObtenerEstadisticasUsuarios',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    $('#newUsersCount').text(data.nuevosMiembrosMes);
                    $('#expiredNoRenewCount').text(data.vencidosSinRenovar);
                    $('#frozenCount').text(data.membresiasCongeladas);
                    $('#expiringWeekCount').text(data.porVencer7Dias);
                    $('#debtUsersCount').text(data.usuariosConDeuda);
                    
                    let montoFormatted = new Intl.NumberFormat('es-PE', { 
                        style: 'currency', 
                        currency: 'PEN' 
                    }).format(data.montoTotalDeuda);
                    
                    $('#totalDebtAmount').text(montoFormatted);
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar estadísticas del dashboard:", error);
                }
            });
        }

        function inicializarGraficos() {
            const ctxMonthly = document.getElementById('monthlyRevenueChart').getContext('2d');
            const ctxWeekly = document.getElementById('weeklyRevenueChart').getContext('2d');

            // Datos estáticos de prueba (Mock)
            const months = ['Nov', 'Dic', 'Ene', 'Feb', 'Mar', 'Abr'];
            const monthlyRevenue = [13800, 14520, 15890, 17640, 18450, 18820];

            const weekLabels = ['Sem 1', 'Sem 2', 'Sem 3', 'Sem 4'];
            const weeklyRevenue = [4250, 4480, 4920, 5180];

            new Chart(ctxMonthly, {
                type: 'bar',
                data: {
                    labels: months,
                    datasets: [{
                        label: 'Ingresos (S/)',
                        data: monthlyRevenue,
                        backgroundColor: 'rgba(13, 110, 253, 0.8)',
                        borderRadius: 6,
                        barPercentage: 0.6
                    }]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { drawBorder: false }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            new Chart(ctxWeekly, {
                type: 'line',
                data: {
                    labels: weekLabels,
                    datasets: [{
                        label: 'Ingresos semanales (S/)',
                        data: weeklyRevenue,
                        borderColor: '#198754',
                        backgroundColor: 'rgba(25, 135, 84, 0.1)',
                        borderWidth: 3,
                        tension: 0.3,
                        fill: true,
                        pointBackgroundColor: '#198754',
                        pointRadius: 4
                    }]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { drawBorder: false }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        }
    </script>
}
