@using GymApp.Constants
@{
    ViewData["Title"] = "Dashboard de Estadísticas";
}

@section Styles {
    <style>
        .card-stats {
            border: none;
            border-radius: 1.5rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 8px 20px rgba(0,0,0,0.03), 0 2px 6px rgba(0,0,0,0.05);
            background: white;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .card-stats:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -12px rgba(0,0,0,0.1);
        }

        .card-stats::after {
            content: 'Ver detalles \2192';
            position: absolute;
            bottom: 10px;
            right: 20px;
            font-size: 0.7rem;
            font-weight: bold;
            opacity: 0;
            transition: opacity 0.3s ease;
            color: inherit;
        }

        .card-stats:hover::after {
            opacity: 0.7;
        }

        .stat-icon {
            width: 52px;
            height: 52px;
            background: rgba(13, 110, 253, 0.12);
            border-radius: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #0d6efd;
            transition: transform 0.3s ease;
        }

        .card-stats:hover .stat-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -1px;
            color: #1e2f41;
        }

        .btn-refresh {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .btn-refresh:hover {
            transform: rotate(180deg);
        }

        .loading-shimmer {
            animation: shimmer 2s infinite linear;
            background: linear-gradient(to right, #f6f7f8 0%, #edeef1 20%, #f6f7f8 40%, #f6f7f8 100%);
            background-size: 800px 104px;
        }

        @@keyframes shimmer {
            0% { background-position: -468px 0; }
            100% { background-position: 468px 0; }
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .text-transparent { color: transparent !important; }
    </style>
}

@if (User.HasClaim(TipoClaim.Permiso, AppPermisos.DashboardVer) || User.HasClaim(TipoClaim.Permiso, AppPermisos.AdminAccesoTotal) || User.IsInRole(AppRoles.Admin))
{
<div class="container-fluid mt-4">
    <!-- ================= SECCIÓN USUARIOS ================= -->
    <div class="mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-users fa-xl text-primary"></i>
                <h3 class="fw-semibold m-0">Panel de Usuarios</h3>
                <span class="badge bg-secondary bg-opacity-25 text-dark">Membresías · Deudas · Vencimientos</span>
            </div>
            <button class="btn btn-outline-primary btn-refresh border-0" onclick="actualizarDashboard()" title="Actualizar datos">
                <i class="fas fa-sync-alt" id="refreshIcon"></i>
            </button>
        </div>

        <div class="row g-4">
            <!-- Nuevos registros del mes -->
            <div class="col-md-3 col-sm-6">
                <div class="card-stats card h-100 p-4 border-start border-4 border-success" onclick="location.href='/Usuarios/Index'">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">NUEVOS MIEMBROS</div>
                            <div class="stat-value counter" id="newUsersCount">0</div>
                            <small class="text-success fw-medium"><i class="fas fa-user-plus me-1"></i>registrados este mes</small>
                        </div>
                        <div class="stat-icon text-success" style="background: rgba(25, 135, 84, 0.12);"><i class="fas fa-user-check"></i></div>
                    </div>
                </div>
            </div>

            <!-- Membresías vencidas SIN renovar -->
            <div class="col-md-3 col-sm-6">
                <div class="card-stats card h-100 p-4 border-start border-4 border-secondary" onclick="location.href='/Membresias/Index?filtro=vencidas'">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">SIN RENOVAR (VENCIDOS)</div>
                            <div class="stat-value counter" id="expiredNoRenewCount">0</div>
                            <small class="text-muted"><i class="fas fa-hourglass-end me-1"></i>no han renovado</small>
                        </div>
                        <div class="stat-icon text-secondary" style="background: rgba(108, 117, 125, 0.12);"><i class="fas fa-user-slash"></i></div>
                    </div>
                </div>
            </div>

            <!-- Membresías Congeladas -->
            <div class="col-md-4 col-sm-6">
                <div class="card-stats card h-100 p-4 border-start border-4 border-primary" onclick="location.href='/Membresias/Index?filtro=congeladas'">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">MEMBRESÍAS CONGELADAS</div>
                            <div class="stat-value counter" id="frozenCount">0</div>
                            <small class="text-primary fw-medium"><i class="fas fa-snowflake me-1"></i>pausa temporal</small>
                        </div>
                        <div class="stat-icon text-primary" style="background: rgba(13, 110, 253, 0.12);"><i class="fas fa-ice-cream"></i></div>
                    </div>
                </div>
            </div>

            <!-- Por vencer en 7 días -->
            <div class="col-md-4 col-sm-6">
                <div class="card-stats card h-100 p-4 border-start border-4 border-warning" onclick="location.href='/Membresias/Index?filtro=porVencer'">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">PRÓXIMO VENCIMIENTO (7d)</div>
                            <div class="stat-value counter" id="expiringWeekCount">0</div>
                            <small class="text-warning fw-bold"><i class="fas fa-calendar-week me-1"></i>por vencer pronto</small>
                        </div>
                        <div class="stat-icon text-warning" style="background: rgba(255, 193, 7, 0.12);"><i class="fas fa-clock"></i></div>
                    </div>
                </div>
            </div>

            <!-- Usuarios con deudas pendientes -->
            <div class="col-md-4 col-sm-6">
                <div class="card-stats card h-100 p-4 border-start border-4 border-danger" onclick="location.href='/Membresias/Index?filtro=deudores'">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">CON DEUDAS PENDIENTES</div>
                            <div class="stat-value counter" id="debtUsersCount">0</div>
                            <small class="text-danger fw-bold" id="debtAlertText">
                                <i class="fas fa-coins me-1"></i> Total adeudado: <strong id="totalDebtAmount">S/. 0.00</strong>
                            </small>
                        </div>
                        <div class="stat-icon text-danger" style="background: rgba(220, 53, 69, 0.12);"><i class="fas fa-file-invoice-dollar"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- ================= SECCIÓN RENDIMIENTO FINANCIERO ================= -->
    <div class="mb-4 mt-5">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-chart-line fa-xl text-success"></i>
                <h3 class="fw-semibold m-0">Tendencia Financiera y Matrículas</h3>
                <span class="badge bg-success bg-opacity-25 text-dark">Ingresos vs Nuevos Miembros</span>
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="Filtro de temporalidad">
                <input type="radio" class="btn-check" name="btnTemporalidad" id="btnSemana" value="Semana" autocomplete="off">
                <label class="btn btn-outline-success" for="btnSemana">Semana</label>

                <input type="radio" class="btn-check" name="btnTemporalidad" id="btnMes" value="Mes" autocomplete="off" checked>
                <label class="btn btn-outline-success" for="btnMes">Mes</label>

                <input type="radio" class="btn-check" name="btnTemporalidad" id="btnAnual" value="Anual" autocomplete="off">
                <label class="btn btn-outline-success" for="btnAnual">Anual</label>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4 p-3">
            <div class="card-body p-0">
                <div style="height: 350px;">
                    <canvas id="tendenciaChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= SECCIÓN GRÁFICO PASES DIARIOS ================= -->
    <div class="mb-4 mt-5">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-door-open fa-xl" style="color:#720e9e;"></i>
                <h3 class="fw-semibold m-0">Tendencia Pases Diarios</h3>
                <span class="badge bg-opacity-25 text-dark" style="background-color:rgba(114,14,158,0.18);">Ingresos por Turno</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <!-- Resumen rápido -->
                <div class="d-flex gap-2" id="pasesResumenBadges">
                    <span class="badge rounded-pill border" style="background:rgba(245,158,11,0.12);color:#92400e;border-color:#f59e0b !important;">
                        <i class="fas fa-sun me-1"></i><span id="pasMañanaTotal">-</span>
                    </span>
                    <span class="badge rounded-pill border" style="background:rgba(59,130,246,0.12);color:#1e3a8a;border-color:#3b82f6 !important;">
                        <i class="fas fa-moon me-1"></i><span id="pasTardeTotal">-</span>
                    </span>
                </div>
                <!-- Filtro temporalidad -->
                <div class="btn-group btn-group-sm" role="group" aria-label="Filtro pases diarios">
                    <input type="radio" class="btn-check" name="btnTempPases" id="pasesSemana" value="Semana" autocomplete="off">
                    <label class="btn btn-outline-secondary" for="pasesSemana" style="--bs-btn-border-color:#720e9e;--bs-btn-hover-bg:#720e9e;--bs-btn-hover-color:#fff;">Semana</label>

                    <input type="radio" class="btn-check" name="btnTempPases" id="pasesMes" value="Mes" autocomplete="off" checked>
                    <label class="btn btn-outline-secondary" for="pasesMes" style="--bs-btn-border-color:#720e9e;--bs-btn-hover-bg:#720e9e;--bs-btn-hover-color:#fff;">Mes</label>

                    <input type="radio" class="btn-check" name="btnTempPases" id="pasesAnual" value="Anual" autocomplete="off">
                    <label class="btn btn-outline-secondary" for="pasesAnual" style="--bs-btn-border-color:#720e9e;--bs-btn-hover-bg:#720e9e;--bs-btn-hover-color:#fff;">Anual</label>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4 p-3" style="border-top: 3px solid #720e9e !important;">
            <div class="card-body p-0">
                <div style="height: 340px; position: relative;">
                    <div id="pasesDiariosLoader" class="d-flex align-items-center justify-content-center h-100" style="display:flex !important;">
                        <div class="text-center text-muted">
                            <div class="spinner-border spinner-border-sm mb-2" style="color:#720e9e;"></div>
                            <div class="small">Cargando datos...</div>
                        </div>
                    </div>
                    <canvas id="pasesDiariosChart" style="display:none;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= SECCIÓN PAGOS RECIENTES ================= -->
    <div class="mb-4 mt-5">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-history fa-xl text-info"></i>
                <h3 class="fw-semibold m-0">Pagos Recientes</h3>
                <span class="badge bg-info bg-opacity-25 text-dark">Últimos 7 movimientos</span>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-uppercase small fw-bold text-muted">Cliente</th>
                            <th class="text-uppercase small fw-bold text-muted">Plan / Membresía</th>
                            <th class="text-uppercase small fw-bold text-muted">Monto</th>
                            <th class="text-uppercase small fw-bold text-muted">Fecha</th>
                            <th class="text-end pe-4 text-uppercase small fw-bold text-muted">Método</th>
                        </tr>
                    </thead>
                    <tbody id="recentPaymentsTable">
                        <!-- Carga dinámica por AJAX -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        $(document).ready(function () {
            cargarEstadisticas();
            cargarGraficoTendencia('Mes');
            cargarPagosRecientes();
            cargarGraficoPasesDiarios('Mes');

            $('input[name="btnTemporalidad"]').change(function() {
                cargarGraficoTendencia(this.value);
            });

            $('input[name="btnTempPases"]').change(function() {
                cargarGraficoPasesDiarios(this.value);
            });
        });

        function actualizarDashboard() {
            const icon = $('#refreshIcon');
            icon.addClass('fa-spin');
            
            cargarEstadisticas();
            const temporalidad = $('input[name="btnTemporalidad"]:checked').val() || 'Mes';
            cargarGraficoTendencia(temporalidad);
            cargarPagosRecientes();
            const tempPases = $('input[name="btnTempPases"]:checked').val() || 'Mes';
            cargarGraficoPasesDiarios(tempPases);

            setTimeout(() => icon.removeClass('fa-spin'), 1000);
        }

        function animateCounter(id, target) {
            $({ countNum: $(id).text() }).animate({ countNum: target }, {
                duration: 1000,
                easing: 'swing',
                step: function() {
                    $(id).text(Math.floor(this.countNum));
                },
                complete: function() {
                    $(id).text(this.countNum);
                }
            });
        }

        function cargarEstadisticas() {
            $('.stat-value').addClass('loading-shimmer text-transparent');

            $.ajax({
                url: '/Reportes/ObtenerEstadisticasUsuarios',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    $('.stat-value').removeClass('loading-shimmer text-transparent');
                    
                    animateCounter('#newUsersCount', data.nuevosMiembrosMes);
                    animateCounter('#expiredNoRenewCount', data.vencidosSinRenovar);
                    animateCounter('#frozenCount', data.membresiasCongeladas);
                    animateCounter('#expiringWeekCount', data.porVencer7Dias);
                    animateCounter('#debtUsersCount', data.usuariosConDeuda);
                    
                    let montoFormatted = new Intl.NumberFormat('es-PE', { 
                        style: 'currency', 
                        currency: 'PEN' 
                    }).format(data.montoTotalDeuda);
                    
                    $('#totalDebtAmount').text(montoFormatted);

                    // Alerta visual si hay deudores
                    if (data.usuariosConDeuda > 0) {
                        $('#debtUsersCount').addClass('text-danger');
                        $('#debtAlertText').addClass('bg-danger bg-opacity-10 rounded px-2 py-1 d-inline-block mt-1');
                    } else {
                        $('#debtUsersCount').removeClass('text-danger');
                        $('#debtAlertText').removeClass('bg-danger bg-opacity-10 rounded px-2 py-1');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar estadísticas del dashboard:", error);
                    $('.stat-value').removeClass('loading-shimmer text-transparent').text('!');
                }
            });
        }

        let tendenciaChartInstance = null;

        function cargarGraficoTendencia(temporalidad) {
            fetch(`/Home/ObtenerDatosGrafico?temporalidad=${temporalidad}`)
                .then(response => {
                    if (!response.ok) throw new Error("Error en la respuesta del servidor");
                    return response.json();
                })
                .then(data => {
                    if (tendenciaChartInstance) {
                        tendenciaChartInstance.destroy();
                    }

                    const ctx = document.getElementById('tendenciaChart').getContext('2d');
                    tendenciaChartInstance = new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.etiquetas,
                            datasets: [
                                {
                                    label: 'Ingresos (S/)',
                                    data: data.ingresos,
                                    backgroundColor: 'rgba(25, 135, 84, 0.7)',
                                    borderColor: 'rgba(25, 135, 84, 1)',
                                    borderWidth: 1,
                                    borderRadius: 4,
                                    yAxisID: 'y'
                                },
                                {
                                    label: 'Nuevas Matrículas',
                                    data: data.matriculas,
                                    type: 'line',
                                    borderColor: '#0d6efd',
                                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                    borderWidth: 3,
                                    tension: 0.3,
                                    fill: true,
                                    pointBackgroundColor: '#0d6efd',
                                    pointRadius: 4,
                                    yAxisID: 'y1'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                mode: 'index',
                                intersect: false,
                            },
                            plugins: {
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            let label = context.dataset.label || '';
                                            if (label) {
                                                label += ': ';
                                            }
                                            if (context.dataset.yAxisID === 'y') {
                                                label += new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(context.raw);
                                            } else {
                                                label += context.raw;
                                            }
                                            return label;
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    type: 'linear',
                                    display: true,
                                    position: 'left',
                                    title: {
                                        display: true,
                                        text: 'Ingresos (S/)'
                                    },
                                    grid: {
                                        drawBorder: false
                                    }
                                },
                                y1: {
                                    type: 'linear',
                                    display: true,
                                    position: 'right',
                                    title: {
                                        display: true,
                                        text: 'Matrículas'
                                    },
                                    grid: {
                                        drawOnChartArea: false,
                                    },
                                    min: 0,
                                    ticks: {
                                        stepSize: 1
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
                })
                .catch(error => console.error("Error al cargar tendencia:", error));
        }

        // ---- Gráfico Pases Diarios por Turno ----
        let pasesDiariosChartInstance = null;

        function cargarGraficoPasesDiarios(temporalidad) {
            const canvas  = document.getElementById('pasesDiariosChart');
            const loader  = document.getElementById('pasesDiariosLoader');

            canvas.style.display = 'none';
            loader.style.display = 'flex';

            fetch(`/Home/ObtenerGraficoPasesDiarios?temporalidad=${temporalidad}`)
                .then(response => {
                    if (!response.ok) throw new Error('Error en la respuesta del servidor');
                    return response.json();
                })
                .then(data => {
                    loader.style.display = 'none';
                    canvas.style.display = 'block';

                    if (pasesDiariosChartInstance) {
                        pasesDiariosChartInstance.destroy();
                    }

                    // Actualizar badges resumen
                    const fmt = v => new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(v);
                    const turnoManana = data.turnoManana || [];
                    const turnoTarde  = data.turnoTarde  || [];
                    const totalManana = turnoManana.reduce((a, b) => a + b, 0);
                    const totalTarde  = turnoTarde.reduce((a, b) => a + b, 0);
                    document.getElementById('pasMañanaTotal').textContent = fmt(totalManana);
                    document.getElementById('pasTardeTotal').textContent  = fmt(totalTarde);

                    const ctx = canvas.getContext('2d');
                    pasesDiariosChartInstance = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.etiquetas || [],
                            datasets: [
                                {
                                    label: 'Total Pases (S/)',
                                    data: data.totalGeneral || [],
                                    borderColor: '#720e9e',
                                    backgroundColor: 'rgba(114,14,158,0.08)',
                                    borderWidth: 3,
                                    tension: 0.4,
                                    fill: true,
                                    pointBackgroundColor: '#720e9e',
                                    pointRadius: 4,
                                    pointHoverRadius: 6,
                                    yAxisID: 'y'
                                },
                                {
                                    label: 'Turno Mañana (S/)',
                                    data: turnoManana,
                                    borderColor: '#f59e0b',
                                    backgroundColor: 'rgba(245,158,11,0.08)',
                                    borderWidth: 2,
                                    borderDash: [5, 3],
                                    tension: 0.4,
                                    fill: false,
                                    pointBackgroundColor: '#f59e0b',
                                    pointRadius: 3,
                                    pointHoverRadius: 5,
                                    yAxisID: 'y'
                                },
                                {
                                    label: 'Turno Tarde (S/)',
                                    data: turnoTarde,
                                    borderColor: '#3b82f6',
                                    backgroundColor: 'rgba(59,130,246,0.08)',
                                    borderWidth: 2,
                                    borderDash: [5, 3],
                                    tension: 0.4,
                                    fill: false,
                                    pointBackgroundColor: '#3b82f6',
                                    pointRadius: 3,
                                    pointHoverRadius: 5,
                                    yAxisID: 'y'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: { mode: 'index', intersect: false },
                            plugins: {
                                legend: {
                                    position: 'top',
                                    labels: { usePointStyle: true, pointStyleWidth: 10, padding: 16 }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return ` ${context.dataset.label}: ` +
                                                new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(context.raw);
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    type: 'linear',
                                    position: 'left',
                                    title: { display: true, text: 'Ingresos (S/)' },
                                    grid: { color: 'rgba(0,0,0,0.05)' },
                                    ticks: {
                                        callback: v => 'S/ ' + v.toLocaleString('es-PE')
                                    }
                                },
                                x: {
                                    grid: { display: false }
                                }
                            }
                        }
                    });
                })
                .catch(error => {
                    loader.innerHTML = '<div class="text-danger text-center"><i class="fas fa-exclamation-triangle me-2"></i>Error al cargar el gráfico</div>';
                    console.error('Error al cargar gráfico pases diarios:', error);
                });
        }

        function cargarPagosRecientes() {
            const tbody = $('#recentPaymentsTable');
            
            // Efecto Shimmer inicial (Skeleton)
            const skeleton = Array(7).fill(`
                <tr>
                    <td class="ps-4"><div class="loading-shimmer py-2 rounded w-75"></div></td>
                    <td><div class="loading-shimmer py-2 rounded w-50"></div></td>
                    <td><div class="loading-shimmer py-2 rounded w-25"></div></td>
                    <td><div class="loading-shimmer py-2 rounded w-50"></div></td>
                    <td class="text-end pe-4"><div class="loading-shimmer py-2 rounded w-25 ms-auto"></div></td>
                </tr>
            `).join('');
            
            tbody.html(skeleton);

            $.ajax({
                url: '/Reportes/ObtenerPagosRecientes',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    tbody.empty();
                    
                    if (!data || data.length === 0) {
                        tbody.append('<tr><td colspan="5" class="text-center py-5 text-muted">No se encontraron pagos recientes</td></tr>');
                        return;
                    }

                    const currencyFormat = new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' });
                    const today = new Date().toLocaleDateString();

                    data.forEach((pago, index) => {
                        const fecha = new Date(pago.fechaPago);
                        const esHoy = fecha.toLocaleDateString() === today;
                        const badgeHoy = esHoy ? '<span class="badge bg-success ms-2 animate__animated animate__pulse animate__infinite" style="font-size: 0.65rem;">HOY</span>' : '';
                        
                        const row = `
                            <tr style="animation: fadeIn 0.4s ease forwards; animation-delay: ${index * 0.08}s; opacity: 0;">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" 
                                             style="width: 35px; height: 35px; font-size: 0.85rem; border: 1px solid rgba(13, 110, 253, 0.1);">
                                            ${pago.nombreCliente.charAt(0).toUpperCase()}
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-dark">${pago.nombreCliente}</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="badge bg-light text-dark fw-normal border">${pago.nombrePlan}</div>
                                </td>
                                <td>
                                    <span class="fw-bold text-success">${currencyFormat.format(pago.monto)}</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center text-muted small">
                                        <i class="far fa-calendar-alt me-2 text-info"></i>
                                        ${fecha.toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' })}
                                        ${badgeHoy}
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <span class="badge rounded-pill ${pago.metodoPago === 'Efectivo' ? 'bg-secondary' : 'bg-primary'} bg-opacity-10 text-dark border border-opacity-10" 
                                          style="font-weight: 500; font-size: 0.75rem;">
                                        <i class="fas ${pago.metodoPago === 'Efectivo' ? 'fa-money-bill-wave' : 'fa-mobile-alt'} me-1 opacity-50"></i>
                                        ${pago.metodoPago}
                                    </span>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar pagos recientes:", error);
                    tbody.html('<tr><td colspan="5" class="text-center py-5 text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Error al conectar con el servidor</td></tr>');
                }
            });
        }
    </script>
}
}
else
{
    <div class="container-fluid mt-5">
        <div class="p-5 mb-4 bg-white rounded-4 shadow-sm border text-center">
            <div class="container-fluid py-5">
                <i class="fas fa-dumbbell fa-4x text-primary mb-3 opacity-75"></i>
                <h1 class="display-5 fw-bold text-dark">Bienvenido a GymApp</h1>
                <p class="col-md-8 mx-auto fs-4 text-muted">Selecciona una opción del menú lateral para comenzar a operar en el sistema.</p>
            </div>
        </div>
    </div>
}
