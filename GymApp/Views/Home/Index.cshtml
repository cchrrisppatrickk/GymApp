@using GymApp.Constants
@{
    ViewData["Title"] = "Dashboard de Estadísticas";
}

@section Styles {
    <style>
        .counter-value {
            font-variant-numeric: tabular-nums;
        }

        .loading-shimmer {
            animation: shimmer 2s infinite linear;
            background: linear-gradient(to right, #f6f7f8 0%, #edeef1 20%, #f6f7f8 40%, #f6f7f8 100%);
            background-size: 800px 104px;
        }

        @@keyframes shimmer {
            0% { background-position: -468px 0; }
            100% { background-position: 468px 0; }
        }

        .text-transparent { color: transparent !important; }
    </style>
}

@if (User.HasClaim(TipoClaim.Permiso, AppPermisos.DashboardVer) || User.HasClaim(TipoClaim.Permiso, AppPermisos.AdminAccesoTotal) || User.IsInRole(AppRoles.Admin))
{
<div class="space-y-12 mt-6">
    <!-- ================= SECCIÓN USUARIOS ================= -->
    <section>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-10 h-10 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shadow-sm">
                        <i data-lucide="users" class="w-6 h-6"></i>
                    </div>
                    <h2 class="text-2xl font-display font-bold text-slate-950 tracking-tight m-0">Panel de Usuarios</h2>
                </div>
                <p class="text-slate-700 text-sm font-medium ml-1">Estado de membresías, deudas y nuevos registros</p>
            </div>
            <button class="group inline-flex items-center justify-center w-11 h-11 rounded-xl bg-white border border-slate-200 text-slate-600 hover:text-indigo-600 hover:border-indigo-200 hover:shadow-sm transition-all duration-300 active:scale-95" onclick="actualizarDashboard()" title="Actualizar datos">
                <i data-lucide="rotate-cw" class="w-6 h-6 transition-transform duration-500 group-hover:rotate-180" id="refreshIcon"></i>
            </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
            <!-- Nuevos registros del mes -->
            <div class="group relative bg-white rounded-3xl border border-slate-200 p-6 shadow-sm hover:shadow-xl hover:shadow-emerald-500/10 transition-all duration-300 hover:-translate-y-1.5 hover:border-emerald-300 hover:bg-emerald-50/30 cursor-pointer overflow-hidden" onclick="location.href='/Usuarios/Index'">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-emerald-500/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="flex flex-col h-full justify-between">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100/50 transition-all duration-300 group-hover:scale-110 group-hover:bg-emerald-100 group-hover:shadow-sm">
                            <i data-lucide="user-plus" class="w-6 h-6"></i>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest uppercase text-emerald-600/70 bg-emerald-50 px-2 py-1 rounded-lg group-hover:bg-emerald-100 transition-colors">Este mes</span>
                    </div>
                    <div>
                        <div class="text-4xl font-display font-extrabold text-slate-950 tracking-tight mb-1 counter-value transition-colors group-hover:text-emerald-900" id="newUsersCount">0</div>
                        <div class="text-xs font-bold text-slate-600 tracking-wider uppercase group-hover:text-emerald-600/60 transition-colors">Nuevos Socios</div>
                    </div>
                </div>
            </div>

            <!-- Membresías vencidas SIN renovar -->
            <div class="group relative bg-white rounded-3xl border border-slate-200 p-6 shadow-sm hover:shadow-xl hover:shadow-slate-500/10 transition-all duration-300 hover:-translate-y-1.5 hover:border-slate-400 hover:bg-slate-50 cursor-pointer overflow-hidden" onclick="location.href='/Membresias/Index?filtro=vencidas'">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-slate-500/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="flex flex-col h-full justify-between">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-slate-100 text-slate-700 flex items-center justify-center border border-slate-200/50 transition-all duration-300 group-hover:scale-110 group-hover:bg-slate-200 group-hover:shadow-sm">
                            <i data-lucide="user-x" class="w-6 h-6"></i>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest uppercase text-slate-600 bg-slate-50 px-2 py-1 rounded-lg group-hover:bg-slate-200 transition-colors">Acción req.</span>
                    </div>
                    <div>
                        <div class="text-4xl font-display font-extrabold text-slate-950 tracking-tight mb-1 counter-value transition-colors group-hover:text-slate-900" id="expiredNoRenewCount">0</div>
                        <div class="text-xs font-bold text-slate-600 tracking-wider uppercase group-hover:text-slate-700 transition-colors">Sin Renovar</div>
                    </div>
                </div>
            </div>

            <!-- Membresías Congeladas -->
            <div class="group relative bg-white rounded-3xl border border-slate-200 p-6 shadow-sm hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300 hover:-translate-y-1.5 hover:border-blue-300 hover:bg-blue-50/30 cursor-pointer overflow-hidden" onclick="location.href='/Membresias/Index?filtro=congeladas'">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-blue-500/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="flex flex-col h-full justify-between">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50 transition-all duration-300 group-hover:scale-110 group-hover:bg-blue-100 group-hover:shadow-sm">
                            <i data-lucide="snowflake" class="w-6 h-6"></i>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest uppercase text-blue-600/70 bg-blue-50 px-2 py-1 rounded-lg group-hover:bg-blue-100 transition-colors">En Pausa</span>
                    </div>
                    <div>
                        <div class="text-4xl font-display font-extrabold text-slate-950 tracking-tight mb-1 counter-value transition-colors group-hover:text-blue-900" id="frozenCount">0</div>
                        <div class="text-xs font-bold text-slate-600 tracking-wider uppercase group-hover:text-blue-600/60 transition-colors">Congeladas</div>
                    </div>
                </div>
            </div>

            <!-- Por vencer en 7 días -->
            <div class="group relative bg-white rounded-3xl border border-slate-200 p-6 shadow-sm hover:shadow-xl hover:shadow-amber-500/10 transition-all duration-300 hover:-translate-y-1.5 hover:border-amber-300 hover:bg-amber-50/30 cursor-pointer overflow-hidden" onclick="location.href='/Membresias/Index?filtro=porVencer'">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-amber-500/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="flex flex-col h-full justify-between">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-100/50 transition-all duration-300 group-hover:scale-110 group-hover:bg-amber-100 group-hover:shadow-sm">
                            <i data-lucide="history" class="w-6 h-6"></i>
                        </div>
                        <span class="text-[10px] font-bold tracking-widest uppercase text-amber-600/70 bg-amber-50 px-2 py-1 rounded-lg group-hover:bg-amber-100 transition-colors">Prox. 7 días</span>
                    </div>
                    <div>
                        <div class="text-4xl font-display font-extrabold text-slate-950 tracking-tight mb-1 counter-value transition-colors group-hover:text-amber-900" id="expiringWeekCount">0</div>
                        <div class="text-xs font-bold text-slate-600 tracking-wider uppercase group-hover:text-amber-600/60 transition-colors">Por Vencer</div>
                    </div>
                </div>
            </div>

            <!-- Usuarios con deudas pendientes -->
            <div class="group relative bg-white rounded-3xl border border-slate-200 p-6 shadow-sm hover:shadow-xl hover:shadow-rose-500/10 transition-all duration-300 hover:-translate-y-1.5 hover:border-rose-300 hover:bg-rose-50/30 cursor-pointer overflow-hidden sm:col-span-2 lg:col-span-1" onclick="location.href='/Membresias/Index?filtro=deudores'">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-rose-500/10 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="flex flex-col h-full justify-between">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-2xl bg-rose-50 text-rose-600 flex items-center justify-center border border-rose-100/50 transition-all duration-300 group-hover:scale-110 group-hover:bg-rose-100 group-hover:shadow-sm">
                            <i data-lucide="wallet" class="w-6 h-6"></i>
                        </div>
                        <div class="text-right">
                            <div class="text-[10px] font-bold tracking-widest uppercase text-rose-600/70 bg-rose-50 px-2 py-1 rounded-lg mb-1 inline-block group-hover:bg-rose-100 transition-colors">Deuda Total</div>
                            <div class="text-sm font-bold text-rose-600 transition-all group-hover:scale-110 group-hover:origin-right" id="totalDebtAmount">S/. 0.00</div>
                        </div>
                    </div>
                    <div>
                        <div class="text-4xl font-display font-extrabold text-slate-950 tracking-tight mb-1 counter-value transition-colors group-hover:text-rose-900" id="debtUsersCount">0</div>
                        <div class="text-xs font-bold text-slate-600 tracking-wider uppercase group-hover:text-rose-600/60 transition-colors">Socios con Deuda</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- ================= SECCIÓN RENDIMIENTO FINANCIERO ================= -->
    <section>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-8">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100/50 shadow-sm">
                        <i data-lucide="trending-up" class="w-6 h-6"></i>
                    </div>
                    <h2 class="text-2xl font-display font-bold text-slate-950 tracking-tight m-0">Tendencia Financiera</h2>
                </div>
                <p class="text-slate-700 text-sm font-medium ml-1">Ingresos vs Nuevos Miembros</p>
            </div>
            
            <div class="inline-flex bg-slate-100 p-1 rounded-2xl border border-slate-200/60 shadow-inner">
                <label class="relative cursor-pointer">
                    <input type="radio" name="btnTemporalidad" value="Semana" class="peer sr-only">
                    <span class="inline-block px-4 py-2 rounded-xl text-xs font-bold text-slate-700 hover:text-slate-900 peer-checked:bg-white peer-checked:text-emerald-600 peer-checked:shadow-sm transition-all duration-200">Semana</span>
                </label>
                <label class="relative cursor-pointer">
                    <input type="radio" name="btnTemporalidad" value="Mes" class="peer sr-only" checked>
                    <span class="inline-block px-4 py-2 rounded-xl text-xs font-bold text-slate-700 hover:text-slate-900 peer-checked:bg-white peer-checked:text-emerald-600 peer-checked:shadow-sm transition-all duration-200">Mes</span>
                </label>
                <label class="relative cursor-pointer">
                    <input type="radio" name="btnTemporalidad" value="Anual" class="peer sr-only">
                    <span class="inline-block px-4 py-2 rounded-xl text-xs font-bold text-slate-700 hover:text-slate-900 peer-checked:bg-white peer-checked:text-emerald-600 peer-checked:shadow-sm transition-all duration-200">Anual</span>
                </label>
            </div>
        </div>

        <div class="bg-white rounded-[2rem] border border-slate-200 p-6 md:p-8 shadow-sm">
            <div class="h-[350px]">
                <canvas id="tendenciaChart"></canvas>
            </div>
        </div>
    </section>

    <!-- ================= SECCIÓN GRÁFICO PASES DIARIOS ================= -->
    <section>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-8">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-10 h-10 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center border border-purple-100/50 shadow-sm">
                        <i data-lucide="door-open" class="w-6 h-6"></i>
                    </div>
                    <h2 class="text-2xl font-display font-bold text-slate-950 tracking-tight m-0">Tendencia Pases Diarios</h2>
                </div>
                <p class="text-slate-700 text-sm font-medium ml-1">Ingresos por Turno (Mañana/Tarde)</p>
            </div>

            <div class="flex flex-wrap items-center gap-4">
                <!-- Resumen rápido -->
                <div class="flex gap-2 mr-2">
                    <div class="flex items-center gap-2 bg-amber-50 border border-amber-100/50 px-3 py-1.5 rounded-xl">
                        <i data-lucide="sun" class="text-amber-500 w-4 h-4"></i>
                        <span id="pasMañanaTotal" class="text-xs font-bold text-amber-700">-</span>
                    </div>
                    <div class="flex items-center gap-2 bg-blue-50 border border-blue-100/50 px-3 py-1.5 rounded-xl">
                        <i data-lucide="moon" class="text-blue-500 w-4 h-4"></i>
                        <span id="pasTardeTotal" class="text-xs font-bold text-blue-700">-</span>
                    </div>
                </div>

                <!-- Filtro temporalidad -->
                <div class="inline-flex bg-slate-100 p-1 rounded-2xl border border-slate-200/60 shadow-inner">
                    <label class="relative cursor-pointer">
                        <input type="radio" name="btnTempPases" value="Semana" class="peer sr-only">
                        <span class="inline-block px-4 py-2 rounded-xl text-xs font-bold text-slate-700 hover:text-slate-900 peer-checked:bg-white peer-checked:text-purple-600 peer-checked:shadow-sm transition-all duration-200">Semana</span>
                    </label>
                    <label class="relative cursor-pointer">
                        <input type="radio" name="btnTempPases" value="Mes" class="peer sr-only" checked>
                        <span class="inline-block px-4 py-2 rounded-xl text-xs font-bold text-slate-700 hover:text-slate-900 peer-checked:bg-white peer-checked:text-purple-600 peer-checked:shadow-sm transition-all duration-200">Mes</span>
                    </label>
                    <label class="relative cursor-pointer">
                        <input type="radio" name="btnTempPases" value="Anual" class="peer sr-only">
                        <span class="inline-block px-4 py-2 rounded-xl text-xs font-bold text-slate-700 hover:text-slate-900 peer-checked:bg-white peer-checked:text-purple-600 peer-checked:shadow-sm transition-all duration-200">Anual</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[2rem] border border-slate-200 p-6 md:p-8 shadow-sm relative overflow-hidden">
            <!-- Loader sutil -->
            <div id="pasesDiariosLoader" class="absolute inset-0 bg-white/80 backdrop-blur-[2px] z-10 flex items-center justify-center transition-opacity duration-300 pointer-events-none opacity-0">
                <div class="flex flex-col items-center gap-2">
                    <div class="w-8 h-8 border-4 border-purple-100 border-t-purple-600 rounded-full animate-spin"></div>
                    <span class="text-xs font-bold text-slate-600 uppercase tracking-widest">Cargando</span>
                </div>
            </div>
            <div class="h-[340px]">
                <canvas id="pasesDiariosChart"></canvas>
            </div>
        </div>
    </section>

    <!-- ================= SECCIÓN PAGOS RECIENTES ================= -->
    <section class="pb-12">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50 shadow-sm">
                        <i data-lucide="history" class="w-6 h-6"></i>
                    </div>
                    <h2 class="text-2xl font-display font-bold text-slate-950 tracking-tight m-0">Pagos Recientes</h2>
                </div>
                <p class="text-slate-700 text-sm font-medium ml-1">Últimos 7 movimientos registrados</p>
            </div>
        </div>

        <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Socio</th>
                            <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Membresía</th>
                            <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Monto</th>
                            <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Fecha</th>
                            <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Método</th>
                        </tr>
                    </thead>
                    <tbody id="recentPaymentsTable" class="divide-y divide-slate-100/80">
                        <!-- Carga dinámica por AJAX -->
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        $(document).ready(function () {
            cargarEstadisticas();
            cargarGraficoTendencia('Mes');
            cargarPagosRecientes();
            cargarGraficoPasesDiarios('Mes');

            $('input[name="btnTemporalidad"]').change(function() {
                cargarGraficoTendencia(this.value);
            });

            $('input[name="btnTempPases"]').change(function() {
                cargarGraficoPasesDiarios(this.value);
            });
        });

        function actualizarDashboard() {
            const icon = $('#refreshIcon');
            // Nota: Para Lucide, podemos usar una clase CSS de rotación o simplemente dejar que lucide.createIcons() haga lo suyo si cambiamos el elemento
            // Pero como es un SVG inyectado, es mejor usar clases de Tailwind para animar
            icon.addClass('animate-spin');
            
            cargarEstadisticas();
            const temporalidad = $('input[name="btnTemporalidad"]:checked').val() || 'Mes';
            cargarGraficoTendencia(temporalidad);
            cargarPagosRecientes();
            const tempPases = $('input[name="btnTempPases"]:checked').val() || 'Mes';
            cargarGraficoPasesDiarios(tempPases);

            setTimeout(() => icon.removeClass('animate-spin'), 1000);
        }

        function animateCounter(id, target) {
            $({ countNum: $(id).text() }).animate({ countNum: target }, {
                duration: 1000,
                easing: 'swing',
                step: function() {
                    $(id).text(Math.floor(this.countNum));
                },
                complete: function() {
                    $(id).text(this.countNum);
                }
            });
        }

        function cargarEstadisticas() {
            $('.stat-value').addClass('loading-shimmer text-transparent');

            $.ajax({
                url: '/Reportes/ObtenerEstadisticasUsuarios',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    $('.stat-value').removeClass('loading-shimmer text-transparent');
                    
                    animateCounter('#newUsersCount', data.nuevosMiembrosMes);
                    animateCounter('#expiredNoRenewCount', data.vencidosSinRenovar);
                    animateCounter('#frozenCount', data.membresiasCongeladas);
                    animateCounter('#expiringWeekCount', data.porVencer7Dias);
                    animateCounter('#debtUsersCount', data.usuariosConDeuda);
                    
                    let montoFormatted = new Intl.NumberFormat('es-PE', { 
                        style: 'currency', 
                        currency: 'PEN' 
                    }).format(data.montoTotalDeuda);
                    
                    $('#totalDebtAmount').text(montoFormatted);

                    // Alerta visual si hay deudores
                    if (data.usuariosConDeuda > 0) {
                        $('#debtUsersCount').addClass('text-danger');
                        $('#debtAlertText').addClass('bg-danger bg-opacity-10 rounded px-2 py-1 d-inline-block mt-1');
                    } else {
                        $('#debtUsersCount').removeClass('text-danger');
                        $('#debtAlertText').removeClass('bg-danger bg-opacity-10 rounded px-2 py-1');
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar estadísticas del dashboard:", error);
                    $('.stat-value').removeClass('loading-shimmer text-transparent').text('!');
                }
            });
        }

        let tendenciaChartInstance = null;

        function cargarGraficoTendencia(temporalidad) {
            fetch(`/Home/ObtenerDatosGrafico?temporalidad=${temporalidad}`)
                .then(response => {
                    if (!response.ok) throw new Error("Error en la respuesta del servidor");
                    return response.json();
                })
                .then(data => {
                    if (tendenciaChartInstance) {
                        tendenciaChartInstance.destroy();
                    }

                    const ctx = document.getElementById('tendenciaChart').getContext('2d');
                    tendenciaChartInstance = new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.etiquetas,
                            datasets: [
                                {
                                    label: 'Ingresos (S/)',
                                    data: data.ingresos,
                                    backgroundColor: 'rgba(25, 135, 84, 0.7)',
                                    borderColor: 'rgba(25, 135, 84, 1)',
                                    borderWidth: 1,
                                    borderRadius: 4,
                                    yAxisID: 'y'
                                },
                                {
                                    label: 'Nuevas Matrículas',
                                    data: data.matriculas,
                                    type: 'line',
                                    borderColor: '#0d6efd',
                                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                    borderWidth: 3,
                                    tension: 0.3,
                                    fill: true,
                                    pointBackgroundColor: '#0d6efd',
                                    pointRadius: 4,
                                    yAxisID: 'y1'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                mode: 'index',
                                intersect: false,
                            },
                            plugins: {
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            let label = context.dataset.label || '';
                                            if (label) {
                                                label += ': ';
                                            }
                                            if (context.dataset.yAxisID === 'y') {
                                                label += new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(context.raw);
                                            } else {
                                                label += context.raw;
                                            }
                                            return label;
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    type: 'linear',
                                    display: true,
                                    position: 'left',
                                    title: {
                                        display: true,
                                        text: 'Ingresos (S/)'
                                    },
                                    grid: {
                                        drawBorder: false
                                    }
                                },
                                y1: {
                                    type: 'linear',
                                    display: true,
                                    position: 'right',
                                    title: {
                                        display: true,
                                        text: 'Matrículas'
                                    },
                                    grid: {
                                        drawOnChartArea: false,
                                    },
                                    min: 0,
                                    ticks: {
                                        stepSize: 1
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
                })
                .catch(error => console.error("Error al cargar tendencia:", error));
        }

        // ---- Gráfico Pases Diarios por Turno ----
        let pasesDiariosChartInstance = null;

        function cargarGraficoPasesDiarios(temporalidad) {
            const canvas  = document.getElementById('pasesDiariosChart');
            const loader  = document.getElementById('pasesDiariosLoader');

            loader.style.opacity = '1';
            loader.style.pointerEvents = 'auto';

            fetch(`/Home/ObtenerGraficoPasesDiarios?temporalidad=${temporalidad}`)
                .then(response => {
                    if (!response.ok) throw new Error('Error en la respuesta del servidor');
                    return response.json();
                })
                .then(data => {
                    loader.style.opacity = '0';
                    loader.style.pointerEvents = 'none';

                    if (pasesDiariosChartInstance) {
                        pasesDiariosChartInstance.destroy();
                    }

                    // Actualizar badges resumen
                    const fmt = v => new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(v);
                    const turnoManana = data.turnoManana || [];
                    const turnoTarde  = data.turnoTarde  || [];
                    const totalManana = turnoManana.reduce((a, b) => a + b, 0);
                    const totalTarde  = turnoTarde.reduce((a, b) => a + b, 0);
                    document.getElementById('pasMañanaTotal').textContent = fmt(totalManana);
                    document.getElementById('pasTardeTotal').textContent  = fmt(totalTarde);

                    const ctx = canvas.getContext('2d');
                    pasesDiariosChartInstance = new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: data.etiquetas || [],
                            datasets: [
                                {
                                    label: 'Total Pases (S/)',
                                    data: data.totalGeneral || [],
                                    backgroundColor: 'rgba(114, 14, 158, 0.65)',
                                    borderColor: '#720e9e',
                                    borderWidth: 1,
                                    borderRadius: 4,
                                    yAxisID: 'y',
                                    order: 3
                                },
                                {
                                    label: 'Turno Mañana (S/)',
                                    data: turnoManana,
                                    type: 'line',
                                    borderColor: '#f59e0b',
                                    backgroundColor: 'rgba(245, 158, 11, 0.1)',
                                    borderWidth: 3,
                                    tension: 0.3,
                                    fill: false,
                                    pointBackgroundColor: '#f59e0b',
                                    pointRadius: 4,
                                    yAxisID: 'y',
                                    order: 1
                                },
                                {
                                    label: 'Turno Tarde (S/)',
                                    data: turnoTarde,
                                    type: 'line',
                                    borderColor: '#3b82f6',
                                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                                    borderWidth: 3,
                                    tension: 0.3,
                                    fill: false,
                                    pointBackgroundColor: '#3b82f6',
                                    pointRadius: 4,
                                    yAxisID: 'y',
                                    order: 2
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: { mode: 'index', intersect: false },
                            plugins: {
                                legend: {
                                    position: 'top',
                                    labels: { usePointStyle: true, pointStyleWidth: 10, padding: 16 }
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return ` ${context.dataset.label}: ` +
                                                new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' }).format(context.raw);
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    type: 'linear',
                                    position: 'left',
                                    title: { display: true, text: 'Monto (S/)' },
                                    grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false },
                                    ticks: {
                                        callback: v => 'S/ ' + v.toLocaleString('es-PE')
                                    }
                                },
                                x: {
                                    grid: { display: false }
                                }
                            }
                        }
                    });
                })
                .catch(error => {
                    loader.innerHTML = `<div class="text-rose-500 text-center"><i data-lucide="alert-triangle" class="w-6 h-6 mx-auto mb-2"></i>Error al cargar el gráfico</div>`;
                    lucide.createIcons();
                    console.error('Error al cargar gráfico pases diarios:', error);
                });
        }

        function cargarPagosRecientes() {
            const tbody = $('#recentPaymentsTable');
            
            // Efecto Shimmer inicial (Skeleton)
            const skeleton = Array(7).fill(`
                <tr>
                    <td class="px-6 py-4"><div class="loading-shimmer h-4 rounded-lg w-3/4"></div></td>
                    <td class="px-6 py-4"><div class="loading-shimmer h-4 rounded-lg w-1/2"></div></td>
                    <td class="px-6 py-4"><div class="loading-shimmer h-4 rounded-lg w-1/4"></div></td>
                    <td class="px-6 py-4"><div class="loading-shimmer h-4 rounded-lg w-1/2"></div></td>
                    <td class="px-6 py-4"><div class="loading-shimmer h-4 rounded-lg w-1/4 ml-auto"></div></td>
                </tr>
            `).join('');
            
            tbody.html(skeleton);

            $.ajax({
                url: '/Reportes/ObtenerPagosRecientes',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    tbody.empty();
                    
                    if (!data || data.length === 0) {
                        tbody.append('<tr><td colspan="5" class="px-6 py-12 text-center text-slate-600 font-medium italic">No se encontraron pagos recientes</td></tr>');
                        return;
                    }

                    const currencyFormat = new Intl.NumberFormat('es-PE', { style: 'currency', currency: 'PEN' });
                    const today = new Date().toLocaleDateString();

                    data.forEach((pago, index) => {
                        const fecha = new Date(pago.fechaPago);
                        const esHoy = fecha.toLocaleDateString() === today;
                        const badgeHoy = esHoy ? '<span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold bg-emerald-100 text-emerald-700 ml-2 animate-pulse uppercase tracking-wider">Hoy</span>' : '';
                        
                        const row = `
                            <tr class="hover:bg-slate-50/80 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-xs border border-indigo-100/50">
                                            ${pago.nombreCliente.charAt(0).toUpperCase()}
                                        </div>
                                        <div class="text-sm font-semibold text-slate-950 truncate max-w-[150px]">${pago.nombreCliente}</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-bold bg-slate-100 text-slate-600 border border-slate-200/50">
                                        ${pago.nombrePlan}
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm font-bold text-emerald-600 font-mono tracking-tight">${currencyFormat.format(pago.monto)}</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2 text-slate-700 text-xs font-medium">
                                        <i data-lucide="calendar" class="w-4 h-4 text-slate-600"></i>
                                        ${fecha.toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' })}
                                        ${badgeHoy}
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider ${pago.metodoPago === 'Efectivo' ? 'bg-slate-100 text-slate-600' : 'bg-indigo-50 text-indigo-600'} border border-current opacity-70">
                                        <i data-lucide="${pago.metodoPago === 'Efectivo' ? 'banknote' : 'smartphone'}" class="w-3.5 h-3.5"></i>
                                        ${pago.metodoPago}
                                    </span>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                    
                    // Re-inicializar iconos para el contenido dinámico
                    lucide.createIcons();
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar pagos recientes:", error);
                    tbody.html('<tr><td colspan="5" class="px-6 py-12 text-center text-rose-500 font-medium"><i data-lucide="alert-triangle" class="w-6 h-6 mx-auto mb-2"></i>Error al conectar con el servidor</td></tr>');
                    lucide.createIcons();
                }
            });
        }
    </script>
}
}
else
{
    <div class="min-h-[80vh] flex items-center justify-center p-6 md:p-12">
        <div class="max-w-2xl w-full bg-white rounded-[2.5rem] border border-slate-200 shadow-xl shadow-slate-200/50 p-8 md:p-12 text-center relative overflow-hidden group">
            <div class="absolute -top-12 -right-12 w-48 h-48 bg-indigo-50 rounded-full opacity-50 group-hover:scale-110 transition-transform duration-700"></div>
            <div class="absolute -bottom-12 -left-12 w-32 h-32 bg-emerald-50 rounded-full opacity-50 group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="relative">
                <div class="w-24 h-24 bg-indigo-600 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-2xl shadow-indigo-500/30 rotate-3 group-hover:-rotate-3 transition-transform duration-500">
                    <i data-lucide="activity" class="text-white w-12 h-12"></i>
                </div>
                <h1 class="text-4xl md:text-5xl font-display font-extrabold text-slate-900 tracking-tight mb-4">Bienvenido a GymApp</h1>
                <p class="text-slate-700 text-lg md:text-xl font-medium mb-8 max-w-lg mx-auto leading-relaxed">Tu plataforma integral para la gestión deportiva y administrativa.</p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <div class="flex items-center gap-2 text-slate-600 font-bold uppercase tracking-widest text-xs">
                        <i data-lucide="arrow-left" class="w-5 h-5"></i>
                        Selecciona una opción del menú
                    </div>
                </div>
            </div>
        </div>
    </div>
}
