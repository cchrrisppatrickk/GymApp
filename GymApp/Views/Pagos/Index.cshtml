@model GymApp.ViewModels.PagedResult<GymApp.ViewModels.PagoListDTO>
@{
    ViewData["Title"] = "Caja y Pagos";
    var buscar = ViewBag.Buscar as string;
    var mes = ViewBag.Mes as int?;
    var anio = ViewBag.Anio as int?;
}

<div class="container-fluid px-4 fade-in">
    <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h2 class="mb-0 text-dark fw-bold"><i class="bi bi-wallet2 text-success me-2"></i>Caja y Tesorería</h2>
            <p class="text-muted small mb-0">Control de ingresos y emisión de comprobantes.</p>
        </div>
        <div class="d-flex gap-2">
@* 
            <button class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-printer me-1"></i> Cierre de Caja
            </button> 
            *@
            <button class="btn btn-success shadow-sm" onclick="abrirModalPago()">
                <i class="bi bi-plus-lg me-1"></i> Registrar Ingreso
            </button>
        </div>
    </div>
    
    <form method="get" asp-action="Index" class="mb-4">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text" name="buscar" class="form-control" placeholder="Buscar por Cliente o DNI..." value="@buscar">
            </div>
            <div class="col-md-3">
                <select name="mes" class="form-select">
                    <option value="">Mes Actual (Por Defecto)</option>
                    @for(int i = 1; i <= 12; i++)
                    {
                        if (mes == i) {
                            <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                        } else {
                            <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="anio" class="form-select">
                    <option value="">Año Actual (Por Defecto)</option>
                    @for(int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                    {
                        if (anio == i) {
                            <option value="@i" selected>@i</option>
                        } else {
                            <option value="@i">@i</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i> Filtrar</button>
            </div>
        </div>
    </form>

    @* 
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-body position-relative">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="text-uppercase text-muted small fw-bold mb-0">Ingresos Totales</h6>
                        <span class="badge bg-success bg-opacity-10 text-success"><i class="bi bi-graph-up-arrow"></i> Hoy</span>
                    </div>
                    <h3 class="fw-bold text-dark mb-0" id="kpiIngresos">$ 0.00</h3>
                    <div class="position-absolute top-0 end-0 opacity-10 p-3">
                        <i class="bi bi-currency-dollar fs-1 text-success"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="text-uppercase text-muted small fw-bold mb-0">Transacciones</h6>
                    </div>
                    <h3 class="fw-bold text-dark mb-0" id="kpiTransacciones">0</h3>
                    <p class="small text-muted mb-0">Operaciones registradas</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 bg-primary bg-gradient text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="text-uppercase text-white-50 small fw-bold mb-0">Último Cobro</h6>
                    </div>
                    <h5 class="fw-bold mb-0" id="kpiUltimoCliente">--</h5>
                    <small class="text-white-50" id="kpiUltimoMonto">--</small>
                </div>
            </div>
        </div>
    </div>
    *@

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaPagos">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Fecha / Hora</th>
                            <th>Cliente</th>
                            <th>Concepto</th>
                            <th>Método</th>
                            <th>Atendido Por</th>
                            <th class="text-end">Monto</th>
                            <th class="text-center">Recibo</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (!Model.Items.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="bi bi-receipt text-muted" style="font-size: 3rem;"></i>
                                    <p class="text-muted mt-2">No se encontraron movimientos con este filtro.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var p in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4">
                                        @{
                                            var partes = p.FechaPago.Split(' ');
                                            var fecha = partes.Length > 0 ? partes[0] : p.FechaPago;
                                            var hora = partes.Length > 1 ? partes[1] : "";
                                        }
                                        <div class="fw-bold text-dark">@fecha</div>
                                        <small class="text-muted">@hora</small>
                                    </td>
                                    <td><span class="fw-bold">@p.NombreCliente</span></td>
                                    <td><span class="text-muted">@p.NombrePlan</span></td>
                                    <td>
                                        @if(p.MetodoPago == "Efectivo") { <span class="badge bg-success bg-opacity-75"><i class="bi bi-cash me-1"></i>Efectivo</span> }
                                        else if(p.MetodoPago == "Tarjeta") { <span class="badge bg-primary bg-opacity-75"><i class="bi bi-credit-card me-1"></i>Tarjeta</span> }
                                        else if(p.MetodoPago.Contains("Yape") || p.MetodoPago.Contains("Plin")) { <span class="badge" style="background-color: #720e9e; color:white;"><i class="bi bi-qr-code me-1"></i>@p.MetodoPago</span> }
                                        else { <span class="badge bg-secondary">@p.MetodoPago</span> }
                                    </td>
                                    <td><small>@p.NombreEmpleado</small></td>
                                    <td class="text-end"><span class="fw-bold text-dark h6">$ @p.Monto.ToString("F2")</span></td>
                                    <td class="text-center">
                                        <a href="/Pagos/Comprobante/@p.PagoId" target="_blank" class="btn btn-sm btn-light border"><i class="bi bi-printer"></i></a>
                                        @if (!p.EsAnulado)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary ms-1" onclick="abrirModalEditarPago(@p.PagoId)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Navegacion de pagos" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.CurrentPage - 1)" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio">
                        <i class="bi bi-chevron-left"></i> Anterior
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(Model.CurrentPage + 1)" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio">
                        Siguiente <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<div class="modal fade" id="modalPago" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-cash-coin me-2"></i>Registrar Cobro</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary text-uppercase small">Buscar Cliente</label>
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" id="txtDniBuscar" placeholder="Buscar por DNI o Nombre del Socio..." autocomplete="off">
                        <button class="btn btn-outline-secondary" type="button" onclick="buscarDeuda()" id="btnBuscar">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                    <div id="resultados-busqueda" class="list-group mt-2 shadow-sm" style="display:none; max-height: 250px; overflow-y: auto;"></div>
                    <div class="form-text">Presiona la lupa o Enter para buscar deudas pendientes.</div>
                </div>

                <div id="infoMembresia" class="card bg-light border-0 shadow-sm mb-3 d-none">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-0 text-dark" id="lblCliente">Cliente</h5>
                                <small class="text-muted" id="lblPlan">Plan</small>
                            </div>
                            <span class="badge" id="lblEstadoBadge">Estado</span>
                        </div>

                        <div class="mb-2">
                            <div class="d-flex justify-content-between text-muted small mb-1">
                                <span>Progreso de Pago</span>
                                <span id="lblPorcentaje">0%</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" role="progressbar" id="progressBarPago" style="width: 0%"></div>
                            </div>
                        </div>

                        <div class="row text-center mt-3 g-0 border rounded bg-white">
                            <div class="col border-end p-2">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">TOTAL PLAN</small>
                                <span class="fw-bold text-dark" id="lblPrecioTotal">$0.00</span>
                            </div>
                            <div class="col border-end p-2">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">PAGADO</small>
                                <span class="fw-bold text-success" id="lblTotalPagado">$0.00</span>
                            </div>
                            <div class="col p-2 bg-danger bg-opacity-10">
                                <small class="text-danger fw-bold d-block" style="font-size: 0.75rem;">DEUDA</small>
                                <span class="fw-bold text-danger" id="lblDeudaPendiente">$0.00</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="formPagoDetalle" class="d-none animate-fade-in">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Monto a Cobrar</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white text-success border-end-0">$</span>
                            <input type="number" class="form-control border-start-0 ps-0 fw-bold text-success"
                                   id="txtMonto" step="0.01" placeholder="0.00">
                        </div>
                        <div class="form-text text-danger d-none" id="errorMontoExcedido">El monto no puede superar la deuda pendiente.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Método de Pago</label>
                        <div class="row g-2">
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="metodoPago" id="metodo1" value="Efectivo" checked>
                                <label class="btn btn-outline-success w-100 py-3" for="metodo1">
                                    <i class="bi bi-cash d-block fs-4"></i><small>Efectivo</small>
                                </label>
                            </div>
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="metodoPago" id="metodo2" value="Yape/Plin">
                                <label class="btn btn-outline-primary w-100 py-3" for="metodo2">
                                    <i class="bi bi-phone d-block fs-4"></i><small>Yape/Plin</small>
                                </label>
                            </div>
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="metodoPago" id="metodo3" value="Tarjeta">
                                <label class="btn btn-outline-dark w-100 py-3" for="metodo3">
                                    <i class="bi bi-credit-card d-block fs-4"></i><small>Tarjeta</small>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="FechaPago" class="form-label fw-bold">Fecha de Pago (Opcional)</label>
                        <input type="datetime-local" id="txtFechaPago" name="FechaPago" class="form-control" />
                        <div class="form-text text-muted">Déjalo en blanco para registrar con la fecha y hora actual. Ideal para data antigua.</div>
                    </div>
                </div>

            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success px-4" id="btnCobrar" onclick="procesarPago()" disabled>
                    <i class="bi bi-check-lg me-2"></i>Confirmar Pago
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal para Editar Pago -->
<div class="modal fade" id="modalEditarPago" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Editar Pago</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="formEditarPago">
                    <input type="hidden" id="editPagoId" name="Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Monto</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control fw-bold text-primary" id="editMonto" name="Monto" step="0.01" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Método de Pago</label>
                        <select class="form-select" id="editMetodoPago" name="MetodoPago" required>
                            <option value="Efectivo">Efectivo</option>
                            <option value="Yape/Plin">Yape/Plin</option>
                            <option value="Tarjeta">Tarjeta</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Observaciones</label>
                        <textarea class="form-control" id="editObservaciones" name="Observaciones" rows="3" placeholder="Motivo de la edición..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" id="btnGuardarEdicion" onclick="guardarEdicionPago()">
                    <i class="bi bi-save me-2"></i>Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let deudaActual = 0; // Variable global para validación

        document.addEventListener("DOMContentLoaded", () => {
            // document.getElementById('filtroFecha').valueAsDate = new Date();
            // cargarHistorial();
        });

        // Eventos
        document.getElementById("txtDniBuscar").addEventListener("keyup", function(event) {
            if (event.key === "Enter") buscarDeuda();
        });

        // Validación visual de monto excedido
        document.getElementById("txtMonto").addEventListener("input", function() {
            const valor = parseFloat(this.value);
            const errorMsg = document.getElementById("errorMontoExcedido");
            const btn = document.getElementById("btnCobrar");

            if(valor > deudaActual) {
                errorMsg.classList.remove("d-none");
                this.classList.add("is-invalid");
                btn.disabled = true;
            } else {
                errorMsg.classList.add("d-none");
                this.classList.remove("is-invalid");
                btn.disabled = false;
            }
        });



        // ============================================
        // LÓGICA DE BÚSQUEDA DE DEUDA (ACTUALIZADA)
        // ============================================
        let membresiaSeleccionada = 0;

        function buscarDeuda() {
            const termino = document.getElementById("txtDniBuscar").value;
            if(!termino) {
                Swal.fire('Atención', 'Ingresa un término para buscar', 'warning');
                return;
            }

            const btn = document.getElementById("btnBuscar");
            const iconOriginal = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btn.disabled = true;

            fetch(`/Pagos/BuscarDeuda?termino=${termino}`)
                .then(res => res.json())
                .then(json => {
                    btn.innerHTML = iconOriginal;
                    btn.disabled = false;

                    const contenedorResultados = document.getElementById("resultados-busqueda");
                    contenedorResultados.innerHTML = "";
                    
                    document.getElementById("infoMembresia").classList.add("d-none");
                    document.getElementById("formPagoDetalle").classList.add("d-none");

                    if (json.success && json.data.length > 0) {
                        contenedorResultados.style.display = "block";
                        json.data.forEach(item => {
                            const dniDisplay = item.dniCliente ? item.dniCliente : "<span class='text-muted fst-italic'>Sin DNI</span>";
                            const link = document.createElement("a");
                            link.href = "#";
                            link.className = "list-group-item list-group-item-action item-resultado";
                            link.dataset.id = item.membresiaId;
                            
                            // Guardamos toda la data para usarla al hacer click
                            link.dataset.completo = JSON.stringify(item);

                            link.innerHTML = `<strong>${item.nombreCliente}</strong> (DNI: ${dniDisplay}) - Plan: ${item.nombrePlan} - Deuda: <span class="text-danger fw-bold">$${item.deudaPendiente.toFixed(2)}</span>`;
                            
                            link.addEventListener("click", function (e) {
                                e.preventDefault();
                                seleccionarCliente(JSON.parse(this.dataset.completo));
                            });
                            contenedorResultados.appendChild(link);
                        });
                    } else {
                        contenedorResultados.style.display = "none";
                        Swal.fire({ icon: 'info', title: 'Sin resultados', text: 'No se encontraron deudas para ese término.' });
                        limpiarModal(false);
                    }
                })
                .catch(err => {
                    console.error(err);
                    btn.innerHTML = iconOriginal;
                    btn.disabled = false;
                    Swal.fire('Error', 'No se pudo consultar la deuda', 'error');
                });
        }

        function seleccionarCliente(data) {
            document.getElementById("resultados-busqueda").style.display = "none";
            membresiaSeleccionada = data.membresiaId;
            deudaActual = data.deudaPendiente;

            // 1. Llenar Datos Básicos
            document.getElementById("lblCliente").innerText = data.nombreCliente;
            document.getElementById("lblPlan").innerText = data.nombrePlan;

            // 2. Configurar Badge de Estado
            const lblBadge = document.getElementById("lblEstadoBadge");
            lblBadge.innerText = data.estado;
            if(data.estado === 'Activa') {
                lblBadge.className = 'badge bg-success';
            } else if(data.estado === 'Pendiente Pago') {
                lblBadge.className = 'badge bg-warning text-dark';
            } else {
                lblBadge.className = 'badge bg-danger';
            }

            // 3. Llenar Datos Financieros
            const total = data.precioTotal || 0;
            const pagado = data.totalPagado || 0;
            const deuda = data.deudaPendiente || 0;

            document.getElementById("lblPrecioTotal").innerText = "$ " + total.toFixed(2);
            document.getElementById("lblTotalPagado").innerText = "$ " + pagado.toFixed(2);
            document.getElementById("lblDeudaPendiente").innerText = "$ " + deuda.toFixed(2);

            // 4. Barra de Progreso
            let porcentaje = 0;
            if(total > 0) porcentaje = (pagado / total) * 100;
            document.getElementById("progressBarPago").style.width = porcentaje + "%";
            document.getElementById("lblPorcentaje").innerText = Math.round(porcentaje) + "% pagado";

            // 5. Configurar Input de Monto (Autofill)
            const inputMonto = document.getElementById("txtMonto");
            if(deuda > 0) {
                inputMonto.value = deuda.toFixed(2); 
                inputMonto.max = deuda.toFixed(2); 
                inputMonto.disabled = false;
                document.getElementById("btnCobrar").disabled = false;

                document.getElementById("infoMembresia").classList.remove("d-none");
                document.getElementById("formPagoDetalle").classList.remove("d-none");
                inputMonto.focus();
            } else {
                Swal.fire('¡Al día!', `El cliente ${data.nombreCliente} no tiene deuda pendiente.`, 'success');
                limpiarModal(false);
            }
        }

        function procesarPago() {
            const metodoSeleccionado = document.querySelector('input[name="metodoPago"]:checked').value;
            const monto = parseFloat(document.getElementById("txtMonto").value);
            const fechaPago = document.getElementById("txtFechaPago").value;

            // Validaciones Cliente-Side
            if(isNaN(monto) || monto <= 0) {
                Swal.fire('Error', 'El monto debe ser válido y mayor a 0', 'error');
                return;
            }
            if(monto > deudaActual) {
                 Swal.fire('Error', `El monto ($${monto}) supera la deuda pendiente ($${deudaActual})`, 'error');
                 return;
            }

            const data = {
                MembresiaId: membresiaSeleccionada,
                Monto: monto,
                MetodoPago: metodoSeleccionado,
                FechaPago: fechaPago ? fechaPago : null
            };

            Swal.fire({
                title: '¿Confirmar cobro?',
                html: `Monto: <b class="text-success fs-4">$${monto.toFixed(2)}</b><br>Método: ${metodoSeleccionado}${fechaPago ? `<br>Fecha: ${fechaPago}` : ''}`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                confirmButtonText: 'Sí, cobrar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Bloquear botón para evitar doble click
                    document.getElementById("btnCobrar").disabled = true;

                    fetch('/Pagos/Registrar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                             const modal = bootstrap.Modal.getInstance(document.getElementById('modalPago'));
                             modal.hide();
                             window.location.reload(); // Recargar para ver el nuevo pago con los filtros actuales

                            Swal.fire({
                                title: '¡Cobro Exitoso!',
                                text: 'El pago se registró y el estado de la membresía se actualizó si corresponde.',
                                icon: 'success',
                                showCancelButton: true,
                                confirmButtonText: 'Imprimir Ticket',
                                cancelButtonText: 'Cerrar'
                            }).then((printResult) => {
                                if (printResult.isConfirmed) {
                                    window.open(`/Pagos/Comprobante/${json.pagoId}`, '_blank');
                                }
                            });
                        } else {
                            document.getElementById("btnCobrar").disabled = false;
                            Swal.fire('Error', json.message, 'error');
                        }
                    })
                    .catch(() => {
                        document.getElementById("btnCobrar").disabled = false;
                    });
                }
            });
        }

        function abrirModalPago() {
            limpiarModal(true);
            new bootstrap.Modal(document.getElementById('modalPago')).show();
            setTimeout(() => document.getElementById("txtDniBuscar").focus(), 500);
        }

        function limpiarModal(fullClear) {
            if(fullClear) document.getElementById("txtDniBuscar").value = "";
            document.getElementById("txtMonto").value = "";
            document.getElementById("txtMonto").classList.remove("is-invalid");
            document.getElementById("errorMontoExcedido").classList.add("d-none");

            document.getElementById("infoMembresia").classList.add("d-none");
            document.getElementById("formPagoDetalle").classList.add("d-none");
            document.getElementById("btnCobrar").disabled = true;
            document.getElementById("resultados-busqueda").style.display = "none";
            membresiaSeleccionada = 0;
            deudaActual = 0;
        }

        // --- LÓGICA DE EDICIÓN DE PAGO ---
        let modalEditar = null;

        function abrirModalEditarPago(id) {
            fetch(`/Pagos/ObtenerParaEdicion/${id}`)
                .then(res => {
                    if (!res.ok) throw new Error('No se pudo cargar la información del pago o está anulado.');
                    return res.json();
                })
                .then(data => {
                    document.getElementById('editPagoId').value = data.id;
                    document.getElementById('editMonto').value = data.monto;
                    
                    // Manejar selectores que pueden tener variaciones como "Yape/Plin" vs "Yape"
                    let selectMetodo = document.getElementById('editMetodoPago');
                    let metodoValue = data.metodoPago;
                    if(metodoValue && (metodoValue.includes('Yape') || metodoValue.includes('Plin'))) {
                        metodoValue = 'Yape/Plin';
                    }
                    selectMetodo.value = metodoValue;
                    
                    document.getElementById('editObservaciones').value = data.observaciones || '';

                    if (!modalEditar) {
                        modalEditar = new bootstrap.Modal(document.getElementById('modalEditarPago'));
                    }
                    modalEditar.show();
                })
                .catch(err => {
                    Swal.fire('Error', err.message, 'error');
                });
        }

        function guardarEdicionPago() {
            const id = document.getElementById('editPagoId').value;
            const monto = document.getElementById('editMonto').value;
            const metodoPago = document.getElementById('editMetodoPago').value;
            const observaciones = document.getElementById('editObservaciones').value;

            if(!monto || monto <= 0) {
                Swal.fire('Error', 'El monto debe ser válido y mayor a 0', 'error');
                return;
            }

            const data = {
                Id: parseInt(id),
                Monto: parseFloat(monto),
                MetodoPago: metodoPago,
                Observaciones: observaciones
            };

            const btn = document.getElementById('btnGuardarEdicion');
            btn.disabled = true;

            fetch('/Pagos/Editar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(async res => {
                const json = await res.json();
                if (res.ok && json.success) {
                    modalEditar.hide();
                    Swal.fire('¡Éxito!', json.message, 'success').then(() => {
                        window.location.reload(); // Recargar para actualizar la tabla con SSR
                    });
                } else {
                    Swal.fire('Error', json.message || 'Error al editar el pago', 'error');
                }
            })
            .catch(err => {
                console.error(err);
                Swal.fire('Error', 'Error de conexión', 'error');
            })
            .finally(() => {
                btn.disabled = false;
            });
        }
    </script>
}