@model GymApp.ViewModels.PagedResult<GymApp.ViewModels.PagoListDTO>
@using GymApp.Constants
@{
    ViewData["Title"] = "Caja y Pagos";
    var buscar = ViewBag.Buscar as string;
    var mes = ViewBag.Mes as int?;
    var anio = ViewBag.Anio as int?;
}

<div class="space-y-8 mt-4">
    <!-- Encabezado -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-2">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100/50 shadow-sm">
                    <i data-lucide="wallet" class="w-6 h-6"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Caja y Tesorería</h2>
            </div>
            <p class="text-slate-700 text-sm font-medium ml-1">Control de ingresos, cobros de membresías y reportes diarios</p>
        </div>
        
        @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PagosCrear) || User.IsInRole(AppRoles.Admin))
        {
            <button class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-md shadow-indigo-600/20 font-medium active:scale-95 group" onclick="abrirModalPago()">
                <i data-lucide="banknote" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                <span>Registrar Ingreso</span>
            </button>
        }
    </div>

    <!-- Filtros -->
    <form method="get" asp-action="Index" class="bg-white rounded-[2rem] border border-slate-200 p-2 shadow-sm">
        <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-2">
            <!-- Búsqueda por Texto -->
            <div class="flex-1 relative group">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-600 group-focus-within:text-indigo-500 transition-colors">
                    <i data-lucide="search" class="w-5 h-5"></i>
                </div>
                <input type="text" name="buscar" class="w-full bg-slate-50 border-transparent focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl pl-11 pr-4 py-2.5 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-600" placeholder="Buscar por socio o DNI..." value="@buscar">
            </div>

            <div class="grid grid-cols-2 md:grid-cols-2 lg:flex gap-2">
                <!-- Mes -->
                <div class="relative min-w-[200px]">
                    <select name="mes" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl px-4 py-2.5 text-sm font-bold text-slate-700 appearance-none cursor-pointer transition-all">
                        <option value="">Mes Actual (Default)</option>
                        @for(int i = 1; i <= 12; i++)
                        {
                            if (mes == i) {
                                <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            } else {
                                <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i).ToUpper()</option>
                            }
                        }
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600 text-xs">
                        <i class="bi bi-chevron-down"></i>
                    </div>
                </div>

                <!-- Año -->
                <div class="relative min-w-[160px]">
                    <select name="anio" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 rounded-2xl px-4 py-2.5 text-sm font-bold text-slate-700 appearance-none cursor-pointer transition-all">
                        <option value="">Año Actual (Default)</option>
                        @for(int i = DateTime.Now.Year - 2; i <= DateTime.Now.Year; i++)
                        {
                            if (anio == i) {
                                <option value="@i" selected>@i</option>
                            } else {
                                <option value="@i">@i</option>
                            }
                        }
                    </select>
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-600 text-xs">
                        <i class="bi bi-chevron-down"></i>
                    </div>
                </div>

                <button type="submit" class="flex-1 lg:flex-none inline-flex items-center justify-center w-full lg:w-11 h-11 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-300 shadow-sm shadow-indigo-600/10 active:scale-95" title="Aplicar filtros">
                    <i data-lucide="filter" class="w-5 h-5"></i>
                    <span class="lg:hidden ml-2 font-bold uppercase tracking-widest text-xs">Filtrar</span>
                </button>
            </div>
        </div>
    </form>

    <!-- Tabla -->
    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden mt-6">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse" id="tablaPagos">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Fecha / Hora</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Socio / Cliente</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Concepto</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Método</th>
                        <th class="px-6 py-4 text-left text-[10px] font-bold text-slate-600 uppercase tracking-widest">Atendido Por</th>
                        <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Monto</th>
                        <th class="px-6 py-4 text-right text-[10px] font-bold text-slate-600 uppercase tracking-widest">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100/80">
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-20 text-center">
                                <div class="max-w-xs mx-auto">
                                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-slate-100">
                                            <i data-lucide="receipt" class="text-slate-300 w-8 h-8"></i>
                                    </div>
                                    <h3 class="text-sm font-bold text-slate-950 uppercase tracking-widest mb-2">Sin Movimientos</h3>
                                    <p class="text-xs text-slate-700 leading-relaxed font-medium">No se encontraron pagos que coincidan con los criterios.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var p in Model.Items)
                        {
                            <tr class="group hover:bg-slate-50/50 transition-colors @(p.EsAnulado ? "opacity-50 grayscale" : "")">
                                <td class="px-6 py-4">
                                    @{
                                        var partes = p.FechaPago.Split(' ');
                                        var fecha = partes.Length > 0 ? partes[0] : p.FechaPago;
                                        var hora = partes.Length > 1 ? partes[1] : "";
                                    }
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-slate-950">@fecha</span>
                                        <span class="text-[10px] font-bold text-slate-700 uppercase">@hora</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-xs border border-emerald-100/50 group-hover:scale-110 transition-transform">
                                            @p.NombreCliente.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="text-sm font-bold text-slate-950 tracking-tight">@p.NombreCliente</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xs font-medium text-slate-700">@p.NombrePlan</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider @(p.MetodoPago == "Efectivo" ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : p.MetodoPago == "Tarjeta" ? "bg-indigo-50 text-indigo-700 border border-indigo-100" : "bg-purple-50 text-purple-700 border border-purple-100")">
                                        @if(p.MetodoPago == "Efectivo") { <i data-lucide="banknote" class="w-3.5 h-3.5"></i> }
                                        else if(p.MetodoPago == "Tarjeta") { <i data-lucide="credit-card" class="w-3.5 h-3.5"></i> }
                                        else { <i data-lucide="smartphone" class="w-3.5 h-3.5"></i> }
                                        @p.MetodoPago
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xs font-medium text-slate-700 italic">@p.NombreEmpleado</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="text-sm font-bold font-mono tracking-tight @(p.EsAnulado ? "text-slate-600 line-through" : "text-slate-950")">S/ @p.Monto.ToString("F2")</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Pagos/Detalles?id=@p.PagoId" class="w-9 h-9 flex items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all duration-300 shadow-sm shadow-indigo-100/50" title="Ver Detalles">
                                            <i data-lucide="eye" class="w-4 h-4"></i>
                                        </a>
                                        @if (!p.EsAnulado)
                                        {
                                            @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PagosEditar) || User.IsInRole(AppRoles.Admin))
                                            {
                                                <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white transition-all duration-300 shadow-sm shadow-amber-100/50" onclick="abrirModalEditarPago(@p.PagoId)" title="Editar">
                                                    <i data-lucide="pencil" class="w-4 h-4"></i>
                                                </button>
                                            }
                                            @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PagosAnular) || User.IsInRole(AppRoles.Admin))
                                            {
                                                <button type="button" class="w-9 h-9 flex items-center justify-center rounded-xl bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all duration-300 shadow-sm shadow-rose-100/50" onclick="anularPago(@p.PagoId)" title="Anular">
                                                    <i data-lucide="x-circle" class="w-4 h-4"></i>
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-[9px] font-black text-rose-500 uppercase tracking-widest px-2">Anulado</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-8 pb-12">
            @if (Model.HasPreviousPage)
            {
                <a class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-white border border-slate-200 text-slate-700 rounded-xl hover:bg-slate-50 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage - 1)" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    <span class="hidden sm:inline">Anterior</span>
                </a>
            }
            else
            {
                <div class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-slate-50 border border-slate-100 text-slate-500 rounded-xl cursor-not-allowed font-medium text-sm">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    <span class="hidden sm:inline">Anterior</span>
                </div>
            }

            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <div class="w-10 h-10 flex items-center justify-center bg-indigo-600 text-white rounded-xl font-bold text-sm shadow-sm shadow-indigo-600/20">@i</div>
                    }
                    else if (i <= 3 || i > Model.TotalPages - 3 || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                    {
                        <a class="w-10 h-10 flex items-center justify-center bg-white border border-slate-200 text-slate-700 rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio">@i</a>
                    }
                    else if (i == 4 && Model.CurrentPage > 5)
                    {
                        <div class="w-10 h-10 flex items-center justify-center text-slate-700">...</div>
                    }
                    else if (i == Model.TotalPages - 3 && Model.CurrentPage < Model.TotalPages - 4)
                    {
                        <div class="w-10 h-10 flex items-center justify-center text-slate-700">...</div>
                    }
                }
            </div>

            @if (Model.HasNextPage)
            {
                <a class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-white border border-slate-200 text-slate-700 rounded-xl hover:bg-slate-50 transition-all font-medium text-sm active:scale-95" asp-action="Index" asp-route-pagina="@(Model.CurrentPage + 1)" asp-route-buscar="@buscar" asp-route-mes="@mes" asp-route-anio="@anio">
                    <span class="hidden sm:inline">Siguiente</span>
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
            }
            else
            {
                <div class="inline-flex items-center justify-center gap-2 px-4 h-10 bg-slate-50 border border-slate-100 text-slate-500 rounded-xl cursor-not-allowed font-medium text-sm">
                    <span class="hidden sm:inline">Siguiente</span>
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </div>
            }
        </div>
    }
</div>

<!-- ========================= -->
<!-- MODAL DE COBRO -->
<!-- ========================= -->
<div class="modal fade" id="modalPago" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100/50 shadow-sm">
                        <i data-lucide="banknote" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight m-0">Registrar Cobro</h5>
                        <p class="text-slate-700 text-[10px] font-bold uppercase tracking-widest mt-1">Ingreso a caja por membresía</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-700 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="modal-body p-8 space-y-8">
                <!-- Búsqueda -->
                <div class="space-y-3 relative">
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest ml-1">1. Buscar Deuda del Socio</label>
                    <div class="relative group">
                        <input type="text" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-2xl pl-5 pr-14 py-4 text-sm font-bold text-slate-950 transition-all placeholder:text-slate-600" id="txtDniBuscar" placeholder="DNI o Nombre del Socio..." autocomplete="off">
                        <button class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-xl bg-indigo-600 text-white shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-95" type="button" onclick="buscarDeuda()" id="btnBuscar">
                            <i data-lucide="search" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <div id="resultados-busqueda" class="absolute left-0 right-0 mt-2 bg-white border border-slate-200 rounded-2xl shadow-2xl z-50 divide-y divide-slate-100 overflow-hidden" style="display:none; max-height: 250px; overflow-y: auto;"></div>
                </div>

                <!-- Info de Membresía -->
                <div id="infoMembresia" class="bg-slate-50 rounded-3xl border border-slate-100 p-6 space-y-6 d-none animate-fade-in">
                    <div class="flex justify-between items-start">
                        <div>
                            <h5 class="text-base font-bold text-slate-950 m-0" id="lblCliente">Cliente</h5>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-lg bg-indigo-100 text-indigo-700 text-[10px] font-black uppercase tracking-widest mt-1" id="lblPlan">Plan</span>
                        </div>
                        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider border border-current" id="lblEstadoBadge">Estado</span>
                    </div>

                    <div class="space-y-2">
                        <div class="flex justify-between items-center text-[10px] font-black uppercase tracking-[0.2em]">
                            <span class="text-slate-700">Progreso de Pago</span>
                            <span class="text-emerald-600" id="lblPorcentaje">0%</span>
                        </div>
                        <div class="w-full h-2.5 bg-slate-200 rounded-full overflow-hidden shadow-inner">
                            <div class="h-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)] transition-all duration-1000" role="progressbar" id="progressBarPago" style="width: 0%"></div>
                        </div>
                    </div>

                    <div class="grid grid-cols-3 gap-1 bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
                        <div class="p-3 text-center border-r border-slate-100">
                            <small class="block text-[8px] font-black text-slate-700 uppercase tracking-widest mb-1">TOTAL</small>
                            <span class="text-xs font-bold text-slate-950 font-mono" id="lblPrecioTotal">$0.00</span>
                        </div>
                        <div class="p-3 text-center border-r border-slate-100 bg-emerald-50/20">
                            <small class="block text-[8px] font-black text-emerald-600 uppercase tracking-widest mb-1">PAGADO</small>
                            <span class="text-xs font-bold text-emerald-700 font-mono" id="lblTotalPagado">$0.00</span>
                        </div>
                        <div class="p-3 text-center bg-rose-50/20">
                            <small class="block text-[8px] font-black text-rose-600 uppercase tracking-widest mb-1">DEUDA</small>
                            <span class="text-xs font-bold text-rose-600 font-mono" id="lblDeudaPendiente">$0.00</span>
                        </div>
                    </div>
                </div>

                <!-- Formulario de Pago -->
                <div id="formPagoDetalle" class="space-y-8 d-none animate-fade-in">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-3 ml-1">2. Monto a Cobrar (S/.)</label>
                        <div class="relative group">
                            <div class="absolute left-5 top-1/2 -translate-y-1/2 text-emerald-500 font-black text-xl">S/</div>
                            <input type="number" class="w-full bg-emerald-50/30 border border-emerald-100 focus:bg-white focus:ring-4 focus:ring-emerald-500/10 focus:border-emerald-500 rounded-2xl pl-14 pr-4 py-5 text-2xl font-display font-black text-emerald-700 transition-all placeholder:text-emerald-100" id="txtMonto" step="0.01" placeholder="0.00">
                        </div>
                        <div class="mt-2 text-rose-600 text-[10px] font-bold uppercase tracking-wide d-none" id="errorMontoExcedido">
                            <i class="bi bi-exclamation-octagon mr-1"></i> El monto excede la deuda pendiente
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-4 ml-1">3. Método de Pago</label>
                        <div class="grid grid-cols-3 gap-3">
                            <label class="relative cursor-pointer">
                                <input type="radio" name="metodoPago" id="metodo1" value="Efectivo" class="peer sr-only" checked>
                                <div class="flex flex-col items-center gap-2 p-4 rounded-2xl border border-slate-200 bg-slate-50 peer-checked:bg-emerald-50 peer-checked:border-emerald-500 peer-checked:ring-1 peer-checked:ring-emerald-500 text-slate-600 peer-checked:text-emerald-600 transition-all">
                                    <i data-lucide="banknote" class="w-6 h-6"></i>
                                    <span class="text-[10px] font-black uppercase tracking-widest">Efectivo</span>
                                </div>
                            </label>
                            <label class="relative cursor-pointer">
                                <input type="radio" name="metodoPago" id="metodo2" value="Yape/Plin" class="peer sr-only">
                                <div class="flex flex-col items-center gap-2 p-4 rounded-2xl border border-slate-200 bg-slate-50 peer-checked:bg-purple-50 peer-checked:border-purple-500 peer-checked:ring-1 peer-checked:ring-purple-500 text-slate-600 peer-checked:text-purple-600 transition-all">
                                    <i data-lucide="smartphone" class="w-6 h-6"></i>
                                    <span class="text-[10px] font-black uppercase tracking-widest">Yape/Plin</span>
                                </div>
                            </label>
                            <label class="relative cursor-pointer">
                                <input type="radio" name="metodoPago" id="metodo3" value="Tarjeta" class="peer sr-only">
                                <div class="flex flex-col items-center gap-2 p-4 rounded-2xl border border-slate-200 bg-slate-50 peer-checked:bg-indigo-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 text-slate-600 peer-checked:text-indigo-600 transition-all">
                                    <i data-lucide="credit-card" class="w-6 h-6"></i>
                                    <span class="text-[10px] font-black uppercase tracking-widest">Tarjeta</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Comprobante (Condicional) -->
                    <div id="contenedorComprobante" class="bg-indigo-50/30 border-2 border-dashed border-indigo-100 p-6 rounded-3xl space-y-6 transition-all d-none">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center shadow-sm">
                                <i data-lucide="qr-code" class="w-4 h-4"></i>
                            </div>
                            <h4 class="text-[11px] font-black text-indigo-900 uppercase tracking-widest m-0">Validación de Operación</h4>
                        </div>
                        
                        <div class="space-y-4">
                            <input type="file" id="ComprobanteArchivo" name="ComprobanteArchivo" accept="image/*" class="block w-full text-[10px] text-slate-700 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-[10px] file:font-bold file:bg-white file:text-indigo-600 hover:file:bg-indigo-50 transition-all cursor-pointer border border-indigo-100/50 rounded-2xl bg-white/50 p-2 shadow-sm" />
                            
                            <div class="relative bg-slate-900 rounded-2xl overflow-hidden aspect-video flex items-center justify-center shadow-inner group/cam">
                                <video id="videoWebcamPago" class="absolute inset-0 w-full h-full object-cover hidden" autoplay playsinline></video>
                                <div id="pagoCamPlaceholder" class="text-center p-6 transition-all duration-300">
                                    <i data-lucide="camera-off" class="w-10 h-10 mx-auto mb-2 opacity-20 text-slate-400"></i>
                                    <p class="text-[9px] font-bold text-slate-700 uppercase tracking-widest">Cámara Inactiva</p>
                                </div>
                                <img id="imgPreviewComprobante" src="" class="absolute inset-0 w-full h-full object-contain bg-slate-950 hidden" />
                            </div>

                            <div class="flex gap-2">
                                <button type="button" id="btnActivarCamaraPago" onclick="activarCamaraPago()" class="flex-1 px-3 py-2.5 bg-white border border-indigo-100 text-indigo-600 rounded-xl hover:bg-indigo-50 transition-all text-[10px] font-bold uppercase tracking-widest shadow-sm">Activar</button>
                                <button type="button" id="btnCapturarPago" onclick="capturarComprobante()" class="flex-1 px-3 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all text-[10px] font-bold uppercase tracking-widest shadow-lg shadow-indigo-600/20 hidden">Capturar</button>
                                <button type="button" id="btnQuitarComprobante" class="flex-1 px-3 py-2.5 bg-rose-50 text-rose-600 rounded-xl hover:bg-rose-100 transition-all text-[10px] font-bold uppercase tracking-widest border border-rose-100 hidden" onclick="limpiarComprobante()">Limpiar</button>
                            </div>
                        </div>

                        <input type="hidden" id="ComprobanteBase64" name="ComprobanteBase64">
                        <canvas id="canvasPago" class="hidden"></canvas>
                        <p class="text-rose-500 text-[10px] font-black uppercase tracking-wide text-center d-none" id="errorComprobante">Comprobante obligatorio</p>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-3 ml-1">4. Fecha Retroactiva (Opcional)</label>
                        <input type="datetime-local" id="txtFechaPago" name="FechaPago" class="w-full bg-slate-50 border border-slate-200 focus:bg-white focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 transition-all" />
                        <p class="mt-2 text-[9px] text-slate-700 font-medium">Usar solo para regularizar pagos de días anteriores.</p>
                    </div>
                </div>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 text-slate-700 hover:text-slate-950 transition-colors font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-8 py-3 bg-emerald-600 text-white rounded-xl hover:bg-emerald-700 shadow-xl shadow-emerald-600/20 transition-all active:scale-95 font-black text-xs uppercase tracking-widest flex items-center justify-center gap-2" id="btnCobrar" onclick="procesarPago()" disabled>
                    <i data-lucide="check" class="w-5 h-5"></i>Confirmar Pago
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Editar Pago -->
<div class="modal fade" id="modalEditarPago" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white rounded-[2rem] border-0 shadow-2xl overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-100/50 shadow-sm">
                        <i data-lucide="pencil" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h5 class="text-xl font-display font-bold text-slate-950 tracking-tight m-0">Editar Pago</h5>
                        <p class="text-slate-700 text-[10px] font-bold uppercase tracking-widest mt-1">Corrección de montos o métodos</p>
                    </div>
                </div>
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-700 hover:bg-slate-100 hover:text-slate-950 transition-colors" data-bs-dismiss="modal">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-8">
                <form id="formEditarPago" class="space-y-6">
                    <input type="hidden" id="editPagoId" name="Id" />
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Nuevo Monto</label>
                        <div class="relative">
                            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">S/</div>
                            <input type="number" class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-10 pr-4 py-3 text-sm font-bold text-slate-950" id="editMonto" name="Monto" step="0.01" required>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Método de Pago</label>
                        <div class="relative">
                            <select class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-slate-950 appearance-none" id="editMetodoPago" name="MetodoPago" required>
                                <option value="Efectivo">Efectivo</option>
                                <option value="Yape/Plin">Yape/Plin</option>
                                <option value="Tarjeta">Tarjeta</option>
                            </select>
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                                <i class="bi bi-chevron-down"></i>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2 ml-1">Observaciones</label>
                        <textarea class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-sm font-medium text-slate-950 transition-all placeholder:text-slate-600" id="editObservaciones" name="Observaciones" rows="3" placeholder="Motivo de la edición..."></textarea>
                    </div>
                </form>
            </div>
            <div class="px-8 py-6 bg-slate-50 border-t border-slate-100 flex flex-col sm:flex-row items-stretch sm:items-center justify-end gap-3">
                <button type="button" class="px-6 py-2.5 text-slate-700 hover:text-slate-950 transition-colors font-bold text-xs uppercase tracking-widest" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="px-8 py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-xl shadow-indigo-600/20 transition-all active:scale-95 font-black text-xs uppercase tracking-widest flex items-center justify-center gap-2" id="btnGuardarEdicion" onclick="guardarEdicionPago()">
                    <i data-lucide="save" class="w-4 h-4"></i>Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ============================================
        // VARIABLES GLOBALES Y ESTADO
        // ============================================
        let deudaActual = 0;
        let membresiaSeleccionada = 0;
        let streamCamaraPago = null;
        let modalEditar = null;

        // ============================================
        // INICIALIZACIÓN
        // ============================================
        document.addEventListener("DOMContentLoaded", () => {
            // Eventos de búsqueda
            const txtBuscar = document.getElementById("txtDniBuscar");
            if(txtBuscar) {
                txtBuscar.addEventListener("keyup", function(event) {
                    if (event.key === "Enter") buscarDeuda();
                });
            }

            // Validación de monto
            const txtMonto = document.getElementById("txtMonto");
            if(txtMonto) {
                txtMonto.addEventListener("input", function() {
                    const valor = parseFloat(this.value);
                    const errorMsg = document.getElementById("errorMontoExcedido");
                    const btn = document.getElementById("btnCobrar");

                    if(valor > deudaActual) {
                        errorMsg.classList.remove("d-none");
                        this.classList.add("!border-rose-500");
                        btn.disabled = true;
                    } else {
                        errorMsg.classList.add("d-none");
                        this.classList.remove("!border-rose-500");
                        btn.disabled = isNaN(valor) || valor <= 0;
                    }
                });
            }

            // Lógica de visibilidad del comprobante
            document.querySelectorAll('input[name="metodoPago"]').forEach(radio => {
                radio.addEventListener('change', function () {
                    const contenedor = document.getElementById('contenedorComprobante');
                    if (this.value === 'Yape/Plin') {
                        contenedor.classList.remove('d-none');
                    } else {
                        contenedor.classList.add('d-none');
                        limpiarComprobante();
                    }
                });
            });

            // Carga de archivo comprobante
            const compArchivo = document.getElementById('ComprobanteArchivo');
            if(compArchivo) {
                compArchivo.addEventListener('change', function () {
                    const file = this.files[0];
                    if (!file) return;
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const base64 = e.target.result;
                        document.getElementById('ComprobanteBase64').value = base64;
                        const img = document.getElementById('imgPreviewComprobante');
                        img.src = base64;
                        img.classList.remove('hidden');
                        document.getElementById('errorComprobante').classList.add('d-none');
                        document.getElementById('btnQuitarComprobante')?.classList.remove('hidden');
                        detenerCamaraPago();
                    };
                    reader.readAsDataURL(file);
                });
            }
        });

        // ============================================
        // FUNCIONES DE BÚSQUEDA
        // ============================================
        function buscarDeuda() {
            const termino = document.getElementById("txtDniBuscar").value;
            if(!termino) return Swal.fire('Atención', 'Ingresa un término para buscar', 'warning');

            const btn = document.getElementById("btnBuscar");
            const iconOriginal = btn.innerHTML;
            btn.innerHTML = '<span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>';
            btn.disabled = true;

            fetch(`/Pagos/BuscarDeuda?termino=${termino}`)
                .then(res => res.json())
                .then(json => {
                    btn.innerHTML = iconOriginal;
                    btn.disabled = false;
                    const contenedorResultados = document.getElementById("resultados-busqueda");
                    contenedorResultados.innerHTML = "";
                    document.getElementById("infoMembresia").classList.add("d-none");
                    document.getElementById("formPagoDetalle").classList.add("d-none");

                    if (json.success && json.data.length > 0) {
                        contenedorResultados.style.display = "block";
                        json.data.forEach(item => {
                            const link = document.createElement("a");
                            link.href = "#";
                            link.className = "flex flex-col gap-1 px-5 py-4 hover:bg-slate-50 transition-colors group";
                            link.innerHTML = `
                                <div class="flex items-center justify-between">
                                    <span class="text-sm font-bold text-slate-950 group-hover:text-indigo-600 transition-colors">${item.nombreCliente}</span>
                                    <span class="text-[10px] font-black text-rose-600 bg-rose-50 px-2 py-0.5 rounded-lg border border-rose-100">$${item.deudaPendiente.toFixed(2)}</span>
                                </div>
                                <div class="flex items-center gap-2 text-[9px] font-bold text-slate-700 uppercase tracking-widest">
                                    <span>${item.dniCliente || 'S/ DNI'}</span> • <span>${item.nombrePlan}</span>
                                </div>`;
                            link.addEventListener("click", (e) => { e.preventDefault(); seleccionarCliente(item); });
                            contenedorResultados.appendChild(link);
                        });
                    } else {
                        contenedorResultados.style.display = "none";
                        Swal.fire({ icon: 'info', title: 'Sin resultados', text: 'No se encontraron deudas pendientes.' });
                        limpiarModal(false);
                    }
                });
        }

        function seleccionarCliente(data) {
            document.getElementById("resultados-busqueda").style.display = "none";
            membresiaSeleccionada = data.membresiaId;
            deudaActual = data.deudaPendiente;

            document.getElementById("lblCliente").innerText = data.nombreCliente;
            document.getElementById("lblPlan").innerText = data.nombrePlan;
            const lblBadge = document.getElementById("lblEstadoBadge");
            lblBadge.innerText = data.estado;
            lblBadge.className = 'inline-flex items-center px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-widest ' + 
                (data.estado === 'Activa' ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' : 'bg-rose-50 text-rose-700 border border-rose-100');

            document.getElementById("lblPrecioTotal").innerText = "$ " + (data.precioTotal || 0).toFixed(2);
            document.getElementById("lblTotalPagado").innerText = "$ " + (data.totalPagado || 0).toFixed(2);
            document.getElementById("lblDeudaPendiente").innerText = "$ " + deudaActual.toFixed(2);

            let porc = data.precioTotal > 0 ? (data.totalPagado / data.precioTotal) * 100 : 100;
            document.getElementById("progressBarPago").style.width = porc + "%";
            document.getElementById("lblPorcentaje").innerText = Math.round(porc) + "%";

            if(deudaActual > 0) {
                document.getElementById("txtMonto").value = deudaActual.toFixed(2);
                document.getElementById("btnCobrar").disabled = false;
                document.getElementById("infoMembresia").classList.remove("d-none");
                document.getElementById("formPagoDetalle").classList.remove("d-none");
                setTimeout(() => document.getElementById("txtMonto").focus(), 300);
            } else {
                Swal.fire('¡Al día!', 'El cliente no tiene deuda pendiente.', 'success');
                limpiarModal(false);
            }
        }

        // ============================================
        // PROCESAMIENTO DE PAGO
        // ============================================
        function procesarPago() {
            const metodo = document.querySelector('input[name="metodoPago"]:checked').value;
            const monto = parseFloat(document.getElementById("txtMonto").value);
            const comp64 = document.getElementById("ComprobanteBase64").value;

            if(isNaN(monto) || monto <= 0) return Swal.fire('Error', 'Monto inválido', 'error');
            if(metodo === 'Yape/Plin' && !comp64) return Swal.fire('Comprobante requerido', 'Adjunta el comprobante para Yape/Plin.', 'warning');

            Swal.fire({
                title: '¿Confirmar cobro?',
                html: `<div class="text-center"><p class="text-emerald-600 font-display font-black text-3xl mb-1">S/ ${monto.toFixed(2)}</p><p class="text-[10px] font-bold uppercase tracking-widest text-slate-700">Vía ${metodo}</p></div>`,
                icon: 'question', showCancelButton: true, confirmButtonText: 'Sí, cobrar', cancelButtonText: 'Cancelar',
                customClass: { confirmButton: 'px-8 py-3 bg-emerald-600 text-white rounded-xl font-black uppercase text-xs mx-2', cancelButton: 'px-8 py-3 bg-slate-100 text-slate-700 rounded-xl font-black uppercase text-xs mx-2' },
                buttonsStyling: false
            }).then((res) => {
                if (res.isConfirmed) {
                    document.getElementById("btnCobrar").disabled = true;
                    fetch('/Pagos/Registrar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ MembresiaId: membresiaSeleccionada, Monto: monto, MetodoPago: metodo, FechaPago: document.getElementById("txtFechaPago").value || null, ComprobanteBase64: comp64 || null })
                    })
                    .then(r => r.json())
                    .then(j => {
                        if (j.success) {
                            Swal.fire({ title: '¡Éxito!', text: 'Pago registrado.', icon: 'success', showCancelButton: true, confirmButtonText: 'Ticket', cancelButtonText: 'Cerrar' })
                            .then((pr) => { window.location.reload(); if (pr.isConfirmed) window.open(`/Pagos/Comprobante/${j.pagoId}`, '_blank'); });
                        } else {
                            document.getElementById("btnCobrar").disabled = false;
                            Swal.fire('Error', j.message, 'error');
                        }
                    });
                }
            });
        }

        // ============================================
        // GESTIÓN DE CÁMARA
        // ============================================
        function activarCamaraPago() {
            navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false })
                .then(stream => {
                    streamCamaraPago = stream;
                    const v = document.getElementById('videoWebcamPago');
                    v.srcObject = stream;
                    v.classList.remove('hidden');
                    document.getElementById('pagoCamPlaceholder').classList.add('hidden');
                    document.getElementById('btnActivarCamaraPago').classList.add('hidden');
                    document.getElementById('btnCapturarPago').classList.remove('hidden');
                    document.getElementById('imgPreviewComprobante').classList.add('hidden');
                })
                .catch(() => Swal.fire('Error', 'No se pudo acceder a la cámara.', 'error'));
        }

        function capturarComprobante() {
            const v = document.getElementById('videoWebcamPago');
            const c = document.getElementById('canvasPago');
            c.width = v.videoWidth; c.height = v.videoHeight;
            c.getContext('2d').drawImage(v, 0, 0);
            const b64 = c.toDataURL('image/jpeg', 0.85);
            document.getElementById('ComprobanteBase64').value = b64;
            const img = document.getElementById('imgPreviewComprobante');
            img.src = b64; img.classList.remove('hidden');
            document.getElementById('btnQuitarComprobante')?.classList.remove('hidden');
            detenerCamaraPago();
        }

        function detenerCamaraPago() {
            if (streamCamaraPago) {
                streamCamaraPago.getTracks().forEach(t => t.stop());
                streamCamaraPago = null;
            }
            const v = document.getElementById('videoWebcamPago');
            if(v) {
                v.srcObject = null;
                v.classList.add('hidden');
            }
            document.getElementById('pagoCamPlaceholder')?.classList.remove('hidden');
            document.getElementById('btnCapturarPago')?.classList.add('hidden');
            document.getElementById('btnActivarCamaraPago')?.classList.remove('hidden');
        }

        function limpiarComprobante() {
            detenerCamaraPago();
            document.getElementById('ComprobanteBase64').value = '';
            document.getElementById('ComprobanteArchivo').value = '';
            const img = document.getElementById('imgPreviewComprobante');
            if(img) { img.src = ''; img.classList.add('hidden'); }
            document.getElementById('btnQuitarComprobante')?.classList.add('hidden');
        }

        // ============================================
        // UTILIDADES MODAL
        // ============================================
        function abrirModalPago() {
            limpiarModal(true);
            new bootstrap.Modal(document.getElementById('modalPago')).show();
            setTimeout(() => document.getElementById("txtDniBuscar").focus(), 500);
        }

        function limpiarModal(full) {
            if(full) document.getElementById("txtDniBuscar").value = "";
            document.getElementById("txtMonto").value = "";
            document.getElementById("infoMembresia").classList.add("d-none");
            document.getElementById("formPagoDetalle").classList.add("d-none");
            document.getElementById("btnCobrar").disabled = true;
            document.getElementById("resultados-busqueda").style.display = "none";
            membresiaSeleccionada = 0; deudaActual = 0;
            limpiarComprobante();
            document.getElementById('contenedorComprobante').classList.add('d-none');
            const m1 = document.getElementById('metodo1'); if(m1) m1.checked = true;
        }

        // ============================================
        // EDICIÓN Y ANULACIÓN
        // ============================================
        function abrirModalEditarPago(id) {
            fetch(`/Pagos/ObtenerParaEdicion/${id}`).then(r => r.json()).then(d => {
                document.getElementById('editPagoId').value = d.id;
                document.getElementById('editMonto').value = d.monto;
                document.getElementById('editMetodoPago').value = d.metodoPago;
                document.getElementById('editObservaciones').value = d.observaciones || '';
                if(!modalEditar) modalEditar = new bootstrap.Modal(document.getElementById('modalEditarPago'));
                modalEditar.show();
            });
        }

        function guardarEdicionPago() {
            const data = { Id: parseInt(document.getElementById('editPagoId').value), Monto: parseFloat(document.getElementById('editMonto').value), MetodoPago: document.getElementById('editMetodoPago').value, Observaciones: document.getElementById('editObservaciones').value };
            fetch('/Pagos/Editar', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(() => window.location.reload());
        }

        function anularPago(id) {
            Swal.fire({ title: '¿Anular Pago?', text: "Esta acción es definitiva.", input: 'textarea', inputPlaceholder: 'Motivo...', icon: 'warning', showCancelButton: true, confirmButtonText: 'Anular' })
            .then((r) => { if (r.isConfirmed && r.value) fetch(`/Pagos/Anular/${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(r.value) }).then(() => window.location.reload()); });
        }
    </script>
}

<style>
    .animate-fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
