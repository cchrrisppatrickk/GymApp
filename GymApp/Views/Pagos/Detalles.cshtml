@model GymApp.ViewModels.PagoDetalleDTO
@{
    ViewData["Title"] = $"Detalle del Pago #{Model.PagoId}";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">
    <!-- Encabezado -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
        <div>
            <div class="flex items-center gap-4 mb-1">
                <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100/50 shadow-sm">
                    <i data-lucide="receipt" class="w-8 h-8"></i>
                </div>
                <h1 class="text-3xl font-display font-extrabold text-slate-950 tracking-tight m-0">Detalle de Cobro #@Model.PagoId</h1>
            </div>
            <div class="flex items-center gap-2 mt-2 ml-1">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider @(Model.EsAnulado ? "bg-rose-50 text-rose-700 border border-rose-100" : "bg-emerald-50 text-emerald-700 border border-emerald-100")">
                    @if(Model.EsAnulado) { <i data-lucide="x-circle" class="w-3 h-3"></i> <span>Anulado</span> } else { <i data-lucide="check-circle" class="w-3 h-3"></i> <span>Válido</span> }
                </span>
                <span class="text-slate-300">/</span>
                <p class="text-slate-600 text-sm font-medium">Método: <span class="font-bold text-slate-900">@Model.MetodoPago</span></p>
            </div>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
            <a asp-action="Index" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-slate-600 hover:text-indigo-600 bg-white hover:bg-slate-50 px-5 py-2.5 rounded-xl border border-slate-200 transition-all active:scale-95">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                <span>Volver a Caja</span>
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-4 bg-rose-50 border border-rose-100 p-5 rounded-3xl animate-fade-in shadow-sm">
            <div class="w-10 h-10 rounded-xl bg-rose-500 text-white flex items-center justify-center flex-shrink-0 shadow-lg shadow-rose-500/20">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
            </div>
            <div class="flex-1">
                <p class="text-sm font-bold text-rose-900 leading-tight">@TempData["Error"]</p>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Columna Izquierda: Detalles del Pago y Seguimiento -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Info del Pago -->
            <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden group">
                <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/30 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-white text-indigo-600 flex items-center justify-center border border-slate-200 shadow-sm group-hover:scale-110 transition-transform">
                        <i data-lucide="info" class="w-6 h-6"></i>
                    </div>
                    <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Información de la Operación</h3>
                </div>
                
                <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
                    <div class="space-y-1">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Socio / Beneficiario</p>
                        <a href="/Usuarios/Details/@Model.UserId" class="text-base font-bold text-slate-900 hover:text-indigo-600 hover:underline transition-colors flex items-center gap-2">
                            @Model.NombreCliente
                            <i data-lucide="external-link" class="w-3.5 h-3.5"></i>
                        </a>
                    </div>
                    <div class="space-y-1 text-right md:text-left">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">DNI / Identificación</p>
                        <p class="text-base font-bold text-slate-700 font-mono">@(Model.DniCliente ?? "—")</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Concepto de Membresía</p>
                        <p class="text-base font-bold text-slate-900">@Model.PlanMembresia</p>
                    </div>
                    <div class="space-y-1 text-right md:text-left">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Registrado por</p>
                        <p class="text-base font-bold text-slate-700">@Model.NombreEmpleado</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Fecha y Hora de Pago</p>
                        <p class="text-base font-bold text-slate-900">
                            @(Model.FechaPago.HasValue ? Model.FechaPago.Value.ToString("dd 'de' MMMM yyyy, hh:mm tt", new System.Globalization.CultureInfo("es-PE")) : "—")
                        </p>
                    </div>
                    <div class="space-y-1 text-right md:text-left">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Monto Recibido</p>
                        <p class="text-2xl font-display font-black text-emerald-600 tracking-tighter">S/ @Model.Monto.ToString("N2")</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                    {
                        <div class="md:col-span-2 p-5 bg-indigo-50/50 rounded-2xl border border-indigo-100 flex items-start gap-3">
                            <i data-lucide="message-square" class="w-5 h-5 text-indigo-400"></i>
                            <div class="text-sm font-medium text-indigo-900 italic">"@Model.Observaciones"</div>
                        </div>
                    }
                </div>
                <div class="px-8 py-4 bg-slate-50 border-t border-slate-100 text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] flex gap-6">
                    <span>Membresía: #@Model.MembresiaId</span>
                    <span>Operación: #@Model.PagoId</span>
                </div>
            </div>

            <!-- Seguimiento de Deuda -->
            @{
                var porcentajePagado = Model.MontoTotal > 0 ? (double)(Model.MontoPagadoAcumulado / Model.MontoTotal * 100) : 100;
                porcentajePagado = Math.Min(porcentajePagado, 100);
                var saldado = Model.DeudaRestante <= 0;
                var barColor = saldado ? "bg-emerald-500" : (porcentajePagado >= 75 ? "bg-amber-500" : "bg-indigo-500");
            }
            <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden group">
                <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50 shadow-sm">
                            <i data-lucide="trending-up" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Balance de la Membresía</h3>
                    </div>
                    @if (saldado) {
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">Saldado</span>
                    }
                </div>
                <div class="p-8 space-y-10">
                    <!-- Barra -->
                    <div class="space-y-4">
                        <div class="flex justify-between items-end">
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Progreso de Pago Total</span>
                            <span class="text-2xl font-display font-black text-slate-950 tracking-tight">@porcentajePagado.ToString("F0")%</span>
                        </div>
                        <div class="w-full h-3 bg-slate-100 rounded-full overflow-hidden shadow-inner">
                            <div class="h-full @barColor transition-all duration-1000 shadow-[0_0_15px_rgba(0,0,0,0.1)]" style="width: @porcentajePagado.ToString("F0")%"></div>
                        </div>
                    </div>

                    <!-- Métricas -->
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div class="p-6 bg-slate-50 border border-slate-100 rounded-3xl text-center space-y-1">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Inversión Total</p>
                            <p class="text-lg font-bold text-slate-900 font-mono">S/ @Model.MontoTotal.ToString("N2")</p>
                        </div>
                        <div class="p-6 bg-emerald-50/50 border border-emerald-100 rounded-3xl text-center space-y-1">
                            <p class="text-[9px] font-black text-emerald-600 uppercase tracking-widest">Cobrado al día</p>
                            <p class="text-lg font-bold text-emerald-700 font-mono">S/ @Model.MontoPagadoAcumulado.ToString("N2")</p>
                        </div>
                        <div class="p-6 @(saldado ? "bg-emerald-500" : "bg-rose-500") rounded-3xl text-center space-y-1 shadow-lg @(saldado ? "shadow-emerald-500/20" : "shadow-rose-500/20")">
                            <p class="text-[9px] font-black text-white/70 uppercase tracking-widest">Saldo Pendiente</p>
                            <p class="text-lg font-bold text-white font-mono">S/ @Model.DeudaRestante.ToString("N2")</p>
                        </div>
                    </div>

                    @if (Model.EsAnulado)
                    {
                        <div class="p-4 bg-rose-50 border border-rose-100 rounded-2xl flex items-center gap-3">
                            <i data-lucide="alert-octagon" class="w-6 h-6 text-rose-500"></i>
                            <p class="text-xs font-bold text-rose-700 uppercase tracking-wide m-0">Este pago no suma al acumulado por estar ANULADO.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Comprobante -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden h-full flex flex-col group">
                <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/30 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-white text-amber-500 flex items-center justify-center border border-slate-200 shadow-sm group-hover:scale-110 transition-transform">
                        <i data-lucide="image" class="w-6 h-6"></i>
                    </div>
                    <h3 class="text-lg font-display font-bold text-slate-950 tracking-tight m-0">Evidencia Digital</h3>
                </div>
                <div class="p-8 flex-1 flex flex-col justify-center items-center">
                    @if (!string.IsNullOrEmpty(Model.Comprobante))
                    {
                        <div class="relative group/img max-w-full">
                            <a href="@Model.Comprobante" target="_blank" class="block rounded-2xl overflow-hidden shadow-2xl border border-slate-200 bg-slate-50 transition-transform duration-500 group-hover/img:scale-[1.02]">
                                <img src="@Model.Comprobante" alt="Comprobante" class="max-h-[450px] object-contain cursor-zoom-in" />
                                <div class="absolute inset-0 bg-indigo-600/10 opacity-0 group-hover/img:opacity-100 transition-opacity"></div>
                            </a>
                            <div class="flex gap-2 mt-6">
                                <a href="@Model.Comprobante" download class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all font-bold text-[10px] uppercase tracking-widest">
                                    <i data-lucide="download" class="w-4 h-4"></i> Guardar
                                </a>
                                <a href="@Model.Comprobante" target="_blank" class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all font-bold text-[10px] uppercase tracking-widest shadow-lg shadow-indigo-600/20">
                                    <i data-lucide="maximize" class="w-4 h-4"></i> Expandir
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-12 space-y-4 max-w-xs">
                            <div class="w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center mx-auto border border-slate-100">
                                <i data-lucide="image-off" class="text-slate-200 w-10 h-10"></i>
                            </div>
                            <div>
                                <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest">Sin Adjunto</h4>
                                <p class="text-xs text-slate-400 font-medium leading-relaxed mt-2">Este pago fue procesado vía <b>@Model.MetodoPago</b> y no registró evidencia fotográfica.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones Inferiores -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 py-8">
        <a asp-action="Index" class="px-8 py-3 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all font-bold text-xs uppercase tracking-widest flex items-center gap-2 active:scale-95">
            <i data-lucide="arrow-left" class="w-4 h-4"></i>Regresar a Caja
        </a>
        <a asp-action="Details" asp-controller="Membresias" asp-route-id="@Model.MembresiaId" class="px-8 py-3 bg-indigo-50 text-indigo-600 border border-indigo-100 rounded-xl hover:bg-indigo-600 hover:text-white transition-all duration-300 font-bold text-xs uppercase tracking-widest shadow-sm shadow-indigo-100/50 flex items-center gap-2 active:scale-95">
            <i data-lucide="user-cog" class="w-4 h-4"></i>Ver Gestión de Membresía
        </a>
    </div>
</div>

<style>
    .animate-fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
