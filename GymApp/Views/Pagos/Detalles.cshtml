@model GymApp.ViewModels.PagoDetalleDTO
@{
    ViewData["Title"] = $"Detalle del Pago #{Model.PagoId}";
}

<div class="container-fluid px-4 fade-in">

    @* ── ENCABEZADO ────────────────────────────────────────────── *@
    <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h2 class="mb-0 text-dark fw-bold">
                <i class="bi bi-receipt text-success me-2"></i>Detalle del Pago
            </h2>
            <p class="text-muted small mb-0">
                Registro #@Model.PagoId &mdash; @Model.MetodoPago
                @if (Model.EsAnulado)
                {
                    <span class="badge bg-danger ms-2">ANULADO</span>
                }
                else
                {
                    <span class="badge bg-success ms-2">VÁLIDO</span>
                }
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver a la lista
        </a>
    </div>

    @* ── ALERTA TEMPDATA ──────────────────────────────────────── *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── GRILLA PRINCIPAL ─────────────────────────────────────── *@
    <div class="row g-4">

        @* ── COL IZQUIERDA: Datos del Pago ──────────────────── *@
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-semibold text-dark">
                        <i class="bi bi-info-circle text-primary me-2"></i>Información del Pago
                    </h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <tbody>
                            <tr>
                                <td class="ps-4 text-muted fw-medium" style="width:40%">
                                    <i class="bi bi-person-circle me-1"></i>Cliente
                                </td>
                                <td class="fw-semibold text-dark">@Model.NombreCliente</td>
                            </tr>
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-card-text me-1"></i>DNI
                                </td>
                                <td>@(Model.DniCliente ?? "—")</td>
                            </tr>
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-award me-1"></i>Plan
                                </td>
                                <td>@Model.PlanMembresia</td>
                            </tr>
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-cash-coin me-1"></i>Monto
                                </td>
                                <td class="fw-bold text-success fs-5">
                                    S/ @Model.Monto.ToString("N2")
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-credit-card me-1"></i>Método de Pago
                                </td>
                                <td>
                                    @if (Model.MetodoPago.Contains("Yape", StringComparison.OrdinalIgnoreCase) ||
                                         Model.MetodoPago.Contains("Plin", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge text-white" style="background:#6f42c1">
                                            <i class="bi bi-phone me-1"></i>@Model.MetodoPago
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@Model.MetodoPago</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-calendar-event me-1"></i>Fecha de Pago
                                </td>
                                <td>
                                    @(Model.FechaPago.HasValue
                                        ? Model.FechaPago.Value.ToString("dd 'de' MMMM yyyy, hh:mm tt",
                                            new System.Globalization.CultureInfo("es-PE"))
                                        : "—")
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-person-badge me-1"></i>Registrado por
                                </td>
                                <td>@Model.NombreEmpleado</td>
                            </tr>
                            @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                            {
                                <tr>
                                    <td class="ps-4 text-muted fw-medium">
                                        <i class="bi bi-chat-left-text me-1"></i>Observaciones
                                    </td>
                                    <td class="fst-italic">@Model.Observaciones</td>
                                </tr>
                            }
                            <tr>
                                <td class="ps-4 text-muted fw-medium">
                                    <i class="bi bi-shield-check me-1"></i>Estado
                                </td>
                                <td>
                                    @if (Model.EsAnulado)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle me-1"></i>Anulado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Válido
                                        </span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white border-top text-muted small px-4 py-2">
                    ID Membresía: #@Model.MembresiaId &nbsp;&bull;&nbsp; ID Pago: #@Model.PagoId
                </div>
            </div>
        </div>

        @* ── COL DERECHA: Comprobante ────────────────────────── *@
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-semibold text-dark">
                        <i class="bi bi-image text-warning me-2"></i>Comprobante de Pago
                    </h5>
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center p-4">
                    @if (!string.IsNullOrEmpty(Model.Comprobante))
                    {
                        <p class="text-muted small mb-3 align-self-start">
                            <i class="bi bi-paperclip me-1"></i>Imagen adjunta al registro del pago.
                        </p>
                        <a href="@Model.Comprobante" target="_blank" title="Abrir en nueva pestaña">
                            <img src="@Model.Comprobante"
                                 alt="Comprobante Yape/Plin"
                                 class="img-fluid rounded border shadow-sm"
                                 style="max-height:420px; object-fit:contain; cursor:zoom-in;" />
                        </a>
                        <div class="mt-3 align-self-start d-flex gap-2">
                            <a href="@Model.Comprobante"
                               download
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-download me-1"></i>Descargar
                            </a>
                            <a href="@Model.Comprobante"
                               target="_blank"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Pantalla completa
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-image-alt text-muted" style="font-size:3.5rem; opacity:.35;"></i>
                            <p class="mt-3 mb-1 fw-semibold text-muted">Sin comprobante adjunto</p>
                            <div class="alert alert-secondary mt-2 mb-0 text-start" role="alert">
                                <i class="bi bi-info-circle me-1"></i>
                                Este pago fue registrado en <strong>@Model.MetodoPago</strong>
                                y no requirió imagen de comprobante.
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>@* /row *@

    @* ── ACCIONES INFERIORES ─────────────────────────────────── *@
    <div class="d-flex gap-2 mt-4 mb-5">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver a la lista
        </a>
        <a asp-action="Index"
           asp-controller="Membresias"
           asp-route-id="@Model.MembresiaId"
           class="btn btn-outline-primary">
            <i class="bi bi-person-lines-fill me-1"></i>Ver Membresía del Cliente
        </a>
    </div>

</div>
