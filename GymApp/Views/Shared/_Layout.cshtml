<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymApp System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-collapsed-width: 70px; /* Reducido un poco para ganar espacio */
            --primary-color: #1a1a2e;
            --secondary-color: #16213e;
            --accent-color: #e94560;
            --text-color: #f8f9fa;
            --hover-color: #0f3460;
            --transition-speed: 0.3s;
        }

        body {
            overflow-x: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
        }

        /* === SIDEBAR === */
        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: var(--primary-color);
            color: var(--text-color);
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1); /* Animación más fluida */
            z-index: 1050; /* Por encima de todo */
            box-shadow: 4px 0 15px rgba(0, 0, 0, 0.2);
        }

            #sidebar.collapsed {
                width: var(--sidebar-collapsed-width);
            }

        .sidebar-header {
            padding: 0 20px;
            background: var(--secondary-color);
            display: flex;
            align-items: center;
            height: 70px;
            overflow: hidden; /* Evita que el texto salte al colapsar */
        }

            .sidebar-header h3 {
                font-size: 1.25rem;
                font-weight: 700;
                margin: 0;
                white-space: nowrap;
                opacity: 1;
                transition: opacity 0.2s;
            }

        #sidebar.collapsed .sidebar-header h3 {
            opacity: 0;
            pointer-events: none;
        }

        /* Scroll elegante para el sidebar */
        .sidebar-content {
            height: calc(100vh - 70px);
            overflow-y: auto;
            overflow-x: hidden;
        }

            /* Personalización del Scrollbar (Webkit) */
            .sidebar-content::-webkit-scrollbar {
                width: 5px;
            }

            .sidebar-content::-webkit-scrollbar-track {
                background: transparent;
            }

            .sidebar-content::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.1);
                border-radius: 10px;
            }

                .sidebar-content::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 255, 255, 0.3);
                }

        /* === MENU ITEMS === */
        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            padding-bottom: 50px;
        }

        .menu-item {
            position: relative;
            margin: 4px 0;
        }

        .menu-link {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            transition: all 0.2s ease;
            border-left: 3px solid transparent;
            font-weight: 500;
        }

            .menu-link:hover, .menu-link.active {
                background: var(--hover-color);
                color: #fff;
                border-left: 3px solid var(--accent-color);
            }

        .menu-icon {
            font-size: 1.2rem;
            min-width: 30px; /* Asegura alineación */
            text-align: center;
            margin-right: 10px;
        }

        .menu-text {
            flex: 1;
            white-space: nowrap;
            opacity: 1;
            transition: opacity 0.2s;
        }

        .menu-arrow {
            font-size: 0.8rem;
            transition: transform 0.3s ease;
        }

        /* Estado Colapsado */
        #sidebar.collapsed .menu-text,
        #sidebar.collapsed .menu-arrow {
            opacity: 0;
            display: none;
        }

        #sidebar.collapsed .menu-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }

        #sidebar.collapsed .menu-icon {
            margin-right: 0;
        }

        /* === SUBMENUS === */
        .submenu {
            list-style: none;
            padding: 0;
            margin: 0;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease-out;
            background-color: rgba(0,0,0,0.15);
        }

        .menu-item.open .submenu {
            max-height: 500px; /* Suficiente para mostrar items */
            transition: max-height 0.4s ease-in;
        }

        .menu-item.open .menu-arrow {
            transform: rotate(180deg);
        }

        .submenu-link {
            display: flex;
            align-items: center;
            padding: 10px 10px 10px 58px; /* Indentación */
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            font-size: 0.9rem;
        }

        #sidebar.collapsed .submenu {
            display: none; /* Ocultar submenús si está colapsado */
        }

        .submenu-link:hover {
            color: #fff;
            background-color: rgba(255,255,255,0.05);
        }

        /* === CONTENT AREA === */
        #content {
            margin-left: var(--sidebar-width);
            padding: 20px;
            transition: margin-left var(--transition-speed) ease;
            min-height: 100vh;
        }

            #content.expanded {
                margin-left: var(--sidebar-collapsed-width);
            }

        /* Navbar Superior */
        .top-navbar {
            background-color: white;
            padding: 12px 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 20px;
            z-index: 900;
        }

        #sidebar-toggle {
            background: transparent;
            color: #333;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 0;
            line-height: 1;
        }

        /* === MOBILE RESPONSIVE (Off-Canvas Style) === */
        @@media (max-width: 768px) {
            #sidebar

        {
            left: -100%; /* Oculto completamente a la izquierda */
            width: 280px; /* Un poco más ancho en móvil para tocar mejor */
        }

        #sidebar.mobile-open {
            left: 0;
            box-shadow: 10px 0 30px rgba(0,0,0,0.5);
        }

        #content {
            margin-left: 0 !important; /* El contenido SIEMPRE ocupa el 100% */
            padding: 15px;
        }

        /* Overlay Oscuro para móvil */
        .mobile-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1040;
            display: none;
            backdrop-filter: blur(2px); /* Efecto vidrio borroso */
            opacity: 0;
            transition: opacity 0.3s;
        }

            .mobile-overlay.show {
                display: block;
                opacity: 1;
            }

        /* Ocultar elementos específicos en móvil */
        .sidebar-header h3 {
            opacity: 1 !important;
            display: block !important;
            width: auto !important;
        }

        }
    </style>
</head>
<body>

    <div class="mobile-overlay" id="mobileOverlay"></div>

    <nav id="sidebar">
        <div class="sidebar-header d-flex justify-content-between">
            <h3><i class="bi bi-exclude me-2 text-danger"></i>Gym App</h3>
            <button class="btn text-white d-md-none" id="mobile-close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="sidebar-content">
            <ul class="sidebar-menu">

                <li class="menu-item">
                    @if (User.IsInRole("Cliente"))
                    {
                        <a asp-controller="ClienteHome" asp-action="Index" class="menu-link">
                            <span class="menu-icon"><i class="bi bi-person-badge"></i></span>
                            <span class="menu-text">Mi Perfil</span>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Index" class="menu-link">
                            <span class="menu-icon"><i class="bi bi-speedometer2"></i></span>
                            <span class="menu-text">Dashboard</span>
                        </a>
                    }
                </li>

                @if (User.IsInRole("Admin") || User.IsInRole("Empleado"))
                {
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

                    <!-- ========== SECCIÓN: OPERACIONES ========== -->
                    <li class="menu-item mt-3 mb-1 px-4 text-muted small fw-bold" style="font-size: 0.7rem; letter-spacing: 1px;">OPERACIONES</li>

                    <li class="menu-item">
                        <a asp-controller="Usuarios" asp-action="Index" class="menu-link @(currentController == "Usuarios" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-people-fill"></i></span>
                            <span class="menu-text">Control de Usuarios</span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a asp-controller="Membresias" asp-action="Index" class="menu-link @(currentController == "Membresias" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-card-checklist"></i></span>
                            <span class="menu-text">Suscripciones</span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a asp-controller="Pagos" asp-action="Index" class="menu-link @(currentController == "Pagos" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-cash-stack"></i></span>
                            <span class="menu-text">Cajas</span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#submenuReportes" class="menu-link submenu-toggle @(currentController == "Reportes" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-graph-up-arrow"></i></span>
                            <span class="menu-text">Reportes</span>
                            <span class="menu-arrow ms-auto"><i class="bi bi-chevron-down"></i></span>
                        </a>
                        <ul class="submenu" id="submenuReportes">
                            <li class="submenu-item">
                                <a asp-controller="Reportes" asp-action="Index" class="submenu-link">
                                    <i class="bi bi-dot me-1"></i> Control de Ingresos General
                                </a>
                            </li>
                            <li class="submenu-item">
                                <a asp-controller="Reportes" asp-action="Membresias" class="submenu-link">
                                    <i class="bi bi-dot me-1"></i> Control de Membresías
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="menu-item">
                        <a asp-controller="Ventas" asp-action="Index" class="menu-link @(currentController == "Ventas" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-cart-fill"></i></span>
                            <span class="menu-text">Ventas</span>
                        </a>
                    </li>

                    <li class="menu-item">
                        <a href="#submenuAcceso" class="menu-link submenu-toggle @(currentController == "Acceso" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-qr-code-scan"></i></span>
                            <span class="menu-text">Control de Acceso</span>
                            <span class="menu-arrow ms-auto"><i class="bi bi-chevron-down"></i></span>
                        </a>
                        <ul class="submenu" id="submenuAcceso">
                            <li class="submenu-item">
                                <a asp-controller="Acceso" asp-action="Index" class="submenu-link">Escáner QR</a>
                            </li>
                            <li class="submenu-item">
                                <a asp-controller="Acceso" asp-action="Historial" class="submenu-link">Historial Visitas</a>
                            </li>
                        </ul>
                    </li>

                    <!-- ========== SECCIÓN: ADMINISTRACIÓN ========== -->
                    <li class="menu-item mt-3 mb-1 px-4 text-muted small fw-bold" style="font-size: 0.7rem; letter-spacing: 1px;">ADMINISTRACIÓN</li>

                    <li class="menu-item">
                        <a href="#submenuConfig" class="menu-link submenu-toggle @(currentController == "Planes" || currentController == "Turnos" || currentController == "Roles" || currentController == "Productos" ? "active" : "")">
                            <span class="menu-icon"><i class="bi bi-gear-fill"></i></span>
                            <span class="menu-text">Configuración</span>
                            <span class="menu-arrow ms-auto"><i class="bi bi-chevron-down"></i></span>
                        </a>
                        <ul class="submenu" id="submenuConfig">
                            <li class="submenu-item">
                                <a asp-controller="Planes" asp-action="Index" class="submenu-link">Planes y Precios</a>
                            </li>
                            <li class="submenu-item">
                                <a asp-controller="Turnos" asp-action="Index" class="submenu-link">Horarios</a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="submenu-item">
                                    <a asp-controller="Roles" asp-action="Index" class="submenu-link">Roles</a>
                                </li>
                            }
                            <li class="submenu-item">
                                <a asp-controller="Productos" asp-action="Index" class="submenu-link">
                                    <i class="bi bi-dot me-1"></i> Productos
                                </a>
                            </li>
                        </ul>
                    </li>

                }

                <li class="menu-item mt-5 pt-3 border-top border-secondary mx-3">
                    <a asp-controller="Auth" asp-action="Logout" class="menu-link text-danger px-0 justify-content-center justify-content-lg-start">
                        <span class="menu-icon"><i class="bi bi-box-arrow-left"></i></span>
                        <span class="menu-text">Cerrar Sesión</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div id="content">
        <div class="top-navbar">
            <div class="d-flex align-items-center">
                <button id="sidebar-toggle">
                    <i class="bi bi-list"></i>
                </button>
                <h5 class="ms-3 mb-0 text-muted d-none d-sm-block">@ViewData["Title"]</h5>
            </div>

            <div class="user-profile d-flex align-items-center">
                <div class="text-end me-2 lh-1">
                    <div class="fw-bold text-dark small">@(User.Identity?.Name ?? "Usuario")</div>
                    @if (User.IsInRole("Admin"))
                    {
                        <span class="badge bg-danger" style="font-size: 0.6rem;">ADMIN</span>
                    }
                    else if (User.IsInRole("Cliente"))
                    {
                        <span class="badge bg-success" style="font-size: 0.6rem;">SOCIO</span>
                    }
                </div>
                <div class="bg-light rounded-circle p-2 border">
                    <i class="bi bi-person-fill fs-5 text-secondary"></i>
                </div>
            </div>
        </div>

        <div class="container-fluid p-0 fade-in">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mx-4 mt-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @Html.Raw(TempData["Success"])
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @Html.Raw(TempData["Error"])
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const content = document.getElementById('content');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const mobileCloseBtn = document.getElementById('mobile-close');
            const overlay = document.getElementById('mobileOverlay');
            const submenuToggles = document.querySelectorAll('.submenu-toggle');

            // Función para detectar si estamos en modo móvil
            const isMobile = () => window.innerWidth <= 768;

            // TOGGLE PRINCIPAL
            toggleBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                if (isMobile()) {
                    // Modo Móvil: Abre el cajón (Off-canvas)
                    sidebar.classList.add('mobile-open');
                    overlay.classList.add('show');
                } else {
                    // Modo Desktop: Colapsa el menú
                    sidebar.classList.toggle('collapsed');
                    content.classList.toggle('expanded');
                }
            });

            // CERRAR EN MOVIL (Botón X o Click en Overlay)
            function closeMobileMenu() {
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('show');
            }

            mobileCloseBtn.addEventListener('click', closeMobileMenu);
            overlay.addEventListener('click', closeMobileMenu);

            // LOGICA SUBMENUS
            submenuToggles.forEach(toggle => {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();

                    // Si el sidebar está colapsado en desktop, lo abrimos automáticamente al intentar abrir un submenú
                    if (!isMobile() && sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        content.classList.remove('expanded');
                    }

                    const parentItem = this.parentElement;

                    // Acordeón: Cerrar otros abiertos
                    document.querySelectorAll('.menu-item.open').forEach(item => {
                        if (item !== parentItem) {
                            item.classList.remove('open');
                        }
                    });

                    parentItem.classList.toggle('open');
                });
            });

            // AUTO-ABRIR submenú que contiene enlace activo
            document.querySelectorAll('.submenu-toggle.active').forEach(activeToggle => {
                activeToggle.parentElement.classList.add('open');
            });

            // RESIZE HANDLER
            window.addEventListener('resize', function() {
                if (!isMobile()) {
                    // Si pasamos a desktop, limpiamos clases móviles
                    sidebar.classList.remove('mobile-open');
                    overlay.classList.remove('show');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>