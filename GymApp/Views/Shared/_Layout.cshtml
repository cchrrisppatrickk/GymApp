@using GymApp.Constants
<!DOCTYPE html>
<html lang="es" class="font-sans antialiased">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymApp System</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS (Legacy - Will be progressively removed) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)

    <style>
        /* Custom styles that are harder to replicate cleanly with just utility classes due to dynamic JS class toggling */
        #sidebar {
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        #sidebar.collapsed {
            width: 5rem; /* w-20 */
        }
        #sidebar.collapsed .menu-text, 
        #sidebar.collapsed .menu-arrow,
        #sidebar.collapsed .sidebar-header h3 {
            opacity: 0;
            display: none;
        }
        #sidebar.collapsed .submenu {
            display: none !important;
        }
        #sidebar.collapsed .menu-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }
        #sidebar.collapsed .menu-icon {
            margin-right: 0;
        }
        
        #content {
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        #content.expanded {
            margin-left: 5rem; /* w-20 */
        }
        
        .submenu {
            max-height: 0;
            opacity: 0;
            transform: scaleY(0.95);
            transform-origin: top;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
                        opacity 0.3s ease-out, 
                        transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .menu-item.open .submenu {
            max-height: 500px;
            opacity: 1;
            transform: scaleY(1);
        }
        .menu-item.open .menu-arrow {
            transform: rotate(180deg);
        }
        
        /* Efecto de entrada secuencial para los items */
        .menu-item.open .submenu li {
            animation: slideInSubmenu 0.3s ease-out forwards;
            opacity: 0;
        }
        @@keyframes slideInSubmenu {
            from { transform: translateX(-10px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .menu-item.open .submenu li:nth-child(1) { animation-delay: 0.05s; }
        .menu-item.open .submenu li:nth-child(2) { animation-delay: 0.1s; }
        .menu-item.open .submenu li:nth-child(3) { animation-delay: 0.15s; }
        .menu-item.open .submenu li:nth-child(4) { animation-delay: 0.2s; }
        .menu-item.open .submenu li:nth-child(5) { animation-delay: 0.25s; }
        
        /* Mobile offcanvas */
        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
            }
            #sidebar.mobile-open {
                transform: translateX(0);
            }
            #content, #content.expanded {
                margin-left: 0;
            }
        }

        /* Smooth fade in animation */
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-950 selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Loading Bar -->
    <div id="loading-bar" class="fixed top-0 left-0 h-[3px] bg-indigo-600 z-[9999] transition-all duration-300 ease-out" style="width: 0%; opacity: 0;"></div>

    <!-- Mobile Overlay -->
    <div id="mobileOverlay" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Sidebar -->
    <partial name="_Sidebar" />

    <!-- Main Content Area -->
    <div id="content" class="md:ml-56 p-4 md:p-8 min-h-screen transition-all duration-300">
        
        <!-- Top Navbar -->
        <div class="top-navbar bg-white p-4 rounded-2xl shadow-sm border border-slate-200 mb-8 flex justify-between items-center sticky top-4 z-40 transition-all duration-300">
            <div class="flex items-center">
                <button id="sidebar-toggle" class="md:hidden text-slate-700 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-xl transition-colors focus:outline-none">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <h5 class="ml-4 md:ml-0 mb-0 text-slate-950 font-display font-semibold text-lg">@ViewData["Title"]</h5>
            </div>

            <div class="user-profile flex items-center">
                <div class="text-right mr-3 leading-tight hidden sm:block">
                    <div class="font-bold text-slate-950 text-sm">@(User.Identity?.Name ?? "Usuario")</div>
                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <span class="inline-block bg-indigo-100 text-indigo-700 text-[0.65rem] font-bold px-2 py-0.5 rounded-md mt-0.5">ADMIN</span>
                    }
                    else if (User.IsInRole("Cliente"))
                    {
                        <span class="inline-block bg-teal-100 text-teal-700 text-[0.65rem] font-bold px-2 py-0.5 rounded-md mt-0.5">SOCIO</span>
                    }
                </div>
                <div class="bg-indigo-50 rounded-full p-2.5 w-10 h-10 flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                    <i data-lucide="user" class="w-6 h-6"></i>
                </div>
            </div>
        </div>

        <!-- Render Body Container -->
        <div class="container-fluid p-0 animate-fade-in">
            @if (TempData["Success"] != null)
            {
                <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl relative mb-6 shadow-sm flex items-start" role="alert">
                    <i data-lucide="check-circle" class="text-emerald-500 mt-0.5 mr-3 w-6 h-6"></i>
                    <div class="flex-1 font-medium">
                        @Html.Raw(TempData["Success"])
                    </div>
                    <button type="button" class="text-emerald-500 hover:text-emerald-700 focus:outline-none" data-bs-dismiss="alert" aria-label="Close" onclick="this.parentElement.style.display='none'">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl relative mb-6 shadow-sm flex items-start" role="alert">
                    <i data-lucide="alert-triangle" class="text-rose-500 mt-0.5 mr-3 w-6 h-6"></i>
                    <div class="flex-1 font-medium">
                        @Html.Raw(TempData["Error"])
                    </div>
                    <button type="button" class="text-rose-500 hover:text-rose-700 focus:outline-none" data-bs-dismiss="alert" aria-label="Close" onclick="this.parentElement.style.display='none'">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            }
            
            <!-- Removed the wrapping bg-white card to allow pages to define their own cards and negative space -->
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Inicializar Lucide Icons
            lucide.createIcons();

            const sidebar = document.getElementById('sidebar');
            const content = document.getElementById('content');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const mobileCloseBtn = document.getElementById('mobile-close');
            const overlay = document.getElementById('mobileOverlay');

            const isMobile = () => window.innerWidth <= 768;

            if (toggleBtn) {
                toggleBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    if (isMobile() && sidebar) {
                        sidebar.classList.add('mobile-open');
                        sidebar.classList.remove('-translate-x-full');
                        if (overlay) {
                            overlay.classList.remove('hidden');
                            setTimeout(() => overlay.classList.remove('opacity-0'), 10);
                        }
                    }
                });
            }

            function closeMobileMenu() {
                if (sidebar) {
                    sidebar.classList.add('-translate-x-full');
                    sidebar.classList.remove('mobile-open');
                }
                if (overlay) {
                    overlay.classList.add('opacity-0');
                    setTimeout(() => overlay.classList.add('hidden'), 300);
                }
            }

            if (mobileCloseBtn) mobileCloseBtn.addEventListener('click', closeMobileMenu);
            if (overlay) overlay.addEventListener('click', closeMobileMenu);

            // Lógica de Submenús
            const submenuToggles = document.querySelectorAll('.submenu-toggle');
            submenuToggles.forEach(toggle => {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    const parentItem = this.closest('.menu-item');
                    
                    // Cerrar otros submenús abiertos si es necesario (opcional)
                    document.querySelectorAll('.menu-item.open').forEach(item => {
                        if (item !== parentItem) {
                            item.classList.remove('open');
                        }
                    });

                    if (parentItem) {
                        parentItem.classList.toggle('open');
                    }
                });
            });

            window.addEventListener('resize', function() {
                if (!isMobile()) {
                    sidebar.classList.remove('-translate-x-full', 'mobile-open');
                    overlay.classList.add('hidden', 'opacity-0');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>