@using GymApp.Constants
<!DOCTYPE html>
<html lang="es" class="font-sans antialiased">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymApp System</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS (Legacy - Will be progressively removed) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)

    <style>
        /* Custom styles that are harder to replicate cleanly with just utility classes due to dynamic JS class toggling */
        #sidebar {
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        #sidebar.collapsed {
            width: 5rem; /* w-20 */
        }
        #sidebar.collapsed .menu-text, 
        #sidebar.collapsed .menu-arrow,
        #sidebar.collapsed .sidebar-header h3 {
            opacity: 0;
            display: none;
        }
        #sidebar.collapsed .submenu {
            display: none !important;
        }
        #sidebar.collapsed .menu-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }
        #sidebar.collapsed .menu-icon {
            margin-right: 0;
        }
        
        #content {
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        #content.expanded {
            margin-left: 5rem; /* w-20 */
        }
        
        .submenu {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease-out;
        }
        .menu-item.open .submenu {
            max-height: 500px;
            transition: max-height 0.4s ease-in;
        }
        .menu-item.open .menu-arrow {
            transform: rotate(180deg);
        }
        
        /* Mobile offcanvas */
        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
            }
            #sidebar.mobile-open {
                transform: translateX(0);
            }
            #content, #content.expanded {
                margin-left: 0;
            }
        }

        /* Smooth fade in animation */
        .animate-fade-in {
            animation: fadeIn 0.4s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 selection:bg-indigo-100 selection:text-indigo-900">

    <!-- Mobile Overlay -->
    <div id="mobileOverlay" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Sidebar -->
    <nav id="sidebar" class="w-64 h-screen fixed top-0 left-0 bg-slate-100/90 backdrop-blur-2xl border-r border-slate-200/80 z-50 flex flex-col shadow-[4px_0_24px_rgba(0,0,0,0.04)]">
        
        <!-- Sidebar Header -->
        <div class="sidebar-header h-20 px-6 flex items-center justify-between border-b border-slate-200/60">
            <h3 class="font-display font-bold text-xl text-slate-800 flex items-center m-0 whitespace-nowrap transition-opacity duration-200">
                <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-500 to-indigo-700 flex items-center justify-center mr-3 shadow-md shadow-indigo-300/50 border border-indigo-400/30">
                    <i class="bi bi-activity text-white text-lg"></i>
                </div>
                GymApp
            </h3>
            <button class="md:hidden text-slate-400 hover:text-slate-600 focus:outline-none" id="mobile-close">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <!-- Sidebar Content -->
        <div class="sidebar-content flex-1 overflow-y-auto overflow-x-hidden py-4 scrollbar-thin scrollbar-thumb-slate-200 scrollbar-track-transparent">
            <ul class="sidebar-menu list-none p-0 m-0 pb-12">
                
                <li class="menu-item relative my-1 px-3">
                    @if (User.IsInRole("Cliente"))
                    {
                        <a asp-controller="ClienteHome" asp-action="Index" class="menu-link flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98]">
                            <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-person-badge"></i></span>
                            <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Mi Perfil</span>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Index" class="menu-link flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98]">
                            <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-speedometer2"></i></span>
                            <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Dashboard</span>
                        </a>
                    }
                </li>

                @if (User.IsInRole(AppRoles.Admin) || User.IsInRole("Empleado"))
                {
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

                    <!-- ========== SECCIÓN: OPERACIONES ========== -->
                    <li class="menu-item mt-6 mb-2 px-6">
                        <span class="text-xs font-bold text-slate-400 tracking-wider uppercase">Operaciones</span>
                    </li>

                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.UsuariosVer) || User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3">
                            <a asp-controller="Usuarios" asp-action="Index" class="menu-link flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Usuarios" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-people"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Socios / Clientes</span>
                            </a>
                        </li>
                    }

                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasVer) || User.HasClaim(TipoClaim.Permiso, AppPermisos.PasesDiariosVer) || User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3 @(currentController == "Membresias" || currentController == "PasesDiarios" ? "open" : "")">
                            <a href="#submenuSuscripciones" class="menu-link submenu-toggle flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Membresias" || currentController == "PasesDiarios" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-card-checklist"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Suscripciones</span>
                                <span class="menu-arrow ml-auto text-xs transition-transform duration-300"><i class="bi bi-chevron-down"></i></span>
                            </a>
                            <ul class="submenu list-none p-0 m-0 mt-1 space-y-1" id="submenuSuscripciones">
                                @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.MembresiasVer) || User.IsInRole(AppRoles.Admin))
                                {
                                    <li class="submenu-item">
                                        <a asp-controller="Membresias" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98] @(currentController == "Membresias" ? "text-indigo-600 font-semibold" : "")">
                                            Planes Regulares
                                        </a>
                                    </li>
                                }
                                @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PasesDiariosVer) || User.IsInRole(AppRoles.Admin))
                                {
                                    <li class="submenu-item">
                                        <a asp-controller="PasesDiarios" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98] @(currentController == "PasesDiarios" ? "text-indigo-600 font-semibold" : "")">
                                            Pases Diarios
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }

                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PagosVer) || User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3">
                            <a asp-controller="Pagos" asp-action="Index" class="menu-link flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Pagos" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-cash-stack"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Cajas</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3 @(currentController == "Reportes" ? "open" : "")">
                            <a href="#submenuReportes" class="menu-link submenu-toggle flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Reportes" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-graph-up-arrow"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Reportes</span>
                                <span class="menu-arrow ml-auto text-xs transition-transform duration-300"><i class="bi bi-chevron-down"></i></span>
                            </a>
                            <ul class="submenu list-none p-0 m-0 mt-1 space-y-1" id="submenuReportes">
                                <li class="submenu-item">
                                    <a asp-controller="Reportes" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">
                                        Control de Ingresos
                                    </a>
                                </li>
                                <li class="submenu-item">
                                    <a asp-controller="Reportes" asp-action="Membresias" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">
                                        Control de Membresías
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.VentasVer) || User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3">
                            <a asp-controller="Ventas" asp-action="Index" class="menu-link flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Ventas" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-cart"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Ventas</span>
                            </a>
                        </li>
                    }

                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.AccesoVer) || User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3 @(currentController == "Acceso" ? "open" : "")">
                            <a href="#submenuAcceso" class="menu-link submenu-toggle flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Acceso" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-qr-code-scan"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Control de Acceso</span>
                                <span class="menu-arrow ml-auto text-xs transition-transform duration-300"><i class="bi bi-chevron-down"></i></span>
                            </a>
                            <ul class="submenu list-none p-0 m-0 mt-1 space-y-1" id="submenuAcceso">
                                <li class="submenu-item">
                                    <a asp-controller="Acceso" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">Escáner QR</a>
                                </li>
                                <li class="submenu-item">
                                    <a asp-controller="Acceso" asp-action="Historial" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">Historial Visitas</a>
                                </li>
                            </ul>
                        </li>
                    }

                    <!-- ========== SECCIÓN: ADMINISTRACIÓN ========== -->
                    <li class="menu-item mt-6 mb-2 px-6">
                        <span class="text-xs font-bold text-slate-400 tracking-wider uppercase">Administración</span>
                    </li>

                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3">
                            <a asp-controller="Administracion" asp-action="Index"
                               class="menu-link flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Administracion" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-shield-lock"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Personal</span>
                                <span class="badge bg-indigo-100 text-indigo-700 ml-auto border-0 py-1 px-2 rounded-md font-bold" style="font-size:0.65rem;">ADMIN</span>
                            </a>
                        </li>
                    }

                    @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PlanesVer) || User.HasClaim(TipoClaim.Permiso, AppPermisos.TurnosVer) || User.HasClaim(TipoClaim.Permiso, AppPermisos.ProductosVer) || User.IsInRole(AppRoles.Admin))
                    {
                        <li class="menu-item relative my-1 px-3 @(currentController == "Planes" || currentController == "Turnos" || currentController == "Roles" || currentController == "Productos" || currentController == "Alertas" ? "open" : "")">
                            <a href="#submenuConfig" class="menu-link submenu-toggle flex items-center px-3 py-2.5 rounded-xl text-slate-600 hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all duration-200 font-medium active:scale-[0.98] @(currentController == "Planes" || currentController == "Turnos" || currentController == "Roles" || currentController == "Productos" || currentController == "Alertas" ? "bg-white shadow-sm text-indigo-700 ring-1 ring-slate-200/50" : "")">
                                <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-gear"></i></span>
                                <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Configuración</span>
                                <span class="menu-arrow ml-auto text-xs transition-transform duration-300"><i class="bi bi-chevron-down"></i></span>
                            </a>
                            <ul class="submenu list-none p-0 m-0 mt-1 space-y-1" id="submenuConfig">
                                @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.PlanesVer) || User.IsInRole(AppRoles.Admin))
                                {
                                    <li class="submenu-item">
                                        <a asp-controller="Planes" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">Planes y Precios</a>
                                    </li>
                                }
                                @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.TurnosVer) || User.IsInRole(AppRoles.Admin))
                                {
                                    <li class="submenu-item">
                                        <a asp-controller="Turnos" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">Horarios</a>
                                    </li>
                                }
                                @if (User.IsInRole(AppRoles.Admin))
                                {
                                    <li class="submenu-item">
                                        <a asp-controller="Roles" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">Roles</a>
                                    </li>
                                    <li class="submenu-item">
                                        <a asp-controller="Alertas" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">Alertas n8n</a>
                                    </li>
                                }
                                @if (User.HasClaim(TipoClaim.Permiso, AppPermisos.ProductosVer) || User.IsInRole(AppRoles.Admin))
                                {
                                    <li class="submenu-item">
                                        <a asp-controller="Productos" asp-action="Index" class="submenu-link flex items-center pl-11 pr-3 py-2 rounded-lg text-sm text-slate-500 hover:text-indigo-600 hover:bg-white hover:shadow-sm transition-all duration-200 active:scale-[0.98]">
                                            Productos
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }

                }

                <li class="menu-item mt-8 mb-2 px-3">
                    <a asp-controller="Auth" asp-action="Logout" class="menu-link flex items-center px-3 py-2.5 rounded-xl text-rose-500 hover:bg-rose-50 transition-colors font-medium">
                        <span class="menu-icon min-w-[30px] text-center mr-2 text-lg"><i class="bi bi-box-arrow-left"></i></span>
                        <span class="menu-text flex-1 whitespace-nowrap transition-opacity duration-200">Cerrar Sesión</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div id="content" class="ml-64 p-4 md:p-8 min-h-screen">
        
        <!-- Top Navbar -->
        <div class="top-navbar bg-white p-4 rounded-2xl shadow-sm border border-slate-200 mb-8 flex justify-between items-center sticky top-4 z-40 transition-all duration-300">
            <div class="flex items-center">
                <button id="sidebar-toggle" class="text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                    <i class="bi bi-list text-xl"></i>
                </button>
                <h5 class="ml-4 mb-0 text-slate-800 font-display font-semibold text-lg hidden sm:block">@ViewData["Title"]</h5>
            </div>

            <div class="user-profile flex items-center">
                <div class="text-right mr-3 leading-tight hidden sm:block">
                    <div class="font-bold text-slate-800 text-sm">@(User.Identity?.Name ?? "Usuario")</div>
                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <span class="inline-block bg-indigo-100 text-indigo-700 text-[0.65rem] font-bold px-2 py-0.5 rounded-md mt-0.5">ADMIN</span>
                    }
                    else if (User.IsInRole("Cliente"))
                    {
                        <span class="inline-block bg-teal-100 text-teal-700 text-[0.65rem] font-bold px-2 py-0.5 rounded-md mt-0.5">SOCIO</span>
                    }
                </div>
                <div class="bg-indigo-50 rounded-full p-2.5 w-10 h-10 flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                    <i class="bi bi-person-fill text-lg"></i>
                </div>
            </div>
        </div>

        <!-- Render Body Container -->
        <div class="container-fluid p-0 animate-fade-in">
            @if (TempData["Success"] != null)
            {
                <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl relative mb-6 shadow-sm flex items-start" role="alert">
                    <i class="bi bi-check-circle-fill text-emerald-500 mt-0.5 mr-3 text-lg"></i>
                    <div class="flex-1 font-medium">
                        @Html.Raw(TempData["Success"])
                    </div>
                    <button type="button" class="text-emerald-500 hover:text-emerald-700 focus:outline-none" data-bs-dismiss="alert" aria-label="Close" onclick="this.parentElement.style.display='none'">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl relative mb-6 shadow-sm flex items-start" role="alert">
                    <i class="bi bi-exclamation-triangle-fill text-rose-500 mt-0.5 mr-3 text-lg"></i>
                    <div class="flex-1 font-medium">
                        @Html.Raw(TempData["Error"])
                    </div>
                    <button type="button" class="text-rose-500 hover:text-rose-700 focus:outline-none" data-bs-dismiss="alert" aria-label="Close" onclick="this.parentElement.style.display='none'">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }
            
            <!-- Removed the wrapping bg-white card to allow pages to define their own cards and negative space -->
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const content = document.getElementById('content');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const mobileCloseBtn = document.getElementById('mobile-close');
            const overlay = document.getElementById('mobileOverlay');
            const submenuToggles = document.querySelectorAll('.submenu-toggle');

            const isMobile = () => window.innerWidth <= 768;

            toggleBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                if (isMobile()) {
                    sidebar.classList.add('mobile-open');
                    overlay.classList.remove('hidden');
                    // Timeout to allow hidden class removal to process before animating opacity
                    setTimeout(() => overlay.classList.remove('opacity-0'), 10);
                } else {
                    sidebar.classList.toggle('collapsed');
                    content.classList.toggle('expanded');
                }
            });

            function closeMobileMenu() {
                sidebar.classList.remove('mobile-open');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }

            mobileCloseBtn.addEventListener('click', closeMobileMenu);
            overlay.addEventListener('click', closeMobileMenu);

            submenuToggles.forEach(toggle => {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();

                    if (!isMobile() && sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        content.classList.remove('expanded');
                    }

                    const parentItem = this.parentElement;

                    document.querySelectorAll('.menu-item.open').forEach(item => {
                        if (item !== parentItem) {
                            item.classList.remove('open');
                        }
                    });

                    parentItem.classList.toggle('open');
                });
            });

            window.addEventListener('resize', function() {
                if (!isMobile()) {
                    sidebar.classList.remove('mobile-open');
                    overlay.classList.add('hidden', 'opacity-0');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>