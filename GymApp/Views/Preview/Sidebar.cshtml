@{
    ViewData["Title"] = "Preview Sidebar";
}

<div class="p-6">
    <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-800 mb-4">Página de Previsualización</h2>
        <p class="text-slate-600">Esta es una página temporal para ver el sidebar sin necesidad de login.</p>
        <div class="mt-6 p-4 bg-indigo-50 rounded-2xl border border-indigo-100 text-indigo-700">
            <p class="text-sm font-medium">Nota: Dado que no hay una sesión activa, el sidebar solo mostrará las opciones que no dependen de permisos específicos (o ninguna si todas están protegidas).</p>
        </div>
    </div>
</div>
