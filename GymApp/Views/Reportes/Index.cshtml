@{
    ViewData["Title"] = "Control de Ingresos";
}

<div class="container-fluid mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold m-0 text-primary"><i class="bi bi-table me-2"></i>Control de Ingresos General</h5>

            <div class="d-flex gap-2">
                <select id="selectMes" class="form-select form-select-sm" style="width: 120px;">
                    <option value="1">Enero</option>
                    <option value="2">Febrero</option>
                    <option value="3">Marzo</option>
                    <option value="4">Abril</option>
                    <option value="5">Mayo</option>
                    <option value="6">Junio</option>
                    <option value="7">Julio</option>
                    <option value="8">Agosto</option>
                    <option value="9">Septiembre</option>
                    <option value="10">Octubre</option>
                    <option value="11">Noviembre</option>
                    <option value="12">Diciembre</option>
                </select>
                <select id="selectAnio" class="form-select form-select-sm" style="width: 100px;">
                    <option value="2025">2025</option>
                    <option value="2026">2026</option>
                </select>
                <button class="btn btn-primary btn-sm" onclick="cargarReporte()">
                    <i class="bi bi-search"></i> Consultar
                </button>

                <button class="btn btn-success btn-sm" onclick="descargarExcel()">
                    <i class="bi bi-file-earmark-excel"></i> Exportar
                </button>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-sm text-center align-middle mb-0" style="font-size: 0.8rem;">
                    <thead>
                        <tr class="text-white">
                            <th rowspan="3" class="bg-dark text-white align-middle" style="width: 40px;">DIA</th>

                            <th colspan="4" class="bg-success bg-opacity-75">BEBIDAS</th>
                            <th rowspan="2" class="bg-secondary text-white small">SUB</th>

                            <th colspan="4" class="bg-warning text-dark">LIBRES</th>
                            <th rowspan="2" class="bg-secondary text-white small">SUB</th>

                            <th colspan="4" class="bg-danger bg-opacity-75">XB</th>
                            <th rowspan="2" class="bg-secondary text-white small">SUB</th>

                            <th rowspan="3" class="bg-success text-white align-middle" style="border-left: 3px solid #333;">TOT.<br>EFECTIVO</th>
                            <th rowspan="3" class="bg-info text-dark align-middle">TOT.<br>YAPE</th>
                            <th rowspan="3" class="bg-dark text-white align-middle fs-6">TOTAL<br>GRAL.</th>
                        </tr>

                        <tr class="fw-bold small">
                            <th colspan="2" class="bg-light">MAÑANA</th>
                            <th colspan="2" class="bg-light">TARDE</th>

                            <th colspan="2" class="bg-light">MAÑANA</th>
                            <th colspan="2" class="bg-light">TARDE</th>

                            <th colspan="2" class="bg-light">MAÑANA</th>
                            <th colspan="2" class="bg-light">TARDE</th>
                        </tr>

                        <tr class="small text-muted" style="font-size: 0.75rem;">
                            <th>Efec</th>
                            <th>Yape</th>
                            <th>Efec</th>
                            <th>Yape</th>
                            <th class="bg-light text-dark">S/.</th>
                            <th>Efec</th>
                            <th>Yape</th>
                            <th>Efec</th>
                            <th>Yape</th>
                            <th class="bg-light text-dark">S/.</th>
                            <th>Efec</th>
                            <th>Yape</th>
                            <th>Efec</th>
                            <th>Yape</th>
                            <th class="bg-light text-dark">S/.</th>
                        </tr>
                    </thead>
                    <tbody id="cuerpoTabla"></tbody>
                    <tfoot class="bg-light fw-bold small" id="pieTabla"></tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const fecha = new Date();
            document.getElementById("selectMes").value = fecha.getMonth() + 1;
            document.getElementById("selectAnio").value = fecha.getFullYear();
            cargarReporte();
        });

        function cargarReporte() {
            const mes = document.getElementById("selectMes").value;
            const anio = document.getElementById("selectAnio").value;
            const tbody = document.getElementById("cuerpoTabla");

            tbody.innerHTML = '<tr><td colspan="19" class="p-4"><div class="spinner-border text-primary"></div></td></tr>';

            fetch(`/Reportes/ObtenerIngresos?mes=${mes}&anio=${anio}`)
                .then(res => res.json())
                .then(json => {
                    const data = json.data;
                    let html = '';
                    let t = inicializarTotales(); // Totales acumulados

                    if(data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="19" class="p-4 text-muted">No hay movimientos.</td></tr>';
                        return;
                    }

                    data.forEach(item => {
                        sumarTotales(t, item);

                        html += `
                        <tr class="hover-row">
                            <td class="fw-bold bg-light">${item.dia}</td>

                            <td>${format(item.bebidasMananaEfectivo)}</td><td>${format(item.bebidasMananaYape)}</td>
                            <td>${format(item.bebidasTardeEfectivo)}</td><td>${format(item.bebidasTardeYape)}</td>
                            <td class="bg-light text-muted">${format(item.totalBebidas)}</td>

                            <td>${format(item.libresMananaEfectivo)}</td><td>${format(item.libresMananaYape)}</td>
                            <td>${format(item.libresTardeEfectivo)}</td><td>${format(item.libresTardeYape)}</td>
                            <td class="bg-light text-muted">${format(item.totalLibres)}</td>

                            <td>${format(item.xbMananaEfectivo)}</td><td>${format(item.xbMananaYape)}</td>
                            <td>${format(item.xbTardeEfectivo)}</td><td>${format(item.xbTardeYape)}</td>
                            <td class="bg-light text-muted">${format(item.totalXB)}</td>

                            <td class="fw-bold text-success border-start border-dark">${format(item.totalDiaEfectivo)}</td>
                            <td class="fw-bold text-info">${format(item.totalDiaYape)}</td>
                            <td class="bg-dark text-white fw-bold">${format(item.totalGeneralDia)}</td>
                        </tr>
                        `;
                    });

                    tbody.innerHTML = html;
                    renderFooter(t);
                });
        }

        function format(num) {
            return num > 0 ? num.toFixed(2) : '';
        }

        function inicializarTotales() {
            // Agregamos totEf (Total Efectivo Global) y totYa (Total Yape Global)
            return {
                bme:0, bmy:0, bte:0, bty:0, bt:0,
                lme:0, lmy:0, lte:0, lty:0, lt:0,
                xme:0, xmy:0, xte:0, xty:0, xt:0,

                // Totales globales
                totEf: 0,
                totYa: 0,
                granTotal: 0
            };
        }

        function sumarTotales(t, i) {
            // Bebidas
            t.bme += i.bebidasMananaEfectivo; t.bmy += i.bebidasMananaYape;
            t.bte += i.bebidasTardeEfectivo; t.bty += i.bebidasTardeYape; t.bt += i.totalBebidas;

            // Libres
            t.lme += i.libresMananaEfectivo; t.lmy += i.libresMananaYape;
            t.lte += i.libresTardeEfectivo; t.lty += i.libresTardeYape; t.lt += i.totalLibres;

            // XB
            t.xme += i.xbMananaEfectivo; t.xmy += i.xbMananaYape;
            t.xte += i.xbTardeEfectivo; t.xty += i.xbTardeYape; t.xt += i.totalXB;

            // Totales Finales
            t.totEf += i.totalDiaEfectivo;
            t.totYa += i.totalDiaYape;
            t.granTotal += i.totalGeneralDia;
        }

        function renderFooter(t) {
            const footer = document.getElementById("pieTabla");
            footer.innerHTML = `
                <tr>
                    <td>TOTAL</td>
                    <td>${t.bme.toFixed(2)}</td><td>${t.bmy.toFixed(2)}</td>
                    <td>${t.bte.toFixed(2)}</td><td>${t.bty.toFixed(2)}</td>
                    <td>${t.bt.toFixed(2)}</td>

                    <td>${t.lme.toFixed(2)}</td><td>${t.lmy.toFixed(2)}</td>
                    <td>${t.lte.toFixed(2)}</td><td>${t.lty.toFixed(2)}</td>
                    <td>${t.lt.toFixed(2)}</td>

                    <td>${t.xme.toFixed(2)}</td><td>${t.xmy.toFixed(2)}</td>
                    <td>${t.xte.toFixed(2)}</td><td>${t.xty.toFixed(2)}</td>
                    <td>${t.xt.toFixed(2)}</td>

                    <td class="bg-success text-white border-start border-dark fs-6">${t.totEf.toFixed(2)}</td>
                    <td class="bg-info text-dark fs-6">${t.totYa.toFixed(2)}</td>
                    <td class="bg-dark text-white fs-6">${t.granTotal.toFixed(2)}</td>
                </tr>
            `;
        }

        function descargarExcel() {
            const mes = document.getElementById("selectMes").value;
            const anio = document.getElementById("selectAnio").value;

            // Redirige al navegador para iniciar la descarga
            window.location.href = `/Reportes/ExportarExcel?mes=${mes}&anio=${anio}`;
        }
    </script>
}