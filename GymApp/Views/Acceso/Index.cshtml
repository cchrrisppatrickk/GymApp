@{
    ViewData["Title"] = "Punto de Acceso QR";
}

<div class="min-h-[calc(100vh-120px)] flex flex-col items-center justify-center py-6 px-4 fade-in">
    <div class="w-full max-w-2xl space-y-6">
        <!-- Encabezado -->
        <div class="text-center space-y-2">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-[2rem] bg-indigo-600 text-white shadow-xl shadow-indigo-600/20 mb-2">
                <i data-lucide="qr-code" class="w-8 h-8"></i>
            </div>
            <h2 class="text-3xl font-display font-bold text-slate-950 tracking-tight m-0">Control de Acceso</h2>
            <p class="text-slate-500 font-medium text-sm">Escanea el código QR del socio para registrar su entrada</p>
        </div>

        <!-- Contenedor del Escáner -->
        <div class="relative bg-slate-950 rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-slate-900 group aspect-square md:aspect-video min-h-[400px]">
            <!-- El lector de QR -->
            <div id="reader" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"></div>
            
            <!-- Overlay de Guía (Visual) -->
            <div class="absolute inset-0 pointer-events-none flex items-center justify-center">
                <div class="w-64 h-64 border-2 border-white/20 rounded-3xl relative">
                    <div class="absolute -top-1 -left-1 w-8 h-8 border-t-4 border-l-4 border-indigo-500 rounded-tl-lg"></div>
                    <div class="absolute -top-1 -right-1 w-8 h-8 border-t-4 border-r-4 border-indigo-500 rounded-tr-lg"></div>
                    <div class="absolute -bottom-1 -left-1 w-8 h-8 border-b-4 border-l-4 border-indigo-500 rounded-bl-lg"></div>
                    <div class="absolute -bottom-1 -right-1 w-8 h-8 border-b-4 border-r-4 border-indigo-500 rounded-br-lg"></div>
                </div>
            </div>

            <!-- Overlay de Resultados -->
            <div id="resultado-overlay" class="absolute inset-0 bg-white/95 backdrop-blur-sm hidden flex-col items-center justify-center p-8 text-center animate-in fade-in zoom-in duration-200 z-50">
                <div id="res-icon-container" class="w-24 h-24 rounded-full flex items-center justify-center mb-6 border-4 shadow-lg transition-transform">
                    <i id="res-icon" class="w-12 h-12"></i>
                </div>

                <div class="space-y-1 mb-6">
                    <h1 class="text-3xl font-display font-black text-slate-950 tracking-tight" id="res-nombre">Usuario</h1>
                    <p class="text-slate-500 font-mono text-sm font-bold" id="res-dni">DNI: ---</p>
                </div>

                <div id="res-status-card" class="w-full max-w-sm p-6 rounded-3xl mb-8 transition-colors">
                    <h2 class="text-4xl font-display font-black mb-1 tracking-tighter" id="res-mensaje">ESPERANDO...</h2>
                    <p class="text-sm font-bold uppercase tracking-widest opacity-70" id="res-submensaje">--</p>
                </div>

                <div class="grid grid-cols-2 gap-4 w-full max-w-sm mb-8">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Plan Actual</p>
                        <p class="text-sm font-bold text-slate-900" id="res-plan">--</p>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Vigencia</p>
                        <p class="text-sm font-bold text-slate-900" id="res-vencimiento">--</p>
                    </div>
                </div>

                <button id="btn-continuar" class="w-full max-w-xs py-4 rounded-2xl font-display font-black text-sm uppercase tracking-widest shadow-xl active:scale-95 transition-all">
                    Continuar Escaneando
                </button>
            </div>
        </div>

        <!-- Controles -->
        <div class="flex flex-col gap-3">
            <button id="btn-iniciar" class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-display font-bold text-sm uppercase tracking-widest shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all active:scale-[0.98] flex items-center justify-center gap-3 group">
                <i data-lucide="camera" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
                Iniciar Escáner
            </button>
            <button id="btn-detener" class="w-full py-4 bg-slate-100 text-slate-600 rounded-2xl font-display font-bold text-sm uppercase tracking-widest hover:bg-slate-200 transition-all hidden">
                Detener Cámara
            </button>
        </div>
    </div>
</div>

<audio id="audio-ok" src="https://assets.mixkit.co/active_storage/sfx/2578/2578-preview.m4a"></audio>
<audio id="audio-error" src="https://assets.mixkit.co/active_storage/sfx/2572/2572-preview.m4a"></audio>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <script>
        const TIEMPO_AUTOCIERE = 5000;
        let html5QrcodeScanner = null;
        let isProcessing = false;
        let timerCierre = null;

        const btnIniciar = document.getElementById('btn-iniciar');
        const btnDetener = document.getElementById('btn-detener');
        const beepOk = document.getElementById('audio-ok');
        const beepError = document.getElementById('audio-error');

        btnIniciar.addEventListener('click', () => {
            btnIniciar.classList.add('hidden');
            btnDetener.classList.remove('hidden');

            html5QrcodeScanner = new Html5Qrcode("reader");
            const config = {
                fps: 15,
                qrbox: { width: 280, height: 280 },
                aspectRatio: 1.0
            };

            html5QrcodeScanner.start({ facingMode: "environment" }, config, onScanSuccess)
            .catch(err => {
                Swal.fire({ title: 'Error de Cámara', text: err, icon: 'error', customClass: { popup: '!rounded-3xl' } });
                detenerScanner();
            });
        });

        btnDetener.addEventListener('click', detenerScanner);

        function detenerScanner() {
            if (html5QrcodeScanner) {
                html5QrcodeScanner.stop().then(() => {
                    document.getElementById('reader').innerHTML = "";
                    btnIniciar.classList.remove('hidden');
                    btnDetener.classList.add('hidden');
                });
            }
        }

        function onScanSuccess(decodedText) {
            if (isProcessing) return;
            isProcessing = true;

            fetch('/Acceso/RegistrarAsistencia', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(decodedText)
            })
            .then(res => res.json())
            .then(data => mostrarOverlay(data))
            .catch(err => {
                mostrarOverlay({ success: false, mensaje: "Error de Conexión", nombre: "Sistema" });
            });
        }

        function mostrarOverlay(data) {
            const overlay = document.getElementById('resultado-overlay');
            const btnContinuar = document.getElementById('btn-continuar');
            const iconContainer = document.getElementById('res-icon-container');
            const icon = document.getElementById('res-icon');
            const statusCard = document.getElementById('res-status-card');

            document.getElementById('res-nombre').innerText = data.nombre || "Socio no Encontrado";
            document.getElementById('res-dni').innerText = data.dni ? `DNI: ${data.dni}` : "Identidad no válida";
            document.getElementById('res-plan').innerText = data.plan || "Ninguno";
            document.getElementById('res-vencimiento').innerText = data.diasRestantes !== undefined ? `${data.diasRestantes} días` : "--";

            const mensaje = document.getElementById('res-mensaje');
            const submensaje = document.getElementById('res-submensaje');

            if (data.success) {
                mensaje.innerText = "ACCESO PERMITIDO";
                submensaje.innerText = "Bienvenido al Club";
                
                statusCard.className = "w-full max-w-sm p-6 rounded-3xl mb-8 bg-emerald-50 text-emerald-700 border border-emerald-100";
                iconContainer.className = "w-24 h-24 rounded-full flex items-center justify-center mb-6 bg-emerald-100 border-emerald-200 text-emerald-600 shadow-lg scale-110";
                icon.setAttribute('data-lucide', 'smile');
                btnContinuar.className = "w-full max-w-xs py-4 rounded-2xl font-display font-black text-sm uppercase tracking-widest shadow-xl shadow-emerald-600/20 bg-emerald-600 text-white hover:bg-emerald-700 active:scale-95 transition-all";
                
                beepOk.play().catch(()=>{});
            } else {
                mensaje.innerText = "ACCESO DENEGADO";
                submensaje.innerText = data.mensaje || "Plan Expirado o Inválido";

                statusCard.className = "w-full max-w-sm p-6 rounded-3xl mb-8 bg-rose-50 text-rose-700 border border-rose-100";
                iconContainer.className = "w-24 h-24 rounded-full flex items-center justify-center mb-6 bg-rose-100 border-rose-200 text-rose-600 shadow-lg scale-110 animate-bounce";
                icon.setAttribute('data-lucide', 'frown');
                btnContinuar.className = "w-full max-w-xs py-4 rounded-2xl font-display font-black text-sm uppercase tracking-widest shadow-xl shadow-rose-600/20 bg-rose-600 text-white hover:bg-rose-700 active:scale-95 transition-all";
                
                beepError.play().catch(()=>{});
            }

            if (typeof lucide !== 'undefined') lucide.createIcons();
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');

            const cerrar = () => {
                overlay.classList.add('hidden');
                overlay.classList.remove('flex');
                isProcessing = false;
                clearTimeout(timerCierre);
            };

            btnContinuar.onclick = cerrar;
            if(timerCierre) clearTimeout(timerCierre);
            timerCierre = setTimeout(cerrar, TIEMPO_AUTOCIERE);
        }
    </script>
}