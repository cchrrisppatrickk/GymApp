@{
    ViewData["Title"] = "Control de Acceso";
}

<style>
    /* Estilos para la tarjeta de resultado superpuesta */
    #resultado-card {
        display: none; /* Oculto por defecto */
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1000;
        width: 90%;
        max-width: 400px;
        text-align: center;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    }

    .acceso-ok {
        background-color: #d4edda;
        border: 2px solid #28a745;
        color: #155724;
    }

    .acceso-error {
        background-color: #f8d7da;
        border: 2px solid #dc3545;
        color: #721c24;
    }

    #reader {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        border: 5px solid #333;
        border-radius: 10px;
        /* Importante: Oculto inicialmente para que no ocupe espacio vacío */
        display: none;
    }

    /* Estilo para el botón de inicio */
    #btn-container {
        margin-top: 50px;
        margin-bottom: 50px;
    }
</style>

<div class="container mt-4 text-center">
    <h2>Control de Acceso</h2>
    <p class="text-muted">Sistema de validación de membresías</p>

    <div id="btn-container">
        <button id="btn-iniciar-scanner" class="btn btn-primary btn-lg px-5 py-3 shadow">
            📷 Iniciar Escáner / Cámara
        </button>
    </div>

    <div id="reader"></div>

    <div id="resultado-card" class="p-4">
        <h3 id="res-nombre" class="fw-bold">--</h3>
        <hr>
        <div class="row">
            <div class="col-6">
                <small>Plan:</small>
                <h5 id="res-plan">--</h5>
            </div>
            <div class="col-6">
                <small>Días Restantes:</small>
                <h4 id="res-dias" class="fw-bold">--</h4>
            </div>
        </div>
        <div class="mt-3">
            <span id="res-status" class="badge bg-dark fs-5">--</span>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>

    <script>
        // Variable global para el scanner
        let html5QrcodeScanner = null;
        let isScanning = true;

        // 1. Lógica del Botón de Inicio
        document.getElementById('btn-iniciar-scanner').addEventListener('click', function() {
            // Ocultar el botón
            document.getElementById('btn-container').style.display = 'none';
            // Mostrar el contenedor de la cámara
            document.getElementById('reader').style.display = 'block';

            // Iniciar la librería
            iniciarScanner();
        });

        function iniciarScanner() {
            html5QrcodeScanner = new Html5QrcodeScanner(
                "reader",
                { fps: 10, qrbox: 250 },
                /* verbose= */ false
            );

            html5QrcodeScanner.render(onScanSuccess, onScanFailure);
        }

        // 2. Lógica de éxito al escanear
        function onScanSuccess(decodedText, decodedResult) {
            if (!isScanning) return;

            isScanning = false;

            // Pausar visualmente el scanner
            html5QrcodeScanner.pause();

            // Enviar al servidor
            fetch('/Acceso/RegistrarAsistencia', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(decodedText)
            })
            .then(response => response.json())
            .then(data => {
                mostrarResultado(data);
            })
            .catch(error => {
                console.error('Error:', error);
                mostrarErrorSistema();
            });
        }

        function onScanFailure(error) {
            // No hacer nada, ruido normal
        }

        function mostrarResultado(data) {
            const card = document.getElementById('resultado-card');
            const nombre = document.getElementById('res-nombre');
            const plan = document.getElementById('res-plan');
            const dias = document.getElementById('res-dias');
            const status = document.getElementById('res-status');

            // Llenar datos
            nombre.innerText = data.nombre || "Desconocido";
            plan.innerText = data.plan || "--";
            dias.innerText = (data.diasRestantes !== undefined ? data.diasRestantes : "--") + " días";
            status.innerText = data.mensaje || "Error";

            // Estilos
            card.classList.remove('acceso-ok', 'acceso-error');
            if(data.success) {
                card.classList.add('acceso-ok');
                status.className = "badge bg-success fs-5";
                let audio = new Audio('/sounds/success.mp3');
                audio.play().catch(e => {});
            } else {
                card.classList.add('acceso-error');
                status.className = "badge bg-danger fs-5";
                let audio = new Audio('/sounds/error.mp3');
                audio.play().catch(e => {});
            }

            // Mostrar tarjeta
            card.style.display = 'block';

            // Temporizador de 5 segundos
            setTimeout(() => {
                card.style.display = 'none';
                isScanning = true;
                // Reactivar cámara
                html5QrcodeScanner.resume();
            }, 5000);
        }

        function mostrarErrorSistema() {
            alert("Error de conexión con el servidor");
            isScanning = true;
            html5QrcodeScanner.resume();
        }
    </script>
}