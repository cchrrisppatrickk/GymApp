@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="text-center mt-5">
    <h1 class="display-4">¡Hola, @ViewData["NombreUsuario"]!</h1>
    <p class="lead">Bienvenido a tu espacio personal.</p>
    <div class="card mx-auto mt-4" style="max-width: 400px;">
        <div class="card-body">
            <h5 class="card-title">Tu Acceso</h5>
            <p class="card-text">Escanea tu código en la entrada.</p>
            <i class="bi bi-qr-code-scan" style="font-size: 5rem;"></i>
        </div>
    </div>
</div>